TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\nMulti-CSV Data Cleaning & Feature Matrix Pipeline\n==================================================\nReads multiple CSV files, applies a configurable preprocessing pipeline:\n  - Missing value handling (drop / fill / interpolate)\n  - Numeric column standardization (z-score / min-max / robust)\n  - Categorical column one-hot encoding\n  - Merges all sources into a single feature matrix\n\nUsage:\n    python data_pipeline.py --config config.yaml\n    python data_pipeline.py --csv data1.csv data2.csv --output features.csv\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport logging\nimport sys\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Literal, Optional, Tuple\n\nimport numpy as np\nimport pandas as pd\n\n# ---------------------------------------------------------------------------\n# Logging\n# ---------------------------------------------------------------------------\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s | %(levelname)-8s | %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"pipeline\")\n\n\n# ---------------------------------------------------------------------------\n# Strategies\n# ---------------------------------------------------------------------------\nFillStrategy = Literal[\"drop\", \"mean\", \"median\", \"mode\", \"zero\", \"ffill\", \"bfill\", \"constant\"]\nScaleStrategy = Literal[\"zscore\", \"minmax\", \"robust\", \"none\"]\n\n\ndef fill_missing(df: pd.DataFrame, strategy: FillStrategy, fill_value: Any = None) -> pd.DataFrame:\n    \"\"\"Handle missing values in-place (returns new DataFrame).\"\"\"\n    df = df.copy()\n    if strategy == \"drop\":\n        return df.dropna().reset_index(drop=True)\n    elif strategy == \"mean\":\n        return df.fillna(df.select_dtypes(include=\"number\").mean())\n    elif strategy == \"median\":\n        return df.fillna(df.select_dtypes(include=\"number\").median())\n    elif strategy == \"mode\":\n        return df.fillna(df.mode().iloc[0])\n    elif strategy == \"zero\":\n        return df.fillna(0)\n    elif strategy == \"ffill\":\n        return df.ffill()\n    elif strategy == \"bfill\":\n        return df.bfill()\n    elif strategy == \"constant\":\n        if fill_value is None:\n            raise ValueError(\"constant strategy requires a fill_value.\")\n        return df.fillna(fill_value)\n    else:\n        raise ValueError(f\"Unknown fill strategy: {strategy}\")\n\n\ndef scale_numeric(\n    df: pd.DataFrame,\n    strategy: ScaleStrategy,\n    columns: Optional[List[str]] = None,\n) -> pd.DataFrame:\n    \"\"\"Standardize numeric columns.\"\"\"\n    df = df.copy()\n    num_cols = columns or df.select_dtypes(include=np.number).columns.tolist()\n    if not num_cols:\n        return df\n\n    if strategy == \"zscore\":\n        mean_, std_ = df[num_cols].mean(), df[num_cols].std()\n        std_.replace(0, 1, inplace=True)          # avoid div-by-zero\n        df[num_cols] = (df[num_cols] - mean_) / std_\n    elif strategy == \"minmax\":\n        min_, max_ = df[num_cols].min(), df[num_cols].max()\n        df[num_cols] = (df[num_cols] - min_) / (max_ - min_).replace(0, 1)\n    elif strategy == \"robust\":\n        med, iqr = df[num_cols].median(), df[num_cols].quantile(0.75) - df[num_cols].quantile(0.25)\n        iqr.replace(0, 1, inplace=True)\n        df[num_cols] = (df[num_cols] - med) / iqr\n    elif strategy == \"none\":\n        pass\n    else:\n        raise ValueError(f\"Unknown scale strategy: {strategy}\")\n    return df\n\n\ndef one_hot_encode(\n    df: pd.DataFrame,\n    columns: Optional[List[str]] = None,\n    drop_first: bool = False,\n    max_categories: Optional[int] = None,\n) -> pd.DataFrame:\n    \"\"\"One-hot encode categorical columns, optionally dropping the first category\n    (avoids dummy-variable trap) or capping cardinality.\"\"\"\n    df = df.copy()\n\n    # Infer categorical if not specified\n    if columns is None:\n        columns = df.select_dtypes(include=[\"object\", \"category\", \"bool\"]).columns.tolist()\n\n    for col in columns:\n        if col not in df.columns:\n            log.warning(\"Column '%s' not found — skipping one-hot.\", col)\n            continue\n\n        # Cardinality check\n        card = df[col].nunique(dropna=False)\n        if max_categories and card > max_categories:\n            log.warning(\n                \"Column '%s' has %d unique values (%d allowed) — \"\n                \"keeping only top-%d categories.\",\n                col, card, max_categories, max_categories,\n            )\n            top = df[col].value_counts().index[:max_categories]\n            df[col] = df[col].where(df[col].isin(top), other=\"other\")\n\n        dummies = pd.get_dummies(df[col], prefix=col, drop_first=drop_first, dummy_na=False)\n        # Ensure consistent dtypes for sparse columns\n        dummies = dummies.astype(int)\n        df = pd.concat([df.drop(columns=[col]), dummies], axis=1)\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Column-type detection (config override)\n# ---------------------------------------------------------------------------\ndef detect_column_types(\n    df: pd.DataFrame,\n    config: Optional[Dict[str, List[str]]] = None,\n) -> Tuple[List[str], List[str]]:\n    \"\"\"Return (numeric_cols, categorical_cols).  Config can override:\n    config = {\"numeric\": [...], \"categorical\": [...], \"ignore\": [...]}\n    \"\"\"\n    if config:\n        ignore = config.get(\"ignore\", [])\n        num = [c for c in config.get(\"numeric\", []) if c in df.columns and c not in ignore]\n        cat = [c for c in config.get(\"categorical\", []) if c in df.columns and c not in ignore]\n        if not num and not cat:\n            log.warning(\"Config specified but no matching columns found; falling back to auto-detect.\")\n        else:\n            return num, cat\n\n    # Auto-detect\n    num_cols = df.select_dtypes(include=np.number).columns.tolist()\n    cat_cols = df.select_dtypes(include=[\"object\", \"category\", \"bool\"]).columns.tolist()\n    return num_cols, cat_cols\n\n\n# ---------------------------------------------------------------------------\n# Pipeline orchestrator\n# ---------------------------------------------------------------------------\nclass DataPipeline:\n    \"\"\"Configurable data-cleaning pipeline for one or more CSV files.\n\n    Parameters\n    ----------\n    fill_strategy : FillStrategy\n        How to handle missing values (default: 'mean').\n    fill_value : optional constant used with 'constant' strategy.\n    scale_strategy : ScaleStrategy\n        How to standardize numeric columns (default: 'zscore').\n    scale_columns : optional whitelist of numeric columns to scale.\n    cat_columns : optional whitelist of categorical columns to encode.\n    drop_first : bool\n        Drop first dummy category to avoid multicollinearity.\n    max_categories : int, optional\n        Max unique categories per column before folding into 'other'.\n    column_config : dict, optional\n        Manual override for column-type detection.\n    merge_on : str or list of str, optional\n        Column(s) to merge on (inner join).  If None, rows are concatenated.\n    \"\"\"\n\n    def __init__(\n        self,\n        fill_strategy: FillStrategy = \"mean\",\n        fill_value: Any = None,\n        scale_strategy: ScaleStrategy = \"zscore\",\n        scale_columns: Optional[List[str]] = None,\n        cat_columns: Optional[List[str]] = None,\n        drop_first: bool = False,\n        max_categories: Optional[int] = None,\n        column_config: Optional[Dict[str, List[str]]] = None,\n        merge_on: Optional[str | List[str]] = None,\n    ):\n        self.fill_strategy = fill_strategy\n        self.fill_value = fill_value\n        self.scale_strategy = scale_strategy\n        self.scale_columns = scale_columns\n        self.cat_columns = cat_columns\n        self.drop_first = drop_first\n        self.max_categories = max_categories\n        self.column_config = column_config\n        self.merge_on = merge_on\n\n    def fit_transform(self, sources: List[pd.DataFrame]) -> pd.DataFrame:\n        \"\"\"Run the full pipeline: fill → scale → encode → combine.\"\"\"\n        cleaned = []\n        for i, df in enumerate(sources):\n            log.info(\"Processing source %d — shape %s\", i, df.shape)\n            df = fill_missing(df, self.fill_strategy, self.fill_value)\n            num_cols, cat_cols = detect_column_types(df, self.column_config)\n\n            use_scale_cols = self.scale_columns or num_cols\n            df = scale_numeric(df, self.scale_strategy, use_scale_cols)\n\n            use_cat_cols = self.cat_columns or cat_cols\n            df = one_hot_encode(df, use_cat_cols, self.drop_first, self.max_categories)\n\n            cleaned.append(df)\n            log.info(\"  After pipeline — shape %s\", df.shape)\n\n        return self._combine(cleaned)\n\n    def _combine(self, frames: List[pd.DataFrame]) -> pd.DataFrame:\n        if self.merge_on:\n            log.info(\"Merging on %s (inner join)\", self.merge_on)\n            merged = frames[0]\n            for i, df in enumerate(frames[1:], 1):\n                merged = merged.merge(df, on=self.merge_on, how=\"inner\")\n                log.info(\"  After merge %d — shape %s\", i, merged.shape)\n            return merged.reset_index(drop=True)\n        else:\n            log.info(\"Concatenating all sources (axis=0)\")\n            combined = pd.concat(frames, axis=0, ignore_index=True)\n            return combined\n\n    def __repr__(self) -> str:\n        return (\n            f\"DataPipeline(fill={self.fill_strategy}, \"\n            f\"scale={self.scale_strategy}, \"\n            f\"drop_first={self.drop_first})\"\n        )\n\n\n# ---------------------------------------------------------------------------\n# I/O helpers\n# ---------------------------------------------------------------------------\ndef load_csvs(paths: List[str | Path]) -> List[pd.DataFrame]:\n    \"\"\"Read CSV files; infer encoding and basic parsing.\"\"\"\n    frames = []\n    for p in paths:\n        p = Path(p)\n        if not p.exists():\n            log.error(\"File not found: %s\", p)\n            continue\n        try:\n            df = pd.read_csv(p)\n            log.info(\"Loaded %s — shape %s, columns=%s\", p.name, df.shape, list(df.columns))\n            frames.append(df)\n        except Exception as exc:\n            log.error(\"Failed to read %s: %s\", p, exc)\n    return frames\n\n\ndef save_features(df: pd.DataFrame, path: str | Path) -> None:\n    \"\"\"Write the final feature matrix to CSV.\"\"\"\n    path = Path(path)\n    path.parent.mkdir(parents=True, exist_ok=True)\n    df.to_csv(path, index=False)\n    log.info(\"Saved feature matrix → %s  (shape %s)\", path, df.shape)\n\n\n# ---------------------------------------------------------------------------\n# Summary report\n# ---------------------------------------------------------------------------\ndef report(df: pd.DataFrame) -> None:\n    \"\"\"Print a compact summary of the output feature matrix.\"\"\"\n    print(\"\\n\" + \"=\" * 60)\n    print(\"FEATURE MATRIX SUMMARY\")\n    print(\"=\" * 60)\n    print(f\"  Shape:                {df.shape[0]:>10_} rows × {df.shape[1]} columns\")\n    print(f\"  Missing values:       {df.isna().sum().sum():>10,}\")\n    print(f\"  Memory usage:         {df.memory_usage(deep=True).sum() / 1024 ** 2:.2f} MB\")\n    print(f\"  Numeric columns:      {len(df.select_dtypes(include=np.number).columns)}\")\n    print(f\"  Categorical/Object:   {len(df.select_dtypes(include=['object', 'category']).columns)}\")\n    print(f\"  Duplicate rows:       {df.duplicated().sum():>10,}\")\n    print(\"-\" * 60)\n    print(\"  Column dtypes:\")\n    for dt, cnt in df.dtypes.value_counts().items():\n        print(f\"    {dt:>20s}  × {cnt}\")\n    print(\"=\" * 60)\n\n\n# ---------------------------------------------------------------------------\n# CLI entry point\n# ---------------------------------------------------------------------------\ndef parse_args(argv: Optional[List[str]] = None) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(\n        description=\"Multi-CSV data cleaning & feature matrix pipeline.\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=__doc__,\n    )\n\n    # Input / output\n    parser.add_argument(\"--csv\", nargs=\"+\", help=\"CSV file(s) to process.\")\n    parser.add_argument(\"--output\", \"-o\", default=\"feature_matrix.csv\", help=\"Output CSV path.\")\n    parser.add_argument(\"--config\", \"-c\", help=\"YAML config file (overrides CLI flags).\")\n\n    # Pipeline options\n    parser.add_argument(\n        \"--fill\", choices=[\"drop\", \"mean\", \"median\", \"mode\", \"zero\", \"ffill\", \"bfill\", \"constant\"],\n        default=\"mean\", help=\"Missing-value fill strategy (default: mean).\",\n    )\n    parser.add_argument(\"--fill-value\", default=None, help=\"Constant fill value (for --fill constant).\")\n    parser.add_argument(\n        \"--scale\", choices=[\"zscore\", \"minmax\", \"robust\", \"none\"],\n        default=\"zscore\", help=\"Numeric scaling strategy (default: zscore).\",\n    )\n    parser.add_argument(\"--scale-columns\", nargs=\"*\", help=\"Numeric columns to scale (default: auto).\")\n    parser.add_argument(\"--cat-columns\", nargs=\"*\", help=\"Categorical columns to encode (default: auto).\")\n    parser.add_argument(\n        \"--drop-first\", action=\"store_true\",\n        help=\"Drop first dummy category (avoid dummy-variable trap).\",\n    )\n    parser.add_argument(\n        \"--max-categories\", type=int, default=None,\n        help=\"Max categories per column before folding into 'other'.\",\n    )\n    parser.add_argument(\n        \"--merge-on\", nargs=\"*\",\n        help=\"Column(s) to inner-join on across CSVs (default: row-concatenate).\",\n    )\n\n    args = parser.parse_args(argv)\n\n    # YAML config override\n    if args.config:\n        try:\n            import yaml\n            with open(args.config) as fh:\n                cfg: dict = yaml.safe_load(fh)\n            for key, val in cfg.items():\n                if hasattr(args, key):\n                    setattr(args, key, val)\n        except ImportError:\n            log.error(\"PyYAML not installed; install with: pip install pyyaml\")\n            sys.exit(1)\n        except Exception as exc:\n            log.error(\"Failed to load config %s: %s\", args.config, exc)\n            sys.exit(1)\n\n    if not args.csv:\n        parser.error(\"At least one --csv file is required (or specify in YAML config).\")\n\n    return args\n\n\ndef main(argv: Optional[List[str]] = None) -> None:\n    args = parse_args(argv)\n\n    pipeline = DataPipeline(\n        fill_strategy=args.fill,\n        fill_value=args.fill_value,\n        scale_strategy=args.scale,\n        scale_columns=args.scale_columns,\n        cat_columns=args.cat_columns,\n        drop_first=args.drop_first,\n        max_categories=args.max_categories,\n        merge_on=args.merge_on,\n    )\n    log.info(\"Pipeline: %s\", pipeline)\n\n    sources = load_csvs(args.csv)\n    if not sources:\n        log.error(\"No CSV files loaded. Exiting.\")\n        sys.exit(1)\n\n    result = pipeline.fit_transform(sources)\n    report(result)\n    save_features(result, args.output)\n\n\nif __name__ == \"__main__\":\n    main()\n"})
