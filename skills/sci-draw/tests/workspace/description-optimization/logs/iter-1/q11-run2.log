TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/clinical_trial_flowchart.py", "content": "#!/usr/bin/env python3\n\"\"\"\nClinical Trial Workflow Flowchart — CONSORT-style\nTarget: NEJM Methods section figure\nStyle: Clean, professional, grayscale-safe with one accent color\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')  # non-interactive backend\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.path import Path\nimport numpy as np\n\n# ──────────────────────────────────────────────\n# Step 3-4: NEJM specs & Style configuration\n# ──────────────────────────────────────────────\n# NEJM typically uses double-column width for flowcharts\n# ~7.0-7.2 inches wide, proportional height\n# Helvetica/Arial font family\n# Clean, minimal, grayscale-friendly\n\nplt.rcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': 8,\n    'axes.linewidth': 0.5,\n    'figure.dpi': 300,\n    'savefig.dpi': 300,\n    'savefig.bbox': 'tight',\n})\n\n# ──────────────────────────────────────────────\n# Color palette — NEJM-appropriate\n# ──────────────────────────────────────────────\n# Primary: deep navy-blue accent (#1A5276)\n# Secondary box fill: very light gray (#F5F5F5)\n# Decision diamond: lighter blue tint (#E8F0F8)\n# Exclusion box: light warm gray (#F8F5F0)\n# Lines/arrows: dark gray (#333333)\n# Text: near-black (#222222)\n# Treatment arms: subtle differentiation\n\nCOLOR_PRIMARY = '#1A5276'      # deep navy-blue accent\nCOLOR_BOX_BG = '#F8F9FA'       # very light gray fill\nCOLOR_DECISION = '#EBF2FA'     # light blue tint for randomization\nCOLOR_EXCLUSION = '#F5F0EB'    # warm light for exclusion box\nCOLOR_ARM_A = '#E8F0F8'        # light blue arm\nCOLOR_ARM_B = '#F0F8F0'        # light green arm\nCOLOR_LINE = '#444444'\nCOLOR_TEXT = '#222222'\nCOLOR_ACCENT = '#1A5276'       # navy accent for title/headers\n\n# ──────────────────────────────────────────────\n# Figure setup\n# ──────────────────────────────────────────────\nfig, ax = plt.subplots(1, 1, figsize=(7.2, 9.8))\nax.set_xlim(0, 10)\nax.set_ylim(0, 13.5)\nax.set_aspect('equal')\nax.axis('off')\n\n# ──────────────────────────────────────────────\n# Helper functions\n# ──────────────────────────────────────────────\n\ndef draw_box(ax, cx, cy, w, h, text_lines, sub_lines=None,\n             facecolor=COLOR_BOX_BG, edgecolor=COLOR_LINE,\n             linewidth=1.2, fontsize=8, sub_fontsize=6.5,\n             bold=False, text_color=COLOR_TEXT, radius=0.15,\n             boxstyle='round,pad=0.1'):\n    \"\"\"Draw a rounded rectangle with centered text.\"\"\"\n    rect = mpatches.FancyBboxPatch(\n        (cx - w/2, cy - h/2), w, h,\n        boxstyle=boxstyle,\n        facecolor=facecolor,\n        edgecolor=edgecolor,\n        linewidth=linewidth,\n        zorder=2,\n    )\n    ax.add_patch(rect)\n\n    # Main text\n    n_lines = len(text_lines)\n    line_spacing = 0.30\n    start_y = cy + (n_lines - 1) * line_spacing / 2\n\n    for i, line in enumerate(text_lines):\n        ax.text(\n            cx, start_y - i * line_spacing, line,\n            ha='center', va='center',\n            fontsize=fontsize,\n            fontweight='bold' if bold else 'normal',\n            color=text_color,\n            zorder=3,\n        )\n\n    # Sub text (smaller, below main text)\n    if sub_lines:\n        n_sub = len(sub_lines)\n        sub_start_y = cy - h/2 + 0.25\n        if n_lines > 1:\n            base_y = start_y - (n_lines - 1) * line_spacing - 0.15\n        else:\n            base_y = cy - 0.15\n\n        for i, line in enumerate(sub_lines):\n            ax.text(\n                cx, base_y - i * 0.22, line,\n                ha='center', va='center',\n                fontsize=sub_fontsize,\n                color=COLOR_LINE,\n                style='italic',\n                zorder=3,\n            )\n\n\ndef draw_decision(ax, cx, cy, size, text_lines,\n                  facecolor=COLOR_DECISION, edgecolor=COLOR_LINE,\n                  linewidth=1.2, fontsize=8, bold=False):\n    \"\"\"Draw a diamond (decision) shape.\"\"\"\n    half = size / 2\n    verts = [\n        (cx, cy + half),          # top\n        (cx + half * 1.3, cy),   # right\n        (cx, cy - half),          # bottom\n        (cx - half * 1.3, cy),   # left\n        (cx, cy + half),          # close\n    ]\n    codes = [Path.MOVETO, Path.LINETO, Path.LINETO, Path.LINETO, Path.CLOSEPOLY]\n    path = Path(verts, codes)\n    patch = mpatches.PathPatch(path, facecolor=facecolor, edgecolor=edgecolor,\n                                linewidth=linewidth, zorder=2)\n    ax.add_patch(patch)\n\n    n_lines = len(text_lines)\n    line_spacing = 0.28\n    start_y = cy + (n_lines - 1) * line_spacing / 2\n\n    for i, line in enumerate(text_lines):\n        ax.text(\n            cx, start_y - i * line_spacing, line,\n            ha='center', va='center',\n            fontsize=fontsize,\n            fontweight='bold' if bold else 'normal',\n            color=COLOR_TEXT,\n            zorder=3,\n        )\n\n\ndef draw_arrow(ax, x1, y1, x2, y2, color=COLOR_LINE, lw=1.0,\n               style='-|>', mutation_scale=12, connectionstyle=None, zorder=1):\n    \"\"\"Draw an arrow between two points.\"\"\"\n    if connectionstyle:\n        arrow = mpatches.FancyArrowPatch(\n            (x1, y1), (x2, y2),\n            arrowstyle=style,\n            color=color,\n            linewidth=lw,\n            mutation_scale=mutation_scale,\n            connectionstyle=connectionstyle,\n            zorder=zorder,\n        )\n    else:\n        arrow = mpatches.FancyArrowPatch(\n            (x1, y1), (x2, y2),\n            arrowstyle=style,\n            color=color,\n            linewidth=lw,\n            mutation_scale=mutation_scale,\n            zorder=zorder,\n        )\n    ax.add_patch(arrow)\n\n\ndef draw_label(ax, x, y, text, fontsize=6.5, color=COLOR_LINE,\n               ha='center', va='center', style='italic'):\n    \"\"\"Draw a small annotation label.\"\"\"\n    ax.text(x, y, text, ha=ha, va=va, fontsize=fontsize,\n            color=color, style=style, zorder=3)\n\n\n# ──────────────────────────────────────────────\n# Figure title\n# ──────────────────────────────────────────────\nax.text(5, 13.0, 'Clinical Trial Flow Diagram', ha='center', va='center',\n        fontsize=11, fontweight='bold', color=COLOR_ACCENT, zorder=3)\n\n# ──────────────────────────────────────────────\n# 1. Enrollment / Assessment\n# ──────────────────────────────────────────────\ndraw_box(ax, 5, 11.5, 4.2, 0.8,\n         text_lines=['Patients Assessed for Eligibility'],\n         sub_lines=['(n = XXX screened)'],\n         bold=True,\n         fontsize=8.5,\n         facecolor=COLOR_BOX_BG)\n\ndraw_arrow(ax, 5, 11.1, 5, 10.35, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 2. Exclusion branch (side)\n# ──────────────────────────────────────────────\ndraw_box(ax, 8.0, 10.1, 2.8, 0.9,\n         text_lines=['Excluded (n = XXX)'],\n         sub_lines=['• Not meeting criteria',\n                    '• Declined to participate',\n                    '• Other reasons'],\n         facecolor=COLOR_EXCLUSION,\n         edgecolor='#999999',\n         fontsize=7.5,\n         sub_fontsize=6)\n\n# Arrow from assessment to exclusion\ndraw_arrow(ax, 6.5, 10.9, 7.5, 10.55,\n           connectionstyle='arc3,rad=-0.25',\n           mutation_scale=8,\n           lw=0.8)\n\n# ──────────────────────────────────────────────\n# 3. Randomization diamond\n# ──────────────────────────────────────────────\ndraw_decision(ax, 5, 9.3, 1.0,\n              text_lines=['Randomized'],\n              bold=True,\n              fontsize=8.5)\n\ndraw_arrow(ax, 5, 10.35, 5, 9.8, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 4. Treatment Arms\n# ──────────────────────────────────────────────\n# Arm A label\ndraw_label(ax, 3.0, 8.75, 'Treatment Arm A', fontsize=7, color=COLOR_ACCENT, style='normal')\n# Arm B label\ndraw_label(ax, 7.0, 8.75, 'Treatment Arm B', fontsize=7, color=COLOR_ACCENT, style='normal')\n\n# Split arrows from randomization\ndraw_arrow(ax, 5, 8.8, 3.0, 8.3, mutation_scale=10)\ndraw_arrow(ax, 5, 8.8, 7.0, 8.3, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 5. Arm A boxes\n# ──────────────────────────────────────────────\ndraw_box(ax, 3.0, 7.6, 3.0, 0.8,\n         text_lines=['Treatment Period'],\n         sub_lines=['(Week 0–24)'],\n         bold=False,\n         facecolor=COLOR_ARM_A,\n         fontsize=7.5)\n\ndraw_box(ax, 3.0, 6.2, 3.0, 0.8,\n         text_lines=['Follow-up Visit 1'],\n         sub_lines=['(Week 12)'],\n         bold=False,\n         facecolor=COLOR_ARM_A,\n         fontsize=7.5)\n\ndraw_box(ax, 3.0, 4.8, 3.0, 0.8,\n         text_lines=['Follow-up Visit 2'],\n         sub_lines=['(Week 24 / EOT)'],\n         bold=False,\n         facecolor=COLOR_ARM_A,\n         fontsize=7.5)\n\ndraw_box(ax, 3.0, 3.4, 3.0, 0.8,\n         text_lines=['Safety Follow-up'],\n         sub_lines=['(Week 28–30)'],\n         bold=False,\n         facecolor=COLOR_ARM_A,\n         fontsize=7.5)\n\n# Arm A arrows\ndraw_arrow(ax, 3.0, 8.3, 3.0, 8.0, mutation_scale=10)\ndraw_arrow(ax, 3.0, 7.2, 3.0, 6.6, mutation_scale=10)\ndraw_arrow(ax, 3.0, 5.8, 3.0, 5.2, mutation_scale=10)\ndraw_arrow(ax, 3.0, 4.4, 3.0, 3.8, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 6. Arm B boxes\n# ──────────────────────────────────────────────\ndraw_box(ax, 7.0, 7.6, 3.0, 0.8,\n         text_lines=['Treatment Period'],\n         sub_lines=['(Week 0–24)'],\n         bold=False,\n         facecolor=COLOR_ARM_B,\n         fontsize=7.5)\n\ndraw_box(ax, 7.0, 6.2, 3.0, 0.8,\n         text_lines=['Follow-up Visit 1'],\n         sub_lines=['(Week 12)'],\n         bold=False,\n         facecolor=COLOR_ARM_B,\n         fontsize=7.5)\n\ndraw_box(ax, 7.0, 4.8, 3.0, 0.8,\n         text_lines=['Follow-up Visit 2'],\n         sub_lines=['(Week 24 / EOT)'],\n         bold=False,\n         facecolor=COLOR_ARM_B,\n         fontsize=7.5)\n\ndraw_box(ax, 7.0, 3.4, 3.0, 0.8,\n         text_lines=['Safety Follow-up'],\n         sub_lines=['(Week 28–30)'],\n         bold=False,\n         facecolor=COLOR_ARM_B,\n         fontsize=7.5)\n\n# Arm B arrows\ndraw_arrow(ax, 7.0, 8.3, 7.0, 8.0, mutation_scale=10)\ndraw_arrow(ax, 7.0, 7.2, 7.0, 6.6, mutation_scale=10)\ndraw_arrow(ax, 7.0, 5.8, 7.0, 5.2, mutation_scale=10)\ndraw_arrow(ax, 7.0, 4.4, 7.0, 3.8, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 7. Discontinuation labels (side annotations)\n# ──────────────────────────────────────────────\ndraw_label(ax, 0.5, 7.0, 'Discontinued (n = XXX)', fontsize=6, color='#888888')\ndraw_label(ax, 0.5, 6.5, '• Adverse event', fontsize=6, color='#888888')\ndraw_label(ax, 0.5, 6.2, '• Withdrew consent', fontsize=6, color='#888888')\ndraw_label(ax, 0.5, 5.9, '• Investigator decision', fontsize=6, color='#888888')\n\ndraw_label(ax, 9.5, 7.0, 'Discontinued (n = XXX)', fontsize=6, color='#888888')\ndraw_label(ax, 9.5, 6.5, '• Adverse event', fontsize=6, color='#888888')\ndraw_label(ax, 9.5, 6.2, '• Withdrew consent', fontsize=6, color='#888888')\ndraw_label(ax, 9.5, 5.9, '• Investigator decision', fontsize=6, color='#888888')\n\n# Dashed lines from discontinuation boxes to arms\nax.plot([0.5, 2.0], [6.8, 6.8], color='#CCCCCC', lw=0.6, ls='--', zorder=1)\nax.plot([2.0, 2.0], [6.8, 5.8], color='#CCCCCC', lw=0.6, ls='--', zorder=1)\n\nax.plot([9.5, 8.0], [6.8, 6.8], color='#CCCCCC', lw=0.6, ls='--', zorder=1)\nax.plot([8.0, 8.0], [6.8, 5.8], color='#CCCCCC', lw=0.6, ls='--', zorder=1)\n\n# ──────────────────────────────────────────────\n# 8. Merge to Analysis\n# ──────────────────────────────────────────────\n# Dashed merge lines from bottom of each arm\nax.plot([3.0, 5.0], [2.9, 2.4], color=COLOR_LINE, lw=0.8, ls='-', zorder=1)\nax.plot([7.0, 5.0], [2.9, 2.4], color=COLOR_LINE, lw=0.8, ls='-', zorder=1)\nax.plot([5.0, 5.0], [2.4, 2.1], color=COLOR_LINE, lw=0.8,\n        zorder=1)\n# Arrow head\ndraw_arrow(ax, 5.0, 2.6, 5.0, 2.4, mutation_scale=8, lw=0.8)\n\n# ──────────────────────────────────────────────\n# 9. Analysis box\n# ──────────────────────────────────────────────\ndraw_box(ax, 5, 1.6, 4.5, 0.9,\n         text_lines=['Final Analysis'],\n         sub_lines=['Intention-to-treat population (n = XXX)',\n                    'Per-protocol population (n = XXX)'],\n         bold=True,\n         fontsize=8.5,\n         facecolor=COLOR_BOX_BG,\n         edgecolor=COLOR_PRIMARY,\n         linewidth=1.5)\n\n# ──────────────────────────────────────────────\n# Legend / footnote at bottom\n# ──────────────────────────────────────────────\nax.text(5, 0.3, 'EOT = End of Treatment',\n        ha='center', va='center', fontsize=6.5, color='#888888',\n        style='italic', zorder=3)\n\n# ──────────────────────────────────────────────\n# Export\n# ──────────────────────────────────────────────\noutput_base = '/home/joe/Documents/repo/skill/sci-draw/clinical_trial_flowchart'\nplt.savefig(f'{output_base}.pdf', dpi=300, bbox_inches='tight', pad_inches=0.3)\nplt.savefig(f'{output_base}.png', dpi=300, bbox_inches='tight', pad_inches=0.3)\nprint(f'Exported: {output_base}.pdf')\nprint(f'Exported: {output_base}.png')\nplt.close()\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/clinical_trial_flowchart.py", "content": "#!/usr/bin/env python3\n\"\"\"\nClinical Trial Workflow Flowchart — CONSORT-style\nTarget: NEJM Methods section figure\nStyle: Clean, professional, grayscale-safe with one accent color\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')  # non-interactive backend\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.path import Path\nimport numpy as np\n\n# ──────────────────────────────────────────────\n# Step 3-4: NEJM specs & Style configuration\n# ──────────────────────────────────────────────\n# NEJM typically uses double-column width for flowcharts\n# ~7.0-7.2 inches wide, proportional height\n# Helvetica/Arial font family\n# Clean, minimal, grayscale-friendly\n\nplt.rcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': 8,\n    'axes.linewidth': 0.5,\n    'figure.dpi': 300,\n    'savefig.dpi': 300,\n    'savefig.bbox': 'tight',\n})\n\n# ──────────────────────────────────────────────\n# Color palette — NEJM-appropriate\n# ──────────────────────────────────────────────\n# Primary: deep navy-blue accent (#1A5276)\n# Secondary box fill: very light gray (#F5F5F5)\n# Decision diamond: lighter blue tint (#E8F0F8)\n# Exclusion box: light warm gray (#F8F5F0)\n# Lines/arrows: dark gray (#333333)\n# Text: near-black (#222222)\n# Treatment arms: subtle differentiation\n\nCOLOR_PRIMARY = '#1A5276'      # deep navy-blue accent\nCOLOR_BOX_BG = '#F8F9FA'       # very light gray fill\nCOLOR_DECISION = '#EBF2FA'     # light blue tint for randomization\nCOLOR_EXCLUSION = '#F5F0EB'    # warm light for exclusion box\nCOLOR_ARM_A = '#E8F0F8'        # light blue arm\nCOLOR_ARM_B = '#F0F8F0'        # light green arm  \nCOLOR_LINE = '#444444'\nCOLOR_TEXT = '#222222'\nCOLOR_ACCENT = '#1A5276'       # navy accent for title/headers\n\n# ──────────────────────────────────────────────\n# Figure setup\n# ──────────────────────────────────────────────\nfig, ax = plt.subplots(1, 1, figsize=(7.2, 9.8))\nax.set_xlim(0, 10)\nax.set_ylim(0, 13.5)\nax.set_aspect('equal')\nax.axis('off')\n\n# ──────────────────────────────────────────────\n# Helper functions\n# ──────────────────────────────────────────────\n\ndef draw_box(ax, cx, cy, w, h, text_lines, sub_lines=None,\n             facecolor=COLOR_BOX_BG, edgecolor=COLOR_LINE,\n             linewidth=1.2, fontsize=8, sub_fontsize=6.5,\n             bold=False, text_color=COLOR_TEXT, radius=0.15,\n             boxstyle='round,pad=0.1'):\n    \"\"\"Draw a rounded rectangle with centered text.\"\"\"\n    rect = mpatches.FancyBboxPatch(\n        (cx - w/2, cy - h/2), w, h,\n        boxstyle=boxstyle,\n        facecolor=facecolor,\n        edgecolor=edgecolor,\n        linewidth=linewidth,\n        zorder=2,\n    )\n    ax.add_patch(rect)\n    \n    # Main text\n    n_lines = len(text_lines)\n    line_spacing = 0.30\n    start_y = cy + (n_lines - 1) * line_spacing / 2\n    \n    for i, line in enumerate(text_lines):\n        ax.text(\n            cx, start_y - i * line_spacing, line,\n            ha='center', va='center',\n            fontsize=fontsize,\n            fontweight='bold' if bold else 'normal',\n            color=text_color,\n            zorder=3,\n        )\n    \n    # Sub text (smaller, below main text)\n    if sub_lines:\n        n_sub = len(sub_lines)\n        sub_start_y = cy - h/2 + 0.25\n        if n_lines > 1:\n            base_y = start_y - (n_lines - 1) * line_spacing - 0.15\n        else:\n            base_y = cy - 0.15\n        \n        for i, line in enumerate(sub_lines):\n            ax.text(\n                cx, base_y - i * 0.22, line,\n                ha='center', va='center',\n                fontsize=sub_fontsize,\n                color=COLOR_LINE,\n                style='italic',\n                zorder=3,\n            )\n\n\ndef draw_decision(ax, cx, cy, size, text_lines,\n                  facecolor=COLOR_DECISION, edgecolor=COLOR_LINE,\n                  linewidth=1.2, fontsize=8, bold=False):\n    \"\"\"Draw a diamond (decision) shape.\"\"\"\n    half = size / 2\n    verts = [\n        (cx, cy + half),          # top\n        (cx + half * 1.3, cy),   # right\n        (cx, cy - half),          # bottom\n        (cx - half * 1.3, cy),   # left\n        (cx, cy + half),          # close\n    ]\n    codes = [Path.MOVETO, Path.LINETO, Path.LINETO, Path.LINETO, Path.CLOSEPOLY]\n    path = Path(verts, codes)\n    patch = mpatches.PathPatch(path, facecolor=facecolor, edgecolor=edgecolor,\n                                linewidth=linewidth, zorder=2)\n    ax.add_patch(patch)\n    \n    n_lines = len(text_lines)\n    line_spacing = 0.28\n    start_y = cy + (n_lines - 1) * line_spacing / 2\n    \n    for i, line in enumerate(text_lines):\n        ax.text(\n            cx, start_y - i * line_spacing, line,\n            ha='center', va='center',\n            fontsize=fontsize,\n            fontweight='bold' if bold else 'normal',\n            color=COLOR_TEXT,\n            zorder=3,\n        )\n\n\ndef draw_arrow(ax, x1, y1, x2, y2, color=COLOR_LINE, lw=1.0,\n               style='-|>', mutation_scale=12, connectionstyle=None, zorder=1):\n    \"\"\"Draw an arrow between two points.\"\"\"\n    if connectionstyle:\n        arrow = mpatches.FancyArrowPatch(\n            (x1, y1), (x2, y2),\n            arrowstyle=style,\n            color=color,\n            linewidth=lw,\n            mutation_scale=mutation_scale,\n            connectionstyle=connectionstyle,\n            zorder=zorder,\n        )\n    else:\n        arrow = mpatches.FancyArrowPatch(\n            (x1, y1), (x2, y2),\n            arrowstyle=style,\n            color=color,\n            linewidth=lw,\n            mutation_scale=mutation_scale,\n            zorder=zorder,\n        )\n    ax.add_patch(arrow)\n\n\ndef draw_label(ax, x, y, text, fontsize=6.5, color=COLOR_LINE,\n               ha='center', va='center', style='italic'):\n    \"\"\"Draw a small annotation label.\"\"\"\n    ax.text(x, y, text, ha=ha, va=va, fontsize=fontsize,\n            color=color, style=style, zorder=3)\n\n\n# ──────────────────────────────────────────────\n# Figure title\n# ──────────────────────────────────────────────\nax.text(5, 13.0, 'Clinical Trial Flow Diagram', ha='center', va='center',\n        fontsize=11, fontweight='bold', color=COLOR_ACCENT, zorder=3)\n\n# ──────────────────────────────────────────────\n# 1. Enrollment / Assessment\n# ──────────────────────────────────────────────\ndraw_box(ax, 5, 11.5, 4.2, 0.8,\n         text_lines=['Patients Assessed for Eligibility'],\n         sub_lines=['(n = XXX screened)'],\n         bold=True,\n         fontsize=8.5,\n         facecolor=COLOR_BOX_BG)\n\ndraw_arrow(ax, 5, 11.1, 5, 10.35, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 2. Exclusion branch (side)\n# ──────────────────────────────────────────────\ndraw_box(ax, 8.0, 10.1, 2.8, 0.9,\n         text_lines=['Excluded (n = XXX)'],\n         sub_lines=['• Not meeting criteria',\n                    '• Declined to participate',\n                    '• Other reasons'],\n         facecolor=COLOR_EXCLUSION,\n         edgecolor='#999999',\n         fontsize=7.5,\n         sub_fontsize=6)\n\n# Arrow from assessment to exclusion\ndraw_arrow(ax, 6.5, 10.9, 7.5, 10.55, \n           connectionstyle='arc3,rad=-0.25',\n           mutation_scale=8,\n           lw=0.8)\n\n# ──────────────────────────────────────────────\n# 3. Randomization diamond\n# ──────────────────────────────────────────────\ndraw_decision(ax, 5, 9.3, 1.0,\n              text_lines=['Randomized'],\n              bold=True,\n              fontsize=8.5)\n\ndraw_arrow(ax, 5, 10.35, 5, 9.8, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 4. Treatment Arms\n# ──────────────────────────────────────────────\n# Arm A label\ndraw_label(ax, 3.0, 8.75, 'Treatment Arm A', fontsize=7, color=COLOR_ACCENT, style='normal')\n# Arm B label\ndraw_label(ax, 7.0, 8.75, 'Treatment Arm B', fontsize=7, color=COLOR_ACCENT, style='normal')\n\n# Split arrows from randomization\ndraw_arrow(ax, 5, 8.8, 3.0, 8.3, mutation_scale=10)\ndraw_arrow(ax, 5, 8.8, 7.0, 8.3, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 5. Arm A boxes\n# ──────────────────────────────────────────────\ndraw_box(ax, 3.0, 7.6, 3.0, 0.8,\n         text_lines=['Treatment Period'],\n         sub_lines=['(Week 0–24)'],\n         bold=False,\n         facecolor=COLOR_ARM_A,\n         fontsize=7.5)\n\ndraw_box(ax, 3.0, 6.2, 3.0, 0.8,\n         text_lines=['Follow-up Visit 1'],\n         sub_lines=['(Week 12)'],\n         bold=False,\n         facecolor=COLOR_ARM_A,\n         fontsize=7.5)\n\ndraw_box(ax, 3.0, 4.8, 3.0, 0.8,\n         text_lines=['Follow-up Visit 2'],\n         sub_lines=['(Week 24 / EOT)'],\n         bold=False,\n         facecolor=COLOR_ARM_A,\n         fontsize=7.5)\n\ndraw_box(ax, 3.0, 3.4, 3.0, 0.8,\n         text_lines=['Safety Follow-up'],\n         sub_lines=['(Week 28–30)'],\n         bold=False,\n         facecolor=COLOR_ARM_A,\n         fontsize=7.5)\n\n# Arm A arrows\ndraw_arrow(ax, 3.0, 8.3, 3.0, 8.0, mutation_scale=10)\ndraw_arrow(ax, 3.0, 7.2, 3.0, 6.6, mutation_scale=10)\ndraw_arrow(ax, 3.0, 5.8, 3.0, 5.2, mutation_scale=10)\ndraw_arrow(ax, 3.0, 4.4, 3.0, 3.8, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 6. Arm B boxes\n# ──────────────────────────────────────────────\ndraw_box(ax, 7.0, 7.6, 3.0, 0.8,\n         text_lines=['Treatment Period'],\n         sub_lines=['(Week 0–24)'],\n         bold=False,\n         facecolor=COLOR_ARM_B,\n         fontsize=7.5)\n\ndraw_box(ax, 7.0, 6.2, 3.0, 0.8,\n         text_lines=['Follow-up Visit 1'],\n         sub_lines=['(Week 12)'],\n         bold=False,\n         facecolor=COLOR_ARM_B,\n         fontsize=7.5)\n\ndraw_box(ax, 7.0, 4.8, 3.0, 0.8,\n         text_lines=['Follow-up Visit 2'],\n         sub_lines=['(Week 24 / EOT)'],\n         bold=False,\n         facecolor=COLOR_ARM_B,\n         fontsize=7.5)\n\ndraw_box(ax, 7.0, 3.4, 3.0, 0.8,\n         text_lines=['Safety Follow-up'],\n         sub_lines=['(Week 28–30)'],\n         bold=False,\n         facecolor=COLOR_ARM_B,\n         fontsize=7.5)\n\n# Arm B arrows\ndraw_arrow(ax, 7.0, 8.3, 7.0, 8.0, mutation_scale=10)\ndraw_arrow(ax, 7.0, 7.2, 7.0, 6.6, mutation_scale=10)\ndraw_arrow(ax, 7.0, 5.8, 7.0, 5.2, mutation_scale=10)\ndraw_arrow(ax, 7.0, 4.4, 7.0, 3.8, mutation_scale=10)\n\n# ──────────────────────────────────────────────\n# 7. Discontinuation labels (side annotations)\n# ──────────────────────────────────────────────\ndraw_label(ax, 0.5, 7.0, 'Discontinued (n = XXX)', fontsize=6, color='#888888')\ndraw_label(ax, 0.5, 6.5, '• Adverse event', fontsize=6, color='#888888')\ndraw_label(ax, 0.5, 6.2, '• Withdrew consent', fontsize=6, color='#888888')\ndraw_label(ax, 0.5, 5.9, '• Investigator decision', fontsize=6, color='#888888')\n\ndraw_label(ax, 9.5, 7.0, 'Discontinued (n = XXX)', fontsize=6, color='#888888')\ndraw_label(ax, 9.5, 6.5, '• Adverse event', fontsize=6, color='#888888')\ndraw_label(ax, 9.5, 6.2, '• Withdrew consent', fontsize=6, color='#888888')\ndraw_label(ax, 9.5, 5.9, '• Investigator decision', fontsize=6, color='#888888')\n\n# Dashed lines from discontinuation boxes to arms\nax.plot([0.5, 2.0], [6.8, 6.8], color='#CCCCCC', lw=0.6, ls='--', zorder=1)\nax.plot([2.0, 2.0], [6.8, 5.8], color='#CCCCCC', lw=0.6, ls='--', zorder=1)\n\nax.plot([9.5, 8.0], [6.8, 6.8], color='#CCCCCC', lw=0.6, ls='--', zorder=1)\nax.plot([8.0, 8.0], [6.8, 5.8], color='#CCCCCC', lw=0.6, ls='--', zorder=1)\n\n# ──────────────────────────────────────────────\n# 8. Merge to Analysis\n# ──────────────────────────────────────────────\n# Dashed merge lines from bottom of each arm\nax.plot([3.0, 5.0], [2.9, 2.4], color=COLOR_LINE, lw=0.8, ls='-', zorder=1)\nax.plot([7.0, 5.0], [2.9, 2.4], color=COLOR_LINE, lw=0.8, ls='-', zorder=1)\nax.plot([5.0, 5.0], [2.4, 2.1], color=COLOR_LINE, lw=0.8,\n        zorder=1)\n# Arrow head\ndraw_arrow(ax, 5.0, 2.6, 5.0, 2.4, mutation_scale=8, lw=0.8)\n\n# ──────────────────────────────────────────────\n# 9. Analysis box\n# ──────────────────────────────────────────────\ndraw_box(ax, 5, 1.6, 4.5, 0.9,\n         text_lines=['Final Analysis'],\n         sub_lines=['Intention-to-treat population (n = XXX)',\n                    'Per-protocol population (n = XXX)'],\n         bold=True,\n         fontsize=8.5,\n         facecolor=COLOR_BOX_BG,\n         edgecolor=COLOR_PRIMARY,\n         linewidth=1.5)\n\n# ──────────────────────────────────────────────\n# Legend / footnote at bottom\n# ──────────────────────────────────────────────\nax.text(5, 0.3, 'EOT = End of Treatment',\n        ha='center', va='center', fontsize=6.5, color='#888888',\n        style='italic', zorder=3)\n\n# ──────────────────────────────────────────────\n# Export\n# ──────────────────────────────────────────────\noutput_base = '/home/joe/Documents/repo/skill/sci-draw/clinical_trial_flowchart'\nplt.savefig(f'{output_base}.pdf', dpi=300, bbox_inches='tight', pad_inches=0.3)\nplt.savefig(f'{output_base}.png', dpi=300, bbox_inches='tight', pad_inches=0.3)\nprint(f'Exported: {output_base}.pdf')\nprint(f'Exported: {output_base}.png')\nplt.close()\n"})
