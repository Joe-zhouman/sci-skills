TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/ga_epr_drug_release.py", "content": "#!/usr/bin/env python3\n\"\"\"\nGraphical Abstract: Nanomedicine EPR effect and pH-responsive drug release\n=========================================================================\nConceptual schematic for high-impact journal submission.\nNo data — pure illustration with arrows and annotations.\n\nDesign flow (left to right):\n  Blood vessel (nanoparticles circulating)\n    → EPR effect (extravasation through leaky endothelium)\n    → Tumor microenvironment (acidic pH triggers drug release)\n    → Tumor cell apoptosis\n\nOutput: 600 DPI TIFF/PNG, publication-ready\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.path import Path\nimport numpy as np\nfrom matplotlib.patches import (\n    Circle, Ellipse, FancyBboxPatch, FancyArrowPatch, Polygon, Arc, Rectangle\n)\nimport matplotlib.patheffects as pe\n\n# =========================================================================\n# COLOR PALETTE (professional, accessible)\n# =========================================================================\nC_BLOOD_VESSEL   = '#DC6C6C'   # blood vessel lining\nC_EC             = '#C0392B'   # endothelial cell\nC_BLOOD_BG       = '#FDE8E8'   # blood background\nC_NP_SHELL       = '#2E86C1'   # nanoparticle shell (blue)\nC_NP_CORE        = '#1A5276'   # nanoparticle core\nC_DRUG           = '#28B463'   # drug molecules (green)\nC_DRUG_GLOW      = '#ABEBC6'   # drug release glow\nC_TUMOR          = '#8E44AD'   # tumor cell (purple)\nC_TUMOR_NUCLEUS  = '#6C3483'   # tumor cell nucleus\nC_TUMOR_BG       = '#F5EEF8'   # tumor background\nC_PH_ACID        = '#F39C12'   # acidic pH indicator\nC_PH_NEUTRAL     = '#2ECC71'   # neutral pH\nC_ARROW          = '#444444'   # arrow color\nC_LABEL          = '#2C3E50'   # dark label text\nC_HIGHLIGHT      = '#E74C3C'   # highlight (EPR emphasis)\nC_STROKE         = '#333333'   # outline stroke\nC_NORMAL_CELL    = '#5DADE2'   # normal cell (for comparison)\nC_H_PLUS         = '#E67E22'   # H+ ions\nC_RBC            = '#E74C3C'   # red blood cell\n\n# =========================================================================\n# FIGURE SETUP\n# =========================================================================\nw_inch, h_inch = 11.5, 5.5\nfig, ax = plt.subplots(1, 1, figsize=(w_inch, h_inch))\nax.set_xlim(0, 11.5)\nax.set_ylim(0, 5.5)\nax.set_aspect('equal')\nax.axis('off')\n\n# =========================================================================\n# HELPER DRAWING FUNCTIONS\n# =========================================================================\n\ndef set_stroke(artist, lw=1.5, color=C_STROKE):\n    \"\"\"Add stroke effect to an artist.\"\"\"\n    artist.set_edgecolor(color)\n    artist.set_linewidth(lw)\n\n\ndef draw_rounded_rect(ax, x, y, w, h, fc='white', ec=C_STROKE, lw=1.5,\n                       alpha=1.0, zorder=0):\n    \"\"\"Draw a rounded rectangle.\"\"\"\n    rect = FancyBboxPatch(\n        (x, y), w, h,\n        boxstyle=\"round,pad=0.08\",\n        facecolor=fc, edgecolor=ec,\n        linewidth=lw, alpha=alpha,\n        zorder=zorder\n    )\n    ax.add_patch(rect)\n    return rect\n\n\ndef draw_arrow(ax, x1, y1, x2, y2, color=C_ARROW, lw=2.2,\n                style='->', connectionstyle='arc3,rad=0',\n                arrowsize=20, zorder=100):\n    \"\"\"Draw a curved or straight arrow.\"\"\"\n    arrow = FancyArrowPatch(\n        (x1, y1), (x2, y2),\n        arrowstyle=style,\n        color=color,\n        linewidth=lw,\n        connectionstyle=connectionstyle,\n        mutation_scale=arrowsize,\n        zorder=zorder\n    )\n    ax.add_patch(arrow)\n    return arrow\n\n\ndef draw_nanoparticle(ax, x, y, r=0.20, shell_color=C_NP_SHELL,\n                       core_color=C_NP_CORE, stroke_lw=1.0, zorder=50):\n    \"\"\"Draw a core-shell nanoparticle.\"\"\"\n    # Outer shell (blue circle)\n    shell = Circle((x, y), r, fc=shell_color, ec=C_STROKE,\n                    lw=stroke_lw, zorder=zorder, alpha=0.9)\n    ax.add_patch(shell)\n\n    # Inner core (darker)\n    core = Circle((x, y), r*0.55, fc=core_color, ec='none',\n                   zorder=zorder+1, alpha=0.9)\n    ax.add_patch(core)\n\n    # Subtle highlight on shell\n    highlight = Circle((x-r*0.2, y+r*0.2), r*0.3,\n                        fc='white', ec='none', alpha=0.35, zorder=zorder+2)\n    ax.add_patch(highlight)\n\n    return shell, core\n\n\ndef draw_nanoparticle_releasing(ax, x, y, r=0.25, zorder=50):\n    \"\"\"Draw a nanoparticle that is releasing drug (slightly disrupted shell).\"\"\"\n    # Disrupted shell (dashed appearance - use partial arcs)\n    angles = np.linspace(0, 2*np.pi, 40)\n    # Draw shell with gaps\n    for i in range(0, 40, 4):\n        start_a = angles[i]\n        end_a = angles[min(i+2, 39)]\n        arc_x = x + r * np.cos(np.linspace(start_a, end_a, 10))\n        arc_y = y + r * np.sin(np.linspace(start_a, end_a, 10))\n        ax.plot(arc_x, arc_y, color=C_STROKE, lw=1.5, zorder=zorder, solid_capstyle='round')\n\n    # Inner core (degrading - smaller, less opaque)\n    core = Circle((x, y), r*0.45, fc=C_NP_CORE, ec='none',\n                   alpha=0.4, zorder=zorder+1)\n    ax.add_patch(core)\n\n    # Small drug molecules escaping\n    drug_positions = [\n        (x + r*1.3, y + r*0.5),\n        (x + r*1.6, y - r*0.3),\n        (x - r*0.8, y + r*1.4),\n        (x + r*0.3, y - r*1.5),\n        (x - r*1.2, y - r*0.8),\n    ]\n    for dx, dy in drug_positions:\n        drug = Circle((dx, dy), r*0.18, fc=C_DRUG, ec=C_STROKE,\n                       lw=0.8, alpha=0.85, zorder=zorder+2)\n        ax.add_patch(drug)\n\n\ndef draw_drug_molecule(ax, x, y, size=0.08, zorder=60):\n    \"\"\"Draw a small drug molecule as a circle with glow.\"\"\"\n    # Glow\n    glow = Circle((x, y), size*2.5, fc=C_DRUG_GLOW, ec='none',\n                   alpha=0.3, zorder=zorder)\n    ax.add_patch(glow)\n    # Core\n    drug = Circle((x, y), size, fc=C_DRUG, ec=C_STROKE,\n                   lw=0.6, zorder=zorder+1)\n    ax.add_patch(drug)\n    return drug\n\n\ndef draw_endothelial_cell(ax, x, y, w, h, zorder=10):\n    \"\"\"Draw a stylized endothelial cell (elongated, curved shape).\"\"\"\n    # Elongated elliptical cell\n    cell = Ellipse((x, y), w, h, fc=C_EC, ec=C_STROKE, lw=1.2,\n                    alpha=0.85, zorder=zorder)\n    ax.add_patch(cell)\n    # Nucleus (darker)\n    nucleus = Ellipse((x, y), w*0.35, h*0.5, fc='#922B21', ec='none',\n                       alpha=0.5, zorder=zorder+1)\n    ax.add_patch(nucleus)\n    return cell\n\n\ndef draw_tumor_cell(ax, x, y, scale=1.0, zorder=20):\n    \"\"\"Draw a stylized tumor cell with irregular shape.\"\"\"\n    r = 0.45 * scale\n    # Create irregular shape using a star-like polygon\n    n_points = 12\n    angles = np.linspace(0, 2*np.pi, n_points, endpoint=False)\n    # Add slight irregularity\n    radii = r + r * 0.15 * np.sin(angles * 3) + r * 0.1 * np.cos(angles * 2)\n    verts = [(x + radii[i] * np.cos(angles[i]),\n              y + radii[i] * np.sin(angles[i]))\n             for i in range(n_points)]\n\n    cell = Polygon(verts, fc=C_TUMOR, ec=C_STROKE, lw=1.5,\n                    alpha=0.9, zorder=zorder)\n    ax.add_patch(cell)\n\n    # Nucleus (larger, irregular - cancer hallmark)\n    nuc_r = r * 0.55\n    nuc_angles = np.linspace(0, 2*np.pi, 8, endpoint=False)\n    nuc_radii = nuc_r + nuc_r * 0.2 * np.sin(nuc_angles * 2)\n    nuc_verts = [(x + nuc_radii[i] * np.cos(nuc_angles[i]),\n                   y + nuc_radii[i] * np.sin(nuc_angles[i]))\n                  for i in range(8)]\n    nucleus = Polygon(nuc_verts, fc=C_TUMOR_NUCLEUS, ec='none',\n                       alpha=0.7, zorder=zorder+1)\n    ax.add_patch(nucleus)\n\n    return cell, nucleus\n\n\ndef draw_normal_cell(ax, x, y, scale=1.0, zorder=20):\n    \"\"\"Draw a normal (healthy) cell for comparison.\"\"\"\n    r = 0.40 * scale\n    cell = Circle((x, y), r, fc=C_NORMAL_CELL, ec=C_STROKE,\n                   lw=1.2, alpha=0.7, zorder=zorder)\n    ax.add_patch(cell)\n    nucleus = Circle((x, y), r*0.4, fc='#1B4F72', ec='none',\n                      alpha=0.5, zorder=zorder+1)\n    ax.add_patch(nucleus)\n    return cell, nucleus\n\n\ndef draw_H_plus(ax, x, y, zorder=40):\n    \"\"\"Draw H+ ion symbol.\"\"\"\n    text = ax.text(x, y, 'H⁺', fontsize=9, fontweight='bold',\n                    color=C_H_PLUS, ha='center', va='center',\n                    zorder=zorder)\n    # Add a subtle circle behind\n    bg = Circle((x, y), 0.12, fc='white', ec=C_H_PLUS, lw=1.0,\n                 alpha=0.7, zorder=zorder-1)\n    ax.add_patch(bg)\n    return text\n\n\ndef draw_label(ax, x, y, text, fontsize=10, fontweight='bold',\n                color=C_LABEL, ha='center', va='center',\n                bg_color='white', bg_alpha=0.8, zorder=200,\n                arrow_pts=None):\n    \"\"\"Draw a label with optional background and pointer arrow.\"\"\"\n    # Add background for readability\n    if bg_color:\n        txt = ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n                       color=color, ha=ha, va=va, zorder=zorder,\n                       path_effects=[pe.withStroke(linewidth=3, foreground=bg_color, alpha=bg_alpha)])\n    else:\n        txt = ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n                       color=color, ha=ha, va=va, zorder=zorder)\n\n    # Optional pointer arrow\n    if arrow_pts:\n        ax.annotate('', xy=(arrow_pts[0], arrow_pts[1]), xytext=(x, y),\n                     arrowprops=dict(arrowstyle='->', color=C_ARROW,\n                                     lw=1.2, connectionstyle='arc3,rad=0'),\n                     zorder=zorder-1)\n    return txt\n\n\ndef draw_blood_vessel_bg(ax, x1, x2, y_center, thickness):\n    \"\"\"Draw a blood vessel cross-section.\"\"\"\n    y_bot = y_center - thickness/2\n    y_top = y_center + thickness/2\n\n    # Vessel lumen (blood background)\n    lumen = FancyBboxPatch(\n        (x1, y_bot), x2 - x1, thickness,\n        boxstyle=\"round,pad=0.05\",\n        fc=C_BLOOD_BG, ec=C_STROKE, lw=2.0, zorder=1\n    )\n    ax.add_patch(lumen)\n\n    # Vessel wall (top and bottom lines)\n    # Top wall\n    ax.plot([x1, x2], [y_top, y_top], color=C_EC, lw=3, zorder=2)\n    ax.plot([x1, x2], [y_bot, y_bot], color=C_EC, lw=3, zorder=2)\n\n    return y_bot, y_top\n\n# =========================================================================\n# SECTION 1: BLOOD VESSEL WITH CIRCULATING NANOPARTICLES\n# =========================================================================\n# Coordinates\nVESSEL_Y = 3.2\nVESSEL_H = 1.3\nVESSEL_X1 = 0.3\nVESSEL_X2 = 3.8\n\ndraw_blood_vessel_bg(ax, VESSEL_X1, VESSEL_X2, VESSEL_Y, VESSEL_H)\n\n# Endothelial cells lining the vessel\nec_positions = [0.7, 1.5, 2.3, 3.1]\nfor i, ex in enumerate(ec_positions):\n    ey = VESSEL_Y - 0.65 if i % 2 == 0 else VESSEL_Y + 0.65\n    draw_endothelial_cell(ax, ex, ey, 0.5, 0.22)\n\n# Red blood cells\nrbc_positions = [(1.0, 3.3), (2.8, 3.5), (1.8, 2.9)]\nfor rx, ry in rbc_positions:\n    rbc = Ellipse((rx, ry), 0.25, 0.15, fc=C_RBC, ec=C_STROKE,\n                   lw=0.8, alpha=0.6, zorder=30)\n    ax.add_patch(rbc)\n\n# Nanoparticles in blood vessel\nnp_positions_blood = [(1.2, 3.1), (2.0, 3.5), (3.0, 3.0), (1.6, 3.7), (2.5, 3.3)]\nfor nx, ny in np_positions_blood:\n    draw_nanoparticle(ax, nx, ny, r=0.18)\n\n# Flow direction arrows in vessel\ndraw_arrow(ax, 0.6, VESSEL_Y, 1.0, VESSEL_Y, color='#999',\n            lw=1.5, arrowsize=12, zorder=5)\ndraw_arrow(ax, 1.8, VESSEL_Y, 2.2, VESSEL_Y, color='#999',\n            lw=1.5, arrowsize=12, zorder=5)\ndraw_arrow(ax, 3.0, VESSEL_Y, 3.4, VESSEL_Y, color='#999',\n            lw=1.5, arrowsize=12, zorder=5)\n\n# Labels\ndraw_label(ax, 2.05, 4.55, 'Blood Vessel', fontsize=12, fontweight='bold')\ndraw_label(ax, 2.05, 4.15, '(Neutral pH ~7.4)', fontsize=8, color='#777')\n\n# pH neutral indicator near vessel\ndraw_label(ax, 3.5, 4.2, 'pH 7.4', fontsize=7, color=C_PH_NEUTRAL,\n            bg_color='white')\n\n# =========================================================================\n# SECTION 2: EPR EFFECT — EXTRAVASATION\n# =========================================================================\n# Leaky blood vessel (right portion with gaps)\nLEAKY_X1 = 3.9\nLEAKY_X2 = 5.2\ndraw_blood_vessel_bg(ax, LEAKY_X1, LEAKY_X2, VESSEL_Y, VESSEL_H)\n\n# Create gaps in the vessel wall (fenestrations)\n# Top wall gaps\ngap_y = VESSEL_Y + VESSEL_H/2\nax.plot([LEAKY_X1+0.2, LEAKY_X1+0.5], [gap_y, gap_y], color=C_EC, lw=3, zorder=2)\nax.plot([LEAKY_X1+0.7, LEAKY_X2-0.1], [gap_y, gap_y], color=C_EC, lw=3, zorder=2)\n# Gap visible - blank space\n\n# Bottom wall gaps\ngap_y_bot = VESSEL_Y - VESSEL_H/2\nax.plot([LEAKY_X1+0.1, LEAKY_X1+0.5], [gap_y_bot, gap_y_bot], color=C_EC, lw=3, zorder=2)\nax.plot([LEAKY_X1+0.7, LEAKY_X2-0.2], [gap_y_bot, gap_y_bot], color=C_EC, lw=3, zorder=2)\n# Gap visible at bottom\n\n# Endothelial cells around the leaky region\ndraw_endothelial_cell(ax, 4.2, VESSEL_Y-0.65, 0.45, 0.2)\ndraw_endothelial_cell(ax, 4.9, VESSEL_Y+0.65, 0.45, 0.2)\n\n# Nanoparticles extravasating through gaps\n# Through top gap\ndraw_nanoparticle(ax, 4.35, VESSEL_Y+VESSEL_H/2-0.1, r=0.15, zorder=45)\ndraw_nanoparticle(ax, 4.6, VESSEL_Y+VESSEL_H/2+0.25, r=0.15, zorder=45)\ndraw_nanoparticle(ax, 4.9, VESSEL_Y+VESSEL_H/2+0.55, r=0.15, zorder=45)\n\n# Through bottom gap\ndraw_nanoparticle(ax, 4.5, VESSEL_Y-VESSEL_H/2+0.15, r=0.15, zorder=45)\ndraw_nanoparticle(ax, 4.8, VESSEL_Y-VESSEL_H/2-0.30, r=0.15, zorder=45)\n\n# Extravasation arrows\ndraw_arrow(ax, 4.35, VESSEL_Y+VESSEL_H/2-0.25, 4.35, VESSEL_Y+VESSEL_H/2+0.05,\n            color=C_ARROW, lw=1.8, arrowsize=12, zorder=100)\ndraw_arrow(ax, 4.5, VESSEL_Y-VESSEL_H/2+0.30, 4.5, VESSEL_Y-VESSEL_H/2-0.05,\n            color=C_ARROW, lw=1.8, arrowsize=12, zorder=100)\n\n# EPR label\ndraw_label(ax, 4.55, 4.55, 'EPR Effect', fontsize=12, fontweight='bold',\n            color=C_HIGHLIGHT)\ndraw_label(ax, 4.55, 4.20, 'Leaky Vasculature', fontsize=8, color='#777')\ndraw_label(ax, 4.55, 3.95, '↓ Permeability', fontsize=7, color='#777')\n\n# Label the gap\ndraw_label(ax, 5.1, VESSEL_Y+VESSEL_H/2, 'Fenestration', fontsize=7,\n            color='#666', bg_color='#FFF')\n\n# =========================================================================\n# SECTION 3: TUMOR MICROENVIRONMENT\n# =========================================================================\nTUMOR_X1 = 5.5\nTUMOR_X2 = 11.2\n\n# Subtle background for tumor region (not a box, just a faint fill)\ntumor_bg_verts = [\n    (TUMOR_X1, 0.3), (TUMOR_X2, 0.3), (TUMOR_X2, 5.2), (TUMOR_X1, 5.2)\n]\ntumor_bg = Polygon(tumor_bg_verts, fc=C_TUMOR_BG, ec='none',\n                    alpha=0.15, zorder=0)\nax.add_patch(tumor_bg)\n\n# Label: Tumor Microenvironment\ndraw_label(ax, 8.3, 5.05, 'Tumor Microenvironment', fontsize=12, fontweight='bold')\n\n# === Stromal / normal cells (for context) ===\ndraw_normal_cell(ax, 6.0, 1.2, scale=0.8)\ndraw_label(ax, 6.0, 0.7, 'Normal Cell', fontsize=7, color='#666')\n\ndraw_normal_cell(ax, 10.0, 1.0, scale=0.7)\ndraw_label(ax, 10.0, 0.55, 'Normal Cell', fontsize=7, color='#666')\n\n# === Tumor cells (main focus) ===\n# Tumor cell 1 (left, being targeted)\ndraw_tumor_cell(ax, 6.9, 2.5, scale=1.0)\ndraw_label(ax, 6.9, 1.7, 'Tumor Cell', fontsize=8, fontweight='bold')\n\n# Tumor cell 2 (right, receiving drug)\ndraw_tumor_cell(ax, 9.0, 3.5, scale=1.0)\ndraw_label(ax, 9.0, 2.7, 'Tumor Cell', fontsize=8, fontweight='bold')\n\n# Tumor cell 3 (bottom)\ndraw_tumor_cell(ax, 8.2, 1.5, scale=0.85)\ndraw_label(ax, 8.2, 0.6, 'Tumor Cell', fontsize=8, fontweight='bold')\n\n# === Nanoparticles that have extravasated into tumor ===\nnp_tumor_positions = [\n    (5.8, 3.8), (6.3, 4.2), (6.8, 3.8), (7.5, 1.2),\n    (8.8, 2.0), (9.5, 4.2), (10.2, 3.0), (7.2, 4.5)\n]\nfor nx, ny in np_tumor_positions:\n    draw_nanoparticle(ax, nx, ny, r=0.18, zorder=30)\n\n# === Acidic pH indicators in tumor region ===\nh_plus_positions = [\n    (6.5, 4.5), (7.8, 4.8), (9.2, 4.5), (10.5, 3.8),\n    (7.0, 0.9), (9.8, 1.5), (11.0, 2.5)\n]\nfor hx, hy in h_plus_positions:\n    draw_H_plus(ax, hx, hy)\n\n# pH label in tumor\ndraw_label(ax, 10.7, 4.35, 'Acidic', fontsize=8, color=C_H_PLUS, fontweight='bold')\ndraw_label(ax, 10.7, 4.00, 'pH 6.5~6.8', fontsize=7, color=C_PH_ACID)\n\n# pH gradient indicator (neutral → acidic)\n# Small colored bar\ngrad_x = np.linspace(5.6, 5.9, 50)\ngrad_y = np.full_like(grad_x, 4.8)\nfor i in range(len(grad_x)-1):\n    t = i / len(grad_x)\n    color = (1-t) * np.array([0.18, 0.80, 0.44]) + t * np.array([0.95, 0.61, 0.07])\n    ax.plot(grad_x[i:i+2], grad_y[i:i+2], color=color, lw=4, zorder=10)\ndraw_label(ax, 5.75, 5.0, 'pH Gradient', fontsize=7, color='#666')\n\n# =========================================================================\n# SECTION 4: pH-RESPONSIVE DRUG RELEASE\n# =========================================================================\n# Nanoparticles undergoing pH-responsive release\n# Near tumor cell 1\ndraw_nanoparticle_releasing(ax, 6.3, 2.8, r=0.22, zorder=55)\ndraw_nanoparticle_releasing(ax, 7.5, 3.0, r=0.20, zorder=55)\ndraw_nanoparticle_releasing(ax, 8.5, 2.2, r=0.20, zorder=55)\n\n# Drug molecules around the releasing nanoparticles\ndrug_release_positions = [\n    (6.5, 3.1), (6.7, 2.7), (6.2, 2.5), (7.4, 3.3),\n    (7.3, 2.7), (7.7, 3.2), (8.7, 1.9), (8.3, 2.0),\n    (8.8, 2.5), (8.3, 2.5)\n]\nfor dx, dy in drug_release_positions:\n    draw_drug_molecule(ax, dx, dy, size=0.07)\n\n# Drug arrows entering tumor cells\ndraw_arrow(ax, 6.5, 3.0, 6.8, 2.8, color=C_DRUG, lw=1.5,\n            arrowsize=10, zorder=100)\ndraw_arrow(ax, 7.4, 3.1, 7.8, 3.3, color=C_DRUG, lw=1.5,\n            arrowsize=10, zorder=100)\ndraw_arrow(ax, 8.6, 2.0, 8.9, 2.2, color=C_DRUG, lw=1.5,\n            arrowsize=10, zorder=100)\n\n# pH-responsive release label\ndraw_label(ax, 7.3, 4.95, 'pH-Responsive Drug Release', fontsize=10,\n            fontweight='bold', color='#1A7A3A')\ndraw_label(ax, 7.3, 4.65, 'Nanoparticle disassembly in acidic pH',\n            fontsize=8, color='#666')\n\n# \"Drug molecules\" legend\ndraw_label(ax, 10.0, 4.95, '● Drug Molecules', fontsize=8, color=C_DRUG,\n            bg_color='white')\n\n# =========================================================================\n# SECTION 5: TUMOR CELL APOPTOSIS\n# =========================================================================\n# Apoptotic tumor cell (fragmented, with X)\napop_x, apop_y = 10.0, 3.5\ndraw_tumor_cell(ax, apop_x, apop_y, scale=0.9)\n# Apoptosis indicators - red X and fragments\nax.plot([apop_x-0.25, apop_x+0.25], [apop_y-0.25, apop_y+0.25],\n         color='#E74C3C', lw=2.5, zorder=30)\nax.plot([apop_x+0.25, apop_x-0.25], [apop_y-0.25, apop_y+0.25],\n         color='#E74C3C', lw=2.5, zorder=30)\n\ndraw_label(ax, apop_x, apop_y-0.7, 'Apoptosis', fontsize=8,\n            color=C_HIGHLIGHT, fontweight='bold')\n\n# Small apoptotic bodies\nfor angle in [0.5, 2.0, 3.8]:\n    bx = apop_x + 0.35 * np.cos(angle)\n    by = apop_y + 0.35 * np.sin(angle)\n    body = Circle((bx, by), 0.06, fc=C_TUMOR, ec=C_STROKE, lw=0.8, alpha=0.7, zorder=25)\n    ax.add_patch(body)\n\n# =========================================================================\n# SECTION 6: MAIN FLOW ARROWS (connecting the story)\n# =========================================================================\n# Arrow: Blood vessel → EPR effect\ndraw_arrow(ax, 3.8, VESSEL_Y, 4.3, VESSEL_Y, lw=2.5, arrowsize=18, zorder=100)\n\n# Arrow: EPR effect → Tumor region\ndraw_arrow(ax, 5.2, VESSEL_Y, 5.8, VESSEL_Y, lw=2.5, arrowsize=18, zorder=100)\n\n# Arrow: Tumor region → Drug release (conceptual, curved)\ndraw_arrow(ax, 6.5, 4.5, 7.0, 3.8, color='#1A7A3A', lw=2.0,\n            arrowsize=15, connectionstyle='arc3,rad=-0.4', zorder=100)\n\n# =========================================================================\n# SECTION 7: TITLES / TOP LABELS\n# =========================================================================\n# Main title\nax.text(5.75, 5.4,\n         'Graphical Abstract',\n         fontsize=14, fontweight='bold', ha='center', va='center',\n         color='#1A1A1A', zorder=300)\n\n# Subtitle\nax.text(5.75, 5.1,\n         'EPR Effect-Mediated Tumor Targeting and pH-Responsive Drug Release',\n         fontsize=10, ha='center', va='center',\n         color='#555555', style='italic', zorder=300)\n\n# =========================================================================\n# SECTION 8: LEGEND (bottom)\n# =========================================================================\nlegend_y = 0.25\nlegend_x_start = 0.5\nlegend_spacing = 1.8\n\n# Nanoparticle legend\ndraw_nanoparticle(ax, legend_x_start, legend_y, r=0.12, zorder=300)\ndraw_label(ax, legend_x_start + 0.3, legend_y, 'Nanoparticle',\n            fontsize=7, bg_color='white')\n\n# Drug molecule legend\ndraw_drug_molecule(ax, legend_x_start + legend_spacing, legend_y, size=0.06)\ndraw_label(ax, legend_x_start + legend_spacing + 0.3, legend_y, 'Drug Molecule',\n            fontsize=7, bg_color='white')\n\n# H+ legend\ndraw_H_plus(ax, legend_x_start + 2*legend_spacing, legend_y)\ndraw_label(ax, legend_x_start + 2*legend_spacing + 0.3, legend_y, 'H⁺ (Acidic pH)',\n            fontsize=7, bg_color='white')\n\n# Tumor cell legend\ndraw_tumor_cell(ax, legend_x_start + 3*legend_spacing, legend_y, scale=0.3)\ndraw_label(ax, legend_x_start + 3*legend_spacing + 0.3, legend_y, 'Tumor Cell',\n            fontsize=7, bg_color='white')\n\n# Normal cell legend\ndraw_normal_cell(ax, legend_x_start + 4*legend_spacing, legend_y, scale=0.3)\ndraw_label(ax, legend_x_start + 4*legend_spacing + 0.3, legend_y, 'Normal Cell',\n            fontsize=7, bg_color='white')\n\n# Red blood cell legend\nrbc_legend = Ellipse((legend_x_start + 5*legend_spacing, legend_y), 0.15, 0.09,\n                      fc=C_RBC, ec=C_STROKE, lw=0.8, alpha=0.6, zorder=300)\nax.add_patch(rbc_legend)\ndraw_label(ax, legend_x_start + 5*legend_spacing + 0.3, legend_y, 'Red Blood Cell',\n            fontsize=7, bg_color='white')\n\n# =========================================================================\n# EXPORT\n# =========================================================================\nplt.tight_layout(pad=0.5)\n\n# Save high-res TIFF (for journal submission)\nfig.savefig(\n    'Graphical_Abstract_EPR_pH_Release.tiff',\n    dpi=600,\n    format='tiff',\n    bbox_inches='tight',\n    pad_inches=0.3,\n    facecolor='white',\n    edgecolor='none'\n)\n\n# Save PNG (for quick viewing)\nfig.savefig(\n    'Graphical_Abstract_EPR_pH_Release.png',\n    dpi=300,\n    format='png',\n    bbox_inches='tight',\n    pad_inches=0.3,\n    facecolor='white',\n    edgecolor='none'\n)\n\nprint(\"✓ Figure generated successfully!\")\nprint(\"  • Graphical_Abstract_EPR_pH_Release.tiff  (600 DPI, for submission)\")\nprint(\"  • Graphical_Abstract_EPR_pH_Release.png   (300 DPI, for preview)\")\nprint(f\"\\nFigure size: {w_inch} × {h_inch} inches\")\nprint(\"Narrative: Blood vessel → EPR Effect → pH-Responsive Drug Release → Apoptosis\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/ga_epr_drug_release.py", "content": "#!/usr/bin/env python3\n\"\"\"\nGraphical Abstract: Nanomedicine EPR effect and pH-responsive drug release\n=========================================================================\nConceptual schematic for high-impact journal submission.\nNo data — pure illustration with arrows and annotations.\n\nDesign flow (left to right):\n  Blood vessel (nanoparticles circulating)\n    → EPR effect (extravasation through leaky endothelium)\n    → Tumor microenvironment (acidic pH triggers drug release)\n    → Tumor cell apoptosis\n\nOutput: 600 DPI TIFF/PNG, publication-ready\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.path import Path\nimport numpy as np\nfrom matplotlib.patches import (\n    Circle, Ellipse, FancyBboxPatch, FancyArrowPatch, Polygon, Arc, Rectangle\n)\nimport matplotlib.patheffects as pe\n\n# =========================================================================\n# COLOR PALETTE (professional, accessible)\n# =========================================================================\nC_BLOOD_VESSEL   = '#DC6C6C'   # blood vessel lining\nC_EC             = '#C0392B'   # endothelial cell\nC_BLOOD_BG       = '#FDE8E8'   # blood background\nC_NP_SHELL       = '#2E86C1'   # nanoparticle shell (blue)\nC_NP_CORE        = '#1A5276'   # nanoparticle core\nC_DRUG           = '#28B463'   # drug molecules (green)\nC_DRUG_GLOW      = '#ABEBC6'   # drug release glow\nC_TUMOR          = '#8E44AD'   # tumor cell (purple)\nC_TUMOR_NUCLEUS  = '#6C3483'   # tumor cell nucleus\nC_TUMOR_BG       = '#F5EEF8'   # tumor background\nC_PH_ACID        = '#F39C12'   # acidic pH indicator\nC_PH_NEUTRAL     = '#2ECC71'   # neutral pH\nC_ARROW          = '#444444'   # arrow color\nC_LABEL          = '#2C3E50'   # dark label text\nC_HIGHLIGHT      = '#E74C3C'   # highlight (EPR emphasis)\nC_STROKE         = '#333333'   # outline stroke\nC_NORMAL_CELL    = '#5DADE2'   # normal cell (for comparison)\nC_H_PLUS         = '#E67E22'   # H+ ions\nC_RBC            = '#E74C3C'   # red blood cell\n\n# =========================================================================\n# FIGURE SETUP\n# =========================================================================\nw_inch, h_inch = 11.5, 5.5\nfig, ax = plt.subplots(1, 1, figsize=(w_inch, h_inch))\nax.set_xlim(0, 11.5)\nax.set_ylim(0, 5.5)\nax.set_aspect('equal')\nax.axis('off')\n\n# =========================================================================\n# HELPER DRAWING FUNCTIONS\n# =========================================================================\n\ndef set_stroke(artist, lw=1.5, color=C_STROKE):\n    \"\"\"Add stroke effect to an artist.\"\"\"\n    artist.set_edgecolor(color)\n    artist.set_linewidth(lw)\n\n\ndef draw_rounded_rect(ax, x, y, w, h, fc='white', ec=C_STROKE, lw=1.5, \n                       alpha=1.0, zorder=0):\n    \"\"\"Draw a rounded rectangle.\"\"\"\n    rect = FancyBboxPatch(\n        (x, y), w, h,\n        boxstyle=\"round,pad=0.08\",\n        facecolor=fc, edgecolor=ec,\n        linewidth=lw, alpha=alpha,\n        zorder=zorder\n    )\n    ax.add_patch(rect)\n    return rect\n\n\ndef draw_arrow(ax, x1, y1, x2, y2, color=C_ARROW, lw=2.2, \n                style='->', connectionstyle='arc3,rad=0',\n                arrowsize=20, zorder=100):\n    \"\"\"Draw a curved or straight arrow.\"\"\"\n    arrow = FancyArrowPatch(\n        (x1, y1), (x2, y2),\n        arrowstyle=style,\n        color=color,\n        linewidth=lw,\n        connectionstyle=connectionstyle,\n        mutation_scale=arrowsize,\n        zorder=zorder\n    )\n    ax.add_patch(arrow)\n    return arrow\n\n\ndef draw_nanoparticle(ax, x, y, r=0.20, shell_color=C_NP_SHELL, \n                       core_color=C_NP_CORE, stroke_lw=1.0, zorder=50):\n    \"\"\"Draw a core-shell nanoparticle.\"\"\"\n    # Outer shell (blue circle)\n    shell = Circle((x, y), r, fc=shell_color, ec=C_STROKE, \n                    lw=stroke_lw, zorder=zorder, alpha=0.9)\n    ax.add_patch(shell)\n    \n    # Inner core (darker)\n    core = Circle((x, y), r*0.55, fc=core_color, ec='none', \n                   zorder=zorder+1, alpha=0.9)\n    ax.add_patch(core)\n    \n    # Subtle highlight on shell\n    highlight = Circle((x-r*0.2, y+r*0.2), r*0.3, \n                        fc='white', ec='none', alpha=0.35, zorder=zorder+2)\n    ax.add_patch(highlight)\n    \n    return shell, core\n\n\ndef draw_nanoparticle_releasing(ax, x, y, r=0.25, zorder=50):\n    \"\"\"Draw a nanoparticle that is releasing drug (slightly disrupted shell).\"\"\"\n    # Disrupted shell (dashed appearance - use partial arcs)\n    angles = np.linspace(0, 2*np.pi, 40)\n    # Draw shell with gaps\n    for i in range(0, 40, 4):\n        start_a = angles[i]\n        end_a = angles[min(i+2, 39)]\n        arc_x = x + r * np.cos(np.linspace(start_a, end_a, 10))\n        arc_y = y + r * np.sin(np.linspace(start_a, end_a, 10))\n        ax.plot(arc_x, arc_y, color=C_STROKE, lw=1.5, zorder=zorder, solid_capstyle='round')\n    \n    # Inner core (degrading - smaller, less opaque)\n    core = Circle((x, y), r*0.45, fc=C_NP_CORE, ec='none', \n                   alpha=0.4, zorder=zorder+1)\n    ax.add_patch(core)\n    \n    # Small drug molecules escaping\n    drug_positions = [\n        (x + r*1.3, y + r*0.5),\n        (x + r*1.6, y - r*0.3),\n        (x - r*0.8, y + r*1.4),\n        (x + r*0.3, y - r*1.5),\n        (x - r*1.2, y - r*0.8),\n    ]\n    for dx, dy in drug_positions:\n        drug = Circle((dx, dy), r*0.18, fc=C_DRUG, ec=C_STROKE, \n                       lw=0.8, alpha=0.85, zorder=zorder+2)\n        ax.add_patch(drug)\n\n\ndef draw_drug_molecule(ax, x, y, size=0.08, zorder=60):\n    \"\"\"Draw a small drug molecule as a circle with glow.\"\"\"\n    # Glow\n    glow = Circle((x, y), size*2.5, fc=C_DRUG_GLOW, ec='none', \n                   alpha=0.3, zorder=zorder)\n    ax.add_patch(glow)\n    # Core\n    drug = Circle((x, y), size, fc=C_DRUG, ec=C_STROKE, \n                   lw=0.6, zorder=zorder+1)\n    ax.add_patch(drug)\n    return drug\n\n\ndef draw_endothelial_cell(ax, x, y, w, h, zorder=10):\n    \"\"\"Draw a stylized endothelial cell (elongated, curved shape).\"\"\"\n    # Elongated elliptical cell\n    cell = Ellipse((x, y), w, h, fc=C_EC, ec=C_STROKE, lw=1.2, \n                    alpha=0.85, zorder=zorder)\n    ax.add_patch(cell)\n    # Nucleus (darker)\n    nucleus = Ellipse((x, y), w*0.35, h*0.5, fc='#922B21', ec='none', \n                       alpha=0.5, zorder=zorder+1)\n    ax.add_patch(nucleus)\n    return cell\n\n\ndef draw_tumor_cell(ax, x, y, scale=1.0, zorder=20):\n    \"\"\"Draw a stylized tumor cell with irregular shape.\"\"\"\n    r = 0.45 * scale\n    # Create irregular shape using a star-like polygon\n    n_points = 12\n    angles = np.linspace(0, 2*np.pi, n_points, endpoint=False)\n    # Add slight irregularity\n    radii = r + r * 0.15 * np.sin(angles * 3) + r * 0.1 * np.cos(angles * 2)\n    verts = [(x + radii[i] * np.cos(angles[i]), \n              y + radii[i] * np.sin(angles[i])) \n             for i in range(n_points)]\n    \n    cell = Polygon(verts, fc=C_TUMOR, ec=C_STROKE, lw=1.5, \n                    alpha=0.9, zorder=zorder)\n    ax.add_patch(cell)\n    \n    # Nucleus (larger, irregular - cancer hallmark)\n    nuc_r = r * 0.55\n    nuc_angles = np.linspace(0, 2*np.pi, 8, endpoint=False)\n    nuc_radii = nuc_r + nuc_r * 0.2 * np.sin(nuc_angles * 2)\n    nuc_verts = [(x + nuc_radii[i] * np.cos(nuc_angles[i]), \n                   y + nuc_radii[i] * np.sin(nuc_angles[i])) \n                  for i in range(8)]\n    nucleus = Polygon(nuc_verts, fc=C_TUMOR_NUCLEUS, ec='none', \n                       alpha=0.7, zorder=zorder+1)\n    ax.add_patch(nucleus)\n    \n    return cell, nucleus\n\n\ndef draw_normal_cell(ax, x, y, scale=1.0, zorder=20):\n    \"\"\"Draw a normal (healthy) cell for comparison.\"\"\"\n    r = 0.40 * scale\n    cell = Circle((x, y), r, fc=C_NORMAL_CELL, ec=C_STROKE, \n                   lw=1.2, alpha=0.7, zorder=zorder)\n    ax.add_patch(cell)\n    nucleus = Circle((x, y), r*0.4, fc='#1B4F72', ec='none', \n                      alpha=0.5, zorder=zorder+1)\n    ax.add_patch(nucleus)\n    return cell, nucleus\n\n\ndef draw_H_plus(ax, x, y, zorder=40):\n    \"\"\"Draw H+ ion symbol.\"\"\"\n    text = ax.text(x, y, 'H⁺', fontsize=9, fontweight='bold', \n                    color=C_H_PLUS, ha='center', va='center',\n                    zorder=zorder)\n    # Add a subtle circle behind\n    bg = Circle((x, y), 0.12, fc='white', ec=C_H_PLUS, lw=1.0, \n                 alpha=0.7, zorder=zorder-1)\n    ax.add_patch(bg)\n    return text\n\n\ndef draw_label(ax, x, y, text, fontsize=10, fontweight='bold', \n                color=C_LABEL, ha='center', va='center',\n                bg_color='white', bg_alpha=0.8, zorder=200,\n                arrow_pts=None):\n    \"\"\"Draw a label with optional background and pointer arrow.\"\"\"\n    # Add background for readability\n    if bg_color:\n        txt = ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n                       color=color, ha=ha, va=va, zorder=zorder,\n                       path_effects=[pe.withStroke(linewidth=3, foreground=bg_color, alpha=bg_alpha)])\n    else:\n        txt = ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n                       color=color, ha=ha, va=va, zorder=zorder)\n    \n    # Optional pointer arrow\n    if arrow_pts:\n        ax.annotate('', xy=(arrow_pts[0], arrow_pts[1]), xytext=(x, y),\n                     arrowprops=dict(arrowstyle='->', color=C_ARROW, \n                                     lw=1.2, connectionstyle='arc3,rad=0'),\n                     zorder=zorder-1)\n    return txt\n\n\ndef draw_blood_vessel_bg(ax, x1, x2, y_center, thickness):\n    \"\"\"Draw a blood vessel cross-section.\"\"\"\n    y_bot = y_center - thickness/2\n    y_top = y_center + thickness/2\n    \n    # Vessel lumen (blood background)\n    lumen = FancyBboxPatch(\n        (x1, y_bot), x2 - x1, thickness,\n        boxstyle=\"round,pad=0.05\",\n        fc=C_BLOOD_BG, ec=C_STROKE, lw=2.0, zorder=1\n    )\n    ax.add_patch(lumen)\n    \n    # Vessel wall (top and bottom lines)\n    # Top wall\n    ax.plot([x1, x2], [y_top, y_top], color=C_EC, lw=3, zorder=2)\n    ax.plot([x1, x2], [y_bot, y_bot], color=C_EC, lw=3, zorder=2)\n    \n    return y_bot, y_top\n\n# =========================================================================\n# SECTION 1: BLOOD VESSEL WITH CIRCULATING NANOPARTICLES\n# =========================================================================\n# Coordinates\nVESSEL_Y = 3.2\nVESSEL_H = 1.3\nVESSEL_X1 = 0.3\nVESSEL_X2 = 3.8\n\ndraw_blood_vessel_bg(ax, VESSEL_X1, VESSEL_X2, VESSEL_Y, VESSEL_H)\n\n# Endothelial cells lining the vessel\nec_positions = [0.7, 1.5, 2.3, 3.1]\nfor i, ex in enumerate(ec_positions):\n    ey = VESSEL_Y - 0.65 if i % 2 == 0 else VESSEL_Y + 0.65\n    draw_endothelial_cell(ax, ex, ey, 0.5, 0.22)\n\n# Red blood cells\nrbc_positions = [(1.0, 3.3), (2.8, 3.5), (1.8, 2.9)]\nfor rx, ry in rbc_positions:\n    rbc = Ellipse((rx, ry), 0.25, 0.15, fc=C_RBC, ec=C_STROKE, \n                   lw=0.8, alpha=0.6, zorder=30)\n    ax.add_patch(rbc)\n\n# Nanoparticles in blood vessel\nnp_positions_blood = [(1.2, 3.1), (2.0, 3.5), (3.0, 3.0), (1.6, 3.7), (2.5, 3.3)]\nfor nx, ny in np_positions_blood:\n    draw_nanoparticle(ax, nx, ny, r=0.18)\n\n# Flow direction arrows in vessel\ndraw_arrow(ax, 0.6, VESSEL_Y, 1.0, VESSEL_Y, color='#999', \n            lw=1.5, arrowsize=12, zorder=5)\ndraw_arrow(ax, 1.8, VESSEL_Y, 2.2, VESSEL_Y, color='#999', \n            lw=1.5, arrowsize=12, zorder=5)\ndraw_arrow(ax, 3.0, VESSEL_Y, 3.4, VESSEL_Y, color='#999', \n            lw=1.5, arrowsize=12, zorder=5)\n\n# Labels\ndraw_label(ax, 2.05, 4.55, 'Blood Vessel', fontsize=12, fontweight='bold')\ndraw_label(ax, 2.05, 4.15, '(Neutral pH ~7.4)', fontsize=8, color='#777')\n\n# pH neutral indicator near vessel\ndraw_label(ax, 3.5, 4.2, 'pH 7.4', fontsize=7, color=C_PH_NEUTRAL, \n            bg_color='white')\n\n# =========================================================================\n# SECTION 2: EPR EFFECT — EXTRAVASATION\n# =========================================================================\n# Leaky blood vessel (right portion with gaps)\nLEAKY_X1 = 3.9\nLEAKY_X2 = 5.2\ndraw_blood_vessel_bg(ax, LEAKY_X1, LEAKY_X2, VESSEL_Y, VESSEL_H)\n\n# Create gaps in the vessel wall (fenestrations)\n# Top wall gaps\ngap_y = VESSEL_Y + VESSEL_H/2\nax.plot([LEAKY_X1+0.2, LEAKY_X1+0.5], [gap_y, gap_y], color=C_EC, lw=3, zorder=2)\nax.plot([LEAKY_X1+0.7, LEAKY_X2-0.1], [gap_y, gap_y], color=C_EC, lw=3, zorder=2)\n# Gap visible - blank space\n\n# Bottom wall gaps\ngap_y_bot = VESSEL_Y - VESSEL_H/2\nax.plot([LEAKY_X1+0.1, LEAKY_X1+0.5], [gap_y_bot, gap_y_bot], color=C_EC, lw=3, zorder=2)\nax.plot([LEAKY_X1+0.7, LEAKY_X2-0.2], [gap_y_bot, gap_y_bot], color=C_EC, lw=3, zorder=2)\n# Gap visible at bottom\n\n# Endothelial cells around the leaky region\ndraw_endothelial_cell(ax, 4.2, VESSEL_Y-0.65, 0.45, 0.2)\ndraw_endothelial_cell(ax, 4.9, VESSEL_Y+0.65, 0.45, 0.2)\n\n# Nanoparticles extravasating through gaps\n# Through top gap\ndraw_nanoparticle(ax, 4.35, VESSEL_Y+VESSEL_H/2-0.1, r=0.15, zorder=45)\ndraw_nanoparticle(ax, 4.6, VESSEL_Y+VESSEL_H/2+0.25, r=0.15, zorder=45)\ndraw_nanoparticle(ax, 4.9, VESSEL_Y+VESSEL_H/2+0.55, r=0.15, zorder=45)\n\n# Through bottom gap\ndraw_nanoparticle(ax, 4.5, VESSEL_Y-VESSEL_H/2+0.15, r=0.15, zorder=45)\ndraw_nanoparticle(ax, 4.8, VESSEL_Y-VESSEL_H/2-0.30, r=0.15, zorder=45)\n\n# Extravasation arrows\ndraw_arrow(ax, 4.35, VESSEL_Y+VESSEL_H/2-0.25, 4.35, VESSEL_Y+VESSEL_H/2+0.05,\n            color=C_ARROW, lw=1.8, arrowsize=12, zorder=100)\ndraw_arrow(ax, 4.5, VESSEL_Y-VESSEL_H/2+0.30, 4.5, VESSEL_Y-VESSEL_H/2-0.05,\n            color=C_ARROW, lw=1.8, arrowsize=12, zorder=100)\n\n# EPR label\ndraw_label(ax, 4.55, 4.55, 'EPR Effect', fontsize=12, fontweight='bold', \n            color=C_HIGHLIGHT)\ndraw_label(ax, 4.55, 4.20, 'Leaky Vasculature', fontsize=8, color='#777')\ndraw_label(ax, 4.55, 3.95, '↓ Permeability', fontsize=7, color='#777')\n\n# Label the gap\ndraw_label(ax, 5.1, VESSEL_Y+VESSEL_H/2, 'Fenestration', fontsize=7, \n            color='#666', bg_color='#FFF')\n\n# =========================================================================\n# SECTION 3: TUMOR MICROENVIRONMENT\n# =========================================================================\nTUMOR_X1 = 5.5\nTUMOR_X2 = 11.2\n\n# Subtle background for tumor region (not a box, just a faint fill)\ntumor_bg_verts = [\n    (TUMOR_X1, 0.3), (TUMOR_X2, 0.3), (TUMOR_X2, 5.2), (TUMOR_X1, 5.2)\n]\ntumor_bg = Polygon(tumor_bg_verts, fc=C_TUMOR_BG, ec='none', \n                    alpha=0.15, zorder=0)\nax.add_patch(tumor_bg)\n\n# Label: Tumor Microenvironment\ndraw_label(ax, 8.3, 5.05, 'Tumor Microenvironment', fontsize=12, fontweight='bold')\n\n# === Stromal / normal cells (for context) ===\ndraw_normal_cell(ax, 6.0, 1.2, scale=0.8)\ndraw_label(ax, 6.0, 0.7, 'Normal Cell', fontsize=7, color='#666')\n\ndraw_normal_cell(ax, 10.0, 1.0, scale=0.7)\ndraw_label(ax, 10.0, 0.55, 'Normal Cell', fontsize=7, color='#666')\n\n# === Tumor cells (main focus) ===\n# Tumor cell 1 (left, being targeted)\ndraw_tumor_cell(ax, 6.9, 2.5, scale=1.0)\ndraw_label(ax, 6.9, 1.7, 'Tumor Cell', fontsize=8, fontweight='bold')\n\n# Tumor cell 2 (right, receiving drug)\ndraw_tumor_cell(ax, 9.0, 3.5, scale=1.0)\ndraw_label(ax, 9.0, 2.7, 'Tumor Cell', fontsize=8, fontweight='bold')\n\n# Tumor cell 3 (bottom)\ndraw_tumor_cell(ax, 8.2, 1.5, scale=0.85)\ndraw_label(ax, 8.2, 0.6, 'Tumor Cell', fontsize=8, fontweight='bold')\n\n# === Nanoparticles that have extravasated into tumor ===\nnp_tumor_positions = [\n    (5.8, 3.8), (6.3, 4.2), (6.8, 3.8), (7.5, 1.2),\n    (8.8, 2.0), (9.5, 4.2), (10.2, 3.0), (7.2, 4.5)\n]\nfor nx, ny in np_tumor_positions:\n    draw_nanoparticle(ax, nx, ny, r=0.18, zorder=30)\n\n# === Acidic pH indicators in tumor region ===\nh_plus_positions = [\n    (6.5, 4.5), (7.8, 4.8), (9.2, 4.5), (10.5, 3.8),\n    (7.0, 0.9), (9.8, 1.5), (11.0, 2.5)\n]\nfor hx, hy in h_plus_positions:\n    draw_H_plus(ax, hx, hy)\n\n# pH label in tumor\ndraw_label(ax, 10.7, 4.35, 'Acidic', fontsize=8, color=C_H_PLUS, fontweight='bold')\ndraw_label(ax, 10.7, 4.00, 'pH 6.5~6.8', fontsize=7, color=C_PH_ACID)\n\n# pH gradient indicator (neutral → acidic)\n# Small colored bar\ngrad_x = np.linspace(5.6, 5.9, 50)\ngrad_y = np.full_like(grad_x, 4.8)\nfor i in range(len(grad_x)-1):\n    t = i / len(grad_x)\n    color = (1-t) * np.array([0.18, 0.80, 0.44]) + t * np.array([0.95, 0.61, 0.07])\n    ax.plot(grad_x[i:i+2], grad_y[i:i+2], color=color, lw=4, zorder=10)\ndraw_label(ax, 5.75, 5.0, 'pH Gradient', fontsize=7, color='#666')\n\n# =========================================================================\n# SECTION 4: pH-RESPONSIVE DRUG RELEASE\n# =========================================================================\n# Nanoparticles undergoing pH-responsive release\n# Near tumor cell 1\ndraw_nanoparticle_releasing(ax, 6.3, 2.8, r=0.22, zorder=55)\ndraw_nanoparticle_releasing(ax, 7.5, 3.0, r=0.20, zorder=55)\ndraw_nanoparticle_releasing(ax, 8.5, 2.2, r=0.20, zorder=55)\n\n# Drug molecules around the releasing nanoparticles\ndrug_release_positions = [\n    (6.5, 3.1), (6.7, 2.7), (6.2, 2.5), (7.4, 3.3), \n    (7.3, 2.7), (7.7, 3.2), (8.7, 1.9), (8.3, 2.0),\n    (8.8, 2.5), (8.3, 2.5)\n]\nfor dx, dy in drug_release_positions:\n    draw_drug_molecule(ax, dx, dy, size=0.07)\n\n# Drug arrows entering tumor cells\ndraw_arrow(ax, 6.5, 3.0, 6.8, 2.8, color=C_DRUG, lw=1.5, \n            arrowsize=10, zorder=100)\ndraw_arrow(ax, 7.4, 3.1, 7.8, 3.3, color=C_DRUG, lw=1.5, \n            arrowsize=10, zorder=100)\ndraw_arrow(ax, 8.6, 2.0, 8.9, 2.2, color=C_DRUG, lw=1.5, \n            arrowsize=10, zorder=100)\n\n# pH-responsive release label\ndraw_label(ax, 7.3, 4.95, 'pH-Responsive Drug Release', fontsize=10, \n            fontweight='bold', color='#1A7A3A')\ndraw_label(ax, 7.3, 4.65, 'Nanoparticle disassembly in acidic pH', \n            fontsize=8, color='#666')\n\n# \"Drug molecules\" legend\ndraw_label(ax, 10.0, 4.95, '● Drug Molecules', fontsize=8, color=C_DRUG, \n            bg_color='white')\n\n# =========================================================================\n# SECTION 5: TUMOR CELL APOPTOSIS\n# =========================================================================\n# Apoptotic tumor cell (fragmented, with X)\napop_x, apop_y = 10.0, 3.5\ndraw_tumor_cell(ax, apop_x, apop_y, scale=0.9)\n# Apoptosis indicators - red X and fragments\nax.plot([apop_x-0.25, apop_x+0.25], [apop_y-0.25, apop_y+0.25], \n         color='#E74C3C', lw=2.5, zorder=30)\nax.plot([apop_x+0.25, apop_x-0.25], [apop_y-0.25, apop_y+0.25], \n         color='#E74C3C', lw=2.5, zorder=30)\n\ndraw_label(ax, apop_x, apop_y-0.7, 'Apoptosis', fontsize=8, \n            color=C_HIGHLIGHT, fontweight='bold')\n\n# Small apoptotic bodies\nfor angle in [0.5, 2.0, 3.8]:\n    bx = apop_x + 0.35 * np.cos(angle)\n    by = apop_y + 0.35 * np.sin(angle)\n    body = Circle((bx, by), 0.06, fc=C_TUMOR, ec=C_STROKE, lw=0.8, alpha=0.7, zorder=25)\n    ax.add_patch(body)\n\n# =========================================================================\n# SECTION 6: MAIN FLOW ARROWS (connecting the story)\n# =========================================================================\n# Arrow: Blood vessel → EPR effect\ndraw_arrow(ax, 3.8, VESSEL_Y, 4.3, VESSEL_Y, lw=2.5, arrowsize=18, zorder=100)\n\n# Arrow: EPR effect → Tumor region\ndraw_arrow(ax, 5.2, VESSEL_Y, 5.8, VESSEL_Y, lw=2.5, arrowsize=18, zorder=100)\n\n# Arrow: Tumor region → Drug release (conceptual, curved)\ndraw_arrow(ax, 6.5, 4.5, 7.0, 3.8, color='#1A7A3A', lw=2.0, \n            arrowsize=15, connectionstyle='arc3,rad=-0.4', zorder=100)\n\n# =========================================================================\n# SECTION 7: TITLES / TOP LABELS\n# =========================================================================\n# Main title\nax.text(5.75, 5.4, \n         'Graphical Abstract', \n         fontsize=14, fontweight='bold', ha='center', va='center',\n         color='#1A1A1A', zorder=300)\n\n# Subtitle\nax.text(5.75, 5.1, \n         'EPR Effect-Mediated Tumor Targeting and pH-Responsive Drug Release', \n         fontsize=10, ha='center', va='center',\n         color='#555555', style='italic', zorder=300)\n\n# =========================================================================\n# SECTION 8: LEGEND (bottom)\n# =========================================================================\nlegend_y = 0.25\nlegend_x_start = 0.5\nlegend_spacing = 1.8\n\n# Nanoparticle legend\ndraw_nanoparticle(ax, legend_x_start, legend_y, r=0.12, zorder=300)\ndraw_label(ax, legend_x_start + 0.3, legend_y, 'Nanoparticle', \n            fontsize=7, bg_color='white')\n\n# Drug molecule legend\ndraw_drug_molecule(ax, legend_x_start + legend_spacing, legend_y, size=0.06)\ndraw_label(ax, legend_x_start + legend_spacing + 0.3, legend_y, 'Drug Molecule', \n            fontsize=7, bg_color='white')\n\n# H+ legend\ndraw_H_plus(ax, legend_x_start + 2*legend_spacing, legend_y)\ndraw_label(ax, legend_x_start + 2*legend_spacing + 0.3, legend_y, 'H⁺ (Acidic pH)', \n            fontsize=7, bg_color='white')\n\n# Tumor cell legend\ndraw_tumor_cell(ax, legend_x_start + 3*legend_spacing, legend_y, scale=0.3)\ndraw_label(ax, legend_x_start + 3*legend_spacing + 0.3, legend_y, 'Tumor Cell', \n            fontsize=7, bg_color='white')\n\n# Normal cell legend\ndraw_normal_cell(ax, legend_x_start + 4*legend_spacing, legend_y, scale=0.3)\ndraw_label(ax, legend_x_start + 4*legend_spacing + 0.3, legend_y, 'Normal Cell', \n            fontsize=7, bg_color='white')\n\n# Red blood cell legend\nrbc_legend = Ellipse((legend_x_start + 5*legend_spacing, legend_y), 0.15, 0.09, \n                      fc=C_RBC, ec=C_STROKE, lw=0.8, alpha=0.6, zorder=300)\nax.add_patch(rbc_legend)\ndraw_label(ax, legend_x_start + 5*legend_spacing + 0.3, legend_y, 'Red Blood Cell', \n            fontsize=7, bg_color='white')\n\n# =========================================================================\n# EXPORT\n# =========================================================================\nplt.tight_layout(pad=0.5)\n\n# Save high-res TIFF (for journal submission)\nfig.savefig(\n    'Graphical_Abstract_EPR_pH_Release.tiff',\n    dpi=600,\n    format='tiff',\n    bbox_inches='tight',\n    pad_inches=0.3,\n    facecolor='white',\n    edgecolor='none'\n)\n\n# Save PNG (for quick viewing)\nfig.savefig(\n    'Graphical_Abstract_EPR_pH_Release.png',\n    dpi=300,\n    format='png',\n    bbox_inches='tight',\n    pad_inches=0.3,\n    facecolor='white',\n    edgecolor='none'\n)\n\nprint(\"✓ Figure generated successfully!\")\nprint(\"  • Graphical_Abstract_EPR_pH_Release.tiff  (600 DPI, for submission)\")\nprint(\"  • Graphical_Abstract_EPR_pH_Release.png   (300 DPI, for preview)\")\nprint(f\"\\nFigure size: {w_inch} × {h_inch} inches\")\nprint(\"Narrative: Blood vessel → EPR Effect → pH-Responsive Drug Release → Apoptosis\")\n"})
