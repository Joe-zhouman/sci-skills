atment\n- Myeloid compartments (Monocytes, Dendritic cells) contract\n- Upregulated effector genes: GZMB, PRF1, IFNG, NKG7, GNLY\n- Downregulated genes suggest reduced monocyte/macrophage activity\n\n## Journal specs\n- Target: **Cell** (Elsevier)\n- Size: {FIG_WIDTH} in × {FIG_HEIGHT} in (double column)\n- Format: PDF (vector) + PNG (300 DPI) + grayscale preview\n- Color: Okabe-Ito colorblind-safe palette\n- Font: Helvetica/Arial, 7-8 pt\n- Panel labels: (A)(B) bold, Cell/Elsevier style\n\"\"\")\n\nprint(f\"\\n[✓] Figure 2 exported. Files saved to figs/fig2_scRNAseq.*\")\nprint(f\"    Description: {desc_path}\")\nprint(f\"    Total DEGs: {df_sig['direction'].value_counts().to_dict()}\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/plot_figure2_scrnaseq.py", "content": "\"\"\"\nFigure 2 — scRNA-seq: Cluster proportion shift + Differential expression\n======================================================================\nPanel (A): Stacked bar chart — cell cluster proportions in Control vs Treatment\nPanel (B): Volcano plot — differentially expressed genes\n\nTarget: Cell (Elsevier)\n  - Double column: 190 mm ≈ 7.48 in\n  - Font: Helvetica/Arial 7-9 pt\n  - Panel labels: (A) (B) bold uppercase with parentheses\n  - Color: Okabe-Ito colorblind-safe palette, unified across panels\n\nUsage:\n    python plot_figure2_scrnaseq.py\n\"\"\"\n\nimport sys, os\nsys.path.insert(0, os.path.join(os.path.dirname(__file__), 'sci-draw/scripts'))\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nfrom matplotlib.patches import FancyBboxPatch\nimport seaborn as sns\nfrom scipy import stats\n\nfrom setup_style import setup_style\nfrom export_figure import export_figure\nfrom visual_qa import audit_layout\n\n# ─── Figure contract ──────────────────────────────────────────────────────────\n# Core conclusion: Treatment induces a shift in cell-type composition and\n#   activates specific transcriptional programs across clusters.\n# Panel (A): Stacked bars show proportion shift — \"which populations expand\n#   or contract under treatment?\"\n# Panel (B): Volcano plot highlights key DEGs — \"which genes drive the\n#   treatment response?\"\n\n# ─── Setup style — Cell (Elsevier) ───────────────────────────────────────────\ninfo = setup_style(journal='nature', lang='en')\n# Cell is Elsevier: double-column = 7.48 in, font 7-9 pt, Helvetica/Arial\n# We use 'nature' preset as base then tweak for Elsevier\nplt.rcParams.update({\n    'font.size': 8,\n    'axes.labelsize': 8,\n    'xtick.labelsize': 7,\n    'ytick.labelsize': 7,\n    'legend.fontsize': 7,\n    'axes.linewidth': 0.6,\n    'xtick.major.width': 0.6,\n    'ytick.major.width': 0.6,\n})\n\n# ─── Color palette (Okabe-Ito, colorblind-safe) ──────────────────────────────\nOKABE = ['#000000', '#E69F00', '#56B4E9', '#009E73',\n         '#F0E442', '#0072B2', '#D55E00', '#CC79A7',\n         '#999999', '#AA4499']\n# Extended with additional distinct colors for more clusters\nCLUSTER_COLORS = OKABE[:] + ['#44AA99', '#88CCEE', '#DDCC77', '#CC6677', '#117733']\nN_CLUSTERS = 8  # number of cell clusters\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  DATA GENERATION (synthetic — replace with real data)\n# ══════════════════════════════════════════════════════════════════════════════\n\nCLUSTER_NAMES = [\n    'CD4+ T cells', 'CD8+ T cells', 'NK cells',\n    'Monocytes', 'Dendritic cells', 'B cells',\n    'Neutrophils', 'Tregs'\n]\n\n# --- Panel A: Cluster proportions ---\n# Realistic proportions: Control has ~40% T cells; Treatment shifts\nrng = np.random.default_rng(42)\nN_CELLS = 5000  # total cells per condition\n\n# Control proportions\nctrl_props = np.array([0.22, 0.12, 0.08, 0.20, 0.10, 0.14, 0.08, 0.06])\nctrl_props = ctrl_props / ctrl_props.sum()\n\n# Treatment proportions (some clusters expand, others contract)\ntreat_props = np.array([0.15, 0.25, 0.14, 0.08, 0.05, 0.10, 0.18, 0.05])\ntreat_props = treat_props / treat_props.sum()\n\n# Build per-condition count data for stacked bar\nctrl_counts = (ctrl_props * N_CELLS).astype(int)\ntreat_counts = (treat_props * N_CELLS).astype(int)\n\n# Build dataframe for the bar plot\ndf_bar = pd.DataFrame({\n    'Cluster': CLUSTER_NAMES * 2,\n    'Condition': ['Control'] * N_CLUSTERS + ['Treatment'] * N_CLUSTERS,\n    'Count': np.concatenate([ctrl_counts, treat_counts]),\n})\n\n# Also build a version for % (proportion)\nctrl_pct = ctrl_props * 100\ntreat_pct = treat_props * 100\ndf_pct = pd.DataFrame({\n    'Cluster': CLUSTER_NAMES * 2,\n    'Condition': ['Control'] * N_CLUSTERS + ['Treatment'] * N_CLUSTERS,\n    'Proportion': np.concatenate([ctrl_pct, treat_pct]),\n})\n\n# --- Panel B: Volcano plot data ---\n# Generate realistic DEG data: ~15000 genes, mostly null\nn_genes = 15000\ngene_names = [f'GENE_{i}' for i in range(n_genes)]\n\n# Seed key genes with known biology-relevant names\nimportant_genes = {\n    42: 'CXCL10',   87: 'CCL5',    156: 'GZMB',\n    203: 'PRF1',    310: 'IFNG',   411: 'TNF',\n    520: 'IL2',     633: 'IL10',   745: 'TGFB1',\n    899: 'CD8A',    1002: 'CD4',   1156: 'FOXP3',\n    1301: 'GZMK',   1489: 'NKG7',  1678: 'GNLY',\n    1845: 'CD14',   2012: 'FCGR3A', 2198: 'CSF1R',\n    2401: 'CLEC9A', 2600: 'IRF8',  2789: 'MS4A1',\n    3001: 'CD79A',  3200: 'JCHAIN', 3400: 'S100A8',\n    3600: 'S100A9', 3800: 'MMP9',  3950: 'CCR7',\n    4100: 'SELL',   4250: 'IL7R',  4400: 'CCL4',\n    4550: 'CCL3',   4700: 'XCL1',  4850: 'CX3CR1',\n    5000: 'FCER1G', 5150: 'LST1',  5300: 'AIF1',\n}\n# Fill non-special genes with generic names\ngenes = list(gene_names)\nfor idx, name in important_genes.items():\n    genes[idx] = name\n\n# log2 fold change: mostly ~N(0,0.3), some strong effects\nlog2fc = rng.normal(0, 0.3, n_genes)\n# Add a block of up-regulated genes\nup_idx = rng.choice(n_genes, 350, replace=False)\nlog2fc[up_idx] = rng.uniform(0.8, 3.5, len(up_idx))\n# Add a block of down-regulated genes\ndown_idx = rng.choice(np.setdiff1d(np.arange(n_genes), up_idx), 250, replace=False)\nlog2fc[down_idx] = rng.uniform(-3.0, -0.8, len(down_idx))\n\n# p-values: convert effect size + noise to p-values\npvals_raw = np.array([\n    2 * (1 - stats.t.cdf(abs(log2fc[i]) / 0.3, df=8))\n    if i in set(up_idx) | set(down_idx) else\n    rng.uniform(0.1, 0.9)\n    for i in range(n_genes)\n])\n# Clamp extreme p-values\npvals_raw = np.clip(pvals_raw, 1e-30, 0.999)\npadj = np.array([min(p * n_genes / (i + 1), 1.0)\n                  for i, p in enumerate(sorted(pvals_raw))])\n# Restore original order\npadj_orig = np.zeros_like(padj)\norder = np.argsort(pvals_raw)\nfor i, o in enumerate(order):\n    padj_orig[o] = padj[i]\npadj = padj_orig\n\ndf_volcano = pd.DataFrame({\n    'gene': genes,\n    'log2FC': log2fc,\n    'pvalue': pvals_raw,\n    'padj': padj,\n    'significant': (np.abs(log2fc) >= 0.8) & (padj < 0.05),\n    'direction': ['up' if (lfc >= 0.8 and p < 0.05) else 'down' if (lfc <= -0.8 and p < 0.05)\n                  else 'ns' for lfc, p in zip(log2fc, padj)],\n})\n# Pick top genes to label\ndf_sig = df_volcano[df_volcano['significant']].copy()\ndf_sig['rank'] = df_sig['padj'].rank()\ndf_sig['abs_fc'] = df_sig['log2FC'].abs()\ndf_label = df_sig.sort_values('padj').head(25)\n# Also include some middle-range but known genes for biological interest\nknown_genes = [v for v in important_genes.values() if v in df_volcano['gene'].values]\nknown_df = df_volcano[df_volcano['gene'].isin(known_genes) & ~df_volcano['gene'].isin(df_label['gene'].values)]\ndf_label = pd.concat([df_label, known_df.head(10)]).drop_duplicates('gene')\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  PLOTTING — Figure 2: 1 row × 2 columns at Cell double-column width\n# ══════════════════════════════════════════════════════════════════════════════\n\nFIG_WIDTH = 7.48   # Cell / Elsevier double-column width\nFIG_HEIGHT = 3.6   # height adjusted for readability\n\nfig, axes = plt.subplots(1, 2, figsize=(FIG_WIDTH, FIG_HEIGHT),\n                         constrained_layout=True)\n\n# ──────────────────────────────────────────────────────────────────────────────\n#  Panel (A): Stacked bar — cluster proportions\n# ──────────────────────────────────────────────────────────────────────────────\nax = axes[0]\n\n# Reshape data for stacked bar: each condition is a bar, clusters are stacks\nconditions = ['Control', 'Treatment']\nbar_data = np.zeros((N_CLUSTERS, len(conditions)))\nbar_data[:, 0] = ctrl_pct\nbar_data[:, 1] = treat_pct\n\nx = np.arange(len(conditions))  # 0, 1\nbar_width = 0.55\n\nbottom = np.zeros(len(conditions))\nbars = []\nfor i i