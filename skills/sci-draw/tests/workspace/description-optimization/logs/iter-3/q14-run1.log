tyle,\n        mutation_scale=20\n    )\n    ax.add_patch(arrow)\n\ndef draw_curved_arrow(ax, x1, y1, x2, y2, rad=0.3, lw=2.5, color=ARROW_COL):\n    draw_arrow(ax, x1, y1, x2, y2, style=f'arc3,rad={rad}', lw=lw, color=color)\n\ndef draw_label(ax, x, y, text, fontsize=12, color=LABEL_COL, ha='center', va='center',\n               bold=False, bbox=None, style='normal'):\n    \"\"\"Add a text label.\"\"\"\n    weight = 'bold' if bold else 'normal'\n    ax.text(x, y, text, fontsize=fontsize, ha=ha, va=va, color=color,\n            fontweight=weight, zorder=5, bbox=bbox, style=style)\n\ndef draw_rounded_box(ax, x, y, w, h, text, color='#E8E8E8', text_color=LABEL_COL,\n                     fontsize=11, alpha=0.85, ec='#CCCCCC'):\n    \"\"\"Draw a rounded box with text (title box).\"\"\"\n    box = FancyBboxPatch((x - w/2, y - h/2), w, h,\n                         boxstyle=\"round,pad=0.15\",\n                         facecolor=color, edgecolor=ec, linewidth=1.5, alpha=alpha)\n    ax.add_patch(box)\n    draw_label(ax, x, y, text, fontsize=fontsize, color=text_color, bold=True)\n\n# ============================================================\n# 1. BLOOD VESSEL (left side) - Nanoparticles in circulation\n# ============================================================\n# Blood vessel shape — a thick curved tube\nvessel = mpatches.Wedge((2.5, 5), 2.8, -30, 30, facecolor=BLOOD_PINK,\n                         edgecolor=BLOOD_RED, linewidth=2.5, alpha=0.6)\nax.add_patch(vessel)\n# Vessel outline\ntheta = np.linspace(-np.pi/6, np.pi/6, 100)\nr_outer = 2.8\nr_inner = 1.8\ncx, cy = 2.5, 5\n# Outer wall\nx_outer = cx + r_outer * np.cos(theta)\ny_outer = cy + r_outer * np.sin(theta)\nax.plot(x_outer, y_outer, color=BLOOD_RED, linewidth=3, alpha=0.7)\n# Inner wall\nx_inner = cx + r_inner * np.cos(theta)\ny_inner = cy + r_inner * np.sin(theta)\nax.plot(x_inner, y_inner, color=BLOOD_RED, linewidth=2, alpha=0.4, linestyle='--')\n\n# Red blood cells (circular discs) inside vessel\nfor angle in [-0.35, -0.1, 0.1, 0.35]:\n    r = 2.3\n    rx = cx + r * np.cos(angle)\n    ry = cy + r * np.sin(angle)\n    cell = Circle((rx, ry), 0.3, facecolor=BLOOD_RED, edgecolor='#A02030',\n                  linewidth=1, alpha=0.7)\n    ax.add_patch(cell)\n\n# --- Nanoparticles in blood vessel ---\ndef draw_nanoparticle(ax, x, y, scale=1.0, with_drugs=True):\n    \"\"\"Draw a core-shell nanoparticle with optional drug payload.\"\"\"\n    # Outer shell (hydrophilic coating)\n    shell = Circle((x, y), 0.28*scale, facecolor=NP_SHELL, edgecolor='#3DAF9E',\n                   linewidth=1.5, alpha=0.85, zorder=3)\n    ax.add_patch(shell)\n    # Core (hydrophobic drug-loaded core)\n    core = Circle((x, y), 0.16*scale, facecolor=NP_CORE, edgecolor='#E55A2B',\n                  linewidth=1.2, zorder=4)\n    ax.add_patch(core)\n    # Drug dots\n    if with_drugs:\n        for da in [0, 2.1, 4.0]:\n            dx = x + 0.08*scale * np.cos(da)\n            dy = y + 0.08*scale * np.sin(da)\n            dot = Circle((dx, dy), 0.035*scale, facecolor=DRUG_COLOR, zorder=5)\n            ax.add_patch(dot)\n\n# Place nanoparticles in the blood vessel\nnp_positions = [(2.2, 5.6), (3.0, 5.8), (1.8, 4.8), (2.8, 4.4), (2.0, 4.2)]\nfor i, (nx, ny) in enumerate(np_positions):\n    draw_nanoparticle(ax, nx, ny, scale=0.9)\n\n# Vessel label\ndraw_label(ax, 2.5, 7.9, \"Blood Vessel\", fontsize=13, bold=True, color=BLOOD_RED)\ndraw_label(ax, 2.5, 7.5, \"(Systemic Circulation)\", fontsize=10, color='#888888')\ndraw_label(ax, 4.6, 6.6, \"Nanoparticles\\nin circulation\", fontsize=9, color=NP_CORE,\n           ha='left', va='center')\n\n# ============================================================\n# 2. TUMOR TISSUE (right side)\n# ============================================================\n# Tumor mass — irregular blobby shape\ntumor_verts = [\n    (10.5, 2.0), (11.8, 1.8), (13.2, 2.2), (14.2, 3.0),\n    (14.8, 4.2), (14.6, 5.5), (13.8, 6.5), (12.5, 7.0),\n    (11.2, 6.8), (10.2, 6.0), (9.6, 4.8), (9.8, 3.5),\n]\ntumor_poly = mpatches.Polygon(tumor_verts, closed=True, facecolor=TUMOR_LIGHT,\n                               edgecolor=TUMOR_PURPLE, linewidth=2.5, alpha=0.6,\n                               zorder=1)\nax.add_patch(tumor_poly)\n\n# --- Leaky tumor vasculature (discontinuous, irregular) ---\n# Upper tumor vessel fragment\nv1_start = (10.8, 6.0)\nv1_end = (12.5, 5.8)\nax.plot([v1_start[0], v1_end[0]], [v1_start[1], v1_end[1]],\n        color=BLOOD_RED, linewidth=3.5, alpha=0.5, zorder=2)\n# Fenestrations (gaps) — draw as white circles over the line\nfor fx in [11.2, 11.8, 12.4]:\n    fen = Circle((fx, 5.9), 0.15, facecolor='white', edgecolor=BLOOD_RED,\n                 linewidth=1, alpha=0.8, zorder=3)\n    ax.add_patch(fen)\n\n# Lower tumor vessel fragment\nv2_start = (10.2, 3.8)\nv2_end = (11.8, 3.4)\nax.plot([v2_start[0], v2_end[0]], [v2_start[1], v2_end[1]],\n        color=BLOOD_RED, linewidth=3.5, alpha=0.5, zorder=2)\nfor fx in [10.6, 11.2]:\n    fen = Circle((fx, 3.6), 0.15, facecolor='white', edgecolor=BLOOD_RED,\n                 linewidth=1, alpha=0.8, zorder=3)\n    ax.add_patch(fen)\n\n# ============================================================\n# 3. EPR EFFECT — Nanoparticles extravasating from vessel into tumor\n# ============================================================\n# Extravasating NPs (shown moving through gaps)\nextrav_positions = [\n    (8.5, 6.4), (9.5, 6.2), (8.0, 5.2), (9.0, 4.8),\n    (7.5, 4.0), (8.8, 3.8), (9.5, 3.0),\n]\nfor nx, ny in extrav_positions:\n    draw_nanoparticle(ax, nx, ny, scale=0.8, with_drugs=True)\n\n# Arrow from vessel to tumor interstitial space\ndraw_curved_arrow(ax, 6.0, 5.8, 8.0, 5.8, rad=0.05, lw=2.5, color='#E74C3C')\ndraw_curved_arrow(ax, 6.0, 3.8, 8.0, 4.2, rad=0.05, lw=2.5, color='#E74C3C')\n\n# EPR label with bracket\ndraw_label(ax, 7.0, 7.4, \"EPR Effect\", fontsize=13, bold=True, color='#C0392B')\ndraw_label(ax, 7.0, 7.0, \"(Leaky Vasculature)\", fontsize=10, color='#888888')\ndraw_label(ax, 7.0, 6.6, \"Passive targeting via\\nenhanced permeability\", fontsize=9,\n           color='#666666', ha='center')\n\n# ============================================================\n# 4. ACIDIC TUMOR MICROENVIRONMENT (pH-triggered drug release)\n# ============================================================\n# Acidic region indicator — a pH gradient zone\nacid_region = Ellipse((12.0, 2.5), 4.0, 1.5, facecolor=ACID_GREEN, edgecolor='#2ECC71',\n                       linewidth=1.5, alpha=0.3, zorder=1)\nax.add_patch(acid_region)\n\n# pH label\ndraw_label(ax, 12.0, 2.5, \"pH ~ 6.5\", fontsize=11, bold=True, color='#27AE60')\ndraw_label(ax, 12.0, 2.1, \"Acidic Tumor\\nMicroenvironment\", fontsize=9, color='#555555')\n\n# Nanoparticle in acidic region — releasing drugs\n# Intact NP\ndraw_nanoparticle(ax, 11.0, 3.2, scale=0.8, with_drugs=True)\n\n# NP releasing drugs (shell degraded)\nreleasing_np_x, releasing_np_y = 12.0, 3.8\nshell_r = 0.25\ncore_r = 0.14\n# Degraded shell fragments\nfor frag_angle in [0, 1.5, 3.0, 4.5]:\n    fx = releasing_np_x + shell_r * 1.2 * np.cos(frag_angle)\n    fy = releasing_np_y + shell_r * 1.2 * np.sin(frag_angle)\n    frag = Circle((fx, fy), 0.06, facecolor=NP_SHELL, alpha=0.6, zorder=3)\n    ax.add_patch(frag)\n# Exposed core\ncore_exposed = Circle((releasing_np_x, releasing_np_y), core_r,\n                       facecolor=NP_CORE, edgecolor='#E55A2B', linewidth=1.2, zorder=4)\nax.add_patch(core_exposed)\n# Drugs releasing outward\nfor da, dr in [(2.8, 0.35), (3.5, 0.45), (4.0, 0.38), (5.0, 0.50), (5.5, 0.42)]:\n    dx = releasing_np_x + dr * np.cos(da)\n    dy = releasing_np_y + dr * np.sin(da)\n    drug_dot = Circle((dx, dy), 0.04, facecolor=DRUG_COLOR, edgecolor='#D4A017',\n                      linewidth=0.5, zorder=5)\n    ax.add_patch(drug_dot)\n\n# Another releasing NP\nrx2, ry2 = 12.8, 3.2\nshell_r2 = 0.22\nfor frag_angle in [0.5, 2.0, 3.5]:\n    fx = rx2 + shell_r2 * 1.2 * np.cos(frag_angle)\n    fy = ry2 + shell_r2 * 1.2 * np.sin(frag_angle)\n    frag = Circle((fx, fy), 0.05, facecolor=NP_SHELL, alpha=0.6, zorder=3)\n    ax.add_patch(frag)\ncore2 = Circle((rx2, ry2), 0.12, facecolor=NP_CORE, edgecolor='#E55A2B', linewidth=1.2, zorder=4)\nax.add_patch(core2)\nfor da, dr in [(1.0, 0.3), (1.8, 0.4), (2.5, 0.35)]:\n    dx = rx2 + dr * np.cos(da)\n    dy = ry2 + dr * np.sin(da)\n    ax.add_patch(Circle((dx, dy), 0.04, facecolor=DRUG_COLOR, zorder=5))\n\n# Arrow from intact to releasing\ndraw_arrow(ax, 11.4, 3.5, 11.8, 3.9, lw=1.8, color='#27AE60',\n           connectionstyle='arc3,rad=0.15', head_width=0.15, head_length=0.2)\n\n# Arrow from releasing to drug action on cancer cell\ndraw_arrow(ax, 12.3, 4.1, 12.5, 5.2, lw=2.0, color='#E74C3C',\n           connectionstyle='arc3,rad=0.2', head_width=0.2, head_length=0.25)\n\n# ============================================================\n# 5. CANCER CELL (bottom right) — drug action\n# ============================================================\n# Cancer cell membrane\ncancer_cell = Circle((13.5, 6.8), 1.2, facecolor='#FFE0E6', edgecolor='#E74C3C',\n                     linewidth=2.5, alpha=0.7, zorder=2)\nax.add_patch(cancer_cell)\n# Irregular membrane — bumpy outline\nfor ang in np.linspace(0, 2*np.pi, 12, endpoint=False):\n    bx = 13.5 + 1.35 * np.cos(ang)\n    by = 6.8 + 1.35 * np.sin(ang)\n    bump = Circle((bx, by), 0.1, facecolor='#FFE0E6', edgecolor='#E74C3C',\n                  linewidth=1, alpha=0.5, zorder=2)\n    ax.add_patch(bump)\n\n# Nucleus\nnucleus = Circle((13.5, 6.8), 0.55, facecolor=NUCLEUS_COL, edgecolor='#1A1A2E',\n                 linewidth=1.5, alpha=0.85, zorder=3)\nax.add_patch(nucleus)\n# Nucleolus\nnucleolus = Circle((13.35, 6.65), 0.15, facecolor='#636E72', zorder=4)\nax.add_patch(nucleolus)\n\n# Drug molecules entering the cell\nfor da in [0.2, 1.5, 3.0, 4.5, 5.5]:\n    dx = 13.5 + 0.9 * np.cos(da)\n    dy = 6.8 + 0.9 * np.sin(da)\n    ax.add_patch(Circle((dx, dy), 0.045, facecolor=DRUG_COLOR, edgecolor='#D4A017',\n                        linewidth=0.3, zorder=5))\n\n# Apoptosis / cell death indicators (small X marks)\nfor xo, yo in [(14.8, 7.8), (15.2, 7.2), (14.9, 6.2)]:\n    ax.plot([xo-0.06, xo+0.06], [yo-0.06, yo+0.06], color='#E74C3C', lw=1.5)\n    ax.plot([xo-0.06, xo+0.06], [yo+0.06, yo-0.06], color='#E74C3C', lw=1.5)\n\ndraw_label(ax, 13.5, 5.3, \"Tumor Cell\", fontsize=11, bold=True, color='#C0392B')\ndraw_label(ax, 13.5, 5.0, \"Apoptosis\", fontsize=10, color='#E74C3C')\n\n# ============================================================\n# 6. OVERALL FLOW ARROWS (left → right)\n# ============================================================\n# Main process flow arrow at top\ndraw_arrow(ax, 1.0, 9.2, 5.0, 9.2, lw=3, color='#2C3E50', head_width=0.35, head_length=0.5,\n           connectionstyle='arc3,rad=0')\ndraw_arrow(ax, 5.5, 9.2, 9.5, 9.2, lw=3, color='#2C3E50', head_width=0.35, head_length=0.5,\n           connectionstyle='arc3,rad=0')\ndraw_arrow(ax, 10.0, 9.2, 14.5, 9.2, lw=3, color='#2C3E50', head_width=0.35, head_length=0.5,\n           connectionstyle='arc3,rad=0')\n\n# Step labels above the flow\nsteps = [\n    (3.0, 9.6, \"① Systemic\\nAdministration\"),\n    (7.5, 9.6, \"② EPR Effect\\n(Passive Targeting)\"),\n    (12.2, 9.6, \"③ pH-Triggered\\nDrug Release\"),\n]\nfor sx, sy, stext in steps:\n    draw_label(ax, sx, sy, stext, fontsize=11, bold=True, color='#2C3E50')\n\n# ============================================================\n# 7. LEGEND\n# ============================================================\nlegend_x = 0.5\nlegend_y = 0.5\nlegend_box = FancyBboxPatch((legend_x, legend_y), 1.6, 0.9,\n                             boxstyle=\"round,pad=0.1\",\n                             facecolor='white', edgecolor='#CCCCCC',\n                             linewidth=1, alpha=0.9, zorder=10)\nax.add_patch(legend_box)\n\n# Legend items\nlegend_items = [\n    (legend_x + 0.2, legend_y + 0.7, NP_SHELL, 'Nanoparticle'),\n    (legend_x + 0.2, legend_y + 0.5, DRUG_COLOR, 'Drug Payload'),\n    (legend_x + 0.2, legend_y + 0.3, TUMOR_LIGHT, 'Tumor Tissue'),\n]\nfor lx, ly, lcolor, ltext in legend_items:\n    rect = mpatches.Rectangle((lx, ly - 0.06), 0.15, 0.12, facecolor=lcolor,\n                               edgecolor='#999999', linewidth=0.8)\n    ax.add_patch(rect)\n    draw_label(ax, lx + 0.3, ly + 0.01, ltext, fontsize=8, ha='left', color='#555555')\n\n# ============================================================\n# 8. TITLE\n# ============================================================\ntitle_color = '#1A1A2E'\ndraw_label(ax, 8.0, 9.9, \"Graphical Abstract: Nanomedicine Tumor Targeting via EPR Effect\",\n           fontsize=16, bold=True, color=title_color)\ndraw_label(ax, 8.0, 0.1, \"pH-responsive drug release in acidic tumor microenvironment\",\n           fontsize=11, color='#888888', style='italic')\n\n# ============================================================\n# Save\n# ============================================================\nplt.tight_layout()\nplt.savefig('graphical_abstract_nanomedicine.png', dpi=300, bbox_inches='tight',\n            facecolor='white')\nplt.savefig('graphical_abstract_nanomedicine.pdf', bbox_inches='tight',\n            facecolor='white')\nprint(\"Saved: graphical_abstract_nanomedicine.png and .pdf\")\nplt.show()\n"})
