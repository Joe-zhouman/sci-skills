 / 2\n\n    # Main text\n    weight = \"bold\" if bold else \"normal\"\n    ax.text(cx, cy + (4 if sub_text else 0), text,\n            ha=\"center\", va=\"center\", fontsize=font_size, fontweight=weight,\n            color=TEXT_COLOR, zorder=4)\n\n    if sub_text:\n        ax.text(cx, cy - font_size * 0.45 - 1, sub_text,\n                ha=\"center\", va=\"top\", fontsize=sub_size, color=\"#555555\",\n                zorder=4, style=\"italic\")\n\n    if extra_lines:\n        base_y = cy - (len(extra_lines) * 8) / 2\n        for i, line in enumerate(extra_lines):\n            ax.text(cx, base_y + i * 8, line,\n                    ha=\"center\", va=\"center\", fontsize=7, color=\"#444444\", zorder=4)\n\n    return rect\n\n\ndef arrow(ax, x1, y1, x2, y2, lw=1.0, color=\"#555555\"):\n    \"\"\"Straight arrow from (x1,y1) to (x2,y2).\"\"\"\n    ax.annotate(\n        \"\", xy=(x2, y2), xytext=(x1, y1),\n        arrowprops=dict(arrowstyle=\"->\", color=color, lw=lw,\n                        shrinkA=0, shrinkB=0),\n        zorder=2,\n    )\n\n\ndef bracket_text(ax, x, y, text, font_size=7.5, color=\"#666666\", ha=\"center\", va=\"top\"):\n    \"\"\"Small annotation alongside an arrow.\"\"\"\n    ax.text(x, y, text, ha=ha, va=va, fontsize=font_size, color=color,\n            fontstyle=\"italic\", zorder=5)\n\n\n# ── Figure ─────────────────────────────────────────────────────────────────\nfig, ax = plt.subplots(1, 1, figsize=(5.2, 7.8))\nax.set_xlim(0, 5.2)\nax.set_ylim(0, 7.8)\nax.axis(\"off\")\n\n# Column centres\nC = 2.6          # centre column\nARM_L = 0.8      # left arm\nARM_R = 4.4      # right arm\n\n# ── Layout grid (y positions, top → bottom) ───────────────────────────────\nY_TOP      = 7.20\nY_ASSESS   = 6.60\nY_ENROLL   = 5.90\nY_RAND     = 5.20\nY_ARM_BOX  = 4.30   # top of the treatment-period boxes\nY_ARM_MID  = 3.40   # center of treatment boxes\nY_EOT      = 2.40\nY_FU       = 1.60\nY_ANALYSIS = 0.80\n\nBOX_W_SLIM = 2.4\nBOX_H      = 0.45\nBOX_H_ARM  = 0.55\n\n# ── 1. Screening / Assessment ────────────────────────────────────────────\nrounded_box(ax, C - 1.8, Y_TOP, 3.6, BOX_H,\n            \"Patients Assessed for Eligibility\",\n            sub_text=\"(N assessed for screening)\",\n            bold=True)\n\n# Exclusion box (side)\nrounded_box(ax, C - 1.8, Y_ASSESS, 3.6, BOX_H,\n            \"Excluded\",\n            sub_text=\"• Not meeting criteria  • Declined  • Other reasons\",\n            fill_color=\"#f8f8f8\", edge_color=\"#bbbbbb\", font_size=8, sub_size=7)\n\narrow(ax, C, Y_TOP - BOX_H, C, Y_ASSESS + BOX_H)\n\n# ── 2. Enrollment ─────────────────────────────────────────────────────────\nrounded_box(ax, C - 1.5, Y_ENROLL, 3.0, BOX_H,\n            \"Enrolled & Consented\",\n            sub_text=\"(N enrolled)\",\n            bold=True)\n\narrow(ax, C, Y_ASSESS - BOX_H, C, Y_ENROLL + BOX_H)\n\n# ── 3. Randomization ───────────────────────────────────────────────────────\nrounded_box(ax, C - 1.0, Y_RAND, 2.0, BOX_H,\n            \"Randomization\",\n            sub_text=\"1:1 allocation\",\n            bold=True, fill_color=\"#eef3f8\", edge_color=BOX_COLOR)\n\narrow(ax, C, Y_ENROLL - BOX_H, C, Y_RAND + BOX_H)\nbracket_text(ax, C + 1.8, Y_RAND + BOX_H * 0.8, \"1:1\", ha=\"left\", va=\"center\")\n\n# ── Fork: two arms ────────────────────────────────────────────────────────\n# Horizontal divider\nax.plot([0.3, 4.9], [Y_RAND - BOX_H + 0.05, Y_RAND - BOX_H + 0.05],\n        color=\"#cccccc\", linewidth=0.6, zorder=1)\n\n# Arrows from Randomization down to arms\narrow(ax, C, Y_RAND - BOX_H, ARM_L + BOX_W_SLIM/2, Y_RAND - BOX_H + 0.55)\narrow(ax, C, Y_RAND - BOX_H, ARM_R - BOX_W_SLIM/2, Y_RAND - BOX_H + 0.55)\n\n# ── 4. Treatment Period ───────────────────────────────────────────────────\n# Left arm — Treatment\nrounded_box(ax, ARM_L, Y_ARM_BOX, BOX_W_SLIM, BOX_H_ARM,\n            \"Treatment Group\",\n            sub_text=\"(Drug Name / Dose Regimen)\",\n            bold=True, fill_color=\"#edf5ff\", edge_color=ACCENT, linewidth=1.4)\n\n# Right arm — Control\nrounded_box(ax, ARM_R - BOX_W_SLIM, Y_ARM_BOX, BOX_W_SLIM, BOX_H_ARM,\n            \"Control Group\",\n            sub_text=\"(Placebo / Standard of Care)\",\n            bold=True, fill_color=\"#f5f9ed\", edge_color=ACCENT2, linewidth=1.4)\n\n# ── 5. Treatment period — on-treatment visits ─────────────────────────────\ntx_visits = [\n    (\"Week 2\",   \"Day 14 ± 3\"),\n    (\"Week 4\",   \"Day 28 ± 3\"),\n    (\"Week 8\",   \"Day 56 ± 7\"),\n    (\"Week 12\",  \"Day 84 ± 7\"),\n]\n\nvisit_y_start = Y_ARM_BOX - 0.55\nvisit_spacing = 0.30\n\nfor i, (label, window) in enumerate(tx_visits):\n    vy = visit_y_start - i * visit_spacing - 0.45\n    # left arm visits\n    rounded_box(ax, ARM_L + 0.15, vy, BOX_W_SLIM - 0.3, 0.24,\n                label, sub_text=window,\n                fill_color=\"#fafcff\", edge_color=\"#b0c4de\", font_size=7, sub_size=6,\n                linewidth=0.6)\n    # right arm visits\n    rounded_box(ax, ARM_R - BOX_W_SLIM + 0.15, vy, BOX_W_SLIM - 0.3, 0.24,\n                label, sub_text=window,\n                fill_color=\"#fafff0\", edge_color=\"#b5c99a\", font_size=7, sub_size=6,\n                linewidth=0.6)\n    # arrows from arm box to first visit and between visits\n    if i == 0:\n        arrow(ax, ARM_L + BOX_W_SLIM/2, Y_ARM_BOX - BOX_H_ARM,\n              ARM_L + BOX_W_SLIM/2, vy + 0.24, lw=0.6)\n        arrow(ax, ARM_R - BOX_W_SLIM/2, Y_ARM_BOX - BOX_H_ARM,\n              ARM_R - BOX_W_SLIM/2, vy + 0.24, lw=0.6)\n    else:\n        prev_vy = visit_y_start - (i-1) * visit_spacing - 0.45\n        arrow(ax, ARM_L + BOX_W_SLIM/2, prev_vy,\n              ARM_L + BOX_W_SLIM/2, vy + 0.24, lw=0.6)\n        arrow(ax, ARM_R - BOX_W_SLIM/2, prev_vy,\n              ARM_R - BOX_W_SLIM/2, vy + 0.24, lw=0.6)\n\nlast_vy = visit_y_start - (len(tx_visits)-1) * visit_spacing - 0.45\n\n# ── 6. End of Treatment ──────────────────────────────────────────────────\narrow(ax, ARM_L + BOX_W_SLIM/2, last_vy - 0.24,\n      ARM_L + BOX_W_SLIM/2, Y_EOT + BOX_H, lw=0.8)\narrow(ax, ARM_R - BOX_W_SLIM/2, last_vy - 0.24,\n      ARM_R - BOX_W_SLIM/2, Y_EOT + BOX_H, lw=0.8)\n\nrounded_box(ax, C - 1.5, Y_EOT, 3.0, BOX_H,\n            \"End of Treatment\",\n            sub_text=\"(Week 12 — Primary Endpoint Assessment)\",\n            bold=True, fill_color=\"#f5f5f5\", edge_color=\"#888888\")\n\n# ── 7. Follow-up Visits ───────────────────────────────────────────────────\narrow(ax, C, Y_EOT - BOX_H, C, Y_FU + BOX_H, lw=0.8)\n\nfu_visits = [\n    \"Week 16  (Follow-up)\",\n    \"Week 20  (Follow-up)\",\n    \"Week 24  (Final Follow-up)\",\n]\nvisit_spacing_fu = 0.26\nfu_start = Y_FU + BOX_H + 0.10\n\nrounded_box(ax, C - 1.6, fu_start, 3.2, 0.22,\n            fu_visits[0], fill_color=\"#fafafa\", edge_color=\"#aaaaaa\",\n            font_size=7, linewidth=0.6, sub_size=6)\narrow(ax, C, Y_FU + BOX_H, C, fu_start + 0.22, lw=0.6)\n\nfor i in range(1, len(fu_visits)):\n    fy = fu_start + i * visit_spacing_fu\n    rounded_box(ax, C - 1.6, fy, 3.2, 0.22,\n                fu_visits[i], fill_color=\"#fafafa\", edge_color=\"#aaaaaa\",\n                font_size=7, linewidth=0.6, sub_size=6)\n    prev_fy = fu_start + (i-1) * visit_spacing_fu\n    arrow(ax, C, prev_fy + 0.22, C, fy + 0.22, lw=0.6)\n\nlast_fu = fu_start + (len(fu_visits)-1) * visit_spacing_fu\n\n# ── 8. Final Analysis ─────────────────────────────────────────────────────\narrow(ax, C, last_fu + 0.22 + 0.08, C, Y_ANALYSIS + BOX_H)\n\nrounded_box(ax, C - 1.8, Y_ANALYSIS, 3.6, BOX_H * 1.2,\n            \"Intention-to-Treat Analysis\",\n            sub_text=\"(N analyzed per arm)\",\n            bold=True, fill_color=\"#1a252f\", edge_color=\"#0d1319\", linewidth=1.6,\n            font_size=9.5, sub_size=8)\n# override text colour for dark box\nax.text(C, Y_ANALYSIS + BOX_H * 0.6 + 3, \"Intention-to-Treat Analysis\",\n        ha=\"center\", va=\"center\", fontsize=9.5, fontweight=\"bold\",\n        color=\"#ffffff\", zorder=5)\nax.text(C, Y_ANALYSIS + BOX_H * 0.6 - 8, \"(N analyzed per arm)\",\n        ha=\"center\", va=\"top\", fontsize=8, color=\"#cccccc\",\n        zorder=5, fontstyle=\"italic\")\n\n# ── Section labels (left margin) ──────────────────────────────────────────\nlabels_y = [Y_TOP + 0.15, Y_ENROLL + 0.15, Y_RAND + 0.15,\n            Y_ARM_BOX + 0.1, Y_EOT + 0.1, Y_ANALYSIS + 0.1]\nlabels_t = [\"Screening\", \"Enrollment\", \"Allocation\",\n            \"Treatment\", \"Follow-Up\", \"Analysis\"]\n\nfor ly, lt in zip(labels_y, labels_t):\n    ax.text(0.05, ly, lt, ha=\"left\", va=\"center\", fontsize=7,\n            color=\"#999999\", fontweight=\"bold\", rotation=0, zorder=1)\n\n# ── Title ──────────────────────────────────────────────────────────────────\nax.text(C, 7.72, \"Trial Profile\", ha=\"center\", va=\"bottom\",\n        fontsize=12, fontweight=\"bold\", color=\"#111111\")\n\n# ── Save ───────────────────────────────────────────────────────────────────\nOUT_PDF = \"/home/joe/Documents/repo/skill/sci-draw/clinical_trial_flowchart.pdf\"\nOUT_PNG  = \"/home/joe/Documents/repo/skill/sci-draw/clinical_trial_flowchart.png\"\n\nfig.savefig(OUT_PDF, dpi=DPI, bbox_inches=\"tight\", pad_inches=0.15)\nfig.savefig(OUT_PNG, dpi=DPI, bbox_inches=\"tight\", pad_inches=0.15)\nplt.close(fig)\n\nprint(f\"Saved: {OUT_PDF}\")\nprint(f\"Saved: {OUT_PNG}\")\n"})
