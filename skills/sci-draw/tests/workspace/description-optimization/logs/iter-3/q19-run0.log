TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\nCSV 数据预处理管道：读取多个 CSV → 清洗 → 编码 → 合并为特征矩阵\n\n使用方法:\n    python data_pipeline.py --input data/*.csv --output features.csv\n    python data_pipeline.py --input raw1.csv raw2.csv raw3.csv --output clean.parquet\n\n依赖: pandas>=1.5, numpy>=1.21, scikit-learn>=1.0\n安装: pip install pandas numpy scikit-learn\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport logging\nimport os\nimport sys\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Literal, Optional, Sequence, Tuple, Union\n\nimport numpy as np\nimport pandas as pd\n\n# ── 日志 ──────────────────────────────────────────────────────────────────────\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s  %(levelname)-8s  %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlogger = logging.getLogger(\"pipeline\")\n\n# ── 可配置的常量 ──────────────────────────────────────────────────────────────\nDEFAULT_MISSING_THRESHOLD = 0.8       # 缺失超过此比例的列将被丢弃\nDEFAULT_NUMERIC_STRATEGY = \"median\"    # 数值列填充策略: mean / median / zero / drop\nDEFAULT_CATEGORICAL_STRATEGY = \"mode\"  # 分类列填充策略: mode / constant / drop\nDEFAULT_CATEGORICAL_FILL_VALUE = \"missing\"  # constant 模式下的填充值\nDEFAULT_MAX_CATEGORIES = 50            # one-hot 编码的最大类别数，超出的视为高基数列\nNUMERIC_TYPES = {np.dtype(x) for x in (\"int8\", \"int16\", \"int32\", \"int64\",\n                                       \"uint8\", \"uint16\", \"uint32\", \"uint64\",\n                                       \"float16\", \"float32\", \"float64\")}\nINT_TYPES = {np.dtype(x) for x in (\"int8\", \"int16\", \"int32\", \"int64\",\n                                   \"uint8\", \"uint16\", \"uint32\", \"uint64\")}\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第一步：加载与合并\n# ══════════════════════════════════════════════════════════════════════════════\ndef load_csvs(\n    paths: Sequence[Union[str, Path]],\n    key_column: Optional[str] = None,\n    parse_dates: Optional[List[str]] = None,\n    dtype_map: Optional[Dict[str, Any]] = None,\n    **kwargs,\n) -> pd.DataFrame:\n    \"\"\"\n    读取多个 CSV 文件并合并为一个 DataFrame。\n\n    Parameters\n    ----------\n    paths : 文件路径列表，支持 glob 通配符。\n    key_column : 如果提供，以此列为合并键执行 outer join；\n                 否则将各行纵向拼接 (pd.concat)。\n    parse_dates : 需要解析为 datetime 的列名列表。\n    dtype_map : 列名到 dtypes 的映射（传给 pd.read_csv）。\n    **kwargs : 传给 pd.read_csv / pd.concat 的其它参数。\n\n    Returns\n    -------\n    pd.DataFrame — 合并后的完整数据。\n    \"\"\"\n    # 展开 glob\n    expanded: List[Path] = []\n    for p in paths:\n        p = Path(p)\n        if \"*\" in p.name or \"?\" in p.name:\n            expanded.extend(sorted(p.parent.glob(p.name)))\n        else:\n            expanded.append(p)\n\n    if not expanded:\n        raise FileNotFoundError(f\"没有找到匹配的 CSV 文件: {paths}\")\n\n    logger.info(\"找到 %d 个 CSV 文件\", len(expanded))\n    for f in expanded:\n        logger.info(\"  ╰ %s  (%s)\", f.name, _fmt_size(f.stat().st_size))\n\n    read_kwargs = dict(dtype=dtype_map or {})\n    if parse_dates:\n        read_kwargs[\"parse_dates\"] = parse_dates\n    # 用户额外参数\n    read_kwargs.update(kwargs)\n\n    if key_column:\n        # ── 按键列 outer join ──\n        frames: Dict[str, pd.DataFrame] = {}\n        for f in expanded:\n            df = pd.read_csv(f, **read_kwargs)\n            key_col = df.pop(key_column) if key_column in df.columns else None\n            if key_col is not None:\n                df = df.set_index(key_col)\n                if df.index.name is None:\n                    df.index.name = key_column\n            df.columns = [f\"{f.stem}_{col}\" for col in df.columns]\n            frames[f.stem] = df\n        merged = pd.concat(frames.values(), axis=1, join=\"outer\")\n        logger.info(\"纵向合并完成: shape = %s\", merged.shape)\n    else:\n        # ── 按列对齐后纵向拼接 ──\n        frames = [pd.read_csv(f, **read_kwargs) for f in expanded]\n        # 为每个源添加来源列（可选）\n        merged = pd.concat(frames, axis=0, ignore_index=True, join=\"outer\")\n        logger.info(\"横向合并完成: shape = %s\", merged.shape)\n\n    return merged\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第二步：自动识别列类型\n# ══════════════════════════════════════════════════════════════════════════════\ndef _infer_dtype_series(s: pd.Series) -> str:\n    \"\"\"判断单列的类型: numeric / categorical / datetime / text / bool / drop (全空).\"\"\"\n    if s.isnull().all():\n        return \"drop\"\n    non_null = s.dropna()\n    if s.dtype in NUMERIC_TYPES:\n        return \"numeric\"\n    if s.dtype == bool:\n        return \"bool\"\n    if pd.api.types.is_datetime64_any_dtype(s.dtype):\n        return \"datetime\"\n    if pd.api.types.is_object_dtype(s.dtype) or pd.api.types.is_string_dtype(s.dtype):\n        # 尝试转为数值\n        try:\n            pd.to_numeric(non_null.head(1000))\n            return \"numeric\"\n        except (ValueError, TypeError):\n            pass\n        # 尝试转为 datetime\n        try:\n            pd.to_datetime(non_null.head(1000), infer_datetime_format=True)\n            return \"datetime\"\n        except (ValueError, TypeError):\n            pass\n        # 类别数 / 总数 < 5% 且 <= max_categories → categorical\n        # 但这里只返回检测名，具体阈值在 encode_categoricals 里控制\n        nunique = non_null.nunique()\n        if nunique <= DEFAULT_MAX_CATEGORIES and nunique / max(len(non_null), 1) < 0.05:\n            return \"categorical\"\n        # 长文本\n        if non_null.str.len().mean() > 100:\n            return \"text\"\n        # 余下的视为类别\n        return \"categorical\"\n    return \"categorical\"\n\n\ndef auto_assign_types(\n    df: pd.DataFrame,\n    force_numeric: Optional[List[str]] = None,\n    force_categorical: Optional[List[str]] = None,\n    force_datetime: Optional[List[str]] = None,\n    force_drop: Optional[List[str]] = None,\n) -> Dict[str, str]:\n    \"\"\"\n    对 DataFrame 的每一列自动分配语义类型，支持人工覆盖。\n\n    Returns\n    -------\n    Dict[列名, 类型名]\n    \"\"\"\n    overrides: Dict[str, str] = {}\n    if force_numeric:\n        overrides.update({c: \"numeric\" for c in force_numeric})\n    if force_categorical:\n        overrides.update({c: \"categorical\" for c in force_categorical})\n    if force_datetime:\n        overrides.update({c: \"datetime\" for c in force_datetime})\n    if force_drop:\n        overrides.update({c: \"drop\" for c in force_drop})\n\n    types: Dict[str, str] = {}\n    for col in df.columns:\n        if col in overrides:\n            t = overrides[col]\n        else:\n            t = _infer_dtype_series(df[col])\n        types[col] = t\n\n    # 汇总\n    summary = pd.Series(list(types.values())).value_counts()\n    logger.info(\"列类型分布:\")\n    for t, cnt in summary.items():\n        logger.info(\"  ╰ %-12s: %d 列\", t, cnt)\n    return types\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第三步：缺失值处理\n# ══════════════════════════════════════════════════════════════════════════════\ndef handle_missing_values(\n    df: pd.DataFrame,\n    types: Dict[str, str],\n    numeric_strategy: str = DEFAULT_NUMERIC_STRATEGY,\n    categorical_strategy: str = DEFAULT_CATEGORICAL_STRATEGY,\n    cat_fill_value: str = DEFAULT_CATEGORICAL_FILL_VALUE,\n    missing_threshold: float = DEFAULT_MISSING_THRESHOLD,\n) -> pd.DataFrame:\n    \"\"\"\n    处理缺失值：\n      - 丢弃缺失超过 `missing_threshold` 比例的列。\n      - 对数值列按策略填充。\n      - 对分类列按策略填充。\n      - 丢弃含缺失的行（仅当相应策略为 \"drop\" 时）。\n    \"\"\"\n    total_rows = len(df)\n    result = df.copy()\n\n    # ── 1) 删除高缺失列 ──\n    before_drop = result.shape[1]\n    drop_cols = []\n    for col in result.columns:\n        if result[col].isnull().mean() >= missing_threshold:\n            drop_cols.append(col)\n    if drop_cols:\n        result.drop(columns=drop_cols, inplace=True)\n        logger.info(\"删除高缺失列 (>%.0f%%): %s\", missing_threshold * 100, drop_cols)\n    after_drop = result.shape[1]\n    _ = before_drop - after_drop  # 仅用于日志，已 log\n\n    # ── 2) 按类型填充 ──\n    for col in result.columns:\n        col_type = types.get(col, _infer_dtype_series(result[col]))\n        if result[col].isnull().sum() == 0:\n            continue\n\n        if col_type == \"numeric\":\n            if numeric_strategy == \"drop\":\n                result.dropna(subset=[col], inplace=True)\n            elif numeric_strategy == \"zero\":\n                result[col] = result[col].fillna(0)\n            elif numeric_strategy in (\"mean\", \"median\"):\n                fill_val = result[col].mean() if numeric_strategy == \"mean\" else result[col].median()\n                result[col] = result[col].fillna(fill_val)\n            else:\n                raise ValueError(f\"不支持的数值列填充策略: {numeric_strategy}\")\n\n        elif col_type in (\"categorical\", \"bool\"):\n            if categorical_strategy == \"drop\":\n                result.dropna(subset=[col], inplace=True)\n            elif categorical_strategy == \"mode\":\n                mode_val = result[col].mode(dropna=True)\n                fill_val = mode_val.iloc[0] if not mode_val.empty else cat_fill_value\n                result[col] = result[col].fillna(fill_val)\n            elif categorical_strategy == \"constant\":\n                result[col] = result[col].fillna(cat_fill_value)\n            else:\n                raise ValueError(f\"不支持的分类列填充策略: {categorical_strategy}\")\n\n        # datetime/text 列: 提示但暂时不特殊处理 — 会在 _preprocess_datetime 中处理\n        elif col_type == \"datetime\":\n            # 不填充，后续可以转化为数值特征\n            pass\n        elif col_type == \"text\":\n            # 文本列填充为空字符串\n            result[col] = result[col].fillna(\"\")\n        # \"drop\": 已经在上一步删除\n\n    dropped = total_rows - len(result)\n    if dropped:\n        logger.warning(\"由于缺失值丢弃了 %d 行 (%.1f%%)\", dropped, 100 * dropped / total_rows)\n    logger.info(\"缺失值处理完成: shape = %s\", result.shape)\n    return result\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第四步：数值列标准化\n# ══════════════════════════════════════════════════════════════════════════════\ndef standardize_numeric(\n    df: pd.DataFrame,\n    types: Dict[str, str],\n    method: Literal[\"zscore\", \"minmax\", \"robust\", \"none\"] = \"zscore\",\n    clip: bool = True,\n    clip_range: Tuple[float, float] = (-3.0, 3.0),\n) -> pd.DataFrame:\n    \"\"\"\n    对数值列做标准化。\n\n    Parameters\n    ----------\n    method :\n        - zscore : (x - mean) / std\n        - minmax : (x - min) / (max - min) → [0, 1]\n        - robust : (x - median) / IQR\n        - none   : 不做标准化\n    clip : 是否裁剪极值（仅 zscore/robust 有效）。\n    \"\"\"\n    if method == \"none\":\n        return df\n\n    result = df.copy()\n    numeric_cols = [c for c in result.columns if types.get(c) == \"numeric\"]\n    if not numeric_cols:\n        return result\n\n    values = result[numeric_cols]\n\n    if method == \"zscore\":\n        means = values.mean()\n        stds = values.std(ddof=0)\n        # 避免除以零\n        stds = stds.replace(0, 1.0)\n        scaled = (values - means) / stds\n        if clip:\n            scaled = scaled.clip(*clip_range)\n\n    elif method == \"minmax\":\n        mins = values.min()\n        maxs = values.max()\n        ranges = maxs - mins\n        ranges = ranges.replace(0, 1.0)\n        scaled = (values - mins) / ranges\n\n    elif method == \"robust\":\n        medians = values.median()\n        q1 = values.quantile(0.25)\n        q3 = values.quantile(0.75)\n        iqr = q3 - q1\n        iqr = iqr.replace(0, 1.0)\n        scaled = (values - medians) / iqr\n        if clip:\n            scaled = scaled.clip(*clip_range)\n    else:\n        raise ValueError(f\"不支持的标准化方法: {method}\")\n\n    result[numeric_cols] = scaled\n\n    _log_scaling(numeric_cols, method)\n    return result\n\n\ndef _log_scaling(cols: List[str], method: str) -> None:\n    logger.info(\"数值列标准化完成 (%s): %d 列\", method, len(cols))\n    if len(cols) <= 10:\n        for c in cols:\n            logger.info(\"  ╰ %s\", c)\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第五步：分类变量 one-hot 编码\n# ══════════════════════════════════════════════════════════════════════════════\ndef encode_categoricals(\n    df: pd.DataFrame,\n    types: Dict[str, str],\n    max_categories: int = DEFAULT_MAX_CATEGORIES,\n    drop_first: bool = False,\n    handle_unknown: Literal[\"error\", \"ignore\"] = \"ignore\",\n    max_onehot_cols: int = 1000,\n) -> pd.DataFrame:\n    \"\"\"\n    One-hot 编码分类列。\n\n    注意：\n      - 超过 `max_categories` 个唯一值的列将被标记为 \"high_cardinality\"\n        并跳过编码（只保留原始列，可在后续步骤自行决定是否删除或做\n        target encoding）。\n      - 二值列 (2 个唯一值) 自动转为 0/1 整数，不会扩展为多列。\n    \"\"\"\n    cat_cols = [c for c in df.columns if types.get(c) == \"categorical\"]\n    if not cat_cols:\n        return df\n\n    result = df.drop(columns=cat_cols)\n    total_onehot_cols = 0\n\n    for col in cat_cols:\n        ser = df[col].astype(str)  # 统一为字符串避免混合类型问题\n        nunique = ser.nunique(dropna=False)\n\n        # ── 高基数列 ──\n        if nunique > max_categories:\n            logger.warning(\n                \"列 '%s' 有 %d 个唯一值 (> %d)，跳过 one-hot 编码。\",\n                col, nunique, max_categories,\n            )\n            result[col] = ser  # 保留原始列\n            continue\n\n        # ── 二值列 → 0/1 ──\n        if nunique == 2:\n            vals = ser.unique().tolist()\n            result[f\"{col}_bin\"] = ser.map({vals[0]: 0, vals[1]: 1}).astype(np.int8)\n            logger.info(\"  ╰ %s  → 二值编码 (%s=%d, %s=%d)\", col, vals[0], 0, vals[1], 1)\n            continue\n\n        # ── 单值列 → 无信息，丢弃 ──\n        if nunique <= 1:\n            logger.info(\"  ╰ %s  → 常数列，丢弃\", col)\n            continue\n\n        # ── 多值列 → one-hot ──\n        dummies = pd.get_dummies(ser, prefix=col, drop_first=drop_first,\n                                 dummy_na=(ser.isnull().any() and not drop_first))\n        # 确保 dummy 列是 int\n        for dc in dummies.columns:\n            dummies[dc] = dummies[dc].astype(np.int8)\n\n        # 检查是否会超出总列数上限\n        if total_onehot_cols + dummies.shape[1] > max_onehot_cols:\n            logger.warning(\n                \"列 '%s' 将产生 %d 个 one-hot 列，超过剩余限额 (%d)，跳过。\",\n                col, dummies.shape[1], max_onehot_cols - total_onehot_cols,\n            )\n            result[col] = ser\n            continue\n\n        result = pd.concat([result, dummies], axis=1)\n        total_onehot_cols += dummies.shape[1]\n        logger.info(\"  ╰ %s  → one-hot (%d 列)\", col, dummies.shape[1])\n\n    logger.info(\"One-hot 编码完成: 新增 %d 列，总计 shape = %s\",\n                total_onehot_cols, result.shape)\n    return result\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第六步：datetime 特征提取\n# ══════════════════════════════════════════════════════════════════════════════\ndef extract_datetime_features(\n    df: pd.DataFrame,\n    types: Dict[str, str],\n    features: Sequence[str] = (\"year\", \"month\", \"day\", \"dayofweek\", \"hour\"),\n    drop_original: bool = True,\n) -> pd.DataFrame:\n    \"\"\"\n    从 datetime 列中提取数值特征（年/月/日/星期/小时等），\n    并删除原始 datetime 列（可选）。\n    \"\"\"\n    dt_cols = [c for c in df.columns if types.get(c) == \"datetime\"]\n    if not dt_cols:\n        return df\n\n    result = df.copy()\n    for col in dt_cols:\n        parsed = pd.to_datetime(result[col], errors=\"coerce\")\n        if parsed.isnull().all():\n            logger.warning(\"列 '%s' 无法解析为日期，保留原始列。\", col)\n            continue\n        for feat in features:\n            if feat == \"year\":\n                result[f\"{col}_year\"] = parsed.dt.year.fillna(-1).astype(np.int16)\n            elif feat == \"month\":\n                result[f\"{col}_month\"] = parsed.dt.month.fillna(-1).astype(np.int8)\n            elif feat == \"day\":\n                result[f\"{col}_day\"] = parsed.dt.day.fillna(-1).astype(np.int8)\n            elif feat == \"dayofweek\":\n                result[f\"{col}_dayofweek\"] = parsed.dt.dayofweek.fillna(-1).astype(np.int8)\n            elif feat == \"hour\":\n                result[f\"{col}_hour\"] = parsed.dt.hour.fillna(-1).astype(np.int8)\n            elif feat == \"quarter\":\n                result[f\"{col}_quarter\"] = parsed.dt.quarter.fillna(-1).astype(np.int8)\n            elif feat == \"is_weekend\":\n                result[f\"{col}_is_weekend\"] = (parsed.dt.dayofweek >= 5).astype(np.int8)\n            elif feat == \"timestamp\":\n                # Unix 秒数\n                result[f\"{col}_ts\"] = (parsed.astype(np.int64) // 10**9).fillna(-1).astype(np.int64)\n            else:\n                logger.warning(\"不支持的时间特征 '%s'，忽略。\", feat)\n\n        if drop_original:\n            result.drop(columns=[col], inplace=True)\n\n    logger.info(\"日期特征提取完成: shape = %s\", result.shape)\n    return result\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第七步：bool 列转为 0/1\n# ══════════════════════════════════════════════════════════════════════════════\ndef convert_bool_columns(df: pd.DataFrame, types: Dict[str, str]) -> pd.DataFrame:\n    \"\"\"将 bool 列转换为 0/1 int。\"\"\"\n    result = df.copy()\n    for col in result.columns:\n        if types.get(col) == \"bool\":\n            result[col] = result[col].astype(int)\n    return result\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  完整 Pipeline\n# ══════════════════════════════════════════════════════════════════════════════\ndef run_pipeline(\n    input_paths: Sequence[Union[str, Path]],\n    output_path: Union[str, Path],\n    *,\n    key_column: Optional[str] = None,\n    parse_dates: Optional[List[str]] = None,\n    dtype_map: Optional[Dict[str, Any]] = None,\n    force_numeric: Optional[List[str]] = None,\n    force_categorical: Optional[List[str]] = None,\n    force_datetime: Optional[List[str]] = None,\n    force_drop: Optional[List[str]] = None,\n    numeric_strategy: str = DEFAULT_NUMERIC_STRATEGY,\n    categorical_strategy: str = DEFAULT_CATEGORICAL_STRATEGY,\n    cat_fill_value: str = DEFAULT_CATEGORICAL_FILL_VALUE,\n    missing_threshold: float = DEFAULT_MISSING_THRESHOLD,\n    scaling_method: Literal[\"zscore\", \"minmax\", \"robust\", \"none\"] = \"zscore\",\n    scaling_clip: bool = True,\n    max_categories: int = DEFAULT_MAX_CATEGORIES,\n    drop_first_encoding: bool = False,\n    extract_dt_features: bool = True,\n    dt_features: Sequence[str] = (\"year\", \"month\", \"day\", \"dayofweek\"),\n    dt_drop_original: bool = True,\n    export_format: Literal[\"csv\", \"parquet\", \"pickle\", \"feather\"] = \"csv\",\n) -> pd.DataFrame:\n    \"\"\"\n    完整预处理 Pipeline:\n\n      1. 加载 & 合并 CSV\n      2. 自动列类型推断\n      3. 缺失值处理\n      4. 数值标准化\n      5. One-hot 编码\n      6. 日期特征提取\n      7. Bool 转换\n      8. 导出\n\n    Returns\n    -------\n    最终的特征矩阵 DataFrame。\n    \"\"\"\n    logger.info(\"=\" * 56)\n    logger.info(\"  数据预处理 Pipeline  开始\")\n    logger.info(\"=\" * 56)\n    logger.info(\"输入文件: %s\", list(input_paths))\n    logger.info(\"输出路径: %s\", output_path)\n\n    # ── Step 1 ──\n    logger.info(\"\\n── Step 1/8: 加载 CSV ──\")\n    df = load_csvs(input_paths, key_column, parse_dates, dtype_map)\n\n    if df.empty:\n        raise ValueError(\"合并后 DataFrame 为空，请检查输入文件。\")\n\n    # ── Step 2 ──\n    logger.info(\"\\n── Step 2/8: 列类型推断 ──\")\n    types = auto_assign_types(df, force_numeric, force_categorical, force_datetime, force_drop)\n\n    # ── Step 3 ���─\n    logger.info(\"\\n── Step 3/8: 缺失值处理 ──\")\n    df = handle_missing_values(df, types, numeric_strategy, categorical_strategy,\n                                cat_fill_value, missing_threshold)\n\n    # ── Step 4 ──\n    logger.info(\"\\n── Step 4/8: 数值标准化 (%s) ──\", scaling_method)\n    df = standardize_numeric(df, types, scaling_method, clip=scaling_clip)\n\n    # ── Step 5 ──\n    logger.info(\"\\n── Step 5/8: One-hot 编码 ──\")\n    df = encode_categoricals(df, types, max_categories, drop_first_encoding)\n\n    # ── Step 6 ──\n    if extract_dt_features:\n        logger.info(\"\\n── Step 6/8: 日期特征提取 ──\")\n        df = extract_datetime_features(df, types, dt_features, dt_drop_original)\n    else:\n        logger.info(\"\\n── Step 6/8: 跳过 (关闭日期特征) ──\")\n\n    # ── Step 7 ──\n    logger.info(\"\\n── Step 7/8: Bool 列转换 ──\")\n    df = convert_bool_columns(df, types)\n\n    # ── Step 8 ──\n    logger.info(f\"\\n── Step 8/8: 导出 [{export_format.upper()}] ──\")\n    export_dataframe(df, output_path, export_format)\n\n    logger.info(\"\\n\" + \"=\" * 56)\n    logger.info(\"  Pipeline 完成！最终 shape: %s\", df.shape)\n    logger.info(\"=\" * 56)\n\n    return df\n\n\ndef export_dataframe(\n    df: pd.DataFrame,\n    path: Union[str, Path],\n    fmt: Literal[\"csv\", \"parquet\", \"pickle\", \"feather\"] = \"csv\",\n) -> None:\n    \"\"\"统一导出接口。\"\"\"\n    path = Path(path)\n    path.parent.mkdir(parents=True, exist_ok=True)\n\n    if fmt == \"csv\":\n        df.to_csv(path, index=False)\n    elif fmt == \"parquet\":\n        df.to_parquet(path, index=False)\n    elif fmt == \"pickle\":\n        df.to_pickle(path)\n    elif fmt == \"feather\":\n        df.to_feather(path)\n    else:\n        raise ValueError(f\"不支持的导出格式: {fmt}\")\n\n    logger.info(\"已保存: %s  (%.1f MB)\", path, path.stat().st_size / 1_000_000)\n\n\n# ── 辅助 ──────────────────────────────────────────────────────────────────────\ndef _fmt_size(bytes_: int) -> str:\n    if bytes_ >= 1_000_000:\n        return f\"{bytes_ / 1_000_000:.1f} MB\"\n    if bytes_ >= 1_000:\n        return f\"{bytes_ / 1_000:.1f} KB\"\n    return f\"{bytes_} B\"\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  CLI 入口\n# ══════════════════════════════════════════════════════════════════════════════\ndef _parse_args(argv: Optional[List[str]] = None) -> argparse.Namespace:\n    p = argparse.ArgumentParser(\n        description=\"CSV 数据预处理 Pipeline：多文件合并 → 清洗 → 编码 → 导出特征矩阵\",\n        formatter_class=argparse.ArgumentDefaultsHelpFormatter,\n    )\n\n    # ── 输入 / 输出 ──\n    p.add_argument(\"--input\", \"-i\", nargs=\"+\", required=True,\n                   help=\"CSV 输入文件或 glob 模式（如 data/*.csv）\")\n    p.add_argument(\"--output\", \"-o\", default=\"features.csv\",\n                   help=\"输出文件路径（扩展名决定推荐格式，用 --format 覆盖）\")\n    p.add_argument(\"--format\", choices=(\"csv\", \"parquet\", \"pickle\", \"feather\"),\n                   default=None,\n                   help=\"输出格式（默认根据 --output 扩展名推断，否则 csv）\")\n    p.add_argument(\"--key-column\", default=None,\n                   help=\"按此列执行 outer join 合并（否则纵向拼接）\")\n\n    # ── 列类型覆盖 ──\n    p.add_argument(\"--force-numeric\", nargs=\"*\", default=None,\n                   help=\"强制指定为数值列的列名\")\n    p.add_argument(\"--force-categorical\", nargs=\"*\", default=None,\n                   help=\"强制指定为分类列的列名\")\n    p.add_argument(\"--force-datetime\", nargs=\"*\", default=None,\n                   help=\"强制指定为日期列的列名\")\n    p.add_argument(\"--force-drop\", nargs=\"*\", default=None,\n                   help=\"强制丢弃的列名\")\n\n    # ── 缺失值 ──\n    p.add_argument(\"--missing-threshold\", type=float, default=DEFAULT_MISSING_THRESHOLD,\n                   help=\"列缺失比例超过此值则丢弃\")\n    p.add_argument(\"--numeric-strategy\", choices=(\"mean\", \"median\", \"zero\", \"drop\"),\n                   default=DEFAULT_NUMERIC_STRATEGY,\n                   help=\"数值列缺失填充策略\")\n    p.add_argument(\"--categorical-strategy\", choices=(\"mode\", \"constant\", \"drop\"),\n                   default=DEFAULT_CATEGORICAL_STRATEGY,\n                   help=\"分类列缺失填充策略\")\n    p.add_argument(\"--cat-fill-value\", default=DEFAULT_CATEGORICAL_FILL_VALUE,\n                   help=\"分类列 constant 填充的值\")\n\n    # ── 标准化 ──\n    p.add_argument(\"--scaling\", choices=(\"zscore\", \"minmax\", \"robust\", \"none\"),\n                   default=\"zscore\", help=\"数值列标准化方法\")\n    p.add_argument(\"--no-clip\", action=\"store_true\",\n                   help=\"不裁剪标准化后的极值（默认裁剪到 ±3σ）\")\n\n    # ── 编码 ──\n    p.add_argument(\"--max-categories\", type=int, default=DEFAULT_MAX_CATEGORIES,\n                   help=\"one-hot 编码的最大类别数，超过则跳过\")\n    p.add_argument(\"--drop-first\", action=\"store_true\",\n                   help=\"one-hot 时丢弃第一个类别（避免多重共线性）\")\n\n    # ── 日期 ──\n    p.add_argument(\"--no-dt-features\", action=\"store_true\",\n                   help=\"不提取日期特征\")\n    p.add_argument(\"--dt-features\", nargs=\"*\",\n                   default=[\"year\", \"month\", \"day\", \"dayofweek\"],\n                   help=\"从日期列提取的特征: year month day dayofweek hour quarter is_weekend timestamp\")\n    p.add_argument(\"--keep-dt-columns\", action=\"store_true\",\n                   help=\"保留原始日期列（默认丢弃）\")\n\n    return p.parse_args(argv)\n\n\ndef main(argv: Optional[List[str]] = None) -> int:\n    args = _parse_args(argv)\n\n    # 自动推断格式\n    if args.format is None:\n        ext = Path(args.output).suffix.lstrip(\".\").lower()\n        fmt = ext if ext in (\"csv\", \"parquet\", \"pickle\", \"feather\") else \"csv\"\n    else:\n        fmt = args.format\n\n    run_pipeline(\n        input_paths=args.input,\n        output_path=args.output,\n        key_column=args.key_column,\n        force_numeric=args.force_numeric,\n        force_categorical=args.force_categorical,\n        force_datetime=args.force_datetime,\n        force_drop=args.force_drop,\n        numeric_strategy=args.numeric_strategy,\n        categorical_strategy=args.categorical_strategy,\n        cat_fill_value=args.cat_fill_value,\n        missing_threshold=args.missing_threshold,\n        scaling_method=args.scaling,\n        scaling_clip=not args.no_clip,\n        max_categories=args.max_categories,\n        drop_first_encoding=args.drop_first,\n        extract_dt_features=not args.no_dt_features,\n        dt_features=args.dt_features,\n        dt_drop_original=not args.keep_dt_columns,\n        export_format=fmt,\n    )\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\nCSV 数据预处理管道：读取多个 CSV → 清洗 → 编码 → 合并为特征矩阵\n\n使用方法:\n    python data_pipeline.py --input data/*.csv --output features.csv\n    python data_pipeline.py --input raw1.csv raw2.csv raw3.csv --output clean.parquet\n\n依赖: pandas>=1.5, numpy>=1.21, scikit-learn>=1.0\n安装: pip install pandas numpy scikit-learn\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport logging\nimport os\nimport sys\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Literal, Optional, Sequence, Tuple, Union\n\nimport numpy as np\nimport pandas as pd\n\n# ── 日志 ──────────────────────────────────────────────────────────────────────\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s  %(levelname)-8s  %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlogger = logging.getLogger(\"pipeline\")\n\n# ── 可配置的常量 ──────────────────────────────────────────────────────────────\nDEFAULT_MISSING_THRESHOLD = 0.8       # 缺失超过此比例的列将被丢弃\nDEFAULT_NUMERIC_STRATEGY = \"median\"    # 数值列填充策略: mean / median / zero / drop\nDEFAULT_CATEGORICAL_STRATEGY = \"mode\"  # 分类列填充策略: mode / constant / drop\nDEFAULT_CATEGORICAL_FILL_VALUE = \"missing\"  # constant 模式下的填充值\nDEFAULT_MAX_CATEGORIES = 50            # one-hot 编码的最大类别数，超出的视为高基数列\nNUMERIC_TYPES = {np.dtype(x) for x in (\"int8\", \"int16\", \"int32\", \"int64\",\n                                       \"uint8\", \"uint16\", \"uint32\", \"uint64\",\n                                       \"float16\", \"float32\", \"float64\")}\nINT_TYPES = {np.dtype(x) for x in (\"int8\", \"int16\", \"int32\", \"int64\",\n                                   \"uint8\", \"uint16\", \"uint32\", \"uint64\")}\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第一步：加载与合并\n# ══════════════════════════════════════════════════════════════════════════════\ndef load_csvs(\n    paths: Sequence[Union[str, Path]],\n    key_column: Optional[str] = None,\n    parse_dates: Optional[List[str]] = None,\n    dtype_map: Optional[Dict[str, Any]] = None,\n    **kwargs,\n) -> pd.DataFrame:\n    \"\"\"\n    读取多个 CSV 文件并合并为一个 DataFrame。\n\n    Parameters\n    ----------\n    paths : 文件路径列表，支持 glob 通配符。\n    key_column : 如果提供，以此列为合并键执行 outer join；\n                 否则将各行纵向拼接 (pd.concat)。\n    parse_dates : 需要解析为 datetime 的列名列表。\n    dtype_map : 列名到 dtypes 的映射（传给 pd.read_csv）。\n    **kwargs : 传给 pd.read_csv / pd.concat 的其它参数。\n\n    Returns\n    -------\n    pd.DataFrame — 合并后的完整数据。\n    \"\"\"\n    # 展开 glob\n    expanded: List[Path] = []\n    for p in paths:\n        p = Path(p)\n        if \"*\" in p.name or \"?\" in p.name:\n            expanded.extend(sorted(p.parent.glob(p.name)))\n        else:\n            expanded.append(p)\n\n    if not expanded:\n        raise FileNotFoundError(f\"没有找到匹配的 CSV 文件: {paths}\")\n\n    logger.info(\"找到 %d 个 CSV 文件\", len(expanded))\n    for f in expanded:\n        logger.info(\"  ╰ %s  (%s)\", f.name, _fmt_size(f.stat().st_size))\n\n    read_kwargs = dict(dtype=dtype_map or {})\n    if parse_dates:\n        read_kwargs[\"parse_dates\"] = parse_dates\n    # 用户额外参数\n    read_kwargs.update(kwargs)\n\n    if key_column:\n        # ── 按键列 outer join ──\n        frames: Dict[str, pd.DataFrame] = {}\n        for f in expanded:\n            df = pd.read_csv(f, **read_kwargs)\n            key_col = df.pop(key_column) if key_column in df.columns else None\n            if key_col is not None:\n                df = df.set_index(key_col)\n                if df.index.name is None:\n                    df.index.name = key_column\n            df.columns = [f\"{f.stem}_{col}\" for col in df.columns]\n            frames[f.stem] = df\n        merged = pd.concat(frames.values(), axis=1, join=\"outer\")\n        logger.info(\"纵向合并完成: shape = %s\", merged.shape)\n    else:\n        # ── 按列对齐后纵向拼接 ──\n        frames = [pd.read_csv(f, **read_kwargs) for f in expanded]\n        # 为每个源添加来源列（可选）\n        merged = pd.concat(frames, axis=0, ignore_index=True, join=\"outer\")\n        logger.info(\"横向合并完成: shape = %s\", merged.shape)\n\n    return merged\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第二步：自动识别列类型\n# ══════════════════════════════════════════════════════════════════════════════\ndef _infer_dtype_series(s: pd.Series) -> str:\n    \"\"\"判断单列的类型: numeric / categorical / datetime / text / bool / drop (全空).\"\"\"\n    if s.isnull().all():\n        return \"drop\"\n    non_null = s.dropna()\n    if s.dtype in NUMERIC_TYPES:\n        return \"numeric\"\n    if s.dtype == bool:\n        return \"bool\"\n    if pd.api.types.is_datetime64_any_dtype(s.dtype):\n        return \"datetime\"\n    if pd.api.types.is_object_dtype(s.dtype) or pd.api.types.is_string_dtype(s.dtype):\n        # 尝试转为数值\n        try:\n            pd.to_numeric(non_null.head(1000))\n            return \"numeric\"\n        except (ValueError, TypeError):\n            pass\n        # 尝试转为 datetime\n        try:\n            pd.to_datetime(non_null.head(1000), infer_datetime_format=True)\n            return \"datetime\"\n        except (ValueError, TypeError):\n            pass\n        # 类别数 / 总数 < 5% 且 <= max_categories → categorical\n        # 但这里只返回检测名，具体阈值在 encode_categoricals 里控制\n        nunique = non_null.nunique()\n        if nunique <= DEFAULT_MAX_CATEGORIES and nunique / max(len(non_null), 1) < 0.05:\n            return \"categorical\"\n        # 长文本\n        if non_null.str.len().mean() > 100:\n            return \"text\"\n        # 余下的视为类别\n        return \"categorical\"\n    return \"categorical\"\n\n\ndef auto_assign_types(\n    df: pd.DataFrame,\n    force_numeric: Optional[List[str]] = None,\n    force_categorical: Optional[List[str]] = None,\n    force_datetime: Optional[List[str]] = None,\n    force_drop: Optional[List[str]] = None,\n) -> Dict[str, str]:\n    \"\"\"\n    对 DataFrame 的每一列自动分配语义类型，支持人工覆盖。\n\n    Returns\n    -------\n    Dict[列名, 类型名]\n    \"\"\"\n    overrides: Dict[str, str] = {}\n    if force_numeric:\n        overrides.update({c: \"numeric\" for c in force_numeric})\n    if force_categorical:\n        overrides.update({c: \"categorical\" for c in force_categorical})\n    if force_datetime:\n        overrides.update({c: \"datetime\" for c in force_datetime})\n    if force_drop:\n        overrides.update({c: \"drop\" for c in force_drop})\n\n    types: Dict[str, str] = {}\n    for col in df.columns:\n        if col in overrides:\n            t = overrides[col]\n        else:\n            t = _infer_dtype_series(df[col])\n        types[col] = t\n\n    # 汇总\n    summary = pd.Series(list(types.values())).value_counts()\n    logger.info(\"列类型分布:\")\n    for t, cnt in summary.items():\n        logger.info(\"  ╰ %-12s: %d 列\", t, cnt)\n    return types\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第三步：缺失值处理\n# ══════════════════════════════════════════════════════════════════════════════\ndef handle_missing_values(\n    df: pd.DataFrame,\n    types: Dict[str, str],\n    numeric_strategy: str = DEFAULT_NUMERIC_STRATEGY,\n    categorical_strategy: str = DEFAULT_CATEGORICAL_STRATEGY,\n    cat_fill_value: str = DEFAULT_CATEGORICAL_FILL_VALUE,\n    missing_threshold: float = DEFAULT_MISSING_THRESHOLD,\n) -> pd.DataFrame:\n    \"\"\"\n    处理缺失值：\n      - 丢弃缺失超过 `missing_threshold` 比例的列。\n      - 对数值列按策略填充。\n      - 对分类列按策略填充。\n      - 丢弃含缺失的行（仅当相应策略为 \"drop\" 时）。\n    \"\"\"\n    total_rows = len(df)\n    result = df.copy()\n\n    # ── 1) 删除高缺失列 ──\n    before_drop = result.shape[1]\n    drop_cols = []\n    for col in result.columns:\n        if result[col].isnull().mean() >= missing_threshold:\n            drop_cols.append(col)\n    if drop_cols:\n        result.drop(columns=drop_cols, inplace=True)\n        logger.info(\"删除高缺失列 (>%.0f%%): %s\", missing_threshold * 100, drop_cols)\n    after_drop = result.shape[1]\n    _ = before_drop - after_drop  # 仅用于日志，已 log\n\n    # ── 2) 按类型填充 ──\n    for col in result.columns:\n        col_type = types.get(col, _infer_dtype_series(result[col]))\n        if result[col].isnull().sum() == 0:\n            continue\n\n        if col_type == \"numeric\":\n            if numeric_strategy == \"drop\":\n                result.dropna(subset=[col], inplace=True)\n            elif numeric_strategy == \"zero\":\n                result[col] = result[col].fillna(0)\n            elif numeric_strategy in (\"mean\", \"median\"):\n                fill_val = result[col].mean() if numeric_strategy == \"mean\" else result[col].median()\n                result[col] = result[col].fillna(fill_val)\n            else:\n                raise ValueError(f\"不支持的数值列填充策略: {numeric_strategy}\")\n\n        elif col_type in (\"categorical\", \"bool\"):\n            if categorical_strategy == \"drop\":\n                result.dropna(subset=[col], inplace=True)\n            elif categorical_strategy == \"mode\":\n                mode_val = result[col].mode(dropna=True)\n                fill_val = mode_val.iloc[0] if not mode_val.empty else cat_fill_value\n                result[col] = result[col].fillna(fill_val)\n            elif categorical_strategy == \"constant\":\n                result[col] = result[col].fillna(cat_fill_value)\n            else:\n                raise ValueError(f\"不支持的分类列填充策略: {categorical_strategy}\")\n\n        # datetime/text 列: 提示但暂时不特殊处理 — 会在 _preprocess_datetime 中处理\n        elif col_type == \"datetime\":\n            # 不填充，后续可以转化为数值特征\n            pass\n        elif col_type == \"text\":\n            # 文本列填充为空字符串\n            result[col] = result[col].fillna(\"\")\n        # \"drop\": 已经在上一步删除\n\n    dropped = total_rows - len(result)\n    if dropped:\n        logger.warning(\"由于缺失值丢弃了 %d 行 (%.1f%%)\", dropped, 100 * dropped / total_rows)\n    logger.info(\"缺失值处理完成: shape = %s\", result.shape)\n    return result\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第四步：数值列标准化\n# ══════════════════════════════════════════════════════════════════════════════\ndef standardize_numeric(\n    df: pd.DataFrame,\n    types: Dict[str, str],\n    method: Literal[\"zscore\", \"minmax\", \"robust\", \"none\"] = \"zscore\",\n    clip: bool = True,\n    clip_range: Tuple[float, float] = (-3.0, 3.0),\n) -> pd.DataFrame:\n    \"\"\"\n    对数值列做标准化。\n\n    Parameters\n    ----------\n    method :\n        - zscore : (x - mean) / std\n        - minmax : (x - min) / (max - min) → [0, 1]\n        - robust : (x - median) / IQR\n        - none   : 不做标准化\n    clip : 是否裁剪极值（仅 zscore/robust 有效）。\n    \"\"\"\n    if method == \"none\":\n        return df\n\n    result = df.copy()\n    numeric_cols = [c for c in result.columns if types.get(c) == \"numeric\"]\n    if not numeric_cols:\n        return result\n\n    values = result[numeric_cols]\n\n    if method == \"zscore\":\n        means = values.mean()\n        stds = values.std(ddof=0)\n        # 避免除以零\n        stds = stds.replace(0, 1.0)\n        scaled = (values - means) / stds\n        if clip:\n            scaled = scaled.clip(*clip_range)\n\n    elif method == \"minmax\":\n        mins = values.min()\n        maxs = values.max()\n        ranges = maxs - mins\n        ranges = ranges.replace(0, 1.0)\n        scaled = (values - mins) / ranges\n\n    elif method == \"robust\":\n        medians = values.median()\n        q1 = values.quantile(0.25)\n        q3 = values.quantile(0.75)\n        iqr = q3 - q1\n        iqr = iqr.replace(0, 1.0)\n        scaled = (values - medians) / iqr\n        if clip:\n            scaled = scaled.clip(*clip_range)\n    else:\n        raise ValueError(f\"不支持的标准化方法: {method}\")\n\n    result[numeric_cols] = scaled\n\n    _log_scaling(numeric_cols, method)\n    return result\n\n\ndef _log_scaling(cols: List[str], method: str) -> None:\n    logger.info(\"数值列标准化完成 (%s): %d 列\", method, len(cols))\n    if len(cols) <= 10:\n        for c in cols:\n            logger.info(\"  ╰ %s\", c)\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第五步：分类变量 one-hot 编码\n# ══════════════════════════════════════════════════════════════════════════════\ndef encode_categoricals(\n    df: pd.DataFrame,\n    types: Dict[str, str],\n    max_categories: int = DEFAULT_MAX_CATEGORIES,\n    drop_first: bool = False,\n    handle_unknown: Literal[\"error\", \"ignore\"] = \"ignore\",\n    max_onehot_cols: int = 1000,\n) -> pd.DataFrame:\n    \"\"\"\n    One-hot 编码分类列。\n\n    注意：\n      - 超过 `max_categories` 个唯一值的列将被标记为 \"high_cardinality\"\n        并跳过编码（只保留原始列，可在后续步骤自行决定是否删除或做\n        target encoding）。\n      - 二值列 (2 个唯一值) 自动转为 0/1 整数，不会扩展为多列。\n    \"\"\"\n    cat_cols = [c for c in df.columns if types.get(c) == \"categorical\"]\n    if not cat_cols:\n        return df\n\n    result = df.drop(columns=cat_cols)\n    total_onehot_cols = 0\n\n    for col in cat_cols:\n        ser = df[col].astype(str)  # 统一为字符串避免混合类型问题\n        nunique = ser.nunique(dropna=False)\n\n        # ── 高基数列 ──\n        if nunique > max_categories:\n            logger.warning(\n                \"列 '%s' 有 %d 个唯一值 (> %d)，跳过 one-hot 编码。\",\n                col, nunique, max_categories,\n            )\n            result[col] = ser  # 保留原始列\n            continue\n\n        # ── 二值列 → 0/1 ──\n        if nunique == 2:\n            vals = ser.unique().tolist()\n            result[f\"{col}_bin\"] = ser.map({vals[0]: 0, vals[1]: 1}).astype(np.int8)\n            logger.info(\"  ╰ %s  → 二值编码 (%s=%d, %s=%d)\", col, vals[0], 0, vals[1], 1)\n            continue\n\n        # ── 单值列 → 无信息，丢弃 ──\n        if nunique <= 1:\n            logger.info(\"  ╰ %s  → 常数列，丢弃\", col)\n            continue\n\n        # ── 多值列 → one-hot ──\n        dummies = pd.get_dummies(ser, prefix=col, drop_first=drop_first,\n                                 dummy_na=(ser.isnull().any() and not drop_first))\n        # 确保 dummy 列是 int\n        for dc in dummies.columns:\n            dummies[dc] = dummies[dc].astype(np.int8)\n\n        # 检查是否会超出总列数上限\n        if total_onehot_cols + dummies.shape[1] > max_onehot_cols:\n            logger.warning(\n                \"列 '%s' 将产生 %d 个 one-hot 列，超过剩余限额 (%d)，跳过。\",\n                col, dummies.shape[1], max_onehot_cols - total_onehot_cols,\n            )\n            result[col] = ser\n            continue\n\n        result = pd.concat([result, dummies], axis=1)\n        total_onehot_cols += dummies.shape[1]\n        logger.info(\"  ╰ %s  → one-hot (%d 列)\", col, dummies.shape[1])\n\n    logger.info(\"One-hot 编码完成: 新增 %d 列，总计 shape = %s\",\n                total_onehot_cols, result.shape)\n    return result\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第六步：datetime 特征提取\n# ══════════════════════════════════════════════════════════════════════════════\ndef extract_datetime_features(\n    df: pd.DataFrame,\n    types: Dict[str, str],\n    features: Sequence[str] = (\"year\", \"month\", \"day\", \"dayofweek\", \"hour\"),\n    drop_original: bool = True,\n) -> pd.DataFrame:\n    \"\"\"\n    从 datetime 列中提取数值特征（年/月/日/星期/小时等），\n    并删除原始 datetime 列（可选）。\n    \"\"\"\n    dt_cols = [c for c in df.columns if types.get(c) == \"datetime\"]\n    if not dt_cols:\n        return df\n\n    result = df.copy()\n    for col in dt_cols:\n        parsed = pd.to_datetime(result[col], errors=\"coerce\")\n        if parsed.isnull().all():\n            logger.warning(\"列 '%s' 无法解析为日期，保留原始列。\", col)\n            continue\n        for feat in features:\n            if feat == \"year\":\n                result[f\"{col}_year\"] = parsed.dt.year.fillna(-1).astype(np.int16)\n            elif feat == \"month\":\n                result[f\"{col}_month\"] = parsed.dt.month.fillna(-1).astype(np.int8)\n            elif feat == \"day\":\n                result[f\"{col}_day\"] = parsed.dt.day.fillna(-1).astype(np.int8)\n            elif feat == \"dayofweek\":\n                result[f\"{col}_dayofweek\"] = parsed.dt.dayofweek.fillna(-1).astype(np.int8)\n            elif feat == \"hour\":\n                result[f\"{col}_hour\"] = parsed.dt.hour.fillna(-1).astype(np.int8)\n            elif feat == \"quarter\":\n                result[f\"{col}_quarter\"] = parsed.dt.quarter.fillna(-1).astype(np.int8)\n            elif feat == \"is_weekend\":\n                result[f\"{col}_is_weekend\"] = (parsed.dt.dayofweek >= 5).astype(np.int8)\n            elif feat == \"timestamp\":\n                # Unix 秒数\n                result[f\"{col}_ts\"] = (parsed.astype(np.int64) // 10**9).fillna(-1).astype(np.int64)\n            else:\n                logger.warning(\"不支持的时间特征 '%s'，忽略。\", feat)\n\n        if drop_original:\n            result.drop(columns=[col], inplace=True)\n\n    logger.info(\"日期特征提取完成: shape = %s\", result.shape)\n    return result\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  第七步：bool 列转为 0/1\n# ══════════════════════════════════════════════════════════════════════════════\ndef convert_bool_columns(df: pd.DataFrame, types: Dict[str, str]) -> pd.DataFrame:\n    \"\"\"将 bool 列转换为 0/1 int。\"\"\"\n    result = df.copy()\n    for col in result.columns:\n        if types.get(col) == \"bool\":\n            result[col] = result[col].astype(int)\n    return result\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  完整 Pipeline\n# ══════════════════════════════════════════════════════════════════════════════\ndef run_pipeline(\n    input_paths: Sequence[Union[str, Path]],\n    output_path: Union[str, Path],\n    *,\n    key_column: Optional[str] = None,\n    parse_dates: Optional[List[str]] = None,\n    dtype_map: Optional[Dict[str, Any]] = None,\n    force_numeric: Optional[List[str]] = None,\n    force_categorical: Optional[List[str]] = None,\n    force_datetime: Optional[List[str]] = None,\n    force_drop: Optional[List[str]] = None,\n    numeric_strategy: str = DEFAULT_NUMERIC_STRATEGY,\n    categorical_strategy: str = DEFAULT_CATEGORICAL_STRATEGY,\n    cat_fill_value: str = DEFAULT_CATEGORICAL_FILL_VALUE,\n    missing_threshold: float = DEFAULT_MISSING_THRESHOLD,\n    scaling_method: Literal[\"zscore\", \"minmax\", \"robust\", \"none\"] = \"zscore\",\n    scaling_clip: bool = True,\n    max_categories: int = DEFAULT_MAX_CATEGORIES,\n    drop_first_encoding: bool = False,\n    extract_dt_features: bool = True,\n    dt_features: Sequence[str] = (\"year\", \"month\", \"day\", \"dayofweek\"),\n    dt_drop_original: bool = True,\n    export_format: Literal[\"csv\", \"parquet\", \"pickle\", \"feather\"] = \"csv\",\n) -> pd.DataFrame:\n    \"\"\"\n    完整预处理 Pipeline:\n\n      1. 加载 & 合并 CSV\n      2. 自动列类型推断\n      3. 缺失值处理\n      4. 数值标准化\n      5. One-hot 编码\n      6. 日期特征提取\n      7. Bool 转换\n      8. 导出\n\n    Returns\n    -------\n    最终的特征矩阵 DataFrame。\n    \"\"\"\n    logger.info(\"=\" * 56)\n    logger.info(\"  数据预处理 Pipeline  开始\")\n    logger.info(\"=\" * 56)\n    logger.info(\"输入文件: %s\", list(input_paths))\n    logger.info(\"输出路径: %s\", output_path)\n\n    # ── Step 1 ──\n    logger.info(\"\\n── Step 1/8: 加载 CSV ──\")\n    df = load_csvs(input_paths, key_column, parse_dates, dtype_map)\n\n    if df.empty:\n        raise ValueError(\"合并后 DataFrame 为空，请检查输入文件。\")\n\n    # ── Step 2 ──\n    logger.info(\"\\n── Step 2/8: 列类型推断 ──\")\n    types = auto_assign_types(df, force_numeric, force_categorical, force_datetime, force_drop)\n\n    # ── Step 3 ──\n    logger.info(\"\\n── Step 3/8: 缺失值处理 ──\")\n    df = handle_missing_values(df, types, numeric_strategy, categorical_strategy,\n                                cat_fill_value, missing_threshold)\n\n    # ── Step 4 ──\n    logger.info(\"\\n── Step 4/8: 数值标准化 (%s) ──\", scaling_method)\n    df = standardize_numeric(df, types, scaling_method, clip=scaling_clip)\n\n    # ── Step 5 ──\n    logger.info(\"\\n── Step 5/8: One-hot 编码 ──\")\n    df = encode_categoricals(df, types, max_categories, drop_first_encoding)\n\n    # ── Step 6 ──\n    if extract_dt_features:\n        logger.info(\"\\n── Step 6/8: 日期特征提取 ──\")\n        df = extract_datetime_features(df, types, dt_features, dt_drop_original)\n    else:\n        logger.info(\"\\n── Step 6/8: 跳过 (关闭日期特征) ──\")\n\n    # ── Step 7 ──\n    logger.info(\"\\n── Step 7/8: Bool 列转换 ──\")\n    df = convert_bool_columns(df, types)\n\n    # ── Step 8 ──\n    logger.info(f\"\\n── Step 8/8: 导出 [{export_format.upper()}] ──\")\n    export_dataframe(df, output_path, export_format)\n\n    logger.info(\"\\n\" + \"=\" * 56)\n    logger.info(\"  Pipeline 完成！最终 shape: %s\", df.shape)\n    logger.info(\"=\" * 56)\n\n    return df\n\n\ndef export_dataframe(\n    df: pd.DataFrame,\n    path: Union[str, Path],\n    fmt: Literal[\"csv\", \"parquet\", \"pickle\", \"feather\"] = \"csv\",\n) -> None:\n    \"\"\"统一导出接口。\"\"\"\n    path = Path(path)\n    path.parent.mkdir(parents=True, exist_ok=True)\n\n    if fmt == \"csv\":\n        df.to_csv(path, index=False)\n    elif fmt == \"parquet\":\n        df.to_parquet(path, index=False)\n    elif fmt == \"pickle\":\n        df.to_pickle(path)\n    elif fmt == \"feather\":\n        df.to_feather(path)\n    else:\n        raise ValueError(f\"不支持的导出格式: {fmt}\")\n\n    logger.info(\"已保存: %s  (%.1f MB)\", path, path.stat().st_size / 1_000_000)\n\n\n# ── 辅助 ──────────────────────────────────────────────────────────────────────\ndef _fmt_size(bytes_: int) -> str:\n    if bytes_ >= 1_000_000:\n        return f\"{bytes_ / 1_000_000:.1f} MB\"\n    if bytes_ >= 1_000:\n        return f\"{bytes_ / 1_000:.1f} KB\"\n    return f\"{bytes_} B\"\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  CLI 入口\n# ══════════════════════════════════════════════════════════════════════════════\ndef _parse_args(argv: Optional[List[str]] = None) -> argparse.Namespace:\n    p = argparse.ArgumentParser(\n        description=\"CSV 数据预处理 Pipeline：多文件合并 → 清洗 → 编码 → 导出特征矩阵\",\n        formatter_class=argparse.ArgumentDefaultsHelpFormatter,\n    )\n\n    # ── 输入 / 输出 ──\n    p.add_argument(\"--input\", \"-i\", nargs=\"+\", required=True,\n                   help=\"CSV 输入文件或 glob 模式（如 data/*.csv）\")\n    p.add_argument(\"--output\", \"-o\", default=\"features.csv\",\n                   help=\"输出文件路径（扩展名决定推荐格式，用 --format 覆盖）\")\n    p.add_argument(\"--format\", choices=(\"csv\", \"parquet\", \"pickle\", \"feather\"),\n                   default=None,\n                   help=\"输出格式（默认根据 --output 扩展名推断，否则 csv）\")\n    p.add_argument(\"--key-column\", default=None,\n                   help=\"按此列执行 outer join 合并（否则纵向拼接）\")\n\n    # ── 列类型覆盖 ──\n    p.add_argument(\"--force-numeric\", nargs=\"*\", default=None,\n                   help=\"强制指定为数值列的列名\")\n    p.add_argument(\"--force-categorical\", nargs=\"*\", default=None,\n                   help=\"强制指定为分类列的列名\")\n    p.add_argument(\"--force-datetime\", nargs=\"*\", default=None,\n                   help=\"强制指定为日期列的列名\")\n    p.add_argument(\"--force-drop\", nargs=\"*\", default=None,\n                   help=\"强制丢弃的列名\")\n\n    # ── 缺失值 ──\n    p.add_argument(\"--missing-threshold\", type=float, default=DEFAULT_MISSING_THRESHOLD,\n                   help=\"列缺失比例超过此值则丢弃\")\n    p.add_argument(\"--numeric-strategy\", choices=(\"mean\", \"median\", \"zero\", \"drop\"),\n                   default=DEFAULT_NUMERIC_STRATEGY,\n                   help=\"数值列缺失填充策略\")\n    p.add_argument(\"--categorical-strategy\", choices=(\"mode\", \"constant\", \"drop\"),\n                   default=DEFAULT_CATEGORICAL_STRATEGY,\n                   help=\"分类列缺失填充策略\")\n    p.add_argument(\"--cat-fill-value\", default=DEFAULT_CATEGORICAL_FILL_VALUE,\n                   help=\"分类列 constant 填充的值\")\n\n    # ── 标准化 ──\n    p.add_argument(\"--scaling\", choices=(\"zscore\", \"minmax\", \"robust\", \"none\"),\n                   default=\"zscore\", help=\"数值列标准化方法\")\n    p.add_argument(\"--no-clip\", action=\"store_true\",\n                   help=\"不裁剪标准化后的极值（默认裁剪到 ±3σ）\")\n\n    # ── 编码 ──\n    p.add_argument(\"--max-categories\", type=int, default=DEFAULT_MAX_CATEGORIES,\n                   help=\"one-hot 编码的最大类别数，超过则跳过\")\n    p.add_argument(\"--drop-first\", action=\"store_true\",\n                   help=\"one-hot 时丢弃第一个类别（避免多重共线性）\")\n\n    # ── 日期 ──\n    p.add_argument(\"--no-dt-features\", action=\"store_true\",\n                   help=\"不提取日期特征\")\n    p.add_argument(\"--dt-features\", nargs=\"*\",\n                   default=[\"year\", \"month\", \"day\", \"dayofweek\"],\n                   help=\"从日期列提取的特征: year month day dayofweek hour quarter is_weekend timestamp\")\n    p.add_argument(\"--keep-dt-columns\", action=\"store_true\",\n                   help=\"保留原始日期列（默认丢弃）\")\n\n    return p.parse_args(argv)\n\n\ndef main(argv: Optional[List[str]] = None) -> int:\n    args = _parse_args(argv)\n\n    # 自动推断格式\n    if args.format is None:\n        ext = Path(args.output).suffix.lstrip(\".\").lower()\n        fmt = ext if ext in (\"csv\", \"parquet\", \"pickle\", \"feather\") else \"csv\"\n    else:\n        fmt = args.format\n\n    run_pipeline(\n        input_paths=args.input,\n        output_path=args.output,\n        key_column=args.key_column,\n        force_numeric=args.force_numeric,\n        force_categorical=args.force_categorical,\n        force_datetime=args.force_datetime,\n        force_drop=args.force_drop,\n        numeric_strategy=args.numeric_strategy,\n        categorical_strategy=args.categorical_strategy,\n        cat_fill_value=args.cat_fill_value,\n        missing_threshold=args.missing_threshold,\n        scaling_method=args.scaling,\n        scaling_clip=not args.no_clip,\n        max_categories=args.max_categories,\n        drop_first_encoding=args.drop_first,\n        extract_dt_features=not args.no_dt_features,\n        dt_features=args.dt_features,\n        dt_drop_original=not args.keep_dt_columns,\n        export_format=fmt,\n    )\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n"})
