TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/plot_neuro_stripplot.py", "content": "#!/usr/bin/env python3\n\"\"\"\nNeuroscience Strip Plot + Mean ± SEM  —  IEEE single-column format\n====================================================================\n5 groups, n = 6 each.  Replaces problematic mean bar charts with a\ntransparent view of every data point + central tendency.\n\nUSAGE:  python plot_neuro_stripplot.py\n\nEdit the DATA section below to plug in your real values.\nEdit the SIGNIFICANCE section to annotate your specific comparisons.\n\"\"\"\n\nimport sys, os\nsys.path.insert(0, os.path.join(os.path.dirname(__file__), 'sci-draw', 'scripts'))\nfrom setup_style import setup_style\nfrom export_figure import export_figure\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nfrom matplotlib.lines import Line2D\nfrom scipy.stats import mannwhitneyu\nfrom itertools import combinations\n\n# ──────────────────────────────────────────────────────────────────────\n# 0.  IEEE single-column style  (Times New Roman, 8 pt, 3.5 in wide)\n# ──────────────────────────────────────────────────────────────────────\nsetup_style(journal='ieee', lang='en', use_sciplots=False)\n\n# Colourblind-safe palette (Okabe-Ito) — also grayscale-friendly with markers\nOKABE = ['#000000', '#E69F00', '#56B4E9', '#009E73',\n         '#F0E442', '#0072B2', '#D55E00', '#CC79A7']\nCOLORS = [OKABE[1], OKABE[2], OKABE[3], OKABE[6], OKABE[7]]  # 5 groups\nMARKERS = ['o', 's', 'D', '^', 'v']  # distinct shapes for grayscale\n\n# ──────────────────────────────────────────────────────────────────────\n# 1.  DATA  —  REPLACE WITH YOUR ACTUAL VALUES\n# ──────────────────────────────────────────────────────────────────────\n# Each group: n = 6 values.  Synthetic example data below —\n# replace the arrays with your measurements.\n\ngroup_names = ['Sham', 'Lesion', 'Drug A', 'Drug B', 'Combination']\n\ndata_values = {\n    'Sham':        [1.2, 1.5, 1.8, 0.9, 1.3, 1.1],      # n = 6\n    'Lesion':      [4.8, 5.2, 3.9, 6.1, 5.5, 4.3],      # n = 6\n    'Drug A':      [3.2, 2.8, 3.5, 4.0, 2.9, 3.7],      # n = 6\n    'Drug B':      [4.1, 3.5, 4.8, 3.8, 5.0, 4.2],      # n = 6\n    'Combination': [2.1, 1.9, 2.5, 2.0, 2.8, 2.2],      # n = 6\n}\n\n# Unit label for y-axis\nYLBL = 'Neural Activity (spikes/s)'\n\n# ──────────────────────────────────────────────────────────────────────\n# 2.  SIGNIFICANCE  —  EDIT PAIRS AND STARS HERE\n# ──────────────────────────────────────────────────────────────────────\n# Format:  (group_i, group_j, 'ns' | '*' | '**' | '***')\n# These will be annotated with brackets above the groups.\n# Set to empty list [] to draw no annotations.\n# For a one-vs-many design, list the comparisons that were significant\n# after Bonferroni correction.  Use the EXACT group_names strings above.\n\nsig_pairs = [\n    ('Sham',        'Lesion',      '***'),   # p < 0.001\n    ('Sham',        'Drug A',      '**'),    # p < 0.01\n    ('Sham',        'Drug B',      '**'),    # p < 0.01\n    ('Sham',        'Combination', 'ns'),    # not significant\n    ('Lesion',      'Combination', '*'),     # p < 0.05\n    ('Drug A',      'Drug B',      'ns'),    # not significant\n    ('Drug A',      'Combination', '*'),     # p < 0.05\n    ('Drug B',      'Combination', '*'),     # p < 0.05\n]\n\n# ──────────────────────────────────────────────────────────────────────\n# 3.  BUILD DATAFRAME\n# ──────────────────────────────────────────────────────────────────────\nrows = []\nfor grp, vals in data_values.items():\n    for v in vals:\n        rows.append({'group': grp, 'value': v})\ndf = pd.DataFrame(rows)\n\n#  Pre-compute means & SEMs for the overlay\nstats_df = df.groupby('group')['value'].agg(['mean', 'std', 'count'])\nstats_df['sem'] = stats_df['std'] / np.sqrt(stats_df['count'])\n\n# ──────────────────────────────────────────────────────────────────────\n# 4.  DRAW FIGURE\n# ──────────────────────────────────────────────────────────────────────\nfig, ax = plt.subplots(figsize=(3.5, 3.0))   # IEEE single-column\n\nx_positions = np.arange(len(group_names))\njitter_width = 0.15\n\n# ── 4a.  Individual data points (strip plot with jitter) ────────────\nfor i, grp in enumerate(group_names):\n    vals = df[df['group'] == grp]['value'].values\n    jitter = np.random.default_rng(i).uniform(-jitter_width, jitter_width, size=len(vals))\n    ax.scatter(\n        x=np.full_like(vals, i) + jitter,\n        y=vals,\n        color=COLORS[i],\n        marker=MARKERS[i],\n        s=35,                        # point size\n        edgecolor='black',\n        linewidth=0.4,\n        zorder=5,                    # on top of error bars\n        clip_on=False,\n        label=grp,\n    )\n\n# ── 4b.  Mean ± SEM overlay ─────────────────────────────────────\nfor i, grp in enumerate(group_names):\n    row = stats_df.loc[grp]\n    ax.errorbar(\n        x=i, y=row['mean'],\n        yerr=row['sem'],\n        color='black',\n        fmt='none',                  # no marker (we use scatter)\n        capsize=2.5,\n        capthick=1.2,\n        elinewidth=1.2,\n        zorder=6,\n    )\n    #  Mean dot (larger, solid)\n    ax.scatter(\n        x=[i], y=[row['mean']],\n        color='black',\n        marker='_',                  # horizontal dash = mean\n        s=80,\n        linewidth=1.5,\n        zorder=7,\n    )\n\n# ── 4c.  Significance bracket annotation ─────────────────────────\ndef sig_bracket(ax, x1, x2, y, h, text, fontsize=6.5):\n    \"\"\"Draw a significance bracket between two group positions.\"\"\"\n    ax.plot([x1, x1, x2, x2], [y, y + h, y + h, y],\n            color='black', linewidth=0.6, clip_on=False)\n    ax.text((x1 + x2) / 2, y + h, text,\n            ha='center', va='bottom', fontsize=fontsize,\n            fontweight='bold', fontfamily='sans-serif')\n\n#  Determine y-baseline for brackets: start just above the tallest data point\ny_max = df['value'].max()\ny_range = df['value'].max() - df['value'].min()\nbracket_base = y_max + 0.08 * y_range\nbracket_step = 0.06 * y_range\n\n#  Only draw significant pairs (skip 'ns')\nsig_draw = [p for p in sig_pairs if p[2] != 'ns']\n\nif sig_draw:\n    #  Count how many brackets per group to space them vertically\n    for idx, (g1, g2, star) in enumerate(sig_draw):\n        xi = group_names.index(g1)\n        xj = group_names.index(g2)\n        offset = idx * bracket_step\n        sig_bracket(ax, xi, xj, bracket_base + offset,\n                    h=0.02 * y_range, text=star)\n\n# Rescale y-axis to fit brackets\nif sig_draw:\n    total_brackets = len(sig_draw)\n    ax.set_ylim(0, bracket_base + total_brackets * bracket_step + 0.15 * y_range)\nelse:\n    ax.set_ylim(0, bracket_base + 0.15 * y_range)\n\n# Allow data points near x-lim to not be clipped\nax.set_xlim(-0.6, len(group_names) - 0.4)\n\n# ── 4d.  Axis styling ─────────────────────────────────────────────\nax.set_xticks(x_positions)\nax.set_xticklabels(group_names, fontsize=7)\nax.set_ylabel(YLBL, fontsize=8)\nax.set_xlabel('')\n\n# IEEE: keep all four spines but make them thin\nfor spine in ax.spines.values():\n    spine.set_linewidth(0.7)\n\nax.tick_params(axis='both', which='major', length=3.5, width=0.7, pad=2)\nax.tick_params(axis='both', which='minor', length=2, width=0.4)\n\n# ── 4e.  Legend (for marker shapes) ──────────────────────────────\n#  Inset legend — small, unobtrusive\nlegend_elements = [\n    Line2D([0], [0], marker=MARKERS[i], color='w',\n           markerfacecolor=COLORS[i], markeredgecolor='black',\n           markeredgewidth=0.4, markersize=5, label=grp)\n    for i, grp in enumerate(group_names)\n]\nlegend = ax.legend(\n    handles=legend_elements, frameon=False,\n    fontsize=6, loc='upper left', bbox_to_anchor=(0, 1),\n    handletextpad=0.5, labelspacing=0.5,\n)\n\n# ──────────────────────────────────────────────────────────────────────\n# 5.  EXPORT\n# ──────────────────────────────────────────────────────────────────────\n#  Use the 