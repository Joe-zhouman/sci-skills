TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\ndata_pipeline.py — 多 CSV 数据清洗 & 特征合并 Pipeline\n\n输入:  一个包含多个 CSV 文件的目录（或显式文件列表）\n输出:  一个统一的特征矩阵 (numpy .npy 或 pandas .parquet)\n流程:\n  1. 扫描并加载 CSV → 2. 逐文件清洗 → 3. 合并 → 4. 导出\n\n用法:\n  python data_pipeline.py --input-dir ./raw_data --output ./features.parquet\n  python data_pipeline.py --input-files a.csv b.csv c.csv --output ./features.npy\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport logging\nimport sys\nfrom pathlib import Path\nfrom typing import Dict, List, Optional, Sequence, Union\n\nimport numpy as np\nimport pandas as pd\nfrom sklearn.preprocessing import StandardScaler, MinMaxScaler, OneHotEncoder\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(levelname)s] %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"pipeline\")\n\n\n# ────────────────────────────────────────────────────────────────\n# Config\n# ────────────────────────────────────────────────────────────────\n\nclass PipelineConfig:\n    \"\"\"集中管理预处理策略，方便调参和复用。\"\"\"\n\n    def __init__(self) -> None:\n        # ---------- 缺失值 ----------\n        self.numeric_fill: Union[str, float] = \"mean\"   # 数值列填充: \"mean\" / \"median\" / \"zero\" / 具体数值\n        self.categorical_fill: str = \"missing\"          # 类别列填充: \"mode\" / \"missing\"（填占位符）\n        self.drop_threshold: float = 0.8                # 缺失比例 ≥ 此值的列直接丢弃\n\n        # ---------- 标准化 ----------\n        self.scaler: str = \"standard\"                   # \"standard\" (z-score) / \"minmax\" / None\n\n        # ---------- 编码 ----------\n        self.min_frequency: Optional[int] = 5           # one-hot 低频类别合并为 \"other\"\n        self.max_categories: Optional[int] = 50         # one-hot 最大类别数（超出的高频截断）\n        self.handle_unknown: str = \"ignore\"             # 未知类别处理: \"ignore\" / \"error\"\n\n        # ---------- 输出 ----------\n        self.index_col: Optional[str] = None            # 用作行 ID 的列（不参与特征化）\n        self.drop_columns: List[str] = []               # 始终丢弃的列名\n\n\n# ────────────────────────────────────────────────────────────────\n# 单文件清洗\n# ────────────────────────────────────────────────────────────────\n\ndef _infer_column_types(df: pd.DataFrame) -> Dict[str, str]:\n    \"\"\"按 dtype 粗分 numeric / categorical，辅助决定后续策略。\"\"\"\n    types: Dict[str, str] = {}\n    for col in df.columns:\n        dtype = df[col].dtype\n        if pd.api.types.is_numeric_dtype(dtype):\n            types[col] = \"numeric\"\n        elif pd.api.types.is_bool_dtype(dtype):\n            types[col] = \"numeric\"          # bool 当作 0/1 数值处理\n        else:\n            types[col] = \"categorical\"\n    return types\n\n\ndef clean_dataframe(\n    df: pd.DataFrame,\n    config: PipelineConfig,\n    *,\n    name: str = \"unknown\",\n) -> pd.DataFrame:\n    \"\"\"对一个 DataFrame 执行全套清洗，返回干净的特征 DataFrame。\n\n    步骤:\n      1. 移除用户指定丢弃的列 & 索引列\n      2. 按缺失率丢弃列\n      3. 填充缺失值（数值 & 类别分开处理）\n      4. 对数值列标准化\n      5. one-hot 编码类别列\n    所有步骤都记录 log 以供审计。\n    \"\"\"\n    df = df.copy()\n\n    # ── 0. 记录原始信息 ──────────────────────────────────────\n    n_rows, n_cols = df.shape\n    log.info(\"[%s] 原始 shape: %d × %d\", name, n_rows, n_cols)\n\n    # ── 1. 丢弃指定的列 ──────────────────────────────────────\n    explicit_drop = list(config.drop_columns) if config.drop_columns else []\n    if config.index_col and config.index_col in df.columns:\n        explicit_drop.append(config.index_col)\n    if explicit_drop:\n        drop_actual = [c for c in explicit_drop if c in df.columns]\n        if drop_actual:\n            df.drop(columns=drop_actual, inplace=True)\n            log.info(\"[%s] 丢弃指定列: %s\", name, drop_actual)\n\n    if df.empty:\n        log.warning(\"[%s] 丢弃后无剩余列，返回空 DataFrame\", name)\n        return pd.DataFrame()\n\n    # ── 2. 按缺失率丢弃列 ────────────────────────────────────\n    miss_ratio = df.isnull().mean()\n    high_miss = miss_ratio[miss_ratio >= config.drop_threshold].index.tolist()\n    if high_miss:\n        df.drop(columns=high_miss, inplace=True)\n        log.info(\n            \"[%s] 缺失率 ≥ %.0f%% 丢弃: %s\",\n            name,\n            config.drop_threshold * 100,\n            high_miss,\n        )\n\n    if df.empty:\n        log.warning(\"[%s] 丢弃高缺失列后无剩余列\", name)\n        return pd.DataFrame()\n\n    # ── 3. 填充缺失值 ────────────────────────────────────────\n    col_types = _infer_column_types(df)\n\n    numeric_cols = [c for c, t in col_types.items() if t == \"numeric\"]\n    cat_cols = [c for c, t in col_types.items() if t == \"categorical\"]\n\n    if numeric_cols:\n        num_miss = df[numeric_cols].isnull().sum().sum()\n        if num_miss > 0:\n            fill_val: float\n            if isinstance(config.numeric_fill, (int, float)):\n                fill_val = float(config.numeric_fill)\n            elif config.numeric_fill == \"median\":\n                fill_val = df[numeric_cols].median().fillna(0).to_dict()\n                df[numeric_cols] = df[numeric_cols].fillna(fill_val)\n                log.info(\"[%s] 数值列缺失值填充 (median)\", name)\n            else:  # \"mean\" (default)\n                fill_val = df[numeric_cols].mean().fillna(0).to_dict()\n                df[numeric_cols] = df[numeric_cols].fillna(fill_val)\n                log.info(\"[%s] 数值列缺失值填充 (mean)\", name)\n\n            # 若 mean/median 结果仍含 NaN（整列缺失时），再补 0\n            still_null = df[numeric_cols].isnull().sum().sum()\n            if still_null > 0:\n                df[numeric_cols] = df[numeric_cols].fillna(0)\n                log.warning(\n                    \"[%s] 仍有 %d 个数值缺失，已统一补 0\", name, still_null\n                )\n\n    if cat_cols:\n        cat_miss = df[cat_cols].isnull().sum().sum()\n        if cat_miss > 0:\n            if config.categorical_fill == \"mode\":\n                fill_map = {}\n                for c in cat_cols:\n                    mode_vals = df[c].mode()\n                    fill_map[c] = mode_vals.iloc[0] if not mode_vals.empty else \"missing\"\n                df[cat_cols] = df[cat_cols].fillna(fill_map)\n                log.info(\"[%s] 类别列缺失值填充 (mode)\", name)\n            else:  # \"missing\"\n                df[cat_cols] = df[cat_cols].fillna(\"__MISSING__\")\n                log.info(\"[%s] 类别列缺失值填充 (placeholder)\", name)\n\n    # ── 4. 标准化数值列 ─────────────────────────────────────\n    if config.scaler is not None and numeric_cols:\n        scaler_map = {\"standard\": StandardScaler, \"minmax\": MinMaxScaler}\n        klass = scaler_map.get(config.scaler)\n        if klass is None:\n            log.warning(\"[%s] 未知 scaler '%s'，跳过\", name, config.scaler)\n        else:\n            # 只对至少有 2 个非重复值的列做标准化\n            stable_cols = [c for c in numeric_cols if df[c].nunique() > 1]\n            if stable_cols:\n                scaler = klass()\n                df[stable_cols] = scaler.fit_transform(df[stable_cols])\n                log.info(\"[%s] 数值列标准化 (%s): %s\", name, config.scaler, stable_cols)\n            else:\n                log.info(\"[%s] 无数值列需要标准化\", name)\n\n    # ── 5. 类别列 one-hot 编码 ─────────────────────────────\n    if cat_cols:\n        encoder = OneHotEncoder(\n            sparse_output=False,\n            handle_unknown=config.handle_unknown,\n            min_frequency=config.min_frequency,\n            max_categories=config.max_categories,\n        )\n        encoded = encoder.fit_transform(df[cat_cols])\n        # 构造列名\n        if hasattr(encoder, \"get_feature_names_out\"):\n            oh_cols = encoder.get_feature_names_out(cat_cols)\n        else:\n            oh_cols = [f\"{c}_{v}\" for c, vals in zip(cat_cols, encoder.categories_) for v in vals]\n\n        df_encoded = pd.DataFrame(encoded, columns=oh_cols, index=df.index)\n        df.drop(columns=cat_cols, inplace=True)\n\n        # 确保 index 对齐（重置避免 NaN index 导致 concat 错位）\n        df_encoded.index = df.index\n        df = pd.concat([df, df_encoded], axis=1)\n\n        log.info(\"[%s] one-hot 后特征数: %d → %d\", name, n_cols, df.shape[1])\n\n    log.info(\"[%s] 最终 shape: %d × %d\", name, df.shape[0], df.shape[1])\n    return df\n\n\n# ────────────────────────────────────────────────────────────────\n# 多文件加载 & 合并\n# ────────────────────────────────────────────────────────────────\n\ndef load_csvs(\n    paths: Sequence[Union[str, Path]],\n    **read_kwargs,\n) -> Dict[str, pd.DataFrame]:\n    \"\"\"加载多个 CSV 为 {名称: DataFrame} 字典。\n\n    名称取自文件名（不含扩展名）；同名 CSV 会互相覆盖（warning）。\n    \"\"\"\n    loaded: Dict[str, pd.DataFrame] = {}\n    for p in paths:\n        p = Path(p)\n        if not p.exists():\n            log.warning(\"文件不存在，跳过: %s\", p)\n            continue\n        try:\n            df = pd.read_csv(p, **read_kwargs)\n        except Exception as exc:\n            log.error(\"读取失败 %s: %s\", p, exc)\n            continue\n        stem = p.stem\n        if stem in loaded:\n            log.warning(\"文件名重复，覆盖: %s\", stem)\n        loaded[stem] = df\n        log.info(\"加载 %s: %d × %d\", p.name, df.shape[0], df.shape[1])\n    return loaded\n\n\ndef merge_dataframes(\n    dfs: Dict[str, pd.DataFrame],\n    how: str = \"inner\",\n) -> pd.DataFrame:\n    \"\"\"合并所有清洗后的 DataFrame。\n\n    支持 3 种模式:\n      \"inner\" — 只保留所有文件共有的列（推荐）\n      \"outer\" — 并集，缺失列补 NaN\n      \"concat\" — 无视列名，直接按行堆叠（各文件列数必须相同）\n    \"\"\"\n    if not dfs:\n        raise ValueError(\"无可用 DataFrame\")\n\n    names = list(dfs.keys())\n    frames = list(dfs.values())\n\n    if how == \"concat\":\n        merged = pd.concat(frames, ignore_index=True)\n        log.info(\"按行堆叠合并: %d 个文件 → %d 行\", len(frames), len(merged))\n        return merged\n\n    # 基于列合并（outer / inner）\n    if how == \"outer\":\n        merged = frames[0]\n        for df in frames[1:]:\n            merged = merged.merge(df, how=\"outer\", left_index=True, right_index=True)\n        log.info(\n            \"outer-merge 合并 %d 个文件 → %d 行 × %d 列\",\n            len(frames),\n            merged.shape[0],\n            merged.shape[1],\n        )\n        return merged\n\n    # \"inner\" — 先找公共列再 merge\n    common_cols = set(frames[0].columns)\n    for df in frames[1:]:\n        common_cols &= set(df.columns)\n    common_cols.discard(\"index\")  # 排除残余\n\n    if not common_cols:\n        raise ValueError(\"文件间无公共列，无法 inner merge\")\n\n    common_list = sorted(common_cols)\n    log.info(\"inner merge 公共列 (%d): %s\", len(common_list), common_list)\n\n    merged = frames[0][common_list].copy()\n    for df in frames[1:]:\n        merged = merged.merge(\n            df[common_list], how=\"inner\", left_index=True, right_index=True\n        )\n    log.info(\n        \"inner-merge 合并 %d 个文件 → %d 行 × %d 列\",\n        len(frames),\n        merged.shape[0],\n        merged.shape[1],\n    )\n    return merged\n\n\n# ────────────────────────────────────────────────────────────────\n# Pipeline 入口\n# ────────────────────────────────────────────────────────────────\n\ndef run_pipeline(\n    csv_paths: List[Path],\n    output: Path,\n    config: Optional[PipelineConfig] = None,\n    merge_how: str = \"inner\",\n    **read_kwargs,\n) -> pd.DataFrame:\n    \"\"\"完整的预处理流程: 加载 → 清洗 → 合并 → 导出。\"\"\"\n    config = config or PipelineConfig()\n\n    # 1. 加载\n    log.info(\"=\" * 50)\n    log.info(\"开始加载 %d 个 CSV 文件\", len(csv_paths))\n    raw = load_csvs(csv_paths, **read_kwargs)\n\n    if not raw:\n        raise RuntimeError(\"没有成功加载任何 CSV 文件\")\n\n    # 2. 逐个清洗\n    cleaned: Dict[str, pd.DataFrame] = {}\n    for name, df in raw.items():\n        if df.empty:\n            log.warning(\"[%s] 空 DataFrame，跳过\", name)\n            continue\n        cleaned[name] = clean_dataframe(df, config, name=name)\n\n    if not cleaned:\n        raise RuntimeError(\"清洗后无有效数据\")\n\n    # 3. 合并\n    log.info(\"─\" * 40)\n    log.info(\"合并方式: %s\", merge_how)\n    merged = merge_dataframes(cleaned, how=merge_how)\n\n    if merged.empty:\n        raise RuntimeError(\"合并后为空\")\n\n    # 4. 导出\n    output = Path(output)\n    output.parent.mkdir(parents=True, exist_ok=True)\n\n    if output.suffix == \".parquet\":\n        merged.to_parquet(output, index=False)\n    elif output.suffix == \".npy\":\n        np.save(str(output), merged.to_numpy(dtype=np.float32, na_value=np.nan))\n    elif output.suffix == \".csv\":\n        merged.to_csv(output, index=False)\n    elif output.suffix == \".pkl\":\n        merged.to_pickle(output)\n    else:\n        merged.to_parquet(output.with_suffix(\".parquet\"), index=False)\n        log.warning(\"未知扩展名，已改为 .parquet 导出\")\n\n    log.info(\"导出完成: %s (%s)\", output.resolve(), format_shape(merged.shape))\n    return merged\n\n\ndef format_shape(shape) -> str:\n    return f\"{shape[0]:,} 行 × {shape[1]:,} 列\"\n\n\n# ────────────────────────────────────────────────────────────────\n# CLI\n# ────────────────────────────────────────────────────────────────\n\ndef parse_args(argv: Optional[List[str]] = None) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(\n        description=\"多 CSV 数据清洗 & 特征合并 Pipeline\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=__doc__,\n    )\n\n    sources = parser.add_mutually_exclusive_group(required=True)\n    sources.add_argument(\n        \"--input-dir\", \"-d\",\n        type=str,\n        help=\"输入目录（扫描所有 .csv 文件）\",\n    )\n    sources.add_argument(\n        \"--input-files\", \"-f\",\n        type=str,\n        nargs=\"+\",\n        help=\"显式指定 CSV 文件列表\",\n    )\n\n    parser.add_argument(\n        \"--output\", \"-o\",\n        type=str,\n        default=\"feature_matrix.parquet\",\n        help=\"输出路径（支持 .parquet / .npy / .csv / .pkl，默认 .parquet）\",\n    )\n    parser.add_argument(\n        \"--merge\",\n        type=str,\n        choices=[\"inner\", \"outer\", \"concat\"],\n        default=\"inner\",\n        help=\"合并策略: inner / outer / concat（默认 inner）\",\n    )\n    parser.add_argument(\n        \"--numeric-fill\",\n        type=str,\n        default=\"mean\",\n        help=\"数值列填充: mean / median / zero / 具体数字（默认 mean）\",\n    )\n    parser.add_argument(\n        \"--categorical-fill\",\n        type=str,\n        default=\"missing\",\n        help=\"类别列填充: mode / missing（默认 missing）\",\n    )\n    parser.add_argument(\n        \"--scaler\",\n        type=str,\n        default=\"standard\",\n        help=\"标准化: standard / minmax / none（默认 standard）\",\n    )\n    parser.add_argument(\n        \"--drop-threshold\",\n        type=float,\n        default=0.8,\n        help=\"缺失率 ≥ 此值则丢弃该列（默认 0.8）\",\n    )\n    parser.add_argument(\n        \"--index-col\",\n        type=str,\n        default=None,\n        help=\"索引列（不参与特征化，仅用于对齐）\",\n    )\n    parser.add_argument(\n        \"--drop-columns\",\n        type=str,\n        nargs=\"*\",\n        default=[],\n        help=\"额外丢弃的列名列表\",\n    )\n\n    return parser.parse_args(argv)\n\n\ndef main() -> None:\n    args = parse_args()\n\n    # 收集文件列表\n    if args.input_dir:\n        paths = sorted(Path(args.input_dir).glob(\"*.csv\"))\n        if not paths:\n            log.error(\"目录 %s 中没有 .csv 文件\", args.input_dir)\n            sys.exit(1)\n    else:\n        paths = [Path(f) for f in args.input_files]\n\n    # 处理 scaler 参数\n    scaler = args.scaler if args.scaler.lower() != \"none\" else None\n\n    # 处理 numeric_fill\n    numeric_fill: Union[str, float] = args.numeric_fill\n    try:\n        numeric_fill = float(args.numeric_fill)\n    except ValueError:\n        pass  # 保留原字符串 \"mean\" / \"median\" / \"zero\"\n\n    config = PipelineConfig()\n    config.numeric_fill = numeric_fill\n    config.categorical_fill = args.categorical_fill\n    config.scaler = scaler\n    config.drop_threshold = args.drop_threshold\n    config.index_col = args.index_col\n    config.drop_columns = args.drop_columns\n\n    try:\n        run_pipeline(\n            csv_paths=paths,\n            output=Path(args.output),\n            config=config,\n            merge_how=args.merge,\n        )\n    except Exception as exc:\n        log.error(\"Pipeline 失败: %s\", exc)\n        sys.exit(1)\n\n\nif __name__ == \"__main__\":\n    main()\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\ndata_pipeline.py — 多 CSV 数据清洗 & 特征合并 Pipeline\n\n输入:  一个包含多个 CSV 文件的目录（或显式文件列表）\n输出:  一个统一的特征矩阵 (numpy .npy 或 pandas .parquet)\n流程:\n  1. 扫描并加载 CSV → 2. 逐文件清洗 → 3. 合并 → 4. 导出\n\n用法:\n  python data_pipeline.py --input-dir ./raw_data --output ./features.parquet\n  python data_pipeline.py --input-files a.csv b.csv c.csv --output ./features.npy\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport logging\nimport sys\nfrom pathlib import Path\nfrom typing import Dict, List, Optional, Sequence, Union\n\nimport numpy as np\nimport pandas as pd\nfrom sklearn.preprocessing import StandardScaler, MinMaxScaler, OneHotEncoder\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(levelname)s] %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"pipeline\")\n\n\n# ────────────────────────────────────────────────────────────────\n# Config\n# ────────────────────────────────────────────────────────────────\n\nclass PipelineConfig:\n    \"\"\"集中管理预处理策略，方便调参和复用。\"\"\"\n\n    def __init__(self) -> None:\n        # ---------- 缺失值 ----------\n        self.numeric_fill: Union[str, float] = \"mean\"   # 数值列填充: \"mean\" / \"median\" / \"zero\" / 具体数值\n        self.categorical_fill: str = \"missing\"          # 类别列填充: \"mode\" / \"missing\"（填占位符）\n        self.drop_threshold: float = 0.8                # 缺失比例 ≥ 此值的列直接丢弃\n\n        # ---------- 标准化 ----------\n        self.scaler: str = \"standard\"                   # \"standard\" (z-score) / \"minmax\" / None\n\n        # ---------- 编码 ----------\n        self.min_frequency: Optional[int] = 5           # one-hot 低频类别合并为 \"other\"\n        self.max_categories: Optional[int] = 50         # one-hot 最大类别数（超出的高频截断）\n        self.handle_unknown: str = \"ignore\"             # 未知类别处理: \"ignore\" / \"error\"\n\n        # ---------- 输出 ----------\n        self.index_col: Optional[str] = None            # 用作行 ID 的列（不参与特征化）\n        self.drop_columns: List[str] = []               # 始终丢弃的列名\n\n\n# ────────────────────────────────────────────────────────────────\n# 单文件清洗\n# ────────────────────────────────────────────────────────────────\n\ndef _infer_column_types(df: pd.DataFrame) -> Dict[str, str]:\n    \"\"\"按 dtype 粗分 numeric / categorical，辅助决定后续策略。\"\"\"\n    types: Dict[str, str] = {}\n    for col in df.columns:\n        dtype = df[col].dtype\n        if pd.api.types.is_numeric_dtype(dtype):\n            types[col] = \"numeric\"\n        elif pd.api.types.is_bool_dtype(dtype):\n            types[col] = \"numeric\"          # bool 当作 0/1 数值处理\n        else:\n            types[col] = \"categorical\"\n    return types\n\n\ndef clean_dataframe(\n    df: pd.DataFrame,\n    config: PipelineConfig,\n    *,\n    name: str = \"unknown\",\n) -> pd.DataFrame:\n    \"\"\"对一个 DataFrame 执行全套清洗，返回干净的特征 DataFrame。\n\n    步骤:\n      1. 移除用户指定丢弃的列 & 索引列\n      2. 按缺失率丢弃列\n      3. 填充缺失值（数值 & 类别分开处理）\n      4. 对数值列标准化\n      5. one-hot 编码类别列\n    所有步骤都记录 log 以供审计。\n    \"\"\"\n    df = df.copy()\n\n    # ── 0. 记录原始信息 ──────────────────────────────────────\n    n_rows, n_cols = df.shape\n    log.info(\"[%s] 原始 shape: %d × %d\", name, n_rows, n_cols)\n\n    # ── 1. 丢弃指定的列 ──────────────────────────────────────\n    explicit_drop = list(config.drop_columns) if config.drop_columns else []\n    if config.index_col and config.index_col in df.columns:\n        explicit_drop.append(config.index_col)\n    if explicit_drop:\n        drop_actual = [c for c in explicit_drop if c in df.columns]\n        if drop_actual:\n            df.drop(columns=drop_actual, inplace=True)\n            log.info(\"[%s] 丢弃指定列: %s\", name, drop_actual)\n\n    if df.empty:\n        log.warning(\"[%s] 丢弃后无剩余列，返回空 DataFrame\", name)\n        return pd.DataFrame()\n\n    # ── 2. 按缺失率丢弃列 ────────────────────────────────────\n    miss_ratio = df.isnull().mean()\n    high_miss = miss_ratio[miss_ratio >= config.drop_threshold].index.tolist()\n    if high_miss:\n        df.drop(columns=high_miss, inplace=True)\n        log.info(\n            \"[%s] 缺失率 ≥ %.0f%% 丢弃: %s\",\n            name,\n            config.drop_threshold * 100,\n            high_miss,\n        )\n\n    if df.empty:\n        log.warning(\"[%s] 丢弃高缺失列后无剩余列\", name)\n        return pd.DataFrame()\n\n    # ── 3. 填充缺失值 ────────────────────────────────────────\n    col_types = _infer_column_types(df)\n\n    numeric_cols = [c for c, t in col_types.items() if t == \"numeric\"]\n    cat_cols = [c for c, t in col_types.items() if t == \"categorical\"]\n\n    if numeric_cols:\n        num_miss = df[numeric_cols].isnull().sum().sum()\n        if num_miss > 0:\n            fill_val: float\n            if isinstance(config.numeric_fill, (int, float)):\n                fill_val = float(config.numeric_fill)\n            elif config.numeric_fill == \"median\":\n                fill_val = df[numeric_cols].median().fillna(0).to_dict()\n                df[numeric_cols] = df[numeric_cols].fillna(fill_val)\n                log.info(\"[%s] 数值列缺失值填充 (median)\", name)\n            else:  # \"mean\" (default)\n                fill_val = df[numeric_cols].mean().fillna(0).to_dict()\n                df[numeric_cols] = df[numeric_cols].fillna(fill_val)\n                log.info(\"[%s] 数值列缺失值填充 (mean)\", name)\n\n            # 若 mean/median 结果仍含 NaN（整列缺失时），再补 0\n            still_null = df[numeric_cols].isnull().sum().sum()\n            if still_null > 0:\n                df[numeric_cols] = df[numeric_cols].fillna(0)\n                log.warning(\n                    \"[%s] 仍有 %d 个数值缺失，已统一补 0\", name, still_null\n                )\n\n    if cat_cols:\n        cat_miss = df[cat_cols].isnull().sum().sum()\n        if cat_miss > 0:\n            if config.categorical_fill == \"mode\":\n                fill_map = {}\n                for c in cat_cols:\n                    mode_vals = df[c].mode()\n                    fill_map[c] = mode_vals.iloc[0] if not mode_vals.empty else \"missing\"\n                df[cat_cols] = df[cat_cols].fillna(fill_map)\n                log.info(\"[%s] 类别列缺失值填充 (mode)\", name)\n            else:  # \"missing\"\n                df[cat_cols] = df[cat_cols].fillna(\"__MISSING__\")\n                log.info(\"[%s] 类别列缺失值填充 (placeholder)\", name)\n\n    # ── 4. 标准化数值列 ─────────────────────────────────────\n    if config.scaler is not None and numeric_cols:\n        scaler_map = {\"standard\": StandardScaler, \"minmax\": MinMaxScaler}\n        klass = scaler_map.get(config.scaler)\n        if klass is None:\n            log.warning(\"[%s] 未知 scaler '%s'，跳过\", name, config.scaler)\n        else:\n            # 只对至少有 2 个非重复值的列做标准化\n            stable_cols = [c for c in numeric_cols if df[c].nunique() > 1]\n            if stable_cols:\n                scaler = klass()\n                df[stable_cols] = scaler.fit_transform(df[stable_cols])\n                log.info(\"[%s] 数值列标准化 (%s): %s\", name, config.scaler, stable_cols)\n            else:\n                log.info(\"[%s] 无数值列需要标准化\", name)\n\n    # ── 5. 类别列 one-hot 编码 ─────────────────────────────\n    if cat_cols:\n        encoder = OneHotEncoder(\n            sparse_output=False,\n            handle_unknown=config.handle_unknown,\n            min_frequency=config.min_frequency,\n            max_categories=config.max_categories,\n        )\n        encoded = encoder.fit_transform(df[cat_cols])\n        # 构造列名\n        if hasattr(encoder, \"get_feature_names_out\"):\n            oh_cols = encoder.get_feature_names_out(cat_cols)\n        else:\n            oh_cols = [f\"{c}_{v}\" for c, vals in zip(cat_cols, encoder.categories_) for v in vals]\n\n        df_encoded = pd.DataFrame(encoded, columns=oh_cols, index=df.index)\n        df.drop(columns=cat_cols, inplace=True)\n\n        # 确保 index 对齐（重置避免 NaN index 导致 concat 错位）\n        df_encoded.index = df.index\n        df = pd.concat([df, df_encoded], axis=1)\n\n        log.info(\"[%s] one-hot 后特征数: %d → %d\", name, n_cols, df.shape[1])\n\n    log.info(\"[%s] 最终 shape: %d × %d\", name, df.shape[0], df.shape[1])\n    return df\n\n\n# ────────────────────────────────────────────────────────────────\n# 多文件加载 & 合并\n# ────────────────────────────────────────────────────────────────\n\ndef load_csvs(\n    paths: Sequence[Union[str, Path]],\n    **read_kwargs,\n) -> Dict[str, pd.DataFrame]:\n    \"\"\"加载多个 CSV 为 {名称: DataFrame} 字典。\n\n    名称取自文件名（不含扩展名）；同名 CSV 会互相覆盖（warning）。\n    \"\"\"\n    loaded: Dict[str, pd.DataFrame] = {}\n    for p in paths:\n        p = Path(p)\n        if not p.exists():\n            log.warning(\"文件不存在，跳过: %s\", p)\n            continue\n        try:\n            df = pd.read_csv(p, **read_kwargs)\n        except Exception as exc:\n            log.error(\"读取失败 %s: %s\", p, exc)\n            continue\n        stem = p.stem\n        if stem in loaded:\n            log.warning(\"文件名重复，覆盖: %s\", stem)\n        loaded[stem] = df\n        log.info(\"加载 %s: %d × %d\", p.name, df.shape[0], df.shape[1])\n    return loaded\n\n\ndef merge_dataframes(\n    dfs: Dict[str, pd.DataFrame],\n    how: str = \"inner\",\n) -> pd.DataFrame:\n    \"\"\"合并所有清洗后的 DataFrame。\n\n    支持 3 种模式:\n      \"inner\" — 只保留所有文件共有的列（推荐）\n      \"outer\" — 并集，缺失列补 NaN\n      \"concat\" — 无视列名，直接按行堆叠（各文件列数必须相同）\n    \"\"\"\n    if not dfs:\n        raise ValueError(\"无可用 DataFrame\")\n\n    names = list(dfs.keys())\n    frames = list(dfs.values())\n\n    if how == \"concat\":\n        merged = pd.concat(frames, ignore_index=True)\n        log.info(\"按行堆叠合并: %d 个文件 → %d 行\", len(frames), len(merged))\n        return merged\n\n    # 基于列合并（outer / inner）\n    if how == \"outer\":\n        merged = frames[0]\n        for df in frames[1:]:\n            merged = merged.merge(df, how=\"outer\", left_index=True, right_index=True)\n        log.info(\n            \"outer-merge 合并 %d 个文件 → %d 行 × %d 列\",\n            len(frames),\n            merged.shape[0],\n            merged.shape[1],\n        )\n        return merged\n\n    # \"inner\" — 先找公共列再 merge\n    common_cols = set(frames[0].columns)\n    for df in frames[1:]:\n        common_cols &= set(df.columns)\n    common_cols.discard(\"index\")  # 排除残余\n\n    if not common_cols:\n        raise ValueError(\"文件间无公共列，无法 inner merge\")\n\n    common_list = sorted(common_cols)\n    log.info(\"inner merge 公共列 (%d): %s\", len(common_list), common_list)\n\n    merged = frames[0][common_list].copy()\n    for df in frames[1:]:\n        merged = merged.merge(\n            df[common_list], how=\"inner\", left_index=True, right_index=True\n        )\n    log.info(\n        \"inner-merge 合并 %d 个文件 → %d 行 × %d 列\",\n        len(frames),\n        merged.shape[0],\n        merged.shape[1],\n    )\n    return merged\n\n\n# ────────────────────────────────────────────────────────────────\n# Pipeline 入口\n# ────────────────────────────────────────────────────────────────\n\ndef run_pipeline(\n    csv_paths: List[Path],\n    output: Path,\n    config: Optional[PipelineConfig] = None,\n    merge_how: str = \"inner\",\n    **read_kwargs,\n) -> pd.DataFrame:\n    \"\"\"完整的预处理流程: 加载 → 清洗 → 合并 → 导出。\"\"\"\n    config = config or PipelineConfig()\n\n    # 1. 加载\n    log.info(\"=\" * 50)\n    log.info(\"开始加载 %d 个 CSV 文件\", len(csv_paths))\n    raw = load_csvs(csv_paths, **read_kwargs)\n\n    if not raw:\n        raise RuntimeError(\"没有成功加载任何 CSV 文件\")\n\n    # 2. 逐个清洗\n    cleaned: Dict[str, pd.DataFrame] = {}\n    for name, df in raw.items():\n        if df.empty:\n            log.warning(\"[%s] 空 DataFrame，跳过\", name)\n            continue\n        cleaned[name] = clean_dataframe(df, config, name=name)\n\n    if not cleaned:\n        raise RuntimeError(\"清洗后无有效数据\")\n\n    # 3. 合并\n    log.info(\"─\" * 40)\n    log.info(\"合并方式: %s\", merge_how)\n    merged = merge_dataframes(cleaned, how=merge_how)\n\n    if merged.empty:\n        raise RuntimeError(\"合并后为空\")\n\n    # 4. 导出\n    output = Path(output)\n    output.parent.mkdir(parents=True, exist_ok=True)\n\n    if output.suffix == \".parquet\":\n        merged.to_parquet(output, index=False)\n    elif output.suffix == \".npy\":\n        np.save(str(output), merged.to_numpy(dtype=np.float32, na_value=np.nan))\n    elif output.suffix == \".csv\":\n        merged.to_csv(output, index=False)\n    elif output.suffix == \".pkl\":\n        merged.to_pickle(output)\n    else:\n        merged.to_parquet(output.with_suffix(\".parquet\"), index=False)\n        log.warning(\"未知扩展名，已改为 .parquet 导出\")\n\n    log.info(\"导出完成: %s (%s)\", output.resolve(), format_shape(merged.shape))\n    return merged\n\n\ndef format_shape(shape) -> str:\n    return f\"{shape[0]:,} 行 × {shape[1]:,} 列\"\n\n\n# ────────────────────────────────────────────────────────────────\n# CLI\n# ────────────────────────────────────────────────────────────────\n\ndef parse_args(argv: Optional[List[str]] = None) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(\n        description=\"多 CSV 数据清洗 & 特征合并 Pipeline\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=__doc__,\n    )\n\n    sources = parser.add_mutually_exclusive_group(required=True)\n    sources.add_argument(\n        \"--input-dir\", \"-d\",\n        type=str,\n        help=\"输入目录（扫描所有 .csv 文件）\",\n    )\n    sources.add_argument(\n        \"--input-files\", \"-f\",\n        type=str,\n        nargs=\"+\",\n        help=\"显式指定 CSV 文件列表\",\n    )\n\n    parser.add_argument(\n        \"--output\", \"-o\",\n        type=str,\n        default=\"feature_matrix.parquet\",\n        help=\"输出路径（支持 .parquet / .npy / .csv / .pkl，默认 .parquet）\",\n    )\n    parser.add_argument(\n        \"--merge\",\n        type=str,\n        choices=[\"inner\", \"outer\", \"concat\"],\n        default=\"inner\",\n        help=\"合并策略: inner / outer / concat（默认 inner）\",\n    )\n    parser.add_argument(\n        \"--numeric-fill\",\n        type=str,\n        default=\"mean\",\n        help=\"数值列填充: mean / median / zero / 具体数字（默认 mean）\",\n    )\n    parser.add_argument(\n        \"--categorical-fill\",\n        type=str,\n        default=\"missing\",\n        help=\"类别列填充: mode / missing（默认 missing）\",\n    )\n    parser.add_argument(\n        \"--scaler\",\n        type=str,\n        default=\"standard\",\n        help=\"标准化: standard / minmax / none（默认 standard）\",\n    )\n    parser.add_argument(\n        \"--drop-threshold\",\n        type=float,\n        default=0.8,\n        help=\"缺失率 ≥ 此值则丢弃该列（默认 0.8）\",\n    )\n    parser.add_argument(\n        \"--index-col\",\n        type=str,\n        default=None,\n        help=\"索引列（不参与特征化，仅用于对齐）\",\n    )\n    parser.add_argument(\n        \"--drop-columns\",\n        type=str,\n        nargs=\"*\",\n        default=[],\n        help=\"额外丢弃的列名列表\",\n    )\n\n    return parser.parse_args(argv)\n\n\ndef main() -> None:\n    args = parse_args()\n\n    # 收集文件列表\n    if args.input_dir:\n        paths = sorted(Path(args.input_dir).glob(\"*.csv\"))\n        if not paths:\n            log.error(\"目录 %s 中没有 .csv 文件\", args.input_dir)\n            sys.exit(1)\n    else:\n        paths = [Path(f) for f in args.input_files]\n\n    # 处理 scaler 参数\n    scaler = args.scaler if args.scaler.lower() != \"none\" else None\n\n    # 处理 numeric_fill\n    numeric_fill: Union[str, float] = args.numeric_fill\n    try:\n        numeric_fill = float(args.numeric_fill)\n    except ValueError:\n        pass  # 保留原字符串 \"mean\" / \"median\" / \"zero\"\n\n    config = PipelineConfig()\n    config.numeric_fill = numeric_fill\n    config.categorical_fill = args.categorical_fill\n    config.scaler = scaler\n    config.drop_threshold = args.drop_threshold\n    config.index_col = args.index_col\n    config.drop_columns = args.drop_columns\n\n    try:\n        run_pipeline(\n            csv_paths=paths,\n            output=Path(args.output),\n            config=config,\n            merge_how=args.merge,\n        )\n    except Exception as exc:\n        log.error(\"Pipeline 失败: %s\", exc)\n        sys.exit(1)\n\n\nif __name__ == \"__main__\":\n    main()\n"})
