TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/neuroscience_stripplot.py", "content": "#!/usr/bin/env python3\n\"\"\"\nNeuroscience Figure: Strip Plot + Mean±SEM (Better Alternative to Bar Charts)\n===========================================================================\nFor: IEEE-format, single-column Neuroscience paper\nGroups: 5 groups × n = 6\nStatistics: Mann-Whitney U tests with Bonferroni correction\n\nWhy NOT bar charts for n=6:\n  - Bars hide the underlying data distribution (→ strip plot shows every point)\n  - With small n, the mean is vulnerable to outliers (→ show raw data)\n  - Bars don't convey sample size visually (→ n=6 is visible from point count)\n  - Bar length implies certainty from 0-value baseline (→ mean±SEM avoids this)\n\nThis script produces:\n  1. A strip/beeswarm plot with every data point shown\n  2. Overlaid mean ± SEM markers\n  3. Significance brackets for significant pairwise comparisons\n  4. Vector PDF output (IEEE-compatible)\n  5. A companion \"replacement bar chart\" version to help convince your PI\n\nBefore running: Replace the SYNTHETIC DATA section with your actual data.\n\"\"\"\n\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')  # headless backend for server/CI environments\nimport matplotlib.pyplot as plt\nfrom scipy.stats import mannwhitneyu\nfrom itertools import combinations\nimport os\n\n# ============================================================================\n# CONFIGURATION —  Change these for your actual data & preferences\n# ============================================================================\n\n# IEEE single-column format: 3.5 inches wide (89 mm)\n# Height chosen to comfortably fit 5 groups + significance brackets\nFIG_WIDTH = 3.5       # inches\nFIG_HEIGHT = 4.0      # inches (adjust if brackets overlap)\n\n# Output file\nOUTPUT_PDF = \"figure_stripplot.pdf\"\nOUTPUT_PNG = \"figure_stripplot.png\"\nOUTPUT_PI_BAR   = \"figure_bar_comparison.pdf\"\nDPI = 300\n\n# Group labels (replace with your actual group names)\nGROUPS = [\n    \"Sham\",\n    \"Low Dose\",\n    \"Mid Dose\",\n    \"High Dose\",\n    \"Control+\"\n]\n\n# Colorblind-safe palette (Okabe-Ito 2019)\n# Accessible to protanopia/deuteranopia/tritanopia — passes Nature's\n# colour-vision deficiency guidelines.\nCB_COLORS = {\n    'sham':       '#0072B2',  # Blue\n    'low_dose':   '#E69F00',  # Orange\n    'mid_dose':   '#009E73',  # Bluish-green\n    'high_dose':  '#CC79A7',  # Reddish-purple\n    'control':    '#F0E442',  # Yellow (used sparingly, hard on white bg)\n}\n# Ordered list matching GROUPS\nCOLORS = ['#0072B2', '#E69F00', '#009E73', '#CC79A7', '#D55E00']\n\n# Font sizes for IEEE (labels ~8-9 pt, tick labels ~7-8 pt)\nFONT_LABEL = 9\nFONT_TICK  = 8\nFONT_LEGEND = 7\nFONT_TITLE = 10\nFONT_SIG   = 8       # significance stars\n\n# Statistical significance threshold after Bonferroni\nALPHA = 0.05\n\n\n# ============================================================================\n# SYNTHETIC DATA —  REPLACE THIS BLOCK WITH YOUR ACTUAL DATA\n# ============================================================================\n\n# Simulating a typical Neuroscience experiment with 5 groups, n=6 each.\n# Replace these arrays with your actual measurements.\nnp.random.seed(42)  # fixed seed for reproducibility of this demo\n\ndata = {\n    'Sham':       np.array([1.2, 2.5, 1.8, 2.0, 1.5, 2.2]),\n    'Low Dose':   np.array([2.8, 3.2, 2.1, 3.5, 2.9, 3.8]),\n    'Mid Dose':   np.array([4.5, 3.9, 5.2, 4.1, 4.8, 5.5]),\n    'High Dose':  np.array([5.8, 6.2, 4.9, 5.5, 6.5, 5.0]),\n    'Control+':   np.array([6.0, 7.2, 5.8, 6.8, 7.5, 6.2]),\n}\n\n# Y-axis label — adjust to your measurement\nYLABEL = \"Neural activity (ΔF/F, %)\"\n\n# ============================================================================\n# STATISTICS: Mann-Whitney U with Bonferroni correction\n# ============================================================================\n\ngroups_list = list(GROUPS)                        # ordered group names\nn_groups = len(groups_list)\n\n# All pairwise comparisons\npairs = list(combinations(range(n_groups), 2))\nn_comparisons = len(pairs)\n\nprint(f\"Performing {n_comparisons} pairwise Mann-Whitney U tests\")\nprint(f\"Bonferroni correction factor: {n_comparisons}\")\nprint(f\"Corrected α = {ALPHA / n_comparisons:.5f}\\n\")\n\nsignificant_pairs = []\np_values = {}\nsig_annotations = {}\n\nfor i, j in pairs:\n    stat, p = mannwhitneyu(data[groups_list[i]], data[groups_list[j]],\n                           alternative='two-sided')\n    p_corrected = min(p * n_comparisons, 1.0)  # Bonferroni: multiply by #tests\n    p_values[(i, j)] = p_corrected\n\n    # Determine star annotation\n    if p_corrected <= 0.001:\n        stars = '***'\n    elif p_corrected <= 0.01:\n        stars = '**'\n    elif p_corrected <= 0.05:\n        stars = '*'\n    else:\n        stars = 'ns'\n\n    sig_annotations[(i, j)] = stars\n\n    print(f\"  {groups_list[i]} vs {groups_list[j]}: \"\n          f\"U={stat:.1f}, raw p={p:.4f}, corrected p={p_corrected:.4f} {stars}\")\n\n    if p_corrected <= ALPHA:\n        significant_pairs.append((i, j))\n\nprint(f\"\\nSignificant pairs after Bonferroni correction: {len(significant_pairs)}\")\n\n# ============================================================================\n# HELPER: Draw significance bracket between two groups\n# ============================================================================\n\ndef draw_significance_bracket(ax, x1, x2, y, stars, color='#333333',\n                              linewidth=0.8, fontsize=FONT_SIG):\n    \"\"\"\n    Draw a bracket line connecting x1 ↔ x2 at height y, with star annotation.\n    \"\"\"\n    # Horizontal line\n    ax.plot([x1, x2], [y, y], color=color, linewidth=linewidth)\n\n    # Vertical ticks\n    tick_height = 0.05 * (ax.get_ylim()[1] - ax.get_ylim()[0])  # 5% of y-range\n    ax.plot([x1, x1], [y - tick_height, y], color=color, linewidth=linewidth)\n    ax.plot([x2, x2], [y - tick_height, y], color=color, linewidth=linewidth)\n\n    # Star annotation\n    ax.text((x1 + x2) / 2, y + tick_height * 0.5, stars,\n            fontsize=fontsize, ha='center', va='bottom', color=color)\n\n\n# ============================================================================\n# FIGURE 1: MAIN — Strip plot + Mean ± SEM\n# ============================================================================\n\nprint(\"\\n--- Generating main figure: Strip plot with Mean ± SEM ---\")\n\nplt.rcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': FONT_TICK,\n    'axes.linewidth': 0.8,\n    'xtick.major.width': 0.6,\n    'ytick.major.width': 0.6,\n    'xtick.major.size': 3,\n    'ytick.major.size': 3,\n    'axes.spines.top': False,\n    'axes.spines.right': False,\n})\n\nfig, ax = plt.subplots(figsize=(FIG_WIDTH, FIG_HEIGHT))\n\npositions = np.arange(n_groups)        # 0, 1, 2, 3, 4\nstrip_width = 0.25                     # half-width of the jitter strip\njitter_strength = 0.12                 # random jitter spread\npoint_size = 28                        # size of individual data points\n\n# Calculate y-range for bracket placement\nall_values = np.concatenate(list(data.values()))\ny_min, y_max = all_values.min(), all_values.max()\ny_range = y_max - y_min\ny_padding = y_range * 0.15\nax.set_ylim(y_min - y_padding * 0.5, y_max + y_padding * 3.5)\n\nfor idx, (group, color) in enumerate(zip(groups_list, COLORS)):\n    values = data[group]\n    mean = np.mean(values)\n    sem = np.std(values, ddof=1) / np.sqrt(len(values))\n\n    # --- Individual data points (jittered strip plot) ---\n    # Add random horizontal jitter so overlapping points are visible\n    jitter = np.random.uniform(-jitter_strength, jitter_strength,\n                               size=len(values))\n    x_positions = idx + jitter\n\n    ax.scatter(x_positions, values,\n               facecolors='white',      # open circles for clarity when overlapping\n               edgecolors=color,\n               linewidths=0.8,\n               s=point_size,\n               zorder=3,\n               alpha=0.9,\n               label='Individual' if idx == 0 else \"\")\n\n    # --- Mean marker ---\n    ax.scatter(idx, mean,\n               facecolors=color,\n               edgecolors='black',\n               linewidths=0.5,\n               s=point_size * 2.5,      # larger than data points\n               zorder=4,\n               marker='o')\n\n    # --- SEM error bar ---\n    ax.errorbar(idx, mean, yerr=sem,\n                color='black',\n                linewidth=1.0,\n                capsize=3,\n                capthick=0.8,\n                zorder=4)\n\n# X-axis labels\nax.set_xticks(positions)\nax.set_xticklabels(groups_list, fontsize=FONT_TICK, rotation=0)\nax.set_ylabel(YLABEL, fontsize=FONT_LABEL)\n\n# Y-axis tick formatting — auto, but keep labels readable\nax.tick_params(axis='y', labelsize=FONT_TICK)\n\n# --- Draw significance brackets ---\n# Place brackets above the data, staggered if needed\n# For 5 groups, the tallest bracket stack might go 3-4 high\n# We need to avoid bracket overlap.\n\n# Strategy: group comparisons by which x-range they span,\n# then stagger overlapping brackets vertically.\n\ndef get_bracket_order(pairs_to_annotate, n_groups):\n    \"\"\"\n    Simple layering: sort by span length (shortest first, bottom-most),\n    then place any bracket that doesn't overlap the previous row.\n    Falls back to stacking if overlaps.\n\n    Returns list of (i, j, layer)\n    \"\"\"\n    # Annotate only significant pairs in a real figure\n    # But you might show all pairs with ns/star annotations\n\n    # Calculate spans\n    spans = [(j - i, i, j) for i, j in pairs_to_annotate]\n    spans.sort()  # short spans first (they go lower)\n\n    layers = []\n    for span_len, i, j in spans:\n        placed = False\n        for layer_idx, layer in enumerate(layers):\n            # Check if this bracket overlaps any in the current layer\n            overlap = any(not (j <= l_i or i >= l_j) for l_i, l_j in layer)\n            if not overlap:\n                layer.append((i, j))\n                placed = True\n                break\n        if not placed:\n            layers.append([(i, j)])\n\n    # Reverse so longest/outermost brackets are on top (higher y)\n    # Actually, layers are already ordered: first layer = bottom, last = top\n    return layers  # list of lists of (i, j) tuples\n\n\nlayers = get_bracket_order(significant_pairs, n_groups)\n\n# Vertical spacing for brackets\nbase_bracket_y = y_max + y_padding * 0.8\nbracket_step = y_padding * 0.45\n\nfor layer_idx, layer in enumerate(layers):\n    bracket_y = base_bracket_y + layer_idx * bracket_step\n    for i, j in layer:\n        stars = sig_annotations[(i, j)]\n        draw_significance_bracket(ax, positions[i], positions[j],\n                                  bracket_y, stars)\n\n# If no significant pairs, add a note\nif not significant_pairs:\n    ax.text(0.5, 0.95, \"No significant pairwise differences\\n(after Bonferroni correction)\",\n            transform=ax.transAxes, ha='center', va='top',\n            fontsize=FONT_TICK, style='italic', color='gray')\n\n# ============================================================================\n# FIGURE NOTES / LEGEND\n# ============================================================================\n\n# Add a small legend explaining the plot elements\n# Position it in the upper left, inside the axes\nlegend_elements = [\n    plt.Line2D([0], [0], marker='o', color='w', markerfacecolor='gray',\n               markersize=5, label='Mean ± SEM', markeredgecolor='black'),\n    plt.Line2D([0], [0], marker='o', color='w', markerfacecolor='white',\n               markersize=4, label='Individual data', markeredgecolor='gray'),\n]\nax.legend(handles=legend_elements, loc='upper left', fontsize=FONT_LEGEND,\n          frameon=True, framealpha=0.8, edgecolor='gray', fancybox=False)\n\n# -----------------------------------------------------------------–\n# STATISTICS BOX (small note in corner)\n# -----------------------------------------------------------------–\nstats_note = (f\"Mann-Whitney U, Bonferroni-corrected\\n\"\n              f\"n = 6 per group\")\nax.text(0.98, 0.02, stats_note, transform=ax.transAxes,\n        ha='right', va='bottom', fontsize=FONT_LEGEND - 1,\n        style='italic', color='gray')\n\nplt.tight_layout()\nplt.savefig(OUTPUT_PDF, dpi=DPI, bbox_inches='tight')\nplt.savefig(OUTPUT_PNG, dpi=DPI, bbox_inches='tight')\nplt.close()\nprint(f\"  ✓ Saved: {OUTPUT_PDF}\")\nprint(f\"  ✓ Saved: {OUTPUT_PNG}\")\n\n\n# ============================================================================\n# FIGURE 2: COMPARISON — Traditional bar chart (for PI negotiation)\n# ============================================================================\n# This shows the bar chart version for side-by-side comparison.\n# Use this to demonstrate WHY the strip plot is better.\n\nprint(\"\\n--- Generating comparison bar chart ---\")\n\nfig2, (ax1, ax2) = plt.subplots(1, 2, figsize=(6.5, 3.0),\n                                gridspec_kw={'wspace': 0.35})\n# Left: bar chart, Right: strip plot\n\nbar_width = 0.6\nx = np.arange(n_groups)\n\n# ---- Left panel: Bar chart (hides distribution) ----\nfor idx, (group, color) in enumerate(zip(groups_list, COLORS)):\n    values = data[group]\n    mean = np.mean(values)\n    sem = np.std(values, ddof=1) / np.sqrt(len(values))\n\n    ax1.bar(idx, mean, width=bar_width, color=color, alpha=0.7,\n            edgecolor='black', linewidth=0.5)\n    ax1.errorbar(idx, mean, yerr=sem, color='black', capsize=2,\n                 linewidth=0.8)\n\nax1.set_xticks(x)\nax1.set_xticklabels(groups_list, fontsize=FONT_TICK - 1, rotation=20, ha='right')\nax1.set_ylabel(YLABEL, fontsize=FONT_LABEL)\nax1.set_title(\"Bar chart (hides distribution)\", fontsize=FONT_TITLE)\nax1.spines['top'].set_visible(False)\nax1.spines['right'].set_visible(False)\n\n# ---- Right panel: Strip plot (shows everything) ----\nfor idx, (group, color) in enumerate(zip(groups_list, COLORS)):\n    values = data[group]\n    mean = np.mean(values)\n    sem = np.std(values, ddof=1) / np.sqrt(len(values))\n\n    jitter = np.random.uniform(-jitter_strength, jitter_strength,\n                               size=len(values))\n    ax2.scatter(idx + jitter, values,\n                facecolors='white', edgecolors=color,\n                linewidths=0.6, s=22, zorder=3, alpha=0.9)\n    ax2.scatter(idx, mean, facecolors=color, edgecolors='black',\n                linewidths=0.5, s=40, zorder=4, marker='o')\n    ax2.errorbar(idx, mean, yerr=sem, color='black',\n                 linewidth=0.8, capsize=2, zorder=4)\n\nax2.set_xticks(x)\nax2.set_xticklabels(groups_list, fontsize=FONT_TICK - 1, rotation=20, ha='right')\nax2.set_ylabel(YLABEL, fontsize=FONT_LABEL)\nax2.set_title(\"Strip plot + Mean±SEM\", fontsize=FONT_TITLE)\nax2.spines['top'].set_visible(False)\nax2.spines['right'].set_visible(False)\n\nplt.tight_layout()\nplt.savefig(OUTPUT_PI_BAR, dpi=DPI, bbox_inches='tight')\nplt.close()\nprint(f\"  ✓ Saved: {OUTPUT_PI_BAR}\")\n\n\n# ============================================================================\n# SUMMARY\n# ============================================================================\n\nprint(\"\\n\" + \"=\" * 55)\nprint(\"  SUMMARY\")\nprint(\"=\" * 55)\nprint(f\"\\n  Main figure: {OUTPUT_PDF}\")\nprint(f\"  Bar comparison: {OUTPUT_PI_BAR}\")\nprint(f\"\\n  Plot type: Strip plot + Mean ± SEM\")\nprint(f\"  Format: IEEE single-column ({FIG_WIDTH} in wide)\")\nprint(f\"  Groups: {n_groups} × n = 6\")\nprint(f\"  Statistics: Mann-Whitney U, Bonferroni-corrected\")\nprint(f\"    Total comparisons: {n_comparisons}\")\nprint(f\"    Significant after correction: {len(significant_pairs)}\")\nprint(f\"\\n  To use your own data:\")\nprint(f\"    1. Edit the 'data' dictionary in the SYNTHETIC DATA section\")\nprint(f\"    2. Update group labels in the GROUPS list\")\nprint(f\"    3. Change YLABEL to your actual measurement unit\")\nprint(f\"    4. Run: python3 {os.path.basename(__file__)}\")\nprint(f\"\\n  Legend for your figure caption:\")\nprint(f\"    \\\"Figure 1. {YLABEL}. Data shown as individual points\")\nprint(f\"    (open circles) with group mean ± SEM (filled circle).\")\nprint(f\"    Mann-Whitney U test with Bonferroni correction for\")\n    f\"{n_comparisons} comparisons. *p < 0.05, **p < 0.01, ***p < 0.001.\\\"\")\nprint()\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/neuroscience_stripplot.py", "content": "#!/usr/bin/env python3\n\"\"\"\nNeuroscience Figure: Strip Plot + Mean±SEM (Better Alternative to Bar Charts)\n===========================================================================\nFor: IEEE-format, single-column Neuroscience paper\nGroups: 5 groups × n = 6\nStatistics: Mann-Whitney U tests with Bonferroni correction\n\nWhy NOT bar charts for n=6:\n  - Bars hide the underlying data distribution (→ strip plot shows every point)\n  - With small n, the mean is vulnerable to outliers (→ show raw data)\n  - Bars don't convey sample size visually (→ n=6 is visible from point count)\n  - Bar length implies certainty from 0-value baseline (→ mean±SEM avoids this)\n\nThis script produces:\n  1. A strip/beeswarm plot with every data point shown\n  2. Overlaid mean ± SEM markers\n  3. Significance brackets for significant pairwise comparisons\n  4. Vector PDF output (IEEE-compatible)\n  5. A companion \"replacement bar chart\" version to help convince your PI\n\nBefore running: Replace the SYNTHETIC DATA section with your actual data.\n\"\"\"\n\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')  # headless backend for server/CI environments\nimport matplotlib.pyplot as plt\nfrom scipy.stats import mannwhitneyu\nfrom itertools import combinations\nimport os\n\n# ============================================================================\n# CONFIGURATION —  Change these for your actual data & preferences\n# ============================================================================\n\n# IEEE single-column format: 3.5 inches wide (89 mm)\n# Height chosen to comfortably fit 5 groups + significance brackets\nFIG_WIDTH = 3.5       # inches\nFIG_HEIGHT = 4.0      # inches (adjust if brackets overlap)\n\n# Output file\nOUTPUT_PDF = \"figure_stripplot.pdf\"\nOUTPUT_PNG = \"figure_stripplot.png\"\nOUTPUT_PI_BAR   = \"figure_bar_comparison.pdf\"\nDPI = 300\n\n# Group labels (replace with your actual group names)\nGROUPS = [\n    \"Sham\",\n    \"Low Dose\",\n    \"Mid Dose\",\n    \"High Dose\",\n    \"Control+\"\n]\n\n# Colorblind-safe palette (Okabe-Ito 2019)\n# Accessible to protanopia/deuteranopia/tritanopia — passes Nature's\n# colour-vision deficiency guidelines.\nCB_COLORS = {\n    'sham':       '#0072B2',  # Blue\n    'low_dose':   '#E69F00',  # Orange\n    'mid_dose':   '#009E73',  # Bluish-green\n    'high_dose':  '#CC79A7',  # Reddish-purple\n    'control':    '#F0E442',  # Yellow (used sparingly, hard on white bg)\n}\n# Ordered list matching GROUPS\nCOLORS = ['#0072B2', '#E69F00', '#009E73', '#CC79A7', '#D55E00']\n\n# Font sizes for IEEE (labels ~8-9 pt, tick labels ~7-8 pt)\nFONT_LABEL = 9\nFONT_TICK  = 8\nFONT_LEGEND = 7\nFONT_TITLE = 10\nFONT_SIG   = 8       # significance stars\n\n# Statistical significance threshold after Bonferroni\nALPHA = 0.05\n\n\n# ============================================================================\n# SYNTHETIC DATA —  REPLACE THIS BLOCK WITH YOUR ACTUAL DATA\n# ============================================================================\n\n# Simulating a typical Neuroscience experiment with 5 groups, n=6 each.\n# Replace these arrays with your actual measurements.\nnp.random.seed(42)  # fixed seed for reproducibility of this demo\n\ndata = {\n    'Sham':       np.array([1.2, 2.5, 1.8, 2.0, 1.5, 2.2]),\n    'Low Dose':   np.array([2.8, 3.2, 2.1, 3.5, 2.9, 3.8]),\n    'Mid Dose':   np.array([4.5, 3.9, 5.2, 4.1, 4.8, 5.5]),\n    'High Dose':  np.array([5.8, 6.2, 4.9, 5.5, 6.5, 5.0]),\n    'Control+':   np.array([6.0, 7.2, 5.8, 6.8, 7.5, 6.2]),\n}\n\n# Y-axis label — adjust to your measurement\nYLABEL = \"Neural activity (ΔF/F, %)\"\n\n# ============================================================================\n# STATISTICS: Mann-Whitney U with Bonferroni correction\n# ============================================================================\n\ngroups_list = list(GROUPS)                        # ordered group names\nn_groups = len(groups_list)\n\n# All pairwise comparisons\npairs = list(combinations(range(n_groups), 2))\nn_comparisons = len(pairs)\n\nprint(f\"Performing {n_comparisons} pairwise Mann-Whitney U tests\")\nprint(f\"Bonferroni correction factor: {n_comparisons}\")\nprint(f\"Corrected α = {ALPHA / n_comparisons:.5f}\\n\")\n\nsignificant_pairs = []\np_values = {}\nsig_annotations = {}\n\nfor i, j in pairs:\n    stat, p = mannwhitneyu(data[groups_list[i]], data[groups_list[j]],\n                           alternative='two-sided')\n    p_corrected = min(p * n_comparisons, 1.0)  # Bonferroni: multiply by #tests\n    p_values[(i, j)] = p_corrected\n\n    # Determine star annotation\n    if p_corrected <= 0.001:\n        stars = '***'\n    elif p_corrected <= 0.01:\n        stars = '**'\n    elif p_corrected <= 0.05:\n        stars = '*'\n    else:\n        stars = 'ns'\n\n    sig_annotations[(i, j)] = stars\n\n    print(f\"  {groups_list[i]} vs {groups_list[j]}: \"\n          f\"U={stat:.1f}, raw p={p:.4f}, corrected p={p_corrected:.4f} {stars}\")\n\n    if p_corrected <= ALPHA:\n        significant_pairs.append((i, j))\n\nprint(f\"\\nSignificant pairs after Bonferroni correction: {len(significant_pairs)}\")\n\n# ============================================================================\n# HELPER: Draw significance bracket between two groups\n# ============================================================================\n\ndef draw_significance_bracket(ax, x1, x2, y, stars, color='#333333',\n                              linewidth=0.8, fontsize=FONT_SIG):\n    \"\"\"\n    Draw a bracket line connecting x1 ↔ x2 at height y, with star annotation.\n    \"\"\"\n    # Horizontal line\n    ax.plot([x1, x2], [y, y], color=color, linewidth=linewidth)\n\n    # Vertical ticks\n    tick_height = 0.05 * (ax.get_ylim()[1] - ax.get_ylim()[0])  # 5% of y-range\n    ax.plot([x1, x1], [y - tick_height, y], color=color, linewidth=linewidth)\n    ax.plot([x2, x2], [y - tick_height, y], color=color, linewidth=linewidth)\n\n    # Star annotation\n    ax.text((x1 + x2) / 2, y + tick_height * 0.5, stars,\n            fontsize=fontsize, ha='center', va='bottom', color=color)\n\n\n# ============================================================================\n# FIGURE 1: MAIN — Strip plot + Mean ± SEM\n# ============================================================================\n\nprint(\"\\n--- Generating main figure: Strip plot with Mean ± SEM ---\")\n\nplt.rcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': FONT_TICK,\n    'axes.linewidth': 0.8,\n    'xtick.major.width': 0.6,\n    'ytick.major.width': 0.6,\n    'xtick.major.size': 3,\n    'ytick.major.size': 3,\n    'axes.spines.top': False,\n    'axes.spines.right': False,\n})\n\nfig, ax = plt.subplots(figsize=(FIG_WIDTH, FIG_HEIGHT))\n\npositions = np.arange(n_groups)        # 0, 1, 2, 3, 4\nstrip_width = 0.25                     # half-width of the jitter strip\njitter_strength = 0.12                 # random jitter spread\npoint_size = 28                        # size of individual data points\n\n# Calculate y-range for bracket placement\nall_values = np.concatenate(list(data.values()))\ny_min, y_max = all_values.min(), all_values.max()\ny_range = y_max - y_min\ny_padding = y_range * 0.15\nax.set_ylim(y_min - y_padding * 0.5, y_max + y_padding * 3.5)\n\nfor idx, (group, color) in enumerate(zip(groups_list, COLORS)):\n    values = data[group]\n    mean = np.mean(values)\n    sem = np.std(values, ddof=1) / np.sqrt(len(values))\n\n    # --- Individual data points (jittered strip plot) ---\n    # Add random horizontal jitter so overlapping points are visible\n    jitter = np.random.uniform(-jitter_strength, jitter_strength,\n                               size=len(values))\n    x_positions = idx + jitter\n\n    ax.scatter(x_positions, values,\n               facecolors='white',      # open circles for clarity when overlapping\n               edgecolors=color,\n               linewidths=0.8,\n               s=point_size,\n               zorder=3,\n               alpha=0.9,\n               label='Individual' if idx == 0 else \"\")\n\n    # --- Mean marker ---\n    ax.scatter(idx, mean,\n               facecolors=color,\n               edgecolors='black',\n               linewidths=0.5,\n               s=point_size * 2.5,      # larger than data points\n               zorder=4,\n               marker='o')\n\n    # --- SEM error bar ---\n    ax.errorbar(idx, mean, yerr=sem,\n                color='black',\n                linewidth=1.0,\n                capsize=3,\n                capthick=0.8,\n                zorder=4)\n\n# X-axis labels\nax.set_xticks(positions)\nax.set_xticklabels(groups_list, fontsize=FONT_TICK, rotation=0)\nax.set_ylabel(YLABEL, fontsize=FONT_LABEL)\n\n# Y-axis tick formatting — auto, but keep labels readable\nax.tick_params(axis='y', labelsize=FONT_TICK)\n\n# --- Draw significance brackets ---\n# Place brackets above the data, staggered if needed\n# For 5 groups, the tallest bracket stack might go 3-4 high\n# We need to avoid bracket overlap.\n\n# Strategy: group comparisons by which x-range they span,\n# then stagger overlapping brackets vertically.\n\ndef get_bracket_order(pairs_to_annotate, n_groups):\n    \"\"\"\n    Simple layering: sort by span length (shortest first, bottom-most),\n    then place any bracket that doesn't overlap the previous row.\n    Falls back to stacking if overlaps.\n\n    Returns list of (i, j, layer)\n    \"\"\"\n    # Annotate only significant pairs in a real figure\n    # But you might show all pairs with ns/star annotations\n\n    # Calculate spans\n    spans = [(j - i, i, j) for i, j in pairs_to_annotate]\n    spans.sort()  # short spans first (they go lower)\n\n    layers = []\n    for span_len, i, j in spans:\n        placed = False\n        for layer_idx, layer in enumerate(layers):\n            # Check if this bracket overlaps any in the current layer\n            overlap = any(not (j <= l_i or i >= l_j) for l_i, l_j in layer)\n            if not overlap:\n                layer.append((i, j))\n                placed = True\n                break\n        if not placed:\n            layers.append([(i, j)])\n\n    # Reverse so longest/outermost brackets are on top (higher y)\n    # Actually, layers are already ordered: first layer = bottom, last = top\n    return layers  # list of lists of (i, j) tuples\n\n\nlayers = get_bracket_order(significant_pairs, n_groups)\n\n# Vertical spacing for brackets\nbase_bracket_y = y_max + y_padding * 0.8\nbracket_step = y_padding * 0.45\n\nfor layer_idx, layer in enumerate(layers):\n    bracket_y = base_bracket_y + layer_idx * bracket_step\n    for i, j in layer:\n        stars = sig_annotations[(i, j)]\n        draw_significance_bracket(ax, positions[i], positions[j],\n                                  bracket_y, stars)\n\n# If no significant pairs, add a note\nif not significant_pairs:\n    ax.text(0.5, 0.95, \"No significant pairwise differences\\n(after Bonferroni correction)\",\n            transform=ax.transAxes, ha='center', va='top',\n            fontsize=FONT_TICK, style='italic', color='gray')\n\n# ============================================================================\n# FIGURE NOTES / LEGEND\n# ============================================================================\n\n# Add a small legend explaining the plot elements\n# Position it in the upper left, inside the axes\nlegend_elements = [\n    plt.Line2D([0], [0], marker='o', color='w', markerfacecolor='gray',\n               markersize=5, label='Mean ± SEM', markeredgecolor='black'),\n    plt.Line2D([0], [0], marker='o', color='w', markerfacecolor='white',\n               markersize=4, label='Individual data', markeredgecolor='gray'),\n]\nax.legend(handles=legend_elements, loc='upper left', fontsize=FONT_LEGEND,\n          frameon=True, framealpha=0.8, edgecolor='gray', fancybox=False)\n\n# -----------------------------------------------------------------–\n# STATISTICS BOX (small note in corner)\n# -----------------------------------------------------------------–\nstats_note = (f\"Mann-Whitney U, Bonferroni-corrected\\n\"\n              f\"n = 6 per group\")\nax.text(0.98, 0.02, stats_note, transform=ax.transAxes,\n        ha='right', va='bottom', fontsize=FONT_LEGEND - 1,\n        style='italic', color='gray')\n\nplt.tight_layout()\nplt.savefig(OUTPUT_PDF, dpi=DPI, bbox_inches='tight')\nplt.savefig(OUTPUT_PNG, dpi=DPI, bbox_inches='tight')\nplt.close()\nprint(f\"  ✓ Saved: {OUTPUT_PDF}\")\nprint(f\"  ✓ Saved: {OUTPUT_PNG}\")\n\n\n# ============================================================================\n# FIGURE 2: COMPARISON — Traditional bar chart (for PI negotiation)\n# ============================================================================\n# This shows the bar chart version for side-by-side comparison.\n# Use this to demonstrate WHY the strip plot is better.\n\nprint(\"\\n--- Generating comparison bar chart ---\")\n\nfig2, (ax1, ax2) = plt.subplots(1, 2, figsize=(6.5, 3.0),\n                                gridspec_kw={'wspace': 0.35})\n# Left: bar chart, Right: strip plot\n\nbar_width = 0.6\nx = np.arange(n_groups)\n\n# ---- Left panel: Bar chart (hides distribution) ----\nfor idx, (group, color) in enumerate(zip(groups_list, COLORS)):\n    values = data[group]\n    mean = np.mean(values)\n    sem = np.std(values, ddof=1) / np.sqrt(len(values))\n\n    ax1.bar(idx, mean, width=bar_width, color=color, alpha=0.7,\n            edgecolor='black', linewidth=0.5)\n    ax1.errorbar(idx, mean, yerr=sem, color='black', capsize=2,\n                 linewidth=0.8)\n\nax1.set_xticks(x)\nax1.set_xticklabels(groups_list, fontsize=FONT_TICK - 1, rotation=20, ha='right')\nax1.set_ylabel(YLABEL, fontsize=FONT_LABEL)\nax1.set_title(\"Bar chart (hides distribution)\", fontsize=FONT_TITLE)\nax1.spines['top'].set_visible(False)\nax1.spines['right'].set_visible(False)\n\n# ---- Right panel: Strip plot (shows everything) ----\nfor idx, (group, color) in enumerate(zip(groups_list, COLORS)):\n    values = data[group]\n    mean = np.mean(values)\n    sem = np.std(values, ddof=1) / np.sqrt(len(values))\n\n    jitter = np.random.uniform(-jitter_strength, jitter_strength,\n                               size=len(values))\n    ax2.scatter(idx + jitter, values,\n                facecolors='white', edgecolors=color,\n                linewidths=0.6, s=22, zorder=3, alpha=0.9)\n    ax2.scatter(idx, mean, facecolors=color, edgecolors='black',\n                linewidths=0.5, s=40, zorder=4, marker='o')\n    ax2.errorbar(idx, mean, yerr=sem, color='black',\n                 linewidth=0.8, capsize=2, zorder=4)\n\nax2.set_xticks(x)\nax2.set_xticklabels(groups_list, fontsize=FONT_TICK - 1, rotation=20, ha='right')\nax2.set_ylabel(YLABEL, fontsize=FONT_LABEL)\nax2.set_title(\"Strip plot + Mean±SEM\", fontsize=FONT_TITLE)\nax2.spines['top'].set_visible(False)\nax2.spines['right'].set_visible(False)\n\nplt.tight_layout()\nplt.savefig(OUTPUT_PI_BAR, dpi=DPI, bbox_inches='tight')\nplt.close()\nprint(f\"  ✓ Saved: {OUTPUT_PI_BAR}\")\n\n\n# ============================================================================\n# SUMMARY\n# ============================================================================\n\nprint(\"\\n\" + \"=\" * 55)\nprint(\"  SUMMARY\")\nprint(\"=\" * 55)\nprint(f\"\\n  Main figure: {OUTPUT_PDF}\")\nprint(f\"  Bar comparison: {OUTPUT_PI_BAR}\")\nprint(f\"\\n  Plot type: Strip plot + Mean ± SEM\")\nprint(f\"  Format: IEEE single-column ({FIG_WIDTH} in wide)\")\nprint(f\"  Groups: {n_groups} × n = 6\")\nprint(f\"  Statistics: Mann-Whitney U, Bonferroni-corrected\")\nprint(f\"    Total comparisons: {n_comparisons}\")\nprint(f\"    Significant after correction: {len(significant_pairs)}\")\nprint(f\"\\n  To use your own data:\")\nprint(f\"    1. Edit the 'data' dictionary in the SYNTHETIC DATA section\")\nprint(f\"    2. Update group labels in the GROUPS list\")\nprint(f\"    3. Change YLABEL to your actual measurement unit\")\nprint(f\"    4. Run: python3 {os.path.basename(__file__)}\")\nprint(f\"\\n  Legend for your figure caption:\")\nprint(f\"    \\\"Figure 1. {YLABEL}. Data shown as individual points\")\nprint(f\"    (open circles) with group mean ± SEM (filled circle).\")\nprint(f\"    Mann-Whitney U test with Bonferroni correction for\")\n    f\"{n_comparisons} comparisons. *p < 0.05, **p < 0.01, ***p < 0.001.\\\"\")\nprint()\n"})
