TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/fig2_expression_plot.py", "content": "#!/usr/bin/env python3\n\"\"\"\nFigure 2: Longitudinal expression levels — Cell-publication-quality figure.\n\nGroups: control, treatment_A, treatment_B  (n=8 per group)\nTime points: 0, 7, 14, 21, 28 days\n\nCombined line + individual-dot plot with colourblind-safe Wong palette.\nExports vector PDF and high-res PNG for Cell submission.\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.ticker as ticker\nfrom matplotlib import rcParams\nfrom scipy import stats\nimport warnings, os, sys\nwarnings.filterwarnings('ignore')\n\n# ── Paths ──────────────────────────────────────────────────────────────\nDATA_FILE = os.path.expanduser('~/experiment/fig2_data.xlsx')\n# If the file isn't there, look in the current directory:\nif not os.path.exists(DATA_FILE):\n    DATA_FILE = 'fig2_data.xlsx'\nOUT_DIR   = '.'\n\n# ── Journal-standard style (Cell) ─────────────────────────────────────\nplt.style.use('default')\n\nrcParams.update({\n    'font.family':      'sans-serif',\n    'font.sans-serif':  ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size':        7,\n    'axes.titlesize':   8,\n    'axes.labelsize':   7,\n    'xtick.labelsize':  6.5,\n    'ytick.labelsize':  6.5,\n    'legend.fontsize':  6.5,\n    'lines.linewidth':  0.8,\n    'axes.linewidth':   0.6,\n    'xtick.major.width': 0.6,\n    'ytick.major.width': 0.6,\n    'xtick.major.size':  3,\n    'ytick.major.size':  3,\n    'xtick.direction':  'out',\n    'ytick.direction':  'out',\n    'axes.spines.top':    False,\n    'axes.spines.right':  False,\n    'figure.dpi':        150,\n    'savefig.dpi':       600,\n    'savefig.format':    'pdf',\n    'pdf.fonttype':      42,      # editable text in PDF\n})\n\n# ── Colourblind-safe palette (Wong 2011, Nature Methods) ──────────────\nCOLORS = {\n    'control':     '#0072B2',   # blue\n    'treatment_A': '#D55E00',   # vermillion\n    'treatment_B': '#009E73',   # green\n}\nGROUP_ORDER = ['control', 'treatment_A', 'treatment_B']\nLINESTYLES  = ['-', '--', '-.']\n\n# ── Read data ──────────────────────────────────────────────────────────\nprint(f\"Reading: {DATA_FILE}\")\nif not os.path.exists(DATA_FILE):\n    sys.exit(f\"ERROR: Data file not found at {DATA_FILE}\\n\"\n             f\"Copy fig2_data.xlsx to the current directory or update DATA_FILE.\")\ndf = pd.read_excel(DATA_FILE)\n\n# Normalise column names (lowercase, strip)\ndf.columns = [c.strip().lower().replace(' ', '_') for c in df.columns]\n\n# Ensure correct dtypes\ndf['group'] = df['group'].astype(str)\ndf['time_point'] = df['time_point'].astype(float)\ndf['expression_level'] = df['expression_level'].astype(float)\n\nprint(f\"  Rows: {len(df)}\")\nprint(f\"  Groups: {df['group'].unique()}\")\nprint(f\"  Time points: {sorted(df['time_point'].unique())}\")\n\n# ── Assemble summary statistics ────────────────────────────────────────\nsummary = (\n    df.groupby(['group', 'time_point'])['expression_level']\n    .agg(['mean', 'std', 'sem', 'count'])\n    .reset_index()\n)\nprint(\"\\nSummary per group × time point:\")\nprint(summary.to_string(index=False))\n\n# ── Statistical testing (repeated measures) ────────────────────────────\n# For each time point: one-way ANOVA + Dunnett-style post-hoc vs control\nprint(\"\\n═══ Statistical tests (vs control at each time point) ═══\")\npval_texts = {}\nalpha = 0.05\n\nfor tp in sorted(df['time_point'].unique()):\n    ct = tp\n    sub = df[df['time_point'] == tp]\n    control_vals = sub.loc[sub['group'] == 'control', 'expression_level'].values\n    results = []\n    for g in ['treatment_A', 'treatment_B']:\n        treat_vals = sub.loc[sub['group'] == g, 'expression_level'].values\n        # Welch's t-test (unequal variance OK)\n        t_stat, p_val = stats.ttest_ind(treat_vals, control_vals, equal_var=False)\n        results.append((g, t_stat, p_val))\n\n        stars = ''\n        if p_val < 0.001:\n            stars = '***'\n        elif p_val < 0.01:\n            stars = '**'\n        elif p_val < 0.05:\n            stars = '*'\n\n        print(f\"  Day {int(tp):>2d}:  {g:15s} vs control  t={t_stat:.3f}  p={p_val:.4f} {stars}\")\n        pval_texts[(g, tp)] = stars\n\n# ── Build the figure ──────────────────────────────────────────────────\n# Cell single-column = 85 mm, 1.5-col = 114 mm, full-page = 174 mm\nfig_width_mm  = 114\nfig_height_mm = 80\nfig = plt.figure(figsize=(fig_width_mm / 25.4, fig_height_mm / 25.4))\nax  = fig.add_subplot(111)\n\ntime_points = sorted(df['time_point'].unique())\nx_jitter = 0.12  # jitter width for individual points\n\n# ── 1) Thin spaghetti lines for individual subjects ───────────────────\nfor g in GROUP_ORDER:\n    g_df = df[df['group'] == g]\n    # Track unique subjects via index → assume consecutive rows = same subject\n    # Each group has 8 subjects; rows appear in subject order within each time\n    subjects = [g_df.iloc[i::8] for i in range(8)]  # every Nth row = same subject\n    # Simpler approach: assume subjects come in order, time sorted\n    sub_data = {}\n    for _, row in g_df.iterrows():\n        sub_data.setdefault(int(row.name) % 8, []).append(row)\n    # Plot each subject as a thin line\n    for sub_idx, rows in sub_data.items():\n        rows.sort(key=lambda r: r['time_point'])\n        xs = [r['time_point'] for r in rows]\n        ys = [r['expression_level'] for r in rows]\n        ax.plot(xs, ys, color=COLORS[g], lw=0.35, alpha=0.25, zorder=1)\n\n# ── 2) Mean ± SEM line with error band ────────────────────────────────\nfor i, g in enumerate(GROUP_ORDER):\n    g_sum = summary[summary['group'] == g].sort_values('time_point')\n    xs = g_sum['time_point'].values\n    ym = g_sum['mean'].values\n    ye = g_sum['sem'].values\n\n    # Shaded error band\n    ax.fill_between(xs, ym - ye, ym + ye, color=COLORS[g], alpha=0.10, lw=0, zorder=2)\n    # Bold mean line\n    ax.plot(xs, ym, color=COLORS[g], ls=LINESTYLES[i], lw=1.6,\n            label=g.replace('_', ' ').title(), zorder=4)\n\n# ── 3) Jittered individual points at each time point ───────────────────\nfor g in GROUP_ORDER:\n    g_df = df[df['group'] == g]\n    for tp in time_points:\n        sub = g_df[g_df['time_point'] == tp]['expression_level'].values\n        if len(sub) == 0:\n            continue\n        jitter = np.random.default_rng(42).uniform(-x_jitter, x_jitter, len(sub))\n        ax.scatter(tp + jitter, sub, s=8, color=COLORS[g],\n                   edgecolors='white', linewidths=0.3, zorder=5, clip_on=False)\n\n# ── 4) Significance markers ────────────────────────────────────────────\n# Find a good y-offset for significance brackets\ny_max = df['expression_level'].max()\ny_min = df['expression_level'].min()\ny_range = y_max - y_min\nsig_y_base = y_max + y_range * 0.05\n\nfor i, tp in enumerate(time_points):\n    stars_list = []\n    for g in ['treatment_A', 'treatment_B']:\n        s = pval_texts.get((g, tp), '')\n        if s:\n            stars_list.append(s)\n\n    if stars_list:\n        # Combine stars for both treatments at this time point\n        combined = '/'.join(stars_list)\n        y_pos = sig_y_base + y_range * 0.04 * i  # stagger if needed\n        ax.text(tp, sig_y_base, combined, ha='center', va='bottom',\n                fontsize=6, fontweight='bold')\n\n# ── Refine axes ───────────────────────────────────────────────────────\nax.set_xlabel('Time (days)')\nax.set_ylabel('Expression level (a.u.)')\nax.set_xlim(-2, 30)\nax.set_xticks(time_points)\nax.set_xticklabels([f'{int(t)}' for t in time_points])\n\n# Y-axis: nice ticks\ny_lo = np.floor(y_min / 5) * 5\ny_hi = np.ceil((y_max + y_range * 0.15) / 5) * 5\nax.set_ylim(y_lo, y_hi)\nax.yaxis.set_major_locator(ticker.MultipleLocator(5))\n\n# Legend\nleg = ax.legend(frameon=False, loc='best',\n                handlelength=1.5, handletextpad=0.5)\n# Ensure legend order matches group order in plot\nhandles, labels = ax.get_legend_handles_labels()\n# Reorder to match GROUP_ORDER — labels are control, Treatment A, Treatment B\norder_map = {l: i for i, l in enumerate(['Control', 'Treatment A', 'Treatment B'])}\ntry:\n    sorted_h = [h for _, h in sorted(zip(labels, handles),\n               key=lambda p: order_map.get(p[0], 99))]\n    sorted_l = sorted(labels, key=lambda l: order_map.get(l, 99))\n    leg = ax.legend(sorted_h, sorted_l, frameon=False, loc='best',\n                    handlelength=1.5, handletextpad=0.5)\nexcept KeyError:\n    pass  # fallback\n\n# ── Export ─────────────────────────────────────────────────────────────\nbase_name = os.path.join(OUT_DIR, 'Fig2_expression_levels')\n\n# PDF (vector, for submission)\nfig.savefig(f'{base_name}.pdf', bbox_inches='tight', pad_inches=0.05)\nprint(f\"\\n✅ Saved: {base_name}.pdf\")\n\n# PNG (600 DPI, for quick viewing)\nplt.savefig(f'{base_name}.png', bbox_inches='tight', pad_inches=0.05, dpi=600)\nprint(f\"✅ Saved: {base_name}.png\")\n\nplt.close()\nprint(\"\\nDone. Both files are ready for Cell submission.\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/fig2_expression_plot.py", "content": "#!/usr/bin/env python3\n\"\"\"\nFigure 2: Longitudinal expression levels — Cell-publication-quality figure.\n\nGroups: control, treatment_A, treatment_B  (n=8 per group)\nTime points: 0, 7, 14, 21, 28 days\n\nCombined line + individual-dot plot with colourblind-safe Wong palette.\nExports vector PDF and high-res PNG for Cell submission.\n\"\"\"\n\nimport pandas as pd\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.ticker as ticker\nfrom matplotlib import rcParams\nfrom scipy import stats\nimport warnings, os, sys\nwarnings.filterwarnings('ignore')\n\n# ── Paths ──────────────────────────────────────────────────────────────\nDATA_FILE = os.path.expanduser('~/experiment/fig2_data.xlsx')\n# If the file isn't there, look in the current directory:\nif not os.path.exists(DATA_FILE):\n    DATA_FILE = 'fig2_data.xlsx'\nOUT_DIR   = '.'\n\n# ── Journal-standard style (Cell) ─────────────────────────────────────\nplt.style.use('default')\n\nrcParams.update({\n    'font.family':      'sans-serif',\n    'font.sans-serif':  ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size':        7,\n    'axes.titlesize':   8,\n    'axes.labelsize':   7,\n    'xtick.labelsize':  6.5,\n    'ytick.labelsize':  6.5,\n    'legend.fontsize':  6.5,\n    'lines.linewidth':  0.8,\n    'axes.linewidth':   0.6,\n    'xtick.major.width': 0.6,\n    'ytick.major.width': 0.6,\n    'xtick.major.size':  3,\n    'ytick.major.size':  3,\n    'xtick.direction':  'out',\n    'ytick.direction':  'out',\n    'axes.spines.top':    False,\n    'axes.spines.right':  False,\n    'figure.dpi':        150,\n    'savefig.dpi':       600,\n    'savefig.format':    'pdf',\n    'pdf.fonttype':      42,      # editable text in PDF\n})\n\n# ── Colourblind-safe palette (Wong 2011, Nature Methods) ──────────────\nCOLORS = {\n    'control':     '#0072B2',   # blue\n    'treatment_A': '#D55E00',   # vermillion\n    'treatment_B': '#009E73',   # green\n}\nGROUP_ORDER = ['control', 'treatment_A', 'treatment_B']\nLINESTYLES  = ['-', '--', '-.']\n\n# ── Read data ──────────────────────────────────────────────────────────\nprint(f\"Reading: {DATA_FILE}\")\nif not os.path.exists(DATA_FILE):\n    sys.exit(f\"ERROR: Data file not found at {DATA_FILE}\\n\"\n             f\"Copy fig2_data.xlsx to the current directory or update DATA_FILE.\")\ndf = pd.read_excel(DATA_FILE)\n\n# Normalise column names (lowercase, strip)\ndf.columns = [c.strip().lower().replace(' ', '_') for c in df.columns]\n\n# Ensure correct dtypes\ndf['group'] = df['group'].astype(str)\ndf['time_point'] = df['time_point'].astype(float)\ndf['expression_level'] = df['expression_level'].astype(float)\n\nprint(f\"  Rows: {len(df)}\")\nprint(f\"  Groups: {df['group'].unique()}\")\nprint(f\"  Time points: {sorted(df['time_point'].unique())}\")\n\n# ── Assemble summary statistics ────────────────────────────────────────\nsummary = (\n    df.groupby(['group', 'time_point'])['expression_level']\n    .agg(['mean', 'std', 'sem', 'count'])\n    .reset_index()\n)\nprint(\"\\nSummary per group × time point:\")\nprint(summary.to_string(index=False))\n\n# ── Statistical testing (repeated measures) ────────────────────────────\n# For each time point: one-way ANOVA + Dunnett-style post-hoc vs control\nprint(\"\\n═══ Statistical tests (vs control at each time point) ═══\")\npval_texts = {}\nalpha = 0.05\n\nfor tp in sorted(df['time_point'].unique()):\n    ct = tp\n    sub = df[df['time_point'] == tp]\n    control_vals = sub.loc[sub['group'] == 'control', 'expression_level'].values\n    results = []\n    for g in ['treatment_A', 'treatment_B']:\n        treat_vals = sub.loc[sub['group'] == g, 'expression_level'].values\n        # Welch's t-test (unequal variance OK)\n        t_stat, p_val = stats.ttest_ind(treat_vals, control_vals, equal_var=False)\n        results.append((g, t_stat, p_val))\n\n        stars = ''\n        if p_val < 0.001:\n            stars = '***'\n        elif p_val < 0.01:\n            stars = '**'\n        elif p_val < 0.05:\n            stars = '*'\n\n        print(f\"  Day {int(tp):>2d}:  {g:15s} vs control  t={t_stat:.3f}  p={p_val:.4f} {stars}\")\n        pval_texts[(g, tp)] = stars\n\n# ── Build the figure ──────────────────────────────────────────────────\n# Cell single-column = 85 mm, 1.5-col = 114 mm, full-page = 174 mm\nfig_width_mm  = 114\nfig_height_mm = 80\nfig = plt.figure(figsize=(fig_width_mm / 25.4, fig_height_mm / 25.4))\nax  = fig.add_subplot(111)\n\ntime_points = sorted(df['time_point'].unique())\nx_jitter = 0.12  # jitter width for individual points\n\n# ── 1) Thin spaghetti lines for individual subjects ───────────────────\nfor g in GROUP_ORDER:\n    g_df = df[df['group'] == g]\n    # Track unique subjects via index → assume consecutive rows = same subject\n    # Each group has 8 subjects; rows appear in subject order within each time\n    subjects = [g_df.iloc[i::8] for i in range(8)]  # every Nth row = same subject\n    # Simpler approach: assume subjects come in order, time sorted\n    sub_data = {}\n    for _, row in g_df.iterrows():\n        sub_data.setdefault(int(row.name) % 8, []).append(row)\n    # Plot each subject as a thin line\n    for sub_idx, rows in sub_data.items():\n        rows.sort(key=lambda r: r['time_point'])\n        xs = [r['time_point'] for r in rows]\n        ys = [r['expression_level'] for r in rows]\n        ax.plot(xs, ys, color=COLORS[g], lw=0.35, alpha=0.25, zorder=1)\n\n# ── 2) Mean ± SEM line with error band ────────────────────────────────\nfor i, g in enumerate(GROUP_ORDER):\n    g_sum = summary[summary['group'] == g].sort_values('time_point')\n    xs = g_sum['time_point'].values\n    ym = g_sum['mean'].values\n    ye = g_sum['sem'].values\n\n    # Shaded error band\n    ax.fill_between(xs, ym - ye, ym + ye, color=COLORS[g], alpha=0.10, lw=0, zorder=2)\n    # Bold mean line\n    ax.plot(xs, ym, color=COLORS[g], ls=LINESTYLES[i], lw=1.6,\n            label=g.replace('_', ' ').title(), zorder=4)\n\n# ── 3) Jittered individual points at each time point ───────────────────\nfor g in GROUP_ORDER:\n    g_df = df[df['group'] == g]\n    for tp in time_points:\n        sub = g_df[g_df['time_point'] == tp]['expression_level'].values\n        if len(sub) == 0:\n            continue\n        jitter = np.random.default_rng(42).uniform(-x_jitter, x_jitter, len(sub))\n        ax.scatter(tp + jitter, sub, s=8, color=COLORS[g],\n                   edgecolors='white', linewidths=0.3, zorder=5, clip_on=False)\n\n# ── 4) Significance markers ────────────────────────────────────────────\n# Find a good y-offset for significance brackets\ny_max = df['expression_level'].max()\ny_min = df['expression_level'].min()\ny_range = y_max - y_min\nsig_y_base = y_max + y_range * 0.05\n\nfor i, tp in enumerate(time_points):\n    stars_list = []\n    for g in ['treatment_A', 'treatment_B']:\n        s = pval_texts.get((g, tp), '')\n        if s:\n            stars_list.append(s)\n\n    if stars_list:\n        # Combine stars for both treatments at this time point\n        combined = '/'.join(stars_list)\n        y_pos = sig_y_base + y_range * 0.04 * i  # stagger if needed\n        ax.text(tp, sig_y_base, combined, ha='center', va='bottom',\n                fontsize=6, fontweight='bold')\n\n# ── Refine axes ───────────────────────────────────────────────────────\nax.set_xlabel('Time (days)')\nax.set_ylabel('Expression level (a.u.)')\nax.set_xlim(-2, 30)\nax.set_xticks(time_points)\nax.set_xticklabels([f'{int(t)}' for t in time_points])\n\n# Y-axis: nice ticks\ny_lo = np.floor(y_min / 5) * 5\ny_hi = np.ceil((y_max + y_range * 0.15) / 5) * 5\nax.set_ylim(y_lo, y_hi)\nax.yaxis.set_major_locator(ticker.MultipleLocator(5))\n\n# Legend\nleg = ax.legend(frameon=False, loc='best',\n                handlelength=1.5, handletextpad=0.5)\n# Ensure legend order matches group order in plot\nhandles, labels = ax.get_legend_handles_labels()\n# Reorder to match GROUP_ORDER — labels are control, Treatment A, Treatment B\norder_map = {l: i for i, l in enumerate(['Control', 'Treatment A', 'Treatment B'])}\ntry:\n    sorted_h = [h for _, h in sorted(zip(labels, handles),\n               key=lambda p: order_map.get(p[0], 99))]\n    sorted_l = sorted(labels, key=lambda l: order_map.get(l, 99))\n    leg = ax.legend(sorted_h, sorted_l, frameon=False, loc='best',\n                    handlelength=1.5, handletextpad=0.5)\nexcept KeyError:\n    pass  # fallback\n\n# ── Export ─────────────────────────────────────────────────────────────\nbase_name = os.path.join(OUT_DIR, 'Fig2_expression_levels')\n\n# PDF (vector, for submission)\nfig.savefig(f'{base_name}.pdf', bbox_inches='tight', pad_inches=0.05)\nprint(f\"\\n✅ Saved: {base_name}.pdf\")\n\n# PNG (600 DPI, for quick viewing)\nplt.savefig(f'{base_name}.png', bbox_inches='tight', pad_inches=0.05, dpi=600)\nprint(f\"✅ Saved: {base_name}.png\")\n\nplt.close()\nprint(\"\\nDone. Both files are ready for Cell submission.\")\n"})
