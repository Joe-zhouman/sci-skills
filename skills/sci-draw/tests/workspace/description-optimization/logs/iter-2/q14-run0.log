TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.py", "content": "\"\"\"\nGraphical Abstract: Nanomedicine Targeting via EPR Effect\nwith pH-Responsive Drug Release in Tumor Microenvironment\n\nCreates a publication-quality conceptual schematic.\n\"\"\"\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.patches import FancyBboxPatch, Ellipse, Circle, FancyArrowPatch\nimport numpy as np\n\n# ============================================================\n# Setup\n# ============================================================\nfig, ax = plt.subplots(figsize=(15, 7.5), facecolor='white')\nax.set_xlim(-0.5, 15.5)\nax.set_ylim(-0.5, 7.5)\nax.set_aspect('equal')\nax.axis('off')\n\n# Color palette\nCOLOR_BG_VESSEL   = '#FDEDEC'  # very light red for vessel lumen\nCOLOR_ENDOTHELIUM = '#D4A574'  # brownish for endothelial cells\nCOLOR_ECM         = '#E8E8E8'  # light gray for extracellular matrix\nCOLOR_NP_CORE     = '#2E86C1'  # blue for nanoparticle core\nCOLOR_NP_SHELL    = '#AED6F1'  # light blue for nanoparticle shell\nCOLOR_NP_SHADOW   = '#5DADE2'  # medium blue\nCOLOR_RBC         = '#E74C3C'  # red for red blood cells\nCOLOR_TUMOR       = '#AF7AC5'  # purple for tumor cells\nCOLOR_NUCLEUS     = '#4A235A'  # dark purple for nucleus\nCOLOR_DRUG        = '#28B463'  # green for drug molecules\nCOLOR_DRUG_GLOW   = '#ABEBC6'  # light green glow\nCOLOR_PH_LOW      = '#E67E22'  # orange for acidic pH\nCOLOR_ARROW_MAIN  = '#1A5276'  # dark blue for main arrows\nCOLOR_LABEL_BG    = '#FEF9E7'  # light yellow for label backgrounds\nCOLOR_LABEL_EDGE  = '#F1C40F'  # yellow edge\nCOLOR_TITLE       = '#1B4F72'  # dark navy for title\nCOLOR_VESSEL_WALL = '#C0392B'  # red for vessel wall outline\nCOLOR_GAP_ARROW   = '#E67E22'  # orange for extravasation arrow\n\n# ============================================================\n# Helper functions\n# ============================================================\n\ndef draw_nanoparticle(x, y, radius=0.25, shell_radius=0.30,\n                       core_color=COLOR_NP_CORE, shell_color=COLOR_NP_SHELL,\n                       alpha=0.9, zorder=10):\n    \"\"\"Draw a core-shell nanoparticle.\"\"\"\n    # Outer shell (polymer/lipid)\n    shell = Circle((x, y), shell_radius,\n                   facecolor=shell_color, edgecolor=core_color,\n                   linewidth=1.0, alpha=alpha, zorder=zorder)\n    ax.add_patch(shell)\n    # Inner core (drug payload)\n    core = Circle((x, y), radius,\n                  facecolor=core_color, edgecolor='white',\n                  linewidth=0.5, alpha=alpha, zorder=zorder+1)\n    ax.add_patch(core)\n    # Highlight/shine\n    shine = Circle((x - radius*0.25, y + radius*0.25), radius*0.3,\n                   facecolor='white', alpha=0.4, zorder=zorder+2)\n    ax.add_patch(shine)\n    return shell, core\n\n\ndef draw_drug_molecule(x, y, size=0.08, color=COLOR_DRUG, zorder=15):\n    \"\"\"Draw a small drug molecule as a star/dot.\"\"\"\n    # Glow\n    glow = Circle((x, y), size*2.5, facecolor=color, alpha=0.15, zorder=zorder-1)\n    ax.add_patch(glow)\n    # Core dot\n    dot = Circle((x, y), size, facecolor=color, edgecolor='white',\n                 linewidth=0.3, zorder=zorder)\n    ax.add_patch(dot)\n    return dot\n\n\ndef draw_tumor_cell(x, y, rx=0.6, ry=0.5, angle=0,\n                    color=COLOR_TUMOR, nucleus_color=COLOR_NUCLEUS, zorder=5):\n    \"\"\"Draw a tumor cell with nucleus.\"\"\"\n    # Cell body\n    cell = Ellipse((x, y), rx*2, ry*2, angle=angle,\n                   facecolor=color, edgecolor=COLOR_NUCLEUS,\n                   linewidth=1.5, alpha=0.85, zorder=zorder)\n    ax.add_patch(cell)\n    # Nucleus (irregular, represented by a smaller ellipse)\n    nucleus = Ellipse((x + rx*0.1, y + ry*0.05), rx*0.7, ry*0.6, angle=angle*0.5,\n                      facecolor=nucleus_color, edgecolor='black',\n                      linewidth=0.8, alpha=0.7, zorder=zorder+1)\n    ax.add_patch(nucleus)\n    # Nucleolus\n    nucleolus = Circle((x + rx*0.15, y - ry*0.05), rx*0.15,\n                       facecolor='#1A0A2E', alpha=0.5, zorder=zorder+2)\n    ax.add_patch(nucleolus)\n    return cell\n\n\ndef draw_endothelial_cell(x, y, width=0.7, height=0.25, angle=0, zorder=4):\n    \"\"\"Draw an elongated endothelial cell.\"\"\"\n    cell = Ellipse((x, y), width, height, angle=angle,\n                   facecolor=COLOR_ENDOTHELIUM, edgecolor='#8B6914',\n                   linewidth=1.0, alpha=0.9, zorder=zorder)\n    ax.add_patch(cell)\n    # Nucleus\n    nuc = Ellipse((x, y), width*0.35, height*0.5, angle=angle,\n                  facecolor='#6B4F1A', edgecolor='#4A3510',\n                  linewidth=0.5, alpha=0.6, zorder=zorder+1)\n    ax.add_patch(nuc)\n    return cell\n\n\ndef draw_arrow_headless(start, end, color=COLOR_ARROW_MAIN, lw=2.0,\n                         ls='-', zorder=3):\n    \"\"\"Draw a simple line (arrow without head).\"\"\"\n    ax.plot([start[0], end[0]], [start[1], end[1]],\n            color=color, linewidth=lw, linestyle=ls, zorder=zorder)\n\n\ndef draw_fancy_arrow(start, end, color=COLOR_ARROW_MAIN, lw=2.5,\n                      connectionstyle='arc3,rad=0', zorder=20,\n                      arrowstyle='-|>', mutation_scale=25):\n    \"\"\"Draw a fancy arrow between two points.\"\"\"\n    arrow = FancyArrowPatch(start, end,\n                            arrowstyle=arrowstyle,\n                            connectionstyle=connectionstyle,\n                            color=color, linewidth=lw,\n                            mutation_scale=mutation_scale, zorder=zorder)\n    ax.add_patch(arrow)\n    return arrow\n\n\ndef add_label_box(x, y, text, bg_color=COLOR_LABEL_BG, edge_color=COLOR_LABEL_EDGE,\n                  fontsize=11, bold=False, pad=0.15, zorder=25):\n    \"\"\"Add a text label with a background box.\"\"\"\n    bbox_props = dict(boxstyle=f\"round,pad={pad}\",\n                      facecolor=bg_color, edgecolor=edge_color,\n                      linewidth=1.5, alpha=0.9)\n    ha = 'center'\n    if bold:\n        text = f\"**{text}**\"  # won't work in plain matplotlib\n    ax.text(x, y, text, fontsize=fontsize, fontweight='bold' if bold else 'normal',\n            ha=ha, va='center', bbox=bbox_props, zorder=zorder,\n            color='#2C3E50')\n    return text\n\n\n# ============================================================\n# SECTION 1: BLOOD VESSEL (Left) — x: 0.5 to 5.5\n# ============================================================\n\n# --- Vessel background / lumen ---\nvessel_lumen = FancyBboxPatch((0.8, 1.8), 4.8, 3.4,\n                               boxstyle=\"round,pad=0.15\",\n                               facecolor=COLOR_BG_VESSEL,\n                               edgecolor=COLOR_VESSEL_WALL,\n                               linewidth=2.0, zorder=1)\nax.add_patch(vessel_lumen)\n\n# --- Top endothelial layer ---\ntop_y = 5.25\nfor x_pos in np.arange(1.0, 5.4, 0.65):\n    jitter = np.random.uniform(-0.05, 0.05)\n    draw_endothelial_cell(x_pos, top_y + jitter, width=0.7, height=0.25, zorder=4)\n\n# --- Bottom endothelial layer (with a gap for extravasation) ---\nbot_y = 1.65\ngap_left, gap_right = 2.8, 4.2\nfor x_pos in np.arange(1.0, 5.4, 0.55):\n    if gap_left < x_pos < gap_right:\n        continue\n    jitter = np.random.uniform(-0.05, 0.05)\n    draw_endothelial_cell(x_pos, bot_y + jitter, width=0.65, height=0.25, zorder=4)\n\n# Gap highlight\ngap_highlight = FancyBboxPatch((gap_left, 1.7), gap_right - gap_left, 0.15,\n                                boxstyle=\"round,pad=0.02\",\n                                facecolor='none', edgecolor=COLOR_GAP_ARROW,\n                                linewidth=1.5, linestyle='--', zorder=3)\nax.add_patch(gap_highlight)\n# Leaky vasculature label near gap\nax.text((gap_left + gap_right)/2, 1.3, \"Leaky vasculature\\n(EPR effect)\",\n        fontsize=8, ha='center', va='top', color=COLOR_GAP_ARROW,\n        fontstyle='italic', zorder=30)\n\n# --- Blood components ---\n# Red blood cells\nfor x, y in [(1.3, 4.0), (2.0, 3.0), (3.5, 4.5), (4.8, 2.8), (1.8, 2.5)]:\n    rbc = Circle((x, y), 0.2, facecolor=COLOR_RBC, edgecolor='#922B21',\n                 linewidth=0.5, alpha=0.7, zorder=5)\n    ax.add_patch(rbc)\n    # RBC biconcave hint\n    inner = Circle((x - 0.04, y), 0.06, facecolor='#FADBD8', alpha=0.6, zorder=6)\n    ax.add_patch(inner)\n\n# Nanoparticles in blood vessel\nnp_positions_vessel = [(1.5, 3.5), (2.2, 2.5), (3.8, 3.5), (4.5, 4.2),\n                        (2.8, 4.0), (4.2, 2.2), (1.2, 2.8), (3.2, 2.0)]\nfor x, y in np_positions_vessel:\n    draw_nanoparticle(x, y, radius=0.12, shell_radius=0.16)\n\n# --- Blood flow direction indicator ---\nflow_arrow = FancyArrowPatch((0.5, 3.5), (1.2, 3.5),\n                              arrowstyle='-|>', mutation_scale=20,\n                              color='#E74C3C', linewidth=2,\n                              alpha=0.6, zorder=2)\nax.add_patch(flow_arrow)\nax.text(0.85, 3.8, \"Blood flow\", fontsize=7, ha='center',\n        color='#E74C3C', alpha=0.7, fontstyle='italic', zorder=2)\n\n# ============================================================\n# SECTION 2: EXTRAVASATION (Middle) — x: 2.8 to 5.5\n# ============================================================\n\n# --- Nanoparticles extravasating through gap ---\nextra_positions = [(3.0, 1.4), (3.3, 1.0), (3.7, 0.7), (4.0, 1.2),\n                    (3.5, 0.4), (3.1, 0.3)]\nfor x, y in extra_positions:\n    draw_nanoparticle(x, y, radius=0.12, shell_radius=0.16, alpha=0.8,\n                       shell_color=COLOR_NP_SHADOW)\n\n# Extravasation direction arrows (small, pointing downward)\nfor x_pos in [3.15, 3.45, 3.85]:\n    ext_arrow = FancyArrowPatch((x_pos, 1.85), (x_pos, 1.55),\n                                 arrowstyle='-|>', mutation_scale=12,\n                                 color=COLOR_GAP_ARROW, linewidth=1.5,\n                                 zorder=15)\n    ax.add_patch(ext_arrow)\n\n# --- Extracellular matrix (ECM) in background ---\n# Draw some wavy fibers\necm_center = 6.0\nfor i in range(12):\n    y_base = np.random.uniform(0.5, 6.5)\n    x_start = np.random.uniform(4.5, 6.5)\n    x_end = x_start + np.random.uniform(0.5, 1.5)\n    ax.plot([x_start, x_end], [y_base, y_base + np.random.uniform(-0.3, 0.3)],\n            color=COLOR_ECM, linewidth=0.8, alpha=0.5, zorder=2)\n\n# ============================================================\n# MAIN FLOW ARROW between blood vessel and tumor\n# ============================================================\nmain_arrow = FancyArrowPatch((5.8, 3.8), (8.5, 3.8),\n                              arrowstyle='-|>', mutation_scale=35,\n                              color=COLOR_ARROW_MAIN, linewidth=3.5,\n                              zorder=20)\nax.add_patch(main_arrow)\n\n# Label on main arrow\nadd_label_box(7.15, 4.4, \"EPR Effect\",\n              bg_color='#D6EAF8', edge_color=COLOR_ARROW_MAIN,\n              fontsize=13, bold=True, pad=0.2)\n\n# Subtitle on arrow\nax.text(7.15, 3.9, \"(Enhanced Permeability\\n& Retention)\",\n        fontsize=8.5, ha='center', va='center', color=COLOR_ARROW_MAIN,\n        fontstyle='italic', zorder=21)\n\n# ============================================================\n# SECTION 3: TUMOR MICROENVIRONMENT (Right) — x: 9.0 to 14.5\n# ============================================================\n\n# --- Background shading for acidic microenvironment ---\nacid_bg = FancyBboxPatch((8.8, 0.3), 6.2, 7.0,\n                          boxstyle=\"round,pad=0.2\",\n                          facecolor='#FDF2E9', edgecolor=COLOR_PH_LOW,\n                          linewidth=2.0, linestyle='--', alpha=0.3, zorder=0)\nax.add_patch(acid_bg)\n\n# pH label in background\nax.text(9.2, 6.8, \"Acidic Tumor Microenvironment (pH ~6.5)\",\n        fontsize=10, color=COLOR_PH_LOW, ha='left', va='top',\n        fontweight='bold', alpha=0.7, zorder=30)\n\n# pH scale indicator (small bar)\nph_y = 6.3\nfor i, (ph_val, color) in enumerate([('7.4', '#2ECC71'), ('7.0', '#F1C40F'),\n                                       ('6.5', '#E67E22'), ('6.0', '#E74C3C')]):\n    x_pos = 9.2 + i * 0.8\n    bar = FancyBboxPatch((x_pos - 0.15, ph_y - 0.1), 0.3, 0.2,\n                          boxstyle=\"round,pad=0.02\",\n                          facecolor=color, edgecolor='gray', linewidth=0.5, zorder=5)\n    ax.add_patch(bar)\n    ax.text(x_pos, ph_y - 0.45, ph_val, fontsize=6.5, ha='center', color='#555')\n\nax.text(9.2, ph_y + 0.3, \"pH\", fontsize=8, ha='left',\n        color='#555', fontweight='bold', zorder=30)\n# Arrow from pH neutral to acidic\nph_arrow = FancyArrowPatch((9.2+0.4, ph_y), (9.2+2.4, ph_y),\n                            arrowstyle='-|>', mutation_scale=12,\n                            color='#999', linewidth=1.5, zorder=5)\nax.add_patch(ph_arrow)\n\n# --- Tumor cells ---\ncell_positions = [\n    (10.5, 5.0, 0.7, 0.6, 0),      # (x, y, rx, ry, angle)\n    (12.0, 5.5, 0.6, 0.55, 15),\n    (11.8, 3.0, 0.65, 0.5, -10),\n    (13.2, 4.0, 0.55, 0.5, 5),\n    (10.2, 2.5, 0.6, 0.5, -5),\n    (13.5, 2.0, 0.5, 0.45, 10),\n    (12.5, 6.2, 0.5, 0.4, -15),    # smaller cell\n]\nfor x, y, rx, ry, angle in cell_positions:\n    draw_tumor_cell(x, y, rx, ry, angle, zorder=8)\n\n# Membrane receptors on tumor cells (small protrusions)\nfor x, y, rx, ry, angle in cell_positions:\n    for _ in range(3):\n        theta = np.random.uniform(0, 2*np.pi)\n        r = np.sqrt((rx*np.cos(theta))**2 + (ry*np.sin(theta))**2) * 1.05\n        rx_pt = x + r * np.cos(theta + angle*np.pi/180)\n        ry_pt = y + r * np.sin(theta + angle*np.pi/180) * 0.8\n        receptor = Circle((rx_pt, ry_pt), 0.04,\n                          facecolor='#F5B041', edgecolor='#D68910',\n                          linewidth=0.3, zorder=12)\n        ax.add_patch(receptor)\n\n# --- Nanoparticles accumulated in tumor (more of them) ---\nnp_positions_tumor = [\n    (9.5, 4.5), (9.8, 3.8), (10.0, 5.8),\n    (10.8, 4.2), (11.2, 2.5), (11.5, 6.0),\n    (12.5, 4.5), (13.0, 5.0), (12.8, 2.8),\n    (9.5, 1.8), (11.0, 1.5), (13.8, 3.0),\n    (10.5, 1.0), (12.2, 1.2),\n]\nfor x, y in np_positions_tumor:\n    draw_nanoparticle(x, y, radius=0.12, shell_radius=0.16, zorder=11)\n\n# --- Drug release ---\n# Nanoparticles that are \"opening\" / releasing drug\nreleasing_np = [(10.2, 3.5), (11.5, 4.8), (12.5, 5.5), (13.5, 3.5), (10.8, 2.0)]\nfor x, y in releasing_np:\n    draw_nanoparticle(x, y, radius=0.12, shell_radius=0.16,\n                       shell_color='#FAD7A0', core_color='#E67E22', zorder=11)\n    # Drug molecules diffusing out\n    for angle in np.linspace(0, 2*np.pi, 5):\n        dx = 0.25 * np.cos(angle + np.random.uniform(-0.3, 0.3))\n        dy = 0.25 * np.sin(angle + np.random.uniform(-0.3, 0.3))\n        draw_drug_molecule(x + dx, y + dy, size=0.06, zorder=16)\n    # Additional drug molecules further out\n    for angle in np.linspace(0, 2*np.pi, 3):\n        dx = 0.45 * np.cos(angle + np.random.uniform(-0.2, 0.2))\n        dy = 0.45 * np.sin(angle + np.random.uniform(-0.2, 0.2))\n        draw_drug_molecule(x + dx, y + dy, size=0.05, alpha=0.7, zorder=14)\n\n# Additional scattered drug molecules (released and diffusing)\ndrug_scatter = [(10.8, 3.0), (11.0, 4.0), (12.0, 4.0), (13.0, 4.5),\n                (11.8, 2.0), (13.8, 2.5), (10.5, 4.5), (9.8, 2.5),\n                (12.8, 3.5), (14.0, 4.8)]\nfor x, y in drug_scatter:\n    draw_drug_molecule(x, y, size=0.055, zorder=14)\n\n# --- Drug release annotation ---\n# Small arrow + label pointing to releasing NP\nrelease_label_arrow = FancyArrowPatch((10.2, 3.1), (10.2, 3.35),\n                                       arrowstyle='-|>', mutation_scale=15,\n                                       color=COLOR_DRUG, linewidth=2.0, zorder=20)\nax.add_patch(release_label_arrow)\nadd_label_box(10.2, 2.7, \"pH-responsive\\ndrug release\",\n              bg_color='#D5F5E3', edge_color=COLOR_DRUG,\n              fontsize=10, bold=True, pad=0.2)\n\n# ============================================================\n# LEGEND\n# ============================================================\nlegend_x, legend_y = 0.7, 6.6\nlegend_box = FancyBboxPatch((legend_x - 0.1, legend_y - 0.15), 3.5, 0.75,\n                             boxstyle=\"round,pad=0.1\",\n                             facecolor='white', edgecolor='#CCC',\n                             linewidth=1.0, zorder=30)\nax.add_patch(legend_box)\n\n# Legend title\nax.text(legend_x + 0.1, legend_y + 0.45, \"Legend:\", fontsize=9,\n        fontweight='bold', color='#555', zorder=31)\n\n# Nanoparticle legend\ndraw_nanoparticle(legend_x + 0.8, legend_y + 0.25, radius=0.08, shell_radius=0.11, zorder=31)\nax.text(legend_x + 1.0, legend_y + 0.25, \"Nanoparticle\", fontsize=7.5,\n        color='#555', va='center', zorder=31)\n\n# Drug legend\ndraw_drug_molecule(legend_x + 2.0, legend_y + 0.25, size=0.05, zorder=31)\nax.text(legend_x + 2.15, legend_y + 0.25, \"Drug molecule\", fontsize=7.5,\n        color='#555', va='center', zorder=31)\n\n# ============================================================\n# SECTION TITLES (top of each region)\n# ============================================================\n# Title\nax.text(7.5, 7.15, \"Graphical Abstract: Nanomedicine Targeting via EPR Effect\",\n        fontsize=16, fontweight='bold', ha='center', va='center',\n        color=COLOR_TITLE, zorder=30)\n\n# Section labels at top\nsection_labels = [\n    (2.8, 6.6, \"① Blood Circulation\", 11),\n    (7.15, 6.6, \"② Tumor Extravasation\", 11),\n    (11.7, 6.6, \"③ Intratumoral Drug Release\", 11),\n]\nfor x, y, text, fontsize in section_labels:\n    ax.text(x, y, text, fontsize=fontsize, fontweight='bold', ha='center',\n            va='center', color=COLOR_ARROW_MAIN, zorder=30)\n\n# ============================================================\n# ANNOTATIONS / CALL-OUTS within each section\n# ============================================================\n\n# --- Blood vessel annotation ---\nadd_label_box(1.0, 5.85, \"Endothelial cells\", fontsize=8, bold=False, pad=0.1)\nadd_label_box(1.0, 1.2, \"i.v. injection\", fontsize=9, bold=True,\n              bg_color='#FDEDEC', edge_color='#E74C3C', pad=0.15)\n\n# --- Tumor annotations ---\nadd_label_box(12.8, 6.65, \"Tumor cells\", fontsize=9, bold=True,\n              bg_color='#E8DAEF', edge_color=COLOR_TUMOR, pad=0.15)\n\n# --- Annotations around the figure ---\n# EPR detail\nax.annotate('Enhanced vascular permeability',\n            xy=(3.5, 1.35), xytext=(5.0, 0.8),\n            fontsize=7.5, color='#555', fontstyle='italic',\n            arrowprops=dict(arrowstyle='->', color='#999', lw=1.0),\n            zorder=25)\n\n# ============================================================\n# FINAL ADJUSTMENTS\n# ============================================================\nplt.tight_layout()\nplt.savefig('/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.png',\n            dpi=400, bbox_inches='tight', facecolor='white')\nprint(\"Saved: graphical_abstract.png\")\n\n# Also save a PDF for publication\nplt.savefig('/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.pdf',\n            bbox_inches='tight', facecolor='white')\nprint(\"Saved: graphical_abstract.pdf\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.py", "content": "\"\"\"\nGraphical Abstract: Nanomedicine Targeting via EPR Effect\nwith pH-Responsive Drug Release in Tumor Microenvironment\n\nCreates a publication-quality conceptual schematic.\n\"\"\"\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.patches import FancyBboxPatch, Ellipse, Circle, FancyArrowPatch\nimport numpy as np\n\n# ============================================================\n# Setup\n# ============================================================\nfig, ax = plt.subplots(figsize=(15, 7.5), facecolor='white')\nax.set_xlim(-0.5, 15.5)\nax.set_ylim(-0.5, 7.5)\nax.set_aspect('equal')\nax.axis('off')\n\n# Color palette\nCOLOR_BG_VESSEL   = '#FDEDEC'  # very light red for vessel lumen\nCOLOR_ENDOTHELIUM = '#D4A574'  # brownish for endothelial cells\nCOLOR_ECM         = '#E8E8E8'  # light gray for extracellular matrix\nCOLOR_NP_CORE     = '#2E86C1'  # blue for nanoparticle core\nCOLOR_NP_SHELL    = '#AED6F1'  # light blue for nanoparticle shell\nCOLOR_NP_SHADOW   = '#5DADE2'  # medium blue\nCOLOR_RBC         = '#E74C3C'  # red for red blood cells\nCOLOR_TUMOR       = '#AF7AC5'  # purple for tumor cells\nCOLOR_NUCLEUS     = '#4A235A'  # dark purple for nucleus\nCOLOR_DRUG        = '#28B463'  # green for drug molecules\nCOLOR_DRUG_GLOW   = '#ABEBC6'  # light green glow\nCOLOR_PH_LOW      = '#E67E22'  # orange for acidic pH\nCOLOR_ARROW_MAIN  = '#1A5276'  # dark blue for main arrows\nCOLOR_LABEL_BG    = '#FEF9E7'  # light yellow for label backgrounds\nCOLOR_LABEL_EDGE  = '#F1C40F'  # yellow edge\nCOLOR_TITLE       = '#1B4F72'  # dark navy for title\nCOLOR_VESSEL_WALL = '#C0392B'  # red for vessel wall outline\nCOLOR_GAP_ARROW   = '#E67E22'  # orange for extravasation arrow\n\n# ============================================================\n# Helper functions\n# ============================================================\n\ndef draw_nanoparticle(x, y, radius=0.25, shell_radius=0.30, \n                       core_color=COLOR_NP_CORE, shell_color=COLOR_NP_SHELL, \n                       alpha=0.9, zorder=10):\n    \"\"\"Draw a core-shell nanoparticle.\"\"\"\n    # Outer shell (polymer/lipid)\n    shell = Circle((x, y), shell_radius, \n                   facecolor=shell_color, edgecolor=core_color, \n                   linewidth=1.0, alpha=alpha, zorder=zorder)\n    ax.add_patch(shell)\n    # Inner core (drug payload)\n    core = Circle((x, y), radius,\n                  facecolor=core_color, edgecolor='white',\n                  linewidth=0.5, alpha=alpha, zorder=zorder+1)\n    ax.add_patch(core)\n    # Highlight/shine\n    shine = Circle((x - radius*0.25, y + radius*0.25), radius*0.3,\n                   facecolor='white', alpha=0.4, zorder=zorder+2)\n    ax.add_patch(shine)\n    return shell, core\n\n\ndef draw_drug_molecule(x, y, size=0.08, color=COLOR_DRUG, zorder=15):\n    \"\"\"Draw a small drug molecule as a star/dot.\"\"\"\n    # Glow\n    glow = Circle((x, y), size*2.5, facecolor=color, alpha=0.15, zorder=zorder-1)\n    ax.add_patch(glow)\n    # Core dot\n    dot = Circle((x, y), size, facecolor=color, edgecolor='white', \n                 linewidth=0.3, zorder=zorder)\n    ax.add_patch(dot)\n    return dot\n\n\ndef draw_tumor_cell(x, y, rx=0.6, ry=0.5, angle=0, \n                    color=COLOR_TUMOR, nucleus_color=COLOR_NUCLEUS, zorder=5):\n    \"\"\"Draw a tumor cell with nucleus.\"\"\"\n    # Cell body\n    cell = Ellipse((x, y), rx*2, ry*2, angle=angle,\n                   facecolor=color, edgecolor=COLOR_NUCLEUS, \n                   linewidth=1.5, alpha=0.85, zorder=zorder)\n    ax.add_patch(cell)\n    # Nucleus (irregular, represented by a smaller ellipse)\n    nucleus = Ellipse((x + rx*0.1, y + ry*0.05), rx*0.7, ry*0.6, angle=angle*0.5,\n                      facecolor=nucleus_color, edgecolor='black',\n                      linewidth=0.8, alpha=0.7, zorder=zorder+1)\n    ax.add_patch(nucleus)\n    # Nucleolus\n    nucleolus = Circle((x + rx*0.15, y - ry*0.05), rx*0.15,\n                       facecolor='#1A0A2E', alpha=0.5, zorder=zorder+2)\n    ax.add_patch(nucleolus)\n    return cell\n\n\ndef draw_endothelial_cell(x, y, width=0.7, height=0.25, angle=0, zorder=4):\n    \"\"\"Draw an elongated endothelial cell.\"\"\"\n    cell = Ellipse((x, y), width, height, angle=angle,\n                   facecolor=COLOR_ENDOTHELIUM, edgecolor='#8B6914',\n                   linewidth=1.0, alpha=0.9, zorder=zorder)\n    ax.add_patch(cell)\n    # Nucleus\n    nuc = Ellipse((x, y), width*0.35, height*0.5, angle=angle,\n                  facecolor='#6B4F1A', edgecolor='#4A3510',\n                  linewidth=0.5, alpha=0.6, zorder=zorder+1)\n    ax.add_patch(nuc)\n    return cell\n\n\ndef draw_arrow_headless(start, end, color=COLOR_ARROW_MAIN, lw=2.0, \n                         ls='-', zorder=3):\n    \"\"\"Draw a simple line (arrow without head).\"\"\"\n    ax.plot([start[0], end[0]], [start[1], end[1]], \n            color=color, linewidth=lw, linestyle=ls, zorder=zorder)\n\n\ndef draw_fancy_arrow(start, end, color=COLOR_ARROW_MAIN, lw=2.5,\n                      connectionstyle='arc3,rad=0', zorder=20,\n                      arrowstyle='-|>', mutation_scale=25):\n    \"\"\"Draw a fancy arrow between two points.\"\"\"\n    arrow = FancyArrowPatch(start, end,\n                            arrowstyle=arrowstyle,\n                            connectionstyle=connectionstyle,\n                            color=color, linewidth=lw,\n                            mutation_scale=mutation_scale, zorder=zorder)\n    ax.add_patch(arrow)\n    return arrow\n\n\ndef add_label_box(x, y, text, bg_color=COLOR_LABEL_BG, edge_color=COLOR_LABEL_EDGE,\n                  fontsize=11, bold=False, pad=0.15, zorder=25):\n    \"\"\"Add a text label with a background box.\"\"\"\n    bbox_props = dict(boxstyle=f\"round,pad={pad}\", \n                      facecolor=bg_color, edgecolor=edge_color, \n                      linewidth=1.5, alpha=0.9)\n    ha = 'center'\n    if bold:\n        text = f\"**{text}**\"  # won't work in plain matplotlib\n    ax.text(x, y, text, fontsize=fontsize, fontweight='bold' if bold else 'normal',\n            ha=ha, va='center', bbox=bbox_props, zorder=zorder,\n            color='#2C3E50')\n    return text\n\n\n# ============================================================\n# SECTION 1: BLOOD VESSEL (Left) — x: 0.5 to 5.5\n# ============================================================\n\n# --- Vessel background / lumen ---\nvessel_lumen = FancyBboxPatch((0.8, 1.8), 4.8, 3.4, \n                               boxstyle=\"round,pad=0.15\",\n                               facecolor=COLOR_BG_VESSEL, \n                               edgecolor=COLOR_VESSEL_WALL, \n                               linewidth=2.0, zorder=1)\nax.add_patch(vessel_lumen)\n\n# --- Top endothelial layer ---\ntop_y = 5.25\nfor x_pos in np.arange(1.0, 5.4, 0.65):\n    jitter = np.random.uniform(-0.05, 0.05)\n    draw_endothelial_cell(x_pos, top_y + jitter, width=0.7, height=0.25, zorder=4)\n\n# --- Bottom endothelial layer (with a gap for extravasation) ---\nbot_y = 1.65\ngap_left, gap_right = 2.8, 4.2\nfor x_pos in np.arange(1.0, 5.4, 0.55):\n    if gap_left < x_pos < gap_right:\n        continue\n    jitter = np.random.uniform(-0.05, 0.05)\n    draw_endothelial_cell(x_pos, bot_y + jitter, width=0.65, height=0.25, zorder=4)\n\n# Gap highlight\ngap_highlight = FancyBboxPatch((gap_left, 1.7), gap_right - gap_left, 0.15,\n                                boxstyle=\"round,pad=0.02\",\n                                facecolor='none', edgecolor=COLOR_GAP_ARROW,\n                                linewidth=1.5, linestyle='--', zorder=3)\nax.add_patch(gap_highlight)\n# Leaky vasculature label near gap\nax.text((gap_left + gap_right)/2, 1.3, \"Leaky vasculature\\n(EPR effect)\", \n        fontsize=8, ha='center', va='top', color=COLOR_GAP_ARROW,\n        fontstyle='italic', zorder=30)\n\n# --- Blood components ---\n# Red blood cells\nfor x, y in [(1.3, 4.0), (2.0, 3.0), (3.5, 4.5), (4.8, 2.8), (1.8, 2.5)]:\n    rbc = Circle((x, y), 0.2, facecolor=COLOR_RBC, edgecolor='#922B21', \n                 linewidth=0.5, alpha=0.7, zorder=5)\n    ax.add_patch(rbc)\n    # RBC biconcave hint\n    inner = Circle((x - 0.04, y), 0.06, facecolor='#FADBD8', alpha=0.6, zorder=6)\n    ax.add_patch(inner)\n\n# Nanoparticles in blood vessel\nnp_positions_vessel = [(1.5, 3.5), (2.2, 2.5), (3.8, 3.5), (4.5, 4.2), \n                        (2.8, 4.0), (4.2, 2.2), (1.2, 2.8), (3.2, 2.0)]\nfor x, y in np_positions_vessel:\n    draw_nanoparticle(x, y, radius=0.12, shell_radius=0.16)\n\n# --- Blood flow direction indicator ---\nflow_arrow = FancyArrowPatch((0.5, 3.5), (1.2, 3.5),\n                              arrowstyle='-|>', mutation_scale=20,\n                              color='#E74C3C', linewidth=2, \n                              alpha=0.6, zorder=2)\nax.add_patch(flow_arrow)\nax.text(0.85, 3.8, \"Blood flow\", fontsize=7, ha='center', \n        color='#E74C3C', alpha=0.7, fontstyle='italic', zorder=2)\n\n# ============================================================\n# SECTION 2: EXTRAVASATION (Middle) — x: 2.8 to 5.5\n# ============================================================\n\n# --- Nanoparticles extravasating through gap ---\nextra_positions = [(3.0, 1.4), (3.3, 1.0), (3.7, 0.7), (4.0, 1.2), \n                    (3.5, 0.4), (3.1, 0.3)]\nfor x, y in extra_positions:\n    draw_nanoparticle(x, y, radius=0.12, shell_radius=0.16, alpha=0.8,\n                       shell_color=COLOR_NP_SHADOW)\n\n# Extravasation direction arrows (small, pointing downward)\nfor x_pos in [3.15, 3.45, 3.85]:\n    ext_arrow = FancyArrowPatch((x_pos, 1.85), (x_pos, 1.55),\n                                 arrowstyle='-|>', mutation_scale=12,\n                                 color=COLOR_GAP_ARROW, linewidth=1.5,\n                                 zorder=15)\n    ax.add_patch(ext_arrow)\n\n# --- Extracellular matrix (ECM) in background ---\n# Draw some wavy fibers\necm_center = 6.0\nfor i in range(12):\n    y_base = np.random.uniform(0.5, 6.5)\n    x_start = np.random.uniform(4.5, 6.5)\n    x_end = x_start + np.random.uniform(0.5, 1.5)\n    ax.plot([x_start, x_end], [y_base, y_base + np.random.uniform(-0.3, 0.3)],\n            color=COLOR_ECM, linewidth=0.8, alpha=0.5, zorder=2)\n\n# ============================================================\n# MAIN FLOW ARROW between blood vessel and tumor\n# ============================================================\nmain_arrow = FancyArrowPatch((5.8, 3.8), (8.5, 3.8),\n                              arrowstyle='-|>', mutation_scale=35,\n                              color=COLOR_ARROW_MAIN, linewidth=3.5,\n                              zorder=20)\nax.add_patch(main_arrow)\n\n# Label on main arrow\nadd_label_box(7.15, 4.4, \"EPR Effect\", \n              bg_color='#D6EAF8', edge_color=COLOR_ARROW_MAIN,\n              fontsize=13, bold=True, pad=0.2)\n\n# Subtitle on arrow\nax.text(7.15, 3.9, \"(Enhanced Permeability\\n& Retention)\", \n        fontsize=8.5, ha='center', va='center', color=COLOR_ARROW_MAIN,\n        fontstyle='italic', zorder=21)\n\n# ============================================================\n# SECTION 3: TUMOR MICROENVIRONMENT (Right) — x: 9.0 to 14.5\n# ============================================================\n\n# --- Background shading for acidic microenvironment ---\nacid_bg = FancyBboxPatch((8.8, 0.3), 6.2, 7.0,\n                          boxstyle=\"round,pad=0.2\",\n                          facecolor='#FDF2E9', edgecolor=COLOR_PH_LOW,\n                          linewidth=2.0, linestyle='--', alpha=0.3, zorder=0)\nax.add_patch(acid_bg)\n\n# pH label in background\nax.text(9.2, 6.8, \"Acidic Tumor Microenvironment (pH ~6.5)\", \n        fontsize=10, color=COLOR_PH_LOW, ha='left', va='top',\n        fontweight='bold', alpha=0.7, zorder=30)\n\n# pH scale indicator (small bar)\nph_y = 6.3\nfor i, (ph_val, color) in enumerate([('7.4', '#2ECC71'), ('7.0', '#F1C40F'), \n                                       ('6.5', '#E67E22'), ('6.0', '#E74C3C')]):\n    x_pos = 9.2 + i * 0.8\n    bar = FancyBboxPatch((x_pos - 0.15, ph_y - 0.1), 0.3, 0.2,\n                          boxstyle=\"round,pad=0.02\",\n                          facecolor=color, edgecolor='gray', linewidth=0.5, zorder=5)\n    ax.add_patch(bar)\n    ax.text(x_pos, ph_y - 0.45, ph_val, fontsize=6.5, ha='center', color='#555')\n\nax.text(9.2, ph_y + 0.3, \"pH\", fontsize=8, ha='left', \n        color='#555', fontweight='bold', zorder=30)\n# Arrow from pH neutral to acidic\nph_arrow = FancyArrowPatch((9.2+0.4, ph_y), (9.2+2.4, ph_y),\n                            arrowstyle='-|>', mutation_scale=12,\n                            color='#999', linewidth=1.5, zorder=5)\nax.add_patch(ph_arrow)\n\n# --- Tumor cells ---\ncell_positions = [\n    (10.5, 5.0, 0.7, 0.6, 0),      # (x, y, rx, ry, angle)\n    (12.0, 5.5, 0.6, 0.55, 15),\n    (11.8, 3.0, 0.65, 0.5, -10),\n    (13.2, 4.0, 0.55, 0.5, 5),\n    (10.2, 2.5, 0.6, 0.5, -5),\n    (13.5, 2.0, 0.5, 0.45, 10),\n    (12.5, 6.2, 0.5, 0.4, -15),    # smaller cell\n]\nfor x, y, rx, ry, angle in cell_positions:\n    draw_tumor_cell(x, y, rx, ry, angle, zorder=8)\n\n# Membrane receptors on tumor cells (small protrusions)\nfor x, y, rx, ry, angle in cell_positions:\n    for _ in range(3):\n        theta = np.random.uniform(0, 2*np.pi)\n        r = np.sqrt((rx*np.cos(theta))**2 + (ry*np.sin(theta))**2) * 1.05\n        rx_pt = x + r * np.cos(theta + angle*np.pi/180)\n        ry_pt = y + r * np.sin(theta + angle*np.pi/180) * 0.8\n        receptor = Circle((rx_pt, ry_pt), 0.04, \n                          facecolor='#F5B041', edgecolor='#D68910',\n                          linewidth=0.3, zorder=12)\n        ax.add_patch(receptor)\n\n# --- Nanoparticles accumulated in tumor (more of them) ---\nnp_positions_tumor = [\n    (9.5, 4.5), (9.8, 3.8), (10.0, 5.8), \n    (10.8, 4.2), (11.2, 2.5), (11.5, 6.0),\n    (12.5, 4.5), (13.0, 5.0), (12.8, 2.8),\n    (9.5, 1.8), (11.0, 1.5), (13.8, 3.0),\n    (10.5, 1.0), (12.2, 1.2),\n]\nfor x, y in np_positions_tumor:\n    draw_nanoparticle(x, y, radius=0.12, shell_radius=0.16, zorder=11)\n\n# --- Drug release ---\n# Nanoparticles that are \"opening\" / releasing drug\nreleasing_np = [(10.2, 3.5), (11.5, 4.8), (12.5, 5.5), (13.5, 3.5), (10.8, 2.0)]\nfor x, y in releasing_np:\n    draw_nanoparticle(x, y, radius=0.12, shell_radius=0.16, \n                       shell_color='#FAD7A0', core_color='#E67E22', zorder=11)\n    # Drug molecules diffusing out\n    for angle in np.linspace(0, 2*np.pi, 5):\n        dx = 0.25 * np.cos(angle + np.random.uniform(-0.3, 0.3))\n        dy = 0.25 * np.sin(angle + np.random.uniform(-0.3, 0.3))\n        draw_drug_molecule(x + dx, y + dy, size=0.06, zorder=16)\n    # Additional drug molecules further out\n    for angle in np.linspace(0, 2*np.pi, 3):\n        dx = 0.45 * np.cos(angle + np.random.uniform(-0.2, 0.2))\n        dy = 0.45 * np.sin(angle + np.random.uniform(-0.2, 0.2))\n        draw_drug_molecule(x + dx, y + dy, size=0.05, alpha=0.7, zorder=14)\n\n# Additional scattered drug molecules (released and diffusing)\ndrug_scatter = [(10.8, 3.0), (11.0, 4.0), (12.0, 4.0), (13.0, 4.5),\n                (11.8, 2.0), (13.8, 2.5), (10.5, 4.5), (9.8, 2.5),\n                (12.8, 3.5), (14.0, 4.8)]\nfor x, y in drug_scatter:\n    draw_drug_molecule(x, y, size=0.055, zorder=14)\n\n# --- Drug release annotation ---\n# Small arrow + label pointing to releasing NP\nrelease_label_arrow = FancyArrowPatch((10.2, 3.1), (10.2, 3.35),\n                                       arrowstyle='-|>', mutation_scale=15,\n                                       color=COLOR_DRUG, linewidth=2.0, zorder=20)\nax.add_patch(release_label_arrow)\nadd_label_box(10.2, 2.7, \"pH-responsive\\ndrug release\", \n              bg_color='#D5F5E3', edge_color=COLOR_DRUG,\n              fontsize=10, bold=True, pad=0.2)\n\n# ============================================================\n# LEGEND\n# ============================================================\nlegend_x, legend_y = 0.7, 6.6\nlegend_box = FancyBboxPatch((legend_x - 0.1, legend_y - 0.15), 3.5, 0.75,\n                             boxstyle=\"round,pad=0.1\",\n                             facecolor='white', edgecolor='#CCC',\n                             linewidth=1.0, zorder=30)\nax.add_patch(legend_box)\n\n# Legend title\nax.text(legend_x + 0.1, legend_y + 0.45, \"Legend:\", fontsize=9, \n        fontweight='bold', color='#555', zorder=31)\n\n# Nanoparticle legend\ndraw_nanoparticle(legend_x + 0.8, legend_y + 0.25, radius=0.08, shell_radius=0.11, zorder=31)\nax.text(legend_x + 1.0, legend_y + 0.25, \"Nanoparticle\", fontsize=7.5, \n        color='#555', va='center', zorder=31)\n\n# Drug legend\ndraw_drug_molecule(legend_x + 2.0, legend_y + 0.25, size=0.05, zorder=31)\nax.text(legend_x + 2.15, legend_y + 0.25, \"Drug molecule\", fontsize=7.5, \n        color='#555', va='center', zorder=31)\n\n# ============================================================\n# SECTION TITLES (top of each region)\n# ============================================================\n# Title\nax.text(7.5, 7.15, \"Graphical Abstract: Nanomedicine Targeting via EPR Effect\", \n        fontsize=16, fontweight='bold', ha='center', va='center',\n        color=COLOR_TITLE, zorder=30)\n\n# Section labels at top\nsection_labels = [\n    (2.8, 6.6, \"① Blood Circulation\", 11),\n    (7.15, 6.6, \"② Tumor Extravasation\", 11),\n    (11.7, 6.6, \"③ Intratumoral Drug Release\", 11),\n]\nfor x, y, text, fontsize in section_labels:\n    ax.text(x, y, text, fontsize=fontsize, fontweight='bold', ha='center',\n            va='center', color=COLOR_ARROW_MAIN, zorder=30)\n\n# ============================================================\n# ANNOTATIONS / CALL-OUTS within each section\n# ============================================================\n\n# --- Blood vessel annotation ---\nadd_label_box(1.0, 5.85, \"Endothelial cells\", fontsize=8, bold=False, pad=0.1)\nadd_label_box(1.0, 1.2, \"i.v. injection\", fontsize=9, bold=True, \n              bg_color='#FDEDEC', edge_color='#E74C3C', pad=0.15)\n\n# --- Tumor annotations ---\nadd_label_box(12.8, 6.65, \"Tumor cells\", fontsize=9, bold=True,\n              bg_color='#E8DAEF', edge_color=COLOR_TUMOR, pad=0.15)\n\n# --- Annotations around the figure ---\n# EPR detail\nax.annotate('Enhanced vascular permeability',\n            xy=(3.5, 1.35), xytext=(5.0, 0.8),\n            fontsize=7.5, color='#555', fontstyle='italic',\n            arrowprops=dict(arrowstyle='->', color='#999', lw=1.0),\n            zorder=25)\n\n# ============================================================\n# FINAL ADJUSTMENTS\n# ============================================================\nplt.tight_layout()\nplt.savefig('/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.png', \n            dpi=400, bbox_inches='tight', facecolor='white')\nprint(\"Saved: graphical_abstract.png\")\n\n# Also save a PDF for publication\nplt.savefig('/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.pdf', \n            bbox_inches='tight', facecolor='white')\nprint(\"Saved: graphical_abstract.pdf\")\n"})
