码\n    #   \"dummy\"            → pd.get_dummies (drop_first=True, 避免多重共线性)\n    #   None               → 不编码\n    cat_encoding: Optional[str] = \"onehot\"\n\n    # ── 列类型指定（可选）────────────────\n    #  留空则自动推断；如需手动指定，填写列名列表\n    numeric_columns: Optional[List[str]] = None   # 例: [\"age\", \"income\"]\n    categorical_columns: Optional[List[str]] = None  # 例: [\"city\", \"gender\"]\n\n    # ── 输出 ──\n    output_dir: str = \"output\"\n    output_file: str = \"feature_matrix.csv\"      # 最终特征矩阵\n    save_intermediate: bool = True                # 是否保存中间步骤结果\n\n    # ── 其他 ──\n    random_state: int = 42\n    verbose: bool = True\n\n\n# ══════════════════════════════════════════════════════════════════════════\n#  核心 Pipeline\n# ══════════════════════════════════════════════════════════════════════════\n\nclass DataPreprocessingPipeline:\n    \"\"\"多 CSV 数据清洗 + 标准化 + 编码 + 合并 Pipeline。\"\"\"\n\n    def __init__(self, cfg: Config):\n        self.cfg = cfg\n        self.scaler_obj = None          # 拟合后的 scaler\n        self.encoded_columns = None     # one-hot 后的列名\n        self.numeric_cols_detected: List[str] = []\n        self.categorical_cols_detected: List[str] = []\n\n    # ── 1. 读取 ──────────────────────────────────────────────────────────\n\n    def load_csvs(self, patterns: List[str]) -> Dict[str, pd.DataFrame]:\n        \"\"\"按 glob pattern 读取所有 CSV，返回 {文件名: DataFrame}。\"\"\"\n        csv_files = []\n        for pat in patterns:\n            csv_files.extend(sorted(glob.glob(pat)))\n\n        if not csv_files:\n            log.error(\"未找到任何 CSV 文件，请检查路径: %s\", patterns)\n            sys.exit(1)\n\n        log.info(\"找到 %d 个 CSV 文件\", len(csv_files))\n        dataframes: Dict[str, pd.DataFrame] = {}\n        for fp in csv_files:\n            name = os.path.splitext(os.path.basename(fp))[0]\n            try:\n                df = pd.read_csv(fp)\n                log.info(\"  ✓ %s  →  %d 行 × %d 列\", name, df.shape[0], df.shape[1])\n                dataframes[name] = df\n            except Exception as e:\n                log.warning(\"  ✗ %s 读取失败: %s\", fp, e)\n        return dataframes\n\n    # ── 2. 列类型推断 ───────────────────────────────────────────────────\n\n    def _infer_column_types(self, df: pd.DataFrame) -> Tuple[List[str], List[str]]:\n        \"\"\"自动推断数值列与分类列（也可通过 Config 手动指定）。\"\"\"\n        if self.cfg.numeric_columns and self.cfg.categorical_columns:\n            return self.cfg.numeric_columns, self.cfg.categorical_columns\n\n        numeric_cols = []\n        categorical_cols = []\n\n        for col in df.columns:\n            # 用户手动指定的优先级最高\n            if self.cfg.numeric_columns and col in self.cfg.numeric_columns:\n                numeric_cols.append(col)\n                continue\n            if self.cfg.categorical_columns and col in self.cfg.categorical_columns:\n                categorical_cols.append(col)\n                continue\n\n            # 自动推断\n            if pd.api.types.is_numeric_dtype(df[col]):\n                if df[col].nunique() < 10:   # 少类别整数 → 视为分类\n                    categorical_cols.append(col)\n                else:\n                    numeric_cols.append(col)\n            else:\n                categorical_cols.append(col)\n\n        return numeric_cols, categorical_cols\n\n    # ── 3. 缺失值处理 ────────────────────────────────────────────────────\n\n    def handle_missing_values(self, df: pd.DataFrame) -> pd.DataFrame:\n        \"\"\"根据配置策略处理缺失值。\"\"\"\n        cfg = self.cfg\n        df = df.copy()\n        before = df.isnull().sum().sum()\n\n        # 策略 1: 删除缺失率过高的列\n        if cfg.na_strategy_num == \"drop_col\" or cfg.na_strategy_cat == \"drop_col\":\n            high_miss = df.columns[df.isnull().mean() > cfg.na_drop_col_threshold]\n            if len(high_miss):\n                log.info(\"  删除缺失率 > %.0f%% 的列: %s\",\n                         cfg.na_drop_col_threshold * 100, list(high_miss))\n                df.drop(columns=high_miss, inplace=True)\n\n        # 重新推断列类型（删除列后）\n        num_cols, cat_cols = self._infer_column_types(df)\n\n        # 策略 2: 按行删除\n        if cfg.na_strategy_num == \"drop_row\" or cfg.na_strategy_cat == \"drop_row\":\n            df.dropna(inplace=True)\n            log.info(\"  删除含缺失的行 → 剩余 %d 行\", len(df))\n            after = df.isnull().sum().sum()\n            log.info(\"  缺失值: %d → %d (处理了 %d 个)\", before, after, before - after)\n            return df\n\n        # 策略 3: 填充\n        # 数值列\n        for col in num_cols:\n            if df[col].isnull().sum() == 0:\n                continue\n            if cfg.na_strategy_num == \"fill_mean\":\n                df[col].fillna(df[col].mean(), inplace=True)\n            elif cfg.na_strategy_num == \"fill_median\":\n                df[col].fillna(df[col].median(), inplace=True)\n            elif cfg.na_strategy_num == \"fill_mode\":\n                mode_val = df[col].mode()\n                if not mode_val.empty:\n                    df[col].fillna(mode_val[0], inplace=True)\n            elif cfg.na_strategy_num == \"fill_const\":\n                df[col].fillna(cfg.na_fill_constant, inplace=True)\n\n        # 分类列\n        for col in cat_cols:\n            if df[col].isnull().sum() == 0:\n                continue\n            if cfg.na_strategy_cat == \"fill_mode\":\n                mode_val = df[col].mode()\n                if not mode_val.empty:\n                    df[col].fillna(mode_val[0], inplace=True)\n            elif cfg.na_strategy_cat == \"fill_const\":\n                df[col].fillna(cfg.na_fill_constant, inplace=True)\n            elif cfg.na_strategy_cat in (\"fill_mean\", \"fill_median\"):\n                log.warning(\"  分类列 '%s' 不能用 mean/median 填充，改用 mode\", col)\n                mode_val = df[col].mode()\n                if not mode_val.empty:\n                    df[col].fillna(mode_val[0], inplace=True)\n\n        after = df.isnull().sum().sum()\n        log.info(\"  缺失值: %d → %d (处理了 %d 个)\", before, after, before - after)\n        return df\n\n    # ── 4. 标准化数值列 ─────────────────────────────────────────────────\n\n    def scale_numeric(self, df: pd.DataFrame) -> pd.DataFrame:\n        \"\"\"对数值列做标准化，并记录 scaler 对象供后续复用。\"\"\"\n        if self.cfg.scaler is None:\n            return df\n\n        df = df.copy()\n        num_cols, _ = self._infer_column_types(df)\n        # 只选真正有数值类型的列\n        num_cols = [c for c in num_cols if pd.api.types.is_numeric_dtype(df[c])]\n        if not num_cols:\n            return df\n\n        scaler_map = {\n            \"standard\": StandardScaler,\n            \"minmax\": MinMaxScaler,\n            \"robust\": RobustScaler,\n        }\n        ScalerClass = scaler_map.get(self.cfg.scaler)\n        if ScalerClass is None:\n            log.warning(\"  未知的 scaler: %s，跳过标准化\", self.cfg.scaler)\n            return df\n\n        self.scaler_obj = ScalerClass()\n        scaled_values = self.scaler_obj.fit_transform(df[num_cols])\n        df[num_cols] = scaled_values\n        log.info(\"  数值列标准化完成 (scaler=%s): %s\", self.cfg.scaler, num_cols)\n        return df\n\n    # ── 5. 分类变量编码 ─────────────────────────────────────────────────\n\n    def encode_categorical(self, df: pd.DataFrame) -> pd.DataFrame:\n        \"\"\"对分类列做 One-hot / Dummy 编码。\"\"\"\n        cfg = self.cfg\n        if cfg.cat_encoding is None:\n            return df\n\n        df = df.copy()\n        _, cat_cols = self._infer_column_types(df)\n        # 过滤掉已不是 object 类型的（可能已被填充改变）\n        cat_cols = [c for c in cat_cols if df[c].dtype in (\"object\", \"category\", \"bool\")\n                    or pd.api.types.is_categorical_dtype(df[c])]\n\n        if not cat_cols:\n            return df\n\n        if cfg.cat_encoding == \"onehot\":\n            encoded = pd.get_dummies(df[cat_cols], prefix=cat_cols, drop_first=False)\n            self.encoded_columns = encoded.columns.tolist()\n            df = pd.concat([df.drop(columns=cat_cols), encoded], axis=1)\n            log.info(\"  One-hot 编码 %d 个分类列 → %d 个哑变量列\",\n                     len(cat_cols), len(self.encoded_columns))\n\n        elif cfg.cat_encoding == \"dummy\":\n            encoded = pd.get_dummies(df[cat_cols], prefix=cat_cols, drop_first=True)\n            self.encoded_columns = encoded.columns.tolist()\n            df = pd.concat([df.drop(columns=cat_cols), encoded], axis=1)\n            log.info(\"  Dummy 编码 %d 个分类列 → %d 个哑变量列 (drop_first)\",\n                     len(cat_cols), len(self.encoded_columns))\n\n        return df\n\n    # ── 6. 合并多个 DataFrame ───────────────────────────────────────────\n\n    def merge_dataframes(self, dfs: Dict[str, pd.DataFrame]) -> pd.DataFrame:\n        \"\"\"\n        将多个 DataFrame 合并为一个。\n        策略: 按 index 外连接（保留所有行），新增 \"source_file\" 列标记来源。\n        \"\"\"\n        names = list(dfs.keys())\n        if not names:\n            log.error(\"没有可合并的 DataFrame\")\n            sys.exit(1)\n\n        if len(names) == 1:\n            result = dfs[names[0]].copy()\n            result.insert(0, \"source_file\", names[0])\n            log.info(\"  仅一个文件，直接返回\")\n            return result\n\n        # 合并: 外连接，缺失补 0（更常见的场景）\n        log.info(\"  合并 %d 个文件，连接方式: outer\", len(names))\n        processed = []\n        for name in names:\n            df = dfs[name].copy()\n            df.insert(0, \"source_file\", name)\n            processed.append(df)\n\n        merged = pd.concat(processed, ignore_index=True)\n        merged.fillna(0, inplace=True)\n        log.info(\"  合并后: %d 行 × %d 列\", merged.shape[0], merged.shape[1])\n        return merged\n\n    # ── 7. 完整流程 ─────────────────────────────────────────────────────\n\n    def run(self) -> pd.DataFrame:\n        \"\"\"执行完整 pipeline，返回最终特征矩阵。\"\"\"\n        log.info(\"=\" * 55)\n        log.info(\"  数据预处理 Pipeline 启动\")\n        log.info(\"=\" * 55)\n\n        # 1. 读取\n        raw_dfs = self.load_csvs(self.cfg.csv_patterns)\n        if self.cfg.save_intermediate:\n            os.makedirs(self.cfg.output_dir, exist_ok=True)\n\n        # 2. 逐文件清洗\n        cleaned_dfs: Dict[str, pd.DataFrame] = {}\n        for name, df in raw_dfs.items():\n            log.info(\"── 处理文件: %s ──\", name)\n            log.info(\"  原始: %d 行 × %d 列\", df.shape[0], df.shape[1])\n\n            df = self.handle_missing_values(df)\n            df = self.scale_numeric(df)\n            df = self.encode_categorical(df)\n\n            cleaned_dfs[name] = df\n\n            if self.cfg.save_intermediate:\n                df.to_csv(os.path.join(self.cfg.output_dir, f\"cleaned_{name}.csv\"), index=False)\n                log.info(\"  中间结果已保存: cleaned_%s.csv\", name)\n\n            log.info(\"  清洗后: %d 行 × %d 列\\n\", df.shape[0], df.shape[1])\n\n        # 3. 合并\n        log.info(\"── 合并特征矩阵 ──\")\n        final_df = self.merge_dataframes(cleaned_dfs)\n\n        # 4. 保存最终结果\n        os.makedirs(self.cfg.output_dir, exist_ok=True)\n        out_path = os.path.join(self.cfg.output_dir, self.cfg.output_file)\n        final_df.to_csv(out_path, index=False)\n        log.info(\"  最终特征矩阵已保存: %s  (%d 行 × %d 列)\",\n                 out_path, final_df.shape[0], final_df.shape[1])\n\n        # 5. 简单摘要\n        log.info(\"\\n\" + \"=\" * 55)\n        log.info(\"  Pipeline 完成\")\n        log.info(\"  ┌ %s\", \"─\" * 45)\n        log.info(\"  │ 最终特征矩阵: %d 行 × %d 列\", final_df.shape[0], final_df.shape[1])\n        log.info(\"  │ 数值列数: %d\", len(final_df.select_dtypes(include=[np.number]).columns))\n        log.info(\"  │ 来源文件数: %d\", len(raw_dfs))\n        if self.scaler_obj is not None:\n            log.info(\"  │ Scaler: %s (拟合完毕)\", type(self.scaler_obj).__name__)\n        log.info(\"  └ %s\", \"─\" * 45)\n        log.info(\"=\" * 55)\n\n        return final_df\n\n\n# ══════════════════════════════════════════════════════════════════════════\n#  快捷函数: 一次调用全部\n# ══════════════════════════════════════════════════════════════════════════\n\ndef run_pipeline(cfg: Optional[Config] = None) -> pd.DataFrame:\n    \"\"\"便捷入口函数。\"\"\"\n    if cfg is None:\n        cfg = Config()\n    pipeline = DataPreprocessingPipeline(cfg)\n    return pipeline.run()\n\n\n# ══════════════════════════════════════════════════════════════════════════\n#  入口\n# ══════════════════════════════════════════════════════════════════════════\n\nif __name__ == \"__main__\":\n    feature_matrix = run_pipeline()\n    print(\"\\n特征矩阵预览 (前 5 行):\")\n    print(feature_matrix.head())\n"})
