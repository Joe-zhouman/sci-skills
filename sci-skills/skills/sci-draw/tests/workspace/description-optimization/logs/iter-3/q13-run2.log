TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/draw_nn_arch.py", "content": "#!/usr/bin/env python3\n\"\"\"\nNeural Network Architecture Diagram\nLSTM with skip connections and dropout notation.\n\"\"\"\n\nimport matplotlib\nmatplotlib.use(\"Agg\")  # headless\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.path import Path\nimport numpy as np\n\n# ---------- style ----------\nplt.rcParams.update({\n    \"font.family\": [\"Noto Sans CJK JP\", \"DejaVu Sans\"],\n    \"font.size\": 11,\n    \"axes.facecolor\": \"white\",\n    \"figure.facecolor\": \"white\",\n})\n\n# ---------- layer definitions ----------\n# (label, width, height, color)\nlayers = [\n    (\"256\", 1.8, 0.6, \"#4A90D9\"),     # Input embedding\n    (\"128\", 1.4, 0.6, \"#E67E22\"),     # LSTM 1\n    (\"64\",  1.0, 0.6, \"#27AE60\"),     # LSTM 2\n    (\"32\",  0.8, 0.6, \"#8E44AD\"),     # LSTM 3\n    (\"softmax\\noutput\", 1.2, 0.6, \"#C0392B\"),  # Output\n]\n\n# y positions (centers) — stack from bottom up with spacing\nlayer_gap = 1.3\nn = len(layers)\nstart_y = 1.2\ny_centers = [start_y + i * layer_gap for i in range(n)]\n# reverse so input is at bottom\ny_centers = y_centers[::-1]\nx_center = 0\n\n# ---------- figure setup ----------\nfig, ax = plt.subplots(figsize=(7, 7.2))\nax.set_xlim(-3.5, 4.5)\nax.set_ylim(0, start_y + n * layer_gap + 0.3)\nax.axis(\"off\")\n\n# ---------- draw layer blocks ----------\n# horizontal \"input flow\" lines between layers: trace through mid-left → mid-right\nfor i, (label, w, h, color) in enumerate(layers):\n    x = x_center - w / 2\n    y = y_centers[i] - h / 2\n    rect = mpatches.FancyBboxPatch(\n        (x, y), w, h,\n        boxstyle=\"round,pad=0.06\",\n        facecolor=color,\n        edgecolor=\"white\",\n        linewidth=2,\n        alpha=0.92,\n        zorder=3,\n    )\n    ax.add_patch(rect)\n\n    # dimension label inside block\n    if i == 0:\n        display = f\"Embedding\\n{label}d\"\n    elif i == n - 1:\n        display = f\"Softmax\\n({label})\"\n    else:\n        display = f\"LSTM\\n{label}d\"\n    ax.text(\n        x_center, y_centers[i], display,\n        ha=\"center\", va=\"center\",\n        color=\"white\", fontweight=\"bold\", fontsize=9,\n        zorder=4,\n    )\n\n# ---------- draw main sequence arrows between layers ----------\nfor i in range(n - 1):\n    y0 = y_centers[i]\n    y1 = y_centers[i + 1]\n    ax.annotate(\n        \"\", xy=(x_center, y1 + layers[i + 1][2] / 2),\n        xytext=(x_center, y0 - layers[i][2] / 2),\n        arrowprops=dict(arrowstyle=\"->\", color=\"#555555\", lw=2.2, shrinkA=0, shrinkB=0),\n    )\n\n# ---------- skip connections (dashed arrows on the right side) ----------\nskip_color = \"#E74C3C\"\nskip_x = x_center + 1.2  # arrow starts here (right of blocks)\n# We'll do diagonal arrows: input(256) -> LSTM64, input(256) -> LSTM32,\n#                       LSTM128 -> LSTM32\nskip_pairs = [\n    (0, 2, \"skip\"),   # 256 -> 64\n    (0, 3, \"skip\"),   # 256 -> 32\n    (1, 3, \"skip\"),   # 128 -> 32\n]\n\nfor src, dst, label in skip_pairs:\n    y_src = y_centers[src]\n    y_dst = y_centers[dst]\n    h_src = layers[src][2]\n    h_dst = layers[dst][2]\n\n    # start from right edge of source, go to right edge of destination\n    x_start = skip_x\n    x_end = skip_x\n    y_start = y_src\n    y_end = y_dst\n\n    # use a curved path so lines don't overlap\n    # control point offset to the right\n    ctrl_offset = 0.5\n    verts = [\n        (x_start, y_start),                             # start\n        (x_start + ctrl_offset, y_start),               # control 1\n        (x_end + ctrl_offset, y_end),                   # control 2\n        (x_end, y_end),                                 # end\n    ]\n    codes = [Path.MOVETO, Path.CURVE4, Path.CURVE4, Path.CURVE4]\n    path = Path(verts, codes)\n    patch = mpatches.PathPatch(\n        path, facecolor=\"none\", edgecolor=skip_color,\n        linestyle=\"dashed\", linewidth=1.8, zorder=2,\n    )\n    ax.add_patch(patch)\n\n    # arrowhead: tiny triangle at end\n    dx = x_end - (x_end + ctrl_offset)  # negative\n    dy = y_end - (y_start + ctrl_offset * (y_end - y_start) / (ctrl_offset * 2 if ctrl_offset else 1))\n    # easier: just use annotate with arrow on the path... or add a manual triangle\n    ax.plot(x_end, y_end, marker=3, color=skip_color, markersize=6, zorder=3)\n\n# Add a legend-style label for skip connections\nax.text(\n    skip_x + 0.8, y_centers[2],\n    \"skip\\nconnection\",\n    color=skip_color, fontsize=7.5, fontstyle=\"italic\",\n    ha=\"left\", va=\"center\",\n    bbox=dict(boxstyle=\"round,pad=0.2\", facecolor=\"white\", edgecolor=skip_color, alpha=0.8),\n)\n\n# ---------- dropout rate annotations (on the left side) ----------\ndropout_color = \"#2C3E50\"\ndropout_x = x_center - 2.5\ndropout_rates = [\"\", \"Dropout=0.3\", \"Dropout=0.3\", \"Dropout=0.2\", \"\"]  # no dropout on input/output\n\nfor i, (label, w, h, color) in enumerate(layers):\n    rate = dropout_rates[i]\n    if rate:\n        # arrow from text to block\n        ax.annotate(\n            rate,\n            xy=(x_center - w / 2, y_centers[i]),\n            xytext=(dropout_x, y_centers[i]),\n            ha=\"right\", va=\"center\",\n            fontsize=8.5, color=dropout_color,\n            fontweight=\"bold\",\n            arrowprops=dict(\n                arrowstyle=\"->\", color=dropout_color, lw=1.2,\n                connectionstyle=\"arc3,rad=0\",\n            ),\n            bbox=dict(boxstyle=\"round,pad=0.25\", facecolor=\"#F0F0F0\", edgecolor=dropout_color, alpha=0.85),\n        )\n\n# ---------- additional labels ----------\n# Input arrow from below\nax.annotate(\n    \"\", xy=(x_center, y_centers[0] - layers[0][2] / 2),\n    xytext=(x_center, y_centers[0] - layers[0][2] / 2 - 0.4),\n    arrowprops=dict(arrowstyle=\"->\", color=\"#555555\", lw=2.2, shrinkA=0, shrinkB=0),\n)\nax.text(\n    x_center, y_centers[0] - layers[0][2] / 2 - 0.65,\n    \"Input Sequence\", ha=\"center\", va=\"center\",\n    fontsize=9, color=\"#555555\", fontstyle=\"italic\",\n)\n\n# Output arrow above\nax.annotate(\n    \"\", xy=(x_center, y_centers[-1] + layers[-1][2] / 2 + 0.4),\n    xytext=(x_center, y_centers[-1] + layers[-1][2] / 2),\n    arrowprops=dict(arrowstyle=\"->\", color=\"#555555\", lw=2.2, shrinkA=0, shrinkB=0),\n)\nax.text(\n    x_center, y_centers[-1] + layers[-1][2] / 2 + 0.65,\n    \"Output Distribution\", ha=\"center\", va=\"center\",\n    fontsize=9, color=\"#555555\", fontstyle=\"italic\",\n)\n\n# ---------- title ----------\nax.text(\n    0, y_centers[-1] + 1.4,\n    \"LSTM Neural Network Architecture\\nwith Skip Connections & Dropout\",\n    ha=\"center\", va=\"center\", fontsize=14, fontweight=\"bold\",\n    color=\"#1a1a1a\",\n)\n\n# ---------- save ----------\nout_path = \"/home/joe/Documents/repo/skill/sci-draw/nn_architecture.png\"\nfig.savefig(out_path, dpi=200, bbox_inches=\"tight\", pad_inches=0.2)\nplt.close(fig)\nprint(f\"Diagram saved to {out_path}\")\n"})
