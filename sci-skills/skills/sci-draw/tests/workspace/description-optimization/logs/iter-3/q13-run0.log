TOOL_USE: Bash({"command": "cat > /home/joe/Documents/repo/skill/sci-draw/nn_arch.py << 'PYEOF'\n#!/usr/bin/env python3\n\"\"\"Draw a neural network architecture diagram: Embedding -> LSTMx3 -> Softmax with skip connections.\"\"\"\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.patches import FancyBboxPatch\n\nplt.rcParams.update({\n    \"font.family\": \"sans-serif\",\n    \"font.sans-serif\": [\"DejaVu Sans\", \"Arial\"],\n    \"font.size\": 12,\n    \"axes.facecolor\": \"#FAFAFA\",\n    \"figure.facecolor\": \"white\",\n})\n\nDARK = \"#2D2D2D\"\n\nCOLORS = {\n    \"input\":   \"#66BB6A\",\n    \"lstm1\":   \"#42A5F5\",\n    \"lstm2\":   \"#FFA726\",\n    \"lstm3\":   \"#AB47BC\",\n    \"output\":  \"#EF5350\",\n    \"skip\":    \"#78909C\",\n    \"dropout\": \"#EC407A\",\n    \"arrow\":   \"#616161\",\n}\n\nlayers = [\n    {\"label\": \"Embedding\\n256-d\",  \"color\": COLORS[\"input\"], \"dim\": \"(256,)\", \"x\": 1.5,  \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n    {\"label\": \"LSTM\\n128\",         \"color\": COLORS[\"lstm1\"], \"dim\": \"(128,)\", \"x\": 4.0,  \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n    {\"label\": \"LSTM\\n64\",          \"color\": COLORS[\"lstm2\"], \"dim\": \"(64,)\",  \"x\": 6.5,  \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n    {\"label\": \"LSTM\\n32\",          \"color\": COLORS[\"lstm3\"], \"dim\": \"(32,)\",  \"x\": 9.0,  \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n    {\"label\": \"Softmax\\nOutput\",   \"color\": COLORS[\"output\"],\"dim\": \"n_cls\",  \"x\": 11.5, \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n]\n\ndropouts = [\n    {\"rate\": \"Dropout = 0.3\", \"x\": 4.0,  \"y\": 3.2},\n    {\"rate\": \"Dropout = 0.3\", \"x\": 6.5,  \"y\": 3.2},\n    {\"rate\": \"Dropout = 0.2\", \"x\": 9.0,  \"y\": 3.2},\n]\n\nskip_conns = [\n    (0, 2), (0, 3), (1, 3), (1, 4), (2, 4),\n]\n\n\ndef rounded_rect(ax, x, y, w, h, color, label, dim_text):\n    box = FancyBboxPatch(\n        (x - w/2, y - h/2), w, h,\n        boxstyle=\"round,pad=0.12,rounding_size=0.15\",\n        facecolor=color, edgecolor=DARK, linewidth=2, zorder=5,\n    )\n    ax.add_patch(box)\n    ax.text(x, y + 0.05, label, ha=\"center\", va=\"center\",\n            fontsize=13, fontweight=\"bold\", color=\"white\", zorder=6)\n    ax.text(x, y - h/2 - 0.30, dim_text, ha=\"center\", va=\"top\",\n            fontsize=11, color=DARK, style=\"italic\", zorder=6)\n\n\ndef draw_arrow(ax, x1, y1, x2, y2, color, lw=2.5):\n    ax.annotate(\n        \"\", xy=(x2, y2), xytext=(x1, y1),\n        arrowprops=dict(arrowstyle=\"->\", color=color, lw=lw,\n                        linestyle=\"-\", connectionstyle=\"arc3,rad=0\"),\n        zorder=4,\n    )\n\n\ndef draw_skip(ax, x1, y1, x2, y2, color, lw=1.8):\n    sx, sy = x1 + 0.8, y1 + 0.1\n    ex, ey = x2 - 0.8, y2 + 0.1\n    ax.annotate(\n        \"\", xy=(ex, ey), xytext=(sx, sy),\n        arrowprops=dict(arrowstyle=\"->\", color=color, lw=lw,\n                        linestyle=\"dashed\",\n                        connectionstyle=\"arc3,rad=0.25\"),\n        zorder=3,\n    )\n\n\nfig, ax = plt.subplots(1, 1, figsize=(16, 10))\n\nfor L in layers:\n    rounded_rect(ax, L[\"x\"], L[\"y\"], L[\"w\"], L[\"h\"], L[\"color\"], L[\"label\"], L[\"dim\"])\n\nfor i in range(len(layers) - 1):\n    l, r = layers[i], layers[i + 1]\n    draw_arrow(ax, l[\"x\"] + l[\"w\"]/2, l[\"y\"], r[\"x\"] - r[\"w\"]/2, r[\"y\"], COLORS[\"arrow\"], lw=3)\n\nfor src, dst in skip_conns:\n    draw_skip(ax, layers[src][\"x\"] + layers[src][\"w\"]/2, layers[src][\"y\"],\n              layers[dst][\"x\"] - layers[dst][\"w\"]/2, layers[dst][\"y\"], COLORS[\"skip\"])\n\nfor d in dropouts:\n    bbox = dict(facecolor=COLORS[\"dropout\"], edgecolor=DARK,\n                boxstyle=\"round,pad=0.3\", linewidth=1.2)\n    ax.text(d[\"x\"], d[\"y\"], d[\"rate\"], ha=\"center\", va=\"center\",\n            fontsize=10, fontweight=\"bold\", color=\"white\", bbox=bbox, zorder=7)\n\nleg_elements = [\n    mpatches.Patch(color=COLORS[\"arrow\"],   label=\"Forward connection\"),\n    mpatches.Patch(color=COLORS[\"skip\"],    label=\"Skip connection\"),\n    mpatches.Patch(color=COLORS[\"dropout\"], label=\"Dropout\"),\n]\nlegend = ax.legend(handles=leg_elements, loc=\"lower center\", ncol=3,\n                   framealpha=0.9, edgecolor=DARK, fontsize=11)\nlegend.get_frame().set_boxstyle(\"round,pad=0.4\")\n\nax.set_title(\n    \"LSTM-based Neural Network Architecture\\n\"\n    \"with Skip Connections and Dropout\",\n    fontsize=18, fontweight=\"bold\", pad=20, color=DARK,\n)\n\nax.set_xlim(0, 14)\nax.set_ylim(1.5, 8)\nax.axis(\"off\")\n\nplt.tight_layout()\nout = \"/home/joe/Documents/repo/skill/sci-draw/nn_architecture.png\"\nplt.savefig(out, dpi=200, bbox_inches=\"tight\")\nprint(f\"Saved to {out}\")\nplt.close()\nPYEOF\necho \"Script written successfully\"", "description": "Write NN architecture diagram Python script"})
