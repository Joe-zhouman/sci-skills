TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/nn_arch.py", "content": "#!/usr/bin/env python3\n\"\"\"Draw a neural network architecture diagram: Embedding → LSTM×3 → Softmax with skip connections.\"\"\"\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.patches import FancyBboxPatch\n\n# ---------------------------------------------------------------------------\n# Styling\n# ---------------------------------------------------------------------------\nplt.rcParams.update({\n    \"font.family\": \"sans-serif\",\n    \"font.sans-serif\": [\"DejaVu Sans\", \"Arial\"],\n    \"font.size\": 12,\n    \"axes.facecolor\": \"#FAFAFA\",\n    \"figure.facecolor\": \"white\",\n})\n\nDARK = \"#2D2D2D\"\nDIMS = {\"width\": 16, \"height\": 10}\n\nCOLORS = {\n    \"input\":    \"#66BB6A\",   # green\n    \"lstm1\":    \"#42A5F5\",   # blue\n    \"lstm2\":    \"#FFA726\",   # orange\n    \"lstm3\":    \"#AB47BC\",   # purple\n    \"output\":   \"#EF5350\",   # red\n    \"skip\":     \"#78909C\",   # blue-grey\n    \"dropout\":  \"#EC407A\",   # pink\n    \"arrow\":    \"#616161\",\n    \"bg\":       \"#FAFAFA\",\n}\n\n# ---------------------------------------------------------------------------\n# Layer definitions\n# ---------------------------------------------------------------------------\n# x, y are the CENTER of each layer block\nlayers = [\n    {\"label\": \"Embedding\\n256-d\",  \"color\": COLORS[\"input\"],  \"dim\": \"(256,)\",    \"x\": 1.5,  \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n    {\"label\": \"LSTM\\n128\",         \"color\": COLORS[\"lstm1\"],  \"dim\": \"(128,)\",    \"x\": 4.0,  \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n    {\"label\": \"LSTM\\n64\",          \"color\": COLORS[\"lstm2\"],  \"dim\": \"(64,)\",     \"x\": 6.5,  \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n    {\"label\": \"LSTM\\n32\",          \"color\": COLORS[\"lstm3\"],  \"dim\": \"(32,)\",     \"x\": 9.0,  \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n    {\"label\": \"Softmax\\nOutput\",   \"color\": COLORS[\"output\"], \"dim\": \"n_classes\", \"x\": 11.5, \"y\": 5.0, \"w\": 1.6, \"h\": 1.4},\n]\n\n# Dropout annotations attached to specific layers (after LSTM layers)\ndropouts = [\n    {\"rate\": \"Dropout = 0.3\", \"layer_idx\": 1, \"x\": 4.0,  \"y\": 3.2},\n    {\"rate\": \"Dropout = 0.3\", \"layer_idx\": 2, \"x\": 6.5,  \"y\": 3.2},\n    {\"rate\": \"Dropout = 0.2\", \"layer_idx\": 3, \"x\": 9.0,  \"y\": 3.2},\n]\n\n# Skip connections: (from_layer_idx, to_layer_idx)\nskip_conns = [\n    (0, 2),   # Embedding → LSTM-64\n    (0, 3),   # Embedding → LSTM-32\n    (1, 3),   # LSTM-128 → LSTM-32\n    (1, 4),   # LSTM-128 → Softmax\n    (2, 4),   # LSTM-64 → Softmax\n]\n\n\ndef rounded_rect(ax, x, y, w, h, color, label, dim_text):\n    \"\"\"Draw a rounded rectangle with label and dimension below.\"\"\"\n    # main block\n    box = FancyBboxPatch(\n        (x - w / 2, y - h / 2), w, h,\n        boxstyle=\"round,pad=0.12,rounding_size=0.15\",\n        facecolor=color, edgecolor=DARK, linewidth=2, zorder=5,\n    )\n    ax.add_patch(box)\n    # layer name inside\n    ax.text(x, y + 0.05, label, ha=\"center\", va=\"center\",\n            fontsize=13, fontweight=\"bold\", color=\"white\", zorder=6)\n    # dimension below\n    ax.text(x, y - h / 2 - 0.30, dim_text, ha=\"center\", va=\"top\",\n            fontsize=11, color=DARK, style=\"italic\", zorder=6)\n\n\ndef draw_arrow(ax, x1, y1, x2, y2, color, lw=2.5, style=\"-\"):\n    \"\"\"Arrow from (x1,y1) to (x2,y2).\"\"\"\n    dx, dy = x2 - x1, y2 - y1\n    ax.annotate(\n        \"\", xy=(x2, y2), xytext=(x1, y1),\n        arrowprops=dict(\n            arrowstyle=\"->\", color=color, lw=lw,\n            linestyle=style, connectionstyle=\"arc3,rad=0\",\n        ),\n        zorder=4,\n    )\n\n\ndef draw_skip(ax, x1, y1, x2, y2, color, lw=1.8):\n    \"\"\"Dashed curved arrow for skip connections.\"\"\"\n    # shift start/end to the right/left edges\n    start_x = x1 + 0.8\n    end_x = x2 - 0.8\n    mid_x = (start_x + end_x) / 2\n    # slight arc\n    ax.annotate(\n        \"\", xy=(end_x, y2), xytext=(start_x, y1),\n        arrowprops=dict(\n            arrowstyle=\"->\", color=color, lw=lw,\n            linestyle=\"dashed\", connectionstyle=f\"arc3,rad=0.25\",\n        ),\n        zorder=3,\n    )\n\n\n# ---------------------------------------------------------------------------\n# Build figure\n# ---------------------------------------------------------------------------\nfig, ax = plt.subplots(1, 1, figsize=(DIMS[\"width\"], DIMS[\"height\"]))\n\n# Draw layers\nfor L in layers:\n    rounded_rect(ax, L[\"x\"], L[\"y\"], L[\"w\"], L[\"h\"], L[\"color\"], L[\"label\"], L[\"dim\"])\n\n# Draw main sequential arrows (left → right between layers)\nfor i in range(len(layers) - 1):\n    l = layers[i]\n    r = layers[i + 1]\n    draw_arrow(ax, l[\"x\"] + l[\"w\"] / 2, l[\"y\"], r[\"x\"] - r[\"w\"] / 2, r[\"y\"],\n               COLORS[\"arrow\"], lw=3)\n\n# Draw skip connections\nfor src, dst in skip_conns:\n    draw_skip(ax,\n              layers[src][\"x\"] + layers[src][\"w\"] / 2,\n              layers[src][\"y\"] + 0.1,\n              layers[dst][\"x\"] - layers[dst][\"w\"] / 2,\n              layers[dst][\"y\"] + 0.1,\n              COLORS[\"skip\"])\n\n# Dropout labels (small badge under each LSTM layer)\nfor d in dropouts:\n    bbox_props = dict(\n        facecolor=COLORS[\"dropout\"], edgecolor=DARK,\n        boxstyle=\"round,pad=0.3\", linewidth=1.2,\n    )\n    ax.text(d[\"x\"], d[\"y\"], d[\"rate\"], ha=\"center\", va=\"center\",\n            fontsize=10, fontweight=\"bold\", color=\"white\", bbox=bbox_props,\n            zorder=7)\n\n# Legend\nlegend_elements = [\n    mpatches.Patch(color=COLORS[\"arrow\"], label=\"Forward connection\"),\n    mpatches.Patch(color=COLORS[\"skip\"], label=\"Skip connection\"),\n    mpatches.Patch(color=COLORS[\"dropout\"], label=\"Dropout\"),\n]\nlegend = ax.legend(\n    handles=legend_elements, loc=\"lower center\",\n    ncol=3, framealpha=0.9, edgecolor=DARK,\n    fontsize=11,\n)\nlegend.get_frame().set_boxstyle(\"round,pad=0.4\")\n\n# Title\nax.set_title(\n    \"LSTM-based Neural Network Architecture\\n\"\n    \"with Skip Connections and Dropout\",\n    fontsize=18, fontweight=\"bold\", pad=20, color=DARK,\n)\n\n# Clean up axes\nax.set_xlim(0, 14)\nax.set_ylim(1.5, 8)\nax.axis(\"off\")\n\nplt.tight_layout()\nout = \"/home/joe/Documents/repo/skill/sci-draw/nn_architecture.png\"\nplt.savefig(out, dpi=200, bbox_inches=\"tight\")\nprint(f\"Saved to {out}\")\nplt.close()\n"})
