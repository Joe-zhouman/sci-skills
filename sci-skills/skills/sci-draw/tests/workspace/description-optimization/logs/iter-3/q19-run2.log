TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\n数据预处理 Pipeline：读取多个 CSV → 清洗 → 标准化 → 编码 → 合并为特征矩阵。\n\n用法:\n    python data_pipeline.py                     # 使用默认配置\n    python data_pipeline.py --config config.json # 自定义配置\n    python data_pipeline.py --csv data/*.csv     # 指定输入文件\n\"\"\"\n\nimport os, sys, re, json, logging, argparse\nfrom pathlib import Path\nfrom typing import Optional\nimport pandas as pd\nimport numpy as np\nfrom sklearn.preprocessing import StandardScaler, MinMaxScaler, RobustScaler, OneHotEncoder\nfrom sklearn.impute import SimpleImputer\n\n# ── 日志 ──────────────────────────────────────────────────────────────────\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(levelname)s] %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"pipeline\")\n\n# ── 配置结构 ──────────────────────────────────────────────────────────────\nDEFAULT_CONFIG = {\n    # CSV 输入\n    \"csv_pattern\": \"data/*.csv\",        # glob 模式，或显式文件列表\n    \"csv_files\": [],                    # 显式列表（优先级高于 pattern）\n    \"read_kwargs\": {                    # 传给 pd.read_csv 的参数\n        \"encoding\": \"utf-8\",\n        \"low_memory\": False,\n    },\n\n    # 缺失值处理\n    \"missing_strategy\": {\n        \"numeric\": \"median\",            # mean / median / most_frequent / constant\n        \"categorical\": \"most_frequent\", # most_frequent / constant / drop\n        \"constant_fill\": 0,             # missing_strategy = constant 时的填充值\n        \"max_missing_ratio\": 0.8,       # 缺失率超过此值的列被丢弃\n    },\n\n    # 数值标准化\n    \"scaler\": \"standard\",               # standard / minmax / robust / None（不做）\n    \"scale_per_column\": True,           # False = 只对全体数值列统一 fit（不常用）\n\n    # 分类编码\n    \"encoding\": \"onehot\",               # onehot / dummy / None\n    \"drop_first\": False,                # dummy 模式下是否 drop_first\n    \"max_categories\": 50,               # 唯一值超过此数量时不编码（视为高基数）\n    \"min_categories\": 2,                # 唯一值少于 2 的列是常量列，直接丢弃\n\n    # 合并\n    \"merge\": \"concat\",                  # concat / merge_by_id\n    \"merge_id\": \"id\",                   # merge_by_id 时使用的列名\n    \"merge_how\": \"outer\",               # inner / outer / left / right\n\n    # 输出\n    \"output\": \"feature_matrix.csv\",\n    \"output_format\": \"csv\",             # csv / parquet / feather\n    \"save_index\": False,\n}\n\n# ── 核心 Pipeline ─────────────────────────────────────────────────────────\n\n\ndef load_config(config_path: Optional[str] = None) -> dict:\n    \"\"\"加载配置，合并默认值。\"\"\"\n    cfg = DEFAULT_CONFIG.copy()\n    if config_path:\n        with open(config_path, \"r\") as f:\n            user_cfg = json.load(f)\n        cfg.update(user_cfg)\n        log.info(\"已加载配置: %s\", config_path)\n    return cfg\n\n\ndef discover_files(cfg: dict) -> list[Path]:\n    \"\"\"发现待处理的 CSV 文件列表。\"\"\"\n    files: list[Path] = []\n\n    # 优先使用显式列表\n    for f in cfg.get(\"csv_files\", []):\n        p = Path(f)\n        if p.exists():\n            files.append(p.resolve())\n        else:\n            log.warning(\"文件不存在，跳过: %s\", p)\n\n    # 否则用 glob 模式\n    if not files and cfg.get(\"csv_pattern\"):\n        import glob as glob_mod\n        matches = sorted(glob_mod.glob(cfg[\"csv_pattern\"], recursive=False))\n        for m in matches:\n            p = Path(m)\n            if p.suffix.lower() == \".csv\":\n                files.append(p.resolve())\n\n    if not files:\n        log.error(\"未找到任何 CSV 文件！请检查 csv_pattern 或 csv_files 配置。\")\n        sys.exit(1)\n\n    log.info(\"发现 %d 个 CSV 文件\", len(files))\n    for f in files:\n        log.info(\"  └ %s\", f)\n    return files\n\n\ndef read_csvs(files: list[Path], cfg: dict) -> dict[str, pd.DataFrame]:\n    \"\"\"读取所有 CSV，返回 {文件名: DataFrame}。\"\"\"\n    kwargs = cfg.get(\"read_kwargs\", {})\n    dataframes: dict[str, pd.DataFrame] = {}\n\n    for fp in files:\n        try:\n            df = pd.read_csv(fp, **kwargs)\n            dataframes[fp.stem] = df\n            log.info(\"读取 %s → shape %s\", fp.name, df.shape)\n        except Exception as e:\n            log.warning(\"读取失败，跳过 %s: %s\", fp.name, e)\n\n    if not dataframes:\n        log.error(\"所有 CSV 文件读取均失败！\")\n        sys.exit(1)\n\n    return dataframes\n\n\ndef flag_column_types(df: pd.DataFrame) -> dict[str, str]:\n    \"\"\"判断每列的类型：numeric / categorical / datetime / id / constant。\n\n    规则:\n    - object / category / bool → categorical\n    - datetime 子类型 → datetime\n    - int/float 且唯一值 ≥ min_categories → numeric\n    - 唯一值少于 min_categories（但 >0）→ constant\n    \"\"\"\n    col_types: dict[str, str] = {}\n    for col in df.columns:\n        dtype = df[col].dtype\n        nunique = df[col].nunique()\n\n        if pd.api.types.is_datetime64_any_dtype(dtype):\n            col_types[col] = \"datetime\"\n        elif pd.api.types.is_bool_dtype(dtype):\n            col_types[col] = \"categorical\"\n        elif pd.api.types.is_object_dtype(dtype) or pd.api.types.is_categorical_dtype(dtype):\n            if nunique <= 2:\n                col_types[col] = \"categorical\"  # 二值字面量仍视为分类\n            else:\n                col_types[col] = \"categorical\"\n        elif pd.api.types.is_numeric_dtype(dtype):\n            # 检查是否实际上是 ID 列（列名含 id / key，且唯一值 == 总行数）\n            if nunique == len(df) and re.search(r\"id|key|uuid|_id$\", col, re.I):\n                col_types[col] = \"id\"\n            elif nunique < 2:\n                col_types[col] = \"constant\"\n            else:\n                col_types[col] = \"numeric\"\n        else:\n            col_types[col] = \"categorical\"  # 兜底\n\n    return col_types\n\n\ndef clean_missing(df: pd.DataFrame, cfg: dict, col_types: dict[str, str]) -> pd.DataFrame:\n    \"\"\"处理缺失值：丢弃高缺失率列，填充其余缺失值。\"\"\"\n    strat = cfg[\"missing_strategy\"]\n    max_ratio = strat.get(\"max_missing_ratio\", 0.8)\n    const_val = strat.get(\"constant_fill\", 0)\n    df = df.copy()\n\n    # ── 1) 丢弃缺失率过高的列 ──\n    for col in list(df.columns):\n        ratio = df[col].isna().mean()\n        if ratio == 0:\n            continue\n        if ratio >= max_ratio:\n            log.info(\"  丢弃列 '%s'（缺失率 %.1f%%）\", col, ratio * 100)\n            df.drop(columns=[col], inplace=True)\n            col_types.pop(col, None)\n\n    # ── 2) 填充剩余缺失值 ──\n    num_strat = strat.get(\"numeric\", \"median\")\n    cat_strat = strat.get(\"categorical\", \"most_frequent\")\n\n    numeric_cols = [c for c, t in col_types.items() if t == \"numeric\"]\n    cat_cols = [c for c, t in col_types.items() if t == \"categorical\"]\n\n    if numeric_cols:\n        filler = SimpleImputer(strategy=num_strat, fill_value=const_val)\n        df[numeric_cols] = filler.fit_transform(df[numeric_cols])\n        log.info(\"  数值列填充: strategy=%s, cols=%d\", num_strat, len(numeric_cols))\n\n    if cat_cols:\n        # categorical 用 SimpleImputer（策略最常用）\n        if cat_strat == \"drop\":\n            df.dropna(subset=cat_cols, inplace=True)\n            log.info(\"  分类列丢弃含缺失的行: cols=%d\", len(cat_cols))\n        else:\n            filler = SimpleImputer(strategy=cat_strat, fill_value=\"MISSING\")\n            df[cat_cols] = filler.fit_transform(df[cat_cols])\n            log.info(\"  分类列填充: strategy=%s, cols=%d\", cat_strat, len(cat_cols))\n\n    # 最后 drop 所有 residual 缺失行\n    before = len(df)\n    df.dropna(inplace=True)\n    dropped = before - len(df)\n    if dropped:\n        log.info(\"  丢弃 %d 行（仍含缺失）\", dropped)\n\n    return df\n\n\ndef scale_numeric(df: pd.DataFrame, cfg: dict, col_types: dict[str, str]) -> pd.DataFrame:\n    \"\"\"标准化数值列。\"\"\"\n    scaler_name = cfg.get(\"scaler\", \"standard\")\n    if scaler_name is None or scaler_name.lower() == \"none\":\n        return df\n\n    numeric_cols = [c for c, t in col_types.items() if t == \"numeric\"]\n    if not numeric_cols:\n        return df\n\n    scaler_map = {\n        \"standard\": StandardScaler(),\n        \"minmax\": MinMaxScaler(),\n        \"robust\": RobustScaler(),\n    }\n    scaler = scaler_map.get(scaler_name.lower())\n    if scaler is None:\n        log.warning(\"不支持的 scaler: %s，跳过标准化\", scaler_name)\n        return df\n\n    df = df.copy()\n    df[numeric_cols] = scaler.fit_transform(df[numeric_cols])\n    log.info(\"  标准化: scaler=%s, cols=%d\", scaler_name, len(numeric_cols))\n    return df\n\n\ndef encode_categorical(\n    df: pd.DataFrame, cfg: dict, col_types: dict[str, str]\n) -> pd.DataFrame:\n    \"\"\"One-hot / dummy 编码分类变量。\"\"\"\n    encoding = cfg.get(\"encoding\", \"onehot\")\n    if encoding is None or encoding.lower() == \"none\":\n        return df\n\n    max_cat = cfg.get(\"max_categories\", 50)\n    min_cat = cfg.get(\"min_categories\", 2)\n    drop_first = cfg.get(\"drop_first\", False)\n\n    cat_cols = [c for c, t in col_types.items() if t == \"categorical\"]\n    if not cat_cols:\n        return df\n\n    # ── 高基数列预警 ──\n    for col in cat_cols[:]:\n        n = df[col].nunique()\n        if n > max_cat:\n            log.warning(\n                \"  列 '%s' 有 %d 个唯一值 > %d，跳过编码，保留原始值\",\n                col, n, max_cat,\n            )\n            cat_cols.remove(col)\n\n    # ── 常量列丢弃 ──\n    for col in cat_cols[:]:\n        n = df[col].nunique()\n        if n < min_cat:\n            log.info(\"  丢弃常量列 '%s'（唯一值=%d）\", col, n)\n            df.drop(columns=[col], inplace=True)\n            cat_cols.remove(col)\n\n    if not cat_cols:\n        return df\n\n    df = df.copy()\n\n    if encoding == \"dummy\":\n        # pd.get_dummies — 方便但可能不跨文件对齐\n        encoded = pd.get_dummies(\n            df[cat_cols],\n            prefix_sep=\"_\",\n            drop_first=drop_first,\n            dtype=int,\n        )\n    else:\n        # sklearn OneHotEncoder — 跨文件一致，稀疏矩阵转 dense\n        encoder = OneHotEncoder(\n            sparse_output=False,\n            drop=\"first\" if drop_first else None,\n            min_frequency=None,\n            handle_unknown=\"ignore\",\n        )\n        encoded_array = encoder.fit_transform(df[cat_cols])\n        # 构造列名\n        encoded_cols = []\n        for i, col in enumerate(cat_cols):\n            categories = encoder.categories_[i]\n            for cat in categories:\n                # 跳过 drop_first 的首类\n                if drop_first and cat == categories[0]:\n                    continue\n                # 清洗列名：替换特殊字符\n                safe_cat = re.sub(r\"[^\\w]\", \"_\", str(cat))\n                encoded_cols.append(f\"{col}_{safe_cat}\")\n        encoded = pd.DataFrame(\n            encoded_array,\n            columns=encoded_cols,\n            index=df.index,\n        ).astype(int)\n\n    # 丢弃原始分类列，追加编码列\n    df.drop(columns=cat_cols, inplace=True)\n    df = pd.concat([df, encoded], axis=1)\n\n    log.info(\n        \"  编码: method=%s, drop_first=%s, categorical=%d → encoded=%d\",\n        encoding, drop_first, len(cat_cols), encoded.shape[1],\n    )\n    return df\n\n\ndef merge_dataframes(\n    dataframes: dict[str, pd.DataFrame], cfg: dict\n) -> pd.DataFrame:\n    \"\"\"合并多个 DataFrame 为一个特征矩阵。\"\"\"\n    merge_mode = cfg.get(\"merge\", \"concat\")\n    df_list = list(dataframes.values())\n\n    if len(df_list) == 1:\n        return df_list[0]\n\n    if merge_mode == \"concat\":\n        # 对齐列后纵向拼接（列不一致时会引入 NaN，后续会 drop）\n        combined = pd.concat(df_list, ignore_index=True, sort=False)\n        log.info(\"合并方式: concat → shape %s\", combined.shape)\n        return combined\n\n    elif merge_mode == \"merge_by_id\":\n        merge_id = cfg.get(\"merge_id\", \"id\")\n        merge_how = cfg.get(\"merge_how\", \"outer\")\n        # 确保每个 df 都有 merge_id 列\n        for name, df in dataframes.items():\n            if merge_id not in df.columns:\n                log.warning(\"DataFrame '%s' 缺少合并键 '%s'\", name, merge_id)\n        combined = df_list[0]\n        for df in df_list[1:]:\n            combined = combined.merge(df, on=merge_id, how=merge_how, suffixes=(\"\", \"_dup\"))\n            # 丢弃重复列（merge 可能产生 _x / _y 后缀）\n            dup_cols = [c for c in combined.columns if c.endswith(\"_dup\")]\n            combined.drop(columns=dup_cols, inplace=True)\n        log.info(\n            \"合并方式: merge(id=%s, how=%s) → shape %s\",\n            merge_id, merge_how, combined.shape,\n        )\n        return combined\n\n    else:\n        log.warning(\"不支持的合并模式 '%s'，使用 concat 兜底\", merge_mode)\n        return pd.concat(df_list, ignore_index=True, sort=False)\n\n\ndef run_pipeline(cfg: dict) -> pd.DataFrame:\n    \"\"\"执行完整数据预处理 pipeline。\"\"\"\n    # 1) 发现 & 读取\n    files = discover_files(cfg)\n    dataframes = read_csvs(files, cfg)\n\n    # 2) 逐文件清洗\n    cleaned = {}\n    for name, df in dataframes.items():\n        log.info(\"── 处理文件: %s ──\", name)\n        col_types = flag_column_types(df)\n        df = clean_missing(df, cfg, col_types)\n        # 重新判断类型（部分列可能已被丢弃）\n        col_types = flag_column_types(df)\n        df = scale_numeric(df, cfg, col_types)\n        df = encode_categorical(df, cfg, col_types)\n        cleaned[name] = df\n\n    # 3) 合并\n    log.info(\"── 合并所有文件 ──\")\n    combined = merge_dataframes(cleaned, cfg)\n\n    # 4) 最终清洗：合并引入的 NaN\n    before = combined.shape[0]\n    combined.dropna(inplace=True)\n    after = combined.shape[0]\n    if before - after:\n        log.info(\"最终丢弃 %d 行（合并后引入的缺失）\", before - after)\n\n    log.info(\"── 完成！最终特征矩阵 shape: %s\", combined.shape)\n\n    return combined\n\n\n# ── CLI ────────────────────────────────────────────────────────────────────\n\n\ndef cli() -> argparse.Namespace:\n    parser = argparse.ArgumentParser(\n        description=\"数据预处理 Pipeline：多 CSV → 清洗 → 特征矩阵\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=\"\"\"\n示例:\n  python data_pipeline.py\n  python data_pipeline.py --csv data/train.csv data/test.csv\n  python data_pipeline.py --config config.json\n  python data_pipeline.py --csv \"data/*.csv\" --output features.csv\n        \"\"\",\n    )\n    parser.add_argument(\"--config\", \"-c\", help=\"JSON 配置文件路径\")\n    parser.add_argument(\"--csv\", nargs=\"*\", help=\"CSV 文件或 glob 模式\")\n    parser.add_argument(\"--output\", \"-o\", default=None, help=\"输出文件路径\")\n    parser.add_argument(\"--scaler\", choices=[\"standard\", \"minmax\", \"robust\", \"none\"], default=None)\n    parser.add_argument(\"--encoding\", choices=[\"onehot\", \"dummy\", \"none\"], default=None)\n    parser.add_argument(\"--merge-id\", help=\"merge_by_id 模式的键列名\")\n    parser.add_argument(\"--no-save\", action=\"store_true\", help=\"不保存结果，仅打印信息\")\n    parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"仅打印文件发现结果，不处理\")\n    return parser.parse_args()\n\n\ndef main():\n    args = cli()\n\n    # 加载配置\n    cfg = load_config(args.config)\n\n    # CLI 参数覆盖\n    if args.csv:\n        cfg[\"csv_files\"] = args.csv\n        cfg[\"csv_pattern\"] = None\n    if args.output:\n        cfg[\"output\"] = args.output\n    if args.scaler and args.scaler != \"none\":\n        cfg[\"scaler\"] = args.scaler\n    elif args.scaler == \"none\":\n        cfg[\"scaler\"] = None\n    if args.encoding and args.encoding != \"none\":\n        cfg[\"encoding\"] = args.encoding\n    elif args.encoding == \"none\":\n        cfg[\"encoding\"] = None\n    if args.merge_id:\n        cfg[\"merge\"] = \"merge_by_id\"\n        cfg[\"merge_id\"] = args.merge_id\n\n    # Dry-run\n    if args.dry_run:\n        files = discover_files(cfg)\n        print(f\"发现 {len(files)} 个文件:\")\n        for f in files:\n            print(f\"  {f}\")\n        return\n\n    # 执行 pipeline\n    result = run_pipeline(cfg)\n\n    # 输出概要\n    print(\"\\n\" + \"=\" * 60)\n    print(f\"特征矩阵: {result.shape[0]} 行 × {result.shape[1]} 列\")\n    print(f\"列名: {list(result.columns)}\")\n    print(f\"数据类型:\\n{result.dtypes.value_counts().to_string()}\")\n    print(\"=\" * 60)\n\n    # 保存\n    if not args.no_save:\n        output_path = cfg[\"output\"]\n        fmt = cfg.get(\"output_format\", \"csv\")\n        if fmt == \"csv\":\n            result.to_csv(output_path, index=cfg.get(\"save_index\", False))\n            log.info(\"已保存: %s (CSV, %.1f MB)\", output_path, result.memory_usage(deep=True).sum() / 1e6)\n        elif fmt == \"parquet\":\n            result.to_parquet(output_path, index=cfg.get(\"save_index\", False))\n            log.info(\"已保存: %s (Parquet)\", output_path)\n        elif fmt == \"feather\":\n            result.to_feather(output_path)\n            log.info(\"已保存: %s (Feather)\", output_path)\n        else:\n            log.warning(\"不支持的输出格式 %s，回退到 CSV\", fmt)\n            result.to_csv(output_path, index=cfg.get(\"save_index\", False))\n            log.info(\"已保存: %s (CSV)\", output_path)\n\n\n# ── 入口 ──────────────────────────────────────────────────────────────────\n\nif __name__ == \"__main__\":\n    main()\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\n数据预处理 Pipeline：读取多个 CSV → 清洗 → 标准化 → 编码 → 合并为特征矩阵。\n\n用法:\n    python data_pipeline.py                     # 使用默认配置\n    python data_pipeline.py --config config.json # 自定义配置\n    python data_pipeline.py --csv data/*.csv     # 指定输入文件\n\"\"\"\n\nimport os, sys, re, json, logging, argparse\nfrom pathlib import Path\nfrom typing import Optional\nimport pandas as pd\nimport numpy as np\nfrom sklearn.preprocessing import StandardScaler, MinMaxScaler, RobustScaler, OneHotEncoder\nfrom sklearn.impute import SimpleImputer\n\n# ── 日志 ──────────────────────────────────────────────────────────────────\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s [%(levelname)s] %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"pipeline\")\n\n# ── 配置结构 ──────────────────────────────────────────────────────────────\nDEFAULT_CONFIG = {\n    # CSV 输入\n    \"csv_pattern\": \"data/*.csv\",        # glob 模式，或显式文件列表\n    \"csv_files\": [],                    # 显式列表（优先级高于 pattern）\n    \"read_kwargs\": {                    # 传给 pd.read_csv 的参数\n        \"encoding\": \"utf-8\",\n        \"low_memory\": False,\n    },\n\n    # 缺失值处理\n    \"missing_strategy\": {\n        \"numeric\": \"median\",            # mean / median / most_frequent / constant\n        \"categorical\": \"most_frequent\", # most_frequent / constant / drop\n        \"constant_fill\": 0,             # missing_strategy = constant 时的填充值\n        \"max_missing_ratio\": 0.8,       # 缺失率超过此值的列被丢弃\n    },\n\n    # 数值标准化\n    \"scaler\": \"standard\",               # standard / minmax / robust / None（不做）\n    \"scale_per_column\": True,           # False = 只对全体数值列统一 fit（不常用）\n\n    # 分类编码\n    \"encoding\": \"onehot\",               # onehot / dummy / None\n    \"drop_first\": False,                # dummy 模式下是否 drop_first\n    \"max_categories\": 50,               # 唯一值超过此数量时不编码（视为高基数）\n    \"min_categories\": 2,                # 唯一值少于 2 的列是常量列，直接丢弃\n\n    # 合并\n    \"merge\": \"concat\",                  # concat / merge_by_id\n    \"merge_id\": \"id\",                   # merge_by_id 时使用的列名\n    \"merge_how\": \"outer\",               # inner / outer / left / right\n\n    # 输出\n    \"output\": \"feature_matrix.csv\",\n    \"output_format\": \"csv\",             # csv / parquet / feather\n    \"save_index\": False,\n}\n\n# ── 核心 Pipeline ─────────────────────────────────────────────────────────\n\n\ndef load_config(config_path: Optional[str] = None) -> dict:\n    \"\"\"加载配置，合并默认值。\"\"\"\n    cfg = DEFAULT_CONFIG.copy()\n    if config_path:\n        with open(config_path, \"r\") as f:\n            user_cfg = json.load(f)\n        cfg.update(user_cfg)\n        log.info(\"已加载配置: %s\", config_path)\n    return cfg\n\n\ndef discover_files(cfg: dict) -> list[Path]:\n    \"\"\"发现待处理的 CSV 文件列表。\"\"\"\n    files: list[Path] = []\n\n    # 优先使用显式列表\n    for f in cfg.get(\"csv_files\", []):\n        p = Path(f)\n        if p.exists():\n            files.append(p.resolve())\n        else:\n            log.warning(\"文件不存在，跳过: %s\", p)\n\n    # 否则用 glob 模式\n    if not files and cfg.get(\"csv_pattern\"):\n        import glob as glob_mod\n        matches = sorted(glob_mod.glob(cfg[\"csv_pattern\"], recursive=False))\n        for m in matches:\n            p = Path(m)\n            if p.suffix.lower() == \".csv\":\n                files.append(p.resolve())\n\n    if not files:\n        log.error(\"未找到任何 CSV 文件！请检查 csv_pattern 或 csv_files 配置。\")\n        sys.exit(1)\n\n    log.info(\"发现 %d 个 CSV 文件\", len(files))\n    for f in files:\n        log.info(\"  └ %s\", f)\n    return files\n\n\ndef read_csvs(files: list[Path], cfg: dict) -> dict[str, pd.DataFrame]:\n    \"\"\"读取所有 CSV，返回 {文件名: DataFrame}。\"\"\"\n    kwargs = cfg.get(\"read_kwargs\", {})\n    dataframes: dict[str, pd.DataFrame] = {}\n\n    for fp in files:\n        try:\n            df = pd.read_csv(fp, **kwargs)\n            dataframes[fp.stem] = df\n            log.info(\"读取 %s → shape %s\", fp.name, df.shape)\n        except Exception as e:\n            log.warning(\"读取失败，跳过 %s: %s\", fp.name, e)\n\n    if not dataframes:\n        log.error(\"所有 CSV 文件读取均失败！\")\n        sys.exit(1)\n\n    return dataframes\n\n\ndef flag_column_types(df: pd.DataFrame) -> dict[str, str]:\n    \"\"\"判断每列的类型：numeric / categorical / datetime / id / constant。\n\n    规则:\n    - object / category / bool → categorical\n    - datetime 子类型 → datetime\n    - int/float 且唯一值 ≥ min_categories → numeric\n    - 唯一值少于 min_categories（但 >0）→ constant\n    \"\"\"\n    col_types: dict[str, str] = {}\n    for col in df.columns:\n        dtype = df[col].dtype\n        nunique = df[col].nunique()\n\n        if pd.api.types.is_datetime64_any_dtype(dtype):\n            col_types[col] = \"datetime\"\n        elif pd.api.types.is_bool_dtype(dtype):\n            col_types[col] = \"categorical\"\n        elif pd.api.types.is_object_dtype(dtype) or pd.api.types.is_categorical_dtype(dtype):\n            if nunique <= 2:\n                col_types[col] = \"categorical\"  # 二值字面量仍视为分类\n            else:\n                col_types[col] = \"categorical\"\n        elif pd.api.types.is_numeric_dtype(dtype):\n            # 检查是否实际上是 ID 列（列名含 id / key，且唯一值 == 总行数）\n            if nunique == len(df) and re.search(r\"id|key|uuid|_id$\", col, re.I):\n                col_types[col] = \"id\"\n            elif nunique < 2:\n                col_types[col] = \"constant\"\n            else:\n                col_types[col] = \"numeric\"\n        else:\n            col_types[col] = \"categorical\"  # 兜底\n\n    return col_types\n\n\ndef clean_missing(df: pd.DataFrame, cfg: dict, col_types: dict[str, str]) -> pd.DataFrame:\n    \"\"\"处理缺失值：丢弃高缺失率列，填充其余缺失值。\"\"\"\n    strat = cfg[\"missing_strategy\"]\n    max_ratio = strat.get(\"max_missing_ratio\", 0.8)\n    const_val = strat.get(\"constant_fill\", 0)\n    df = df.copy()\n\n    # ── 1) 丢弃缺失率过高的列 ──\n    for col in list(df.columns):\n        ratio = df[col].isna().mean()\n        if ratio == 0:\n            continue\n        if ratio >= max_ratio:\n            log.info(\"  丢弃列 '%s'（缺失率 %.1f%%）\", col, ratio * 100)\n            df.drop(columns=[col], inplace=True)\n            col_types.pop(col, None)\n\n    # ── 2) 填充剩余缺失值 ──\n    num_strat = strat.get(\"numeric\", \"median\")\n    cat_strat = strat.get(\"categorical\", \"most_frequent\")\n\n    numeric_cols = [c for c, t in col_types.items() if t == \"numeric\"]\n    cat_cols = [c for c, t in col_types.items() if t == \"categorical\"]\n\n    if numeric_cols:\n        filler = SimpleImputer(strategy=num_strat, fill_value=const_val)\n        df[numeric_cols] = filler.fit_transform(df[numeric_cols])\n        log.info(\"  数值列填充: strategy=%s, cols=%d\", num_strat, len(numeric_cols))\n\n    if cat_cols:\n        # categorical 用 SimpleImputer（策略最常用）\n        if cat_strat == \"drop\":\n            df.dropna(subset=cat_cols, inplace=True)\n            log.info(\"  分类列丢弃含缺失的行: cols=%d\", len(cat_cols))\n        else:\n            filler = SimpleImputer(strategy=cat_strat, fill_value=\"MISSING\")\n            df[cat_cols] = filler.fit_transform(df[cat_cols])\n            log.info(\"  分类列填充: strategy=%s, cols=%d\", cat_strat, len(cat_cols))\n\n    # 最后 drop 所有 residual 缺失行\n    before = len(df)\n    df.dropna(inplace=True)\n    dropped = before - len(df)\n    if dropped:\n        log.info(\"  丢弃 %d 行（仍含缺失）\", dropped)\n\n    return df\n\n\ndef scale_numeric(df: pd.DataFrame, cfg: dict, col_types: dict[str, str]) -> pd.DataFrame:\n    \"\"\"标准化数值列。\"\"\"\n    scaler_name = cfg.get(\"scaler\", \"standard\")\n    if scaler_name is None or scaler_name.lower() == \"none\":\n        return df\n\n    numeric_cols = [c for c, t in col_types.items() if t == \"numeric\"]\n    if not numeric_cols:\n        return df\n\n    scaler_map = {\n        \"standard\": StandardScaler(),\n        \"minmax\": MinMaxScaler(),\n        \"robust\": RobustScaler(),\n    }\n    scaler = scaler_map.get(scaler_name.lower())\n    if scaler is None:\n        log.warning(\"不支持的 scaler: %s，跳过标准化\", scaler_name)\n        return df\n\n    df = df.copy()\n    df[numeric_cols] = scaler.fit_transform(df[numeric_cols])\n    log.info(\"  标准化: scaler=%s, cols=%d\", scaler_name, len(numeric_cols))\n    return df\n\n\ndef encode_categorical(\n    df: pd.DataFrame, cfg: dict, col_types: dict[str, str]\n) -> pd.DataFrame:\n    \"\"\"One-hot / dummy 编码分类变量。\"\"\"\n    encoding = cfg.get(\"encoding\", \"onehot\")\n    if encoding is None or encoding.lower() == \"none\":\n        return df\n\n    max_cat = cfg.get(\"max_categories\", 50)\n    min_cat = cfg.get(\"min_categories\", 2)\n    drop_first = cfg.get(\"drop_first\", False)\n\n    cat_cols = [c for c, t in col_types.items() if t == \"categorical\"]\n    if not cat_cols:\n        return df\n\n    # ── 高基数列预警 ──\n    for col in cat_cols[:]:\n        n = df[col].nunique()\n        if n > max_cat:\n            log.warning(\n                \"  列 '%s' 有 %d 个唯一值 > %d，跳过编码，保留原始值\",\n                col, n, max_cat,\n            )\n            cat_cols.remove(col)\n\n    # ── 常量列丢弃 ──\n    for col in cat_cols[:]:\n        n = df[col].nunique()\n        if n < min_cat:\n            log.info(\"  丢弃常量列 '%s'（唯一值=%d）\", col, n)\n            df.drop(columns=[col], inplace=True)\n            cat_cols.remove(col)\n\n    if not cat_cols:\n        return df\n\n    df = df.copy()\n\n    if encoding == \"dummy\":\n        # pd.get_dummies — 方便但可能不跨文件对齐\n        encoded = pd.get_dummies(\n            df[cat_cols],\n            prefix_sep=\"_\",\n            drop_first=drop_first,\n            dtype=int,\n        )\n    else:\n        # sklearn OneHotEncoder — 跨文件一致，稀疏矩阵转 dense\n        encoder = OneHotEncoder(\n            sparse_output=False,\n            drop=\"first\" if drop_first else None,\n            min_frequency=None,\n            handle_unknown=\"ignore\",\n        )\n        encoded_array = encoder.fit_transform(df[cat_cols])\n        # 构造列名\n        encoded_cols = []\n        for i, col in enumerate(cat_cols):\n            categories = encoder.categories_[i]\n            for cat in categories:\n                # 跳过 drop_first 的首类\n                if drop_first and cat == categories[0]:\n                    continue\n                # 清洗列名：替换特殊字符\n                safe_cat = re.sub(r\"[^\\w]\", \"_\", str(cat))\n                encoded_cols.append(f\"{col}_{safe_cat}\")\n        encoded = pd.DataFrame(\n            encoded_array,\n            columns=encoded_cols,\n            index=df.index,\n        ).astype(int)\n\n    # 丢弃原始分类列，追加编码列\n    df.drop(columns=cat_cols, inplace=True)\n    df = pd.concat([df, encoded], axis=1)\n\n    log.info(\n        \"  编码: method=%s, drop_first=%s, categorical=%d → encoded=%d\",\n        encoding, drop_first, len(cat_cols), encoded.shape[1],\n    )\n    return df\n\n\ndef merge_dataframes(\n    dataframes: dict[str, pd.DataFrame], cfg: dict\n) -> pd.DataFrame:\n    \"\"\"合并多个 DataFrame 为一个特征矩阵。\"\"\"\n    merge_mode = cfg.get(\"merge\", \"concat\")\n    df_list = list(dataframes.values())\n\n    if len(df_list) == 1:\n        return df_list[0]\n\n    if merge_mode == \"concat\":\n        # 对齐列后纵向拼接（列不一致时会引入 NaN，后续会 drop）\n        combined = pd.concat(df_list, ignore_index=True, sort=False)\n        log.info(\"合并方式: concat → shape %s\", combined.shape)\n        return combined\n\n    elif merge_mode == \"merge_by_id\":\n        merge_id = cfg.get(\"merge_id\", \"id\")\n        merge_how = cfg.get(\"merge_how\", \"outer\")\n        # 确保每个 df 都有 merge_id 列\n        for name, df in dataframes.items():\n            if merge_id not in df.columns:\n                log.warning(\"DataFrame '%s' 缺少合并键 '%s'\", name, merge_id)\n        combined = df_list[0]\n        for df in df_list[1:]:\n            combined = combined.merge(df, on=merge_id, how=merge_how, suffixes=(\"\", \"_dup\"))\n            # 丢弃重复列（merge 可能产生 _x / _y 后缀）\n            dup_cols = [c for c in combined.columns if c.endswith(\"_dup\")]\n            combined.drop(columns=dup_cols, inplace=True)\n        log.info(\n            \"合并方式: merge(id=%s, how=%s) → shape %s\",\n            merge_id, merge_how, combined.shape,\n        )\n        return combined\n\n    else:\n        log.warning(\"不支持的合并模式 '%s'，使用 concat 兜底\", merge_mode)\n        return pd.concat(df_list, ignore_index=True, sort=False)\n\n\ndef run_pipeline(cfg: dict) -> pd.DataFrame:\n    \"\"\"执行完整数据预处理 pipeline。\"\"\"\n    # 1) 发现 & 读取\n    files = discover_files(cfg)\n    dataframes = read_csvs(files, cfg)\n\n    # 2) 逐文件清洗\n    cleaned = {}\n    for name, df in dataframes.items():\n        log.info(\"── 处理文件: %s ──\", name)\n        col_types = flag_column_types(df)\n        df = clean_missing(df, cfg, col_types)\n        # 重新判断类型（部分列可能已被丢弃）\n        col_types = flag_column_types(df)\n        df = scale_numeric(df, cfg, col_types)\n        df = encode_categorical(df, cfg, col_types)\n        cleaned[name] = df\n\n    # 3) 合并\n    log.info(\"── 合并所有文件 ──\")\n    combined = merge_dataframes(cleaned, cfg)\n\n    # 4) 最终清洗：合并引入的 NaN\n    before = combined.shape[0]\n    combined.dropna(inplace=True)\n    after = combined.shape[0]\n    if before - after:\n        log.info(\"最终丢弃 %d 行（合并后引入的缺失）\", before - after)\n\n    log.info(\"── 完成！最终特征矩阵 shape: %s\", combined.shape)\n\n    return combined\n\n\n# ── CLI ────────────────────────────────────────────────────────────────────\n\n\ndef cli() -> argparse.Namespace:\n    parser = argparse.ArgumentParser(\n        description=\"数据预处理 Pipeline：多 CSV → 清洗 → 特征矩阵\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=\"\"\"\n示例:\n  python data_pipeline.py\n  python data_pipeline.py --csv data/train.csv data/test.csv\n  python data_pipeline.py --config config.json\n  python data_pipeline.py --csv \"data/*.csv\" --output features.csv\n        \"\"\",\n    )\n    parser.add_argument(\"--config\", \"-c\", help=\"JSON 配置文件路径\")\n    parser.add_argument(\"--csv\", nargs=\"*\", help=\"CSV 文件或 glob 模式\")\n    parser.add_argument(\"--output\", \"-o\", default=None, help=\"输出文件路径\")\n    parser.add_argument(\"--scaler\", choices=[\"standard\", \"minmax\", \"robust\", \"none\"], default=None)\n    parser.add_argument(\"--encoding\", choices=[\"onehot\", \"dummy\", \"none\"], default=None)\n    parser.add_argument(\"--merge-id\", help=\"merge_by_id 模式的键列名\")\n    parser.add_argument(\"--no-save\", action=\"store_true\", help=\"不保存结果，仅打印信息\")\n    parser.add_argument(\"--dry-run\", action=\"store_true\", help=\"仅打印文件发现结果，不处理\")\n    return parser.parse_args()\n\n\ndef main():\n    args = cli()\n\n    # 加载配置\n    cfg = load_config(args.config)\n\n    # CLI 参数覆盖\n    if args.csv:\n        cfg[\"csv_files\"] = args.csv\n        cfg[\"csv_pattern\"] = None\n    if args.output:\n        cfg[\"output\"] = args.output\n    if args.scaler and args.scaler != \"none\":\n        cfg[\"scaler\"] = args.scaler\n    elif args.scaler == \"none\":\n        cfg[\"scaler\"] = None\n    if args.encoding and args.encoding != \"none\":\n        cfg[\"encoding\"] = args.encoding\n    elif args.encoding == \"none\":\n        cfg[\"encoding\"] = None\n    if args.merge_id:\n        cfg[\"merge\"] = \"merge_by_id\"\n        cfg[\"merge_id\"] = args.merge_id\n\n    # Dry-run\n    if args.dry_run:\n        files = discover_files(cfg)\n        print(f\"发现 {len(files)} 个文件:\")\n        for f in files:\n            print(f\"  {f}\")\n        return\n\n    # 执行 pipeline\n    result = run_pipeline(cfg)\n\n    # 输出概要\n    print(\"\\n\" + \"=\" * 60)\n    print(f\"特征矩阵: {result.shape[0]} 行 × {result.shape[1]} 列\")\n    print(f\"列名: {list(result.columns)}\")\n    print(f\"数据类型:\\n{result.dtypes.value_counts().to_string()}\")\n    print(\"=\" * 60)\n\n    # 保存\n    if not args.no_save:\n        output_path = cfg[\"output\"]\n        fmt = cfg.get(\"output_format\", \"csv\")\n        if fmt == \"csv\":\n            result.to_csv(output_path, index=cfg.get(\"save_index\", False))\n            log.info(\"已保存: %s (CSV, %.1f MB)\", output_path, result.memory_usage(deep=True).sum() / 1e6)\n        elif fmt == \"parquet\":\n            result.to_parquet(output_path, index=cfg.get(\"save_index\", False))\n            log.info(\"已保存: %s (Parquet)\", output_path)\n        elif fmt == \"feather\":\n            result.to_feather(output_path)\n            log.info(\"已保存: %s (Feather)\", output_path)\n        else:\n            log.warning(\"不支持的输出格式 %s，回退到 CSV\", fmt)\n            result.to_csv(output_path, index=cfg.get(\"save_index\", False))\n            log.info(\"已保存: %s (CSV)\", output_path)\n\n\n# ── 入口 ──────────────────────────────────────────────────────────────────\n\nif __name__ == \"__main__\":\n    main()\n"})
