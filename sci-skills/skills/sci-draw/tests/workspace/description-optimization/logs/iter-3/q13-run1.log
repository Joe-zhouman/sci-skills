  \"\", xy=end, xytext=start,\n        arrowprops=dict(arrowstyle=\"->\", color=color, lw=1.5,\n                        connectionstyle=f\"arc3,rad={rad}\",\n                        linestyle=\"dashed\"),\n        zorder=1,\n    )\n    if label:\n        mx = (x_src + x_dst) / 2 + rad * 0.5\n        my = (start[1] + end[1]) / 2\n        ax.text(mx, my, label, ha=\"center\", va=\"center\",\n                fontsize=7.5, color=color, fontweight=\"bold\",\n                bbox=dict(boxstyle=\"round,pad=0.15\",\n                          facecolor=\"white\", edgecolor=\"none\", alpha=0.8),\n                zorder=5)\n\n# ── Draw all layers ────────────────────────────────────────────────────────\nfor i, L in enumerate(layers):\n    y = ys[i]\n    draw_layer(ax, x_cen, y, box_w, box_h, L[\"name\"], L[\"dim\"], L[\"color\"])\n    if L[\"dropout\"]:\n        draw_dropout_label(ax, x_cen, y, L[\"dropout\"], L[\"color\"])\n\n# ── Forward connections ───────────────────────────────────────────────────\nfor i in range(N - 1):\n    forward_arrow(ax, x_cen, ys[i], ys[i + 1], \"#888888\")\n\n# ── Skip connections ──────────────────────────────────────────────────────\n# Input -> LSTM-64   (skip LSTM-128)\nskip_arrow(ax, x_cen, ys[0], x_cen + 1.0, ys[2],\n           color=\"#4C72B0\", label=\"Skip\", rad=0.45)\n\n# Input -> LSTM-32   (skip LSTM-128 & LSTM-64)\nskip_arrow(ax, x_cen - 0.15, ys[0], x_cen - 1.0, ys[3],\n           color=\"#4C72B0\", label=\"Skip\", rad=-0.55)\n\n# LSTM-128 -> Output (skip LSTM-64 & LSTM-32)\nskip_arrow(ax, x_cen, ys[1], x_cen + 1.0, ys[4],\n           color=\"#55A868\", label=\"Skip\", rad=0.65)\n\n# ── Title ──────────────────────────────────────────────────────────────────\nax.text(0, ys[0] + box_h / 2 + 0.45,\n        \"LSTM-based Neural Network Architecture\\nwith Skip Connections & Dropout\",\n        ha=\"center\", va=\"center\", fontsize=15, fontweight=\"bold\",\n        color=\"#333333\", zorder=5)\n\n# ── Legend ─────────────────────────────────────────────────────────────────\nlegend_elements = [\n    mpatches.Patch(facecolor=\"#999999\", edgecolor=\"none\", alpha=0.5,\n                   label=\"Forward connection\"),\n    mpatches.Patch(facecolor=\"#AAAAAA\", edgecolor=\"none\", alpha=0.5,\n                   label=\"Skip connection (residual)\"),\n]\nax.legend(handles=legend_elements, loc=\"lower center\",\n          fontsize=9, ncol=2,\n          bbox_to_anchor=(1.35, 0.02),\n          framealpha=0.9, edgecolor=\"#cccccc\")\n\n# ── Save ───────────────────────────────────────────────────────────────────\nout_path = \"/home/joe/Documents/repo/skill/sci-draw/nn_architecture.png\"\nfig.savefig(out_path, dpi=200, bbox_inches=\"tight\", facecolor=\"white\")\nplt.close(fig)\nprint(f\"Saved to {out_path}\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/nn_arch.py", "content": "#!/usr/bin/env python3\n\"\"\"\nNeural Network Architecture Diagram:\n  Input (256-dim Embedding)\n    -> LSTM(128) -> LSTM(64) -> LSTM(32) -> Softmax Output\n  With skip connections and dropout labels.\n\"\"\"\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport numpy as np\n\n# ── Style ──────────────────────────────────────────────────────────────────\nplt.rcParams.update({\n    \"font.family\": \"sans-serif\",\n    \"font.sans-serif\": [\"DejaVu Sans\", \"Arial\", \"Helvetica\"],\n    \"font.size\": 12,\n})\n\n# ── Layer definitions ──────────────────────────────────────────────────────\nlayers = [\n    {\"name\": \"Embedding\\nInput\",     \"dim\": \"256\",   \"color\": \"#4C72B0\", \"dropout\": None},\n    {\"name\": \"LSTM\\nHidden 1\",       \"dim\": \"128\",   \"color\": \"#55A868\", \"dropout\": \"0.3\"},\n    {\"name\": \"LSTM\\nHidden 2\",       \"dim\": \"64\",    \"color\": \"#DD8452\", \"dropout\": \"0.3\"},\n    {\"name\": \"LSTM\\nHidden 3\",       \"dim\": \"32\",    \"color\": \"#C44E52\", \"dropout\": \"0.2\"},\n    {\"name\": \"Softmax\\nOutput\",      \"dim\": \"C\",     \"color\": \"#937860\", \"dropout\": None},\n]\n\nN = len(layers)\n\n# ── Layout parameters ──────────────────────────────────────────────────────\nbox_w = 1.6      # box width  (inches)\nbox_h = 0.9      # box height (inches)\nx_cen = 0.0      # center x of the column\nys = -np.arange(N) * 1.6   # y positions (top to bottom)\n\nfig_w = 7.5\nfig_h = 2.0 + (N - 1) * 1.6 + box_h\nfig, ax = plt.subplots(1, 1, figsize=(fig_w, fig_h))\nax.set_xlim(-2.5, 5.0)\nax.set_ylim(ys[-1] - box_h - 0.6, 0.6)\nax.set_aspect(\"equal\")\nax.axis(\"off\")\n\n# ── Helper: draw a rounded box with text ──────────────────────────────────\ndef draw_layer(ax, x, y, w, h, name, dim, color, alpha=0.92):\n    \"\"\"Draw a rounded-rect layer box with centered text.\"\"\"\n    box = mpatches.FancyBboxPatch(\n        (x - w / 2, y - h / 2), w, h,\n        boxstyle=mpatches.BoxStyle(\"Round\", pad=0.08),\n        facecolor=color, edgecolor=\"white\", linewidth=2.5,\n        alpha=alpha, zorder=3,\n    )\n    ax.add_patch(box)\n    # Layer name\n    ax.text(x, y + 0.12, name, ha=\"center\", va=\"center\",\n            fontsize=12, fontweight=\"bold\", color=\"white\", zorder=4)\n    # Dimension\n    ax.text(x, y - 0.28, f\"dim={dim}\", ha=\"center\", va=\"center\",\n            fontsize=9.5, color=\"white\", alpha=0.85, zorder=4)\n\ndef draw_dropout_label(ax, x, y, rate, color):\n    \"\"\"Draw a small badge for the dropout rate.\"\"\"\n    lbl = mpatches.FancyBboxPatch(\n        (x + box_w / 2 + 0.08, y - 0.22), 0.82, 0.44,\n        boxstyle=mpatches.BoxStyle(\"Round\", pad=0.06),\n        facecolor=color, edgecolor=\"white\", linewidth=1.2,\n        alpha=0.85, zorder=3,\n    )\n    ax.add_patch(lbl)\n    ax.text(x + box_w / 2 + 0.48, y, \"Dropout\", ha=\"center\", va=\"center\",\n            fontsize=8, color=\"white\", fontweight=\"bold\", zorder=4)\n    ax.text(x + box_w / 2 + 0.48, y - 0.16, f\"rate = {rate}\",\n            ha=\"center\", va=\"center\", fontsize=7.5, color=\"white\",\n            alpha=0.9, zorder=4)\n\n# ── Helper: forward arrow ─────────────────────────────────────────────────\ndef forward_arrow(ax, x, y0, y1, color=\"#999999\"):\n    ax.annotate(\n        \"\", xy=(x, y1 + box_h / 2), xytext=(x, y0 - box_h / 2),\n        arrowprops=dict(arrowstyle=\"->\", color=color, lw=2.0,\n                        connectionstyle=\"arc3,rad=0\"),\n        zorder=2,\n    )\n\n# ── Helper: skip-connection curved arrow ──────────────────────────────────\ndef skip_arrow(ax, x_src, y_src, x_dst, y_dst, color=\"#AAAAAA\",\n               label=\"\", rad=0.0):\n    \"\"\"Curved arrow from top of src to bottom of dst. rad>0 bows right.\"\"\"\n    start = (x_src, y_src + box_h / 2)\n    end   = (x_dst, y_dst - box_h / 2)\n    ax.annotate(\n        \"\", xy=end, xytext=start,\n        arrowprops=dict(arrowstyle=\"->\", color=color, lw=1.5,\n                        connectionstyle=f\"arc3,rad={rad}\",\n                        linestyle=\"dashed\"),\n        zorder=1,\n    )\n    if label:\n        mx = (x_src + x_dst) / 2 + rad * 0.5\n        my = (start[1] + end[1]) / 2\n        ax.text(mx, my, label, ha=\"center\", va=\"center\",\n                fontsize=7.5, color=color, fontweight=\"bold\",\n                bbox=dict(boxstyle=\"round,pad=0.15\",\n                          facecolor=\"white\", edgecolor=\"none\", alpha=0.8),\n                zorder=5)\n\n# ── Draw all layers ────────────────────────────────────────────────────────\nfor i, L in enumerate(layers):\n    y = ys[i]\n    draw_layer(ax, x_cen, y, box_w, box_h, L[\"name\"], L[\"dim\"], L[\"color\"])\n    if L[\"dropout\"]:\n        draw_dropout_label(ax, x_cen, y, L[\"dropout\"], L[\"color\"])\n\n# ── Forward connections ───────────────────────────────────────────────────\nfor i in range(N - 1):\n    forward_arrow(ax, x_cen, ys[i], ys[i + 1], \"#888888\")\n\n# ── Skip connections ──────────────────────────────────────────────────────\n# Input -> LSTM-64   (skip LSTM-128)\nskip_arrow(ax, x_cen, ys[0], x_cen + 1.0, ys[2],\n           color=\"#4C72B0\", label=\"Skip\", rad=0.45)\n\n# Input -> LSTM-32   (skip LSTM-128 & LSTM-64)\nskip_arrow(ax, x_cen - 0.15, ys[0], x_cen - 1.0, ys[3],\n           color=\"#4C72B0\", label=\"Skip\", rad=-0.55)\n\n# LSTM-128 -> Output (skip LSTM-64 & LSTM-32)\nskip_arrow(ax, x_cen, ys[1], x_cen + 1.0, ys[4],\n           color=\"#55A868\", label=\"Skip\", rad=0.65)\n\n# ── Title ──────────────────────────────────────────────────────────────────\nax.text(0, ys[0] + box_h / 2 + 0.45,\n        \"LSTM-based Neural Network Architecture\\nwith Skip Connections & Dropout\",\n        ha=\"center\", va=\"center\", fontsize=15, fontweight=\"bold\",\n        color=\"#333333\", zorder=5)\n\n# ── Legend ─────────────────────────────────────────────────────────────────\nlegend_elements = [\n    mpatches.Patch(facecolor=\"#999999\", edgecolor=\"none\", alpha=0.5,\n                   label=\"Forward connection\"),\n    mpatches.Patch(facecolor=\"#AAAAAA\", edgecolor=\"none\", alpha=0.5,\n                   label=\"Skip connection (residual)\"),\n]\nax.legend(handles=legend_elements, loc=\"lower center\",\n          fontsize=9, ncol=2,\n          bbox_to_anchor=(1.35, 0.02),\n          framealpha=0.9, edgecolor=\"#cccccc\")\n\n# ── Save ───────────────────────────────────────────────────────────────────\nout_path = \"/home/joe/Documents/repo/skill/sci-draw/nn_architecture.png\"\nfig.savefig(out_path, dpi=200, bbox_inches=\"tight\", facecolor=\"white\")\nplt.close(fig)\nprint(f\"Saved to {out_path}\")\n"})
