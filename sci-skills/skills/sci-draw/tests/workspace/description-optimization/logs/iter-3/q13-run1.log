, y - 0.22), 0.82, 0.44,\n        boxstyle=mpatches.BoxStyle(\"Round\", pad=0.06),\n        facecolor=color, edgecolor=\"white\", linewidth=1.2,\n        alpha=0.85, zorder=3)\n    ax.add_patch(lbl)\n    ax.text(x + box_w/2 + 0.48, y, \"Dropout\", ha=\"center\", va=\"center\",\n            fontsize=8, color=\"white\", fontweight=\"bold\", zorder=4)\n    ax.text(x + box_w/2 + 0.48, y - 0.16, f\"rate = {rate}\",\n            ha=\"center\", va=\"center\", fontsize=7.5, color=\"white\",\n            alpha=0.9, zorder=4)\n\ndef forward_arrow(ax, x, y0, y1, color=\"#999999\"):\n    ax.annotate(\"\", xy=(x, y1 + box_h/2), xytext=(x, y0 - box_h/2),\n                arrowprops=dict(arrowstyle=\"->\", color=color, lw=2.0,\n                                connectionstyle=\"arc3,rad=0\"), zorder=2)\n\ndef skip_arrow(ax, x_src, y_src, x_dst, y_dst, color=\"#AAAAAA\", label=\"\", rad=0.0):\n    start = (x_src, y_src + box_h/2)\n    end   = (x_dst, y_dst - box_h/2)\n    ax.annotate(\"\", xy=end, xytext=start,\n                arrowprops=dict(arrowstyle=\"->\", color=color, lw=1.5,\n                                connectionstyle=f\"arc3,rad={rad}\",\n                                linestyle=\"dashed\"), zorder=1)\n    if label:\n        mx = (x_src + x_dst)/2 + rad*0.5\n        my = (start[1] + end[1])/2\n        ax.text(mx, my, label, ha=\"center\", va=\"center\",\n                fontsize=7.5, color=color, fontweight=\"bold\",\n                bbox=dict(boxstyle=\"round,pad=0.15\",\n                          facecolor=\"white\", edgecolor=\"none\", alpha=0.8),\n                zorder=5)\n\nfor i, L in enumerate(layers):\n    y = ys[i]\n    draw_layer(ax, x_cen, y, box_w, box_h, L[\"name\"], L[\"dim\"], L[\"color\"])\n    if L[\"dropout\"]:\n        draw_dropout_label(ax, x_cen, y, L[\"dropout\"], L[\"color\"])\n\nfor i in range(N - 1):\n    forward_arrow(ax, x_cen, ys[i], ys[i+1], \"#888888\")\n\n# Skip connections\nskip_arrow(ax, x_cen, ys[0], x_cen + 1.0, ys[2],\n           color=\"#4C72B0\", label=\"Skip\", rad=0.45)\nskip_arrow(ax, x_cen - 0.15, ys[0], x_cen - 1.0, ys[3],\n           color=\"#4C72B0\", label=\"Skip\", rad=-0.55)\nskip_arrow(ax, x_cen, ys[1], x_cen + 1.0, ys[4],\n           color=\"#55A868\", label=\"Skip\", rad=0.65)\n\nax.text(0, ys[0] + box_h/2 + 0.45,\n        \"LSTM-based Neural Network Architecture\\nwith Skip Connections & Dropout\",\n        ha=\"center\", va=\"center\", fontsize=15, fontweight=\"bold\",\n        color=\"#333333\", zorder=5)\n\nlegend_elements = [\n    mpatches.Patch(facecolor=\"#999999\", edgecolor=\"none\", alpha=0.5,\n                   label=\"Forward connection\"),\n    mpatches.Patch(facecolor=\"#AAAAAA\", edgecolor=\"none\", alpha=0.5,\n                   label=\"Skip connection (residual)\"),\n]\nax.legend(handles=legend_elements, loc=\"lower center\",\n          fontsize=9, ncol=2, bbox_to_anchor=(1.35, 0.02),\n          framealpha=0.9, edgecolor=\"#cccccc\")\n\nout_path = \"nn_architecture.png\"\nfig.savefig(out_path, dpi=200, bbox_inches=\"tight\", facecolor=\"white\")\nplt.close(fig)\nprint(f\"Done: {out_path}\")\n'\n", "timeout": 30000})
