TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure1_science.py", "content": "#!/usr/bin/env python3\n\"\"\"\nScience Figure 1 — Multi-panel figure for publication\nPanels: (a) PCA, (b) Tumor volume curve, (c) Day 28 box plot, (d) Volcano plot\nTarget: Science double-column layout (183 mm full width)\n\"\"\"\n\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.lines import Line2D\nfrom matplotlib.font_manager import FontProperties\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ──────────────────────────────────────────────\n# GLOBAL SETTINGS — Science journal style\n# ──────────────────────────────────────────────\nplt.rcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': 7,\n    'axes.linewidth': 0.8,\n    'axes.labelsize': 7.5,\n    'axes.titlesize': 8,\n    'xtick.labelsize': 6.5,\n    'ytick.labelsize': 6.5,\n    'xtick.major.width': 0.6,\n    'ytick.major.width': 0.6,\n    'xtick.major.size': 3,\n    'ytick.major.size': 3,\n    'xtick.direction': 'in',\n    'ytick.direction': 'in',\n    'legend.fontsize': 6.5,\n    'legend.frameon': False,\n    'figure.dpi': 300,\n    'savefig.dpi': 600,\n    'savefig.bbox': 'tight',\n    'savefig.pad_inches': 0.05,\n})\n\n# ──────────────────────────────────────────────\n# COLOR PALETTE — colorblind-safe\n# ──────────────────────────────────────────────\nCOLORS = {\n    'Ctrl':   '#3B7DD8',   # steel blue\n    'TrtA':   '#E8834A',   # burnt orange\n    'TrtB':   '#4DAF7A',   # emerald green\n}\n\nGROUP_ORDER = ['Ctrl', 'TrtA', 'TrtB']\nGROUP_LABELS = ['Control', 'Treatment A', 'Treatment B']\n\n# Marker styles for curves\nMARKERS = ['o', 's', 'D']\n# Fill styles for boxplot\nBOX_FILL = [True, True, True]\n\n# ──────────────────────────────────────────────\n# SEED for reproducibility\n# ──────────────────────────────────────────────\nnp.random.seed(42)\n\n# ──────────────────────────────────────────────\n# DATA GENERATION\n# ──────────────────────────────────────────────\nN_SAMPLES = {'Ctrl': 8, 'TrtA': 8, 'TrtB': 8}\n# Time points (days)\nTIME_POINTS = np.array([0, 4, 8, 12, 16, 20, 24, 28])\n\n# --- Tumor volume simulation (exponential growth with treatment effect) ---\ndef simulate_tumor_volumes(group, n, time_pts):\n    \"\"\"Simulate realistic tumor growth curves.\"\"\"\n    base = np.zeros((n, len(time_pts)))\n    for i in range(n):\n        # V(t) = V0 * exp(k * t) with per-mouse noise\n        V0 = 60 + np.random.uniform(-15, 15)   # initial volume ~60 mm³\n        noise_level = np.random.uniform(0.85, 1.15)\n\n        if group == 'Ctrl':\n            k = 0.12 + np.random.normal(0, 0.015)     # fast growth\n        elif group == 'TrtA':\n            k = 0.07 + np.random.normal(0, 0.012)     # moderate inhibition\n        else:  # TrtB\n            k = 0.03 + np.random.normal(0, 0.010)     # strong inhibition\n\n        # Ensure positive growth\n        k = max(0.01, k)\n\n        raw = V0 * np.exp(k * time_pts)\n        # Add autocorrelated noise\n        noise = np.random.normal(1, 0.06, len(time_pts))\n        noise = np.cumsum(noise - 1) * 0.03 + 1\n        raw = raw * noise\n        raw = np.clip(raw, 20, 3500)\n        base[i] = raw\n    return base\n\ntumor_data = {}\nfor g in GROUP_ORDER:\n    tumor_data[g] = simulate_tumor_volumes(g, N_SAMPLES[g], TIME_POINTS)\n\n# --- PCA data simulation (multivariate with group separation) ---\ndef simulate_pca_data():\n    \"\"\"Simulate gene expression data (50 features) with group structure.\"\"\"\n    n_features = 50\n    X_list, y_list = [], []\n    for idx, g in enumerate(GROUP_ORDER):\n        n = N_SAMPLES[g]\n        # Base expression with group-specific shift on first few PCs\n        mu = np.zeros(n_features)\n        mu[:3] = [idx * 3.0, idx * 2.0, -idx * 1.5]\n        cov = np.eye(n_features) * 0.8\n        # Add some correlation structure\n        for j in range(n_features):\n            for k in range(j+1, min(j+3, n_features)):\n                cov[j,k] = cov[k,j] = 0.2\n        X_g = np.random.multivariate_normal(mu, cov, size=n)\n        X_list.append(X_g)\n        y_list.extend([g] * n)\n    return np.vstack(X_list), y_list\n\nX_pca, y_pca = simulate_pca_data()\n\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.decomposition import PCA\nX_scaled = StandardScaler().fit_transform(X_pca)\npca = PCA(n_components=2)\nX_pcs = pca.fit_transform(X_scaled)\npca_var = pca.explained_variance_ratio_ * 100\n\n# --- Day 28 data for boxplot ---\nday28_data = {g: tumor_data[g][:, -1] for g in GROUP_ORDER}\n\n# --- Volcano plot data ---\ndef simulate_volcano():\n    \"\"\"Simulate differential expression results (Ctrl vs TrtB).\"\"\"\n    n_genes = 4000\n    # log2 fold changes\n    lfc = np.random.normal(0, 0.6, n_genes)\n    # Add some truly DE genes\n    de_indices = np.random.choice(n_genes, size=180, replace=False)\n    lfc[de_indices[:90]] = np.random.choice([-1]*45 + [-1.5]*25 + [-2]*12 + [-3]*8, 90)\n    lfc[de_indices[90:]] = np.random.choice([1]*45 + [1.5]*25 + [2]*12 + [3]*8, 90)\n\n    # p-values\n    pvals = np.random.uniform(0.01, 1.0, n_genes)\n    for idx in de_indices:\n        # DE genes get small p-values\n        pvals[idx] = 10 ** np.random.uniform(-8, -1.5)\n\n    # Adjust direction: DE in one direction only for TrtB\n    # TrtB is effective, so many downregulated genes (negative LFC = lower in TrtB)\n    # And some upregulated (positive LFC = higher in TrtB)\n\n    return lfc, pvals\n\nlfc, pvals = simulate_volcano()\n# Calculate -log10 p-value\nneg_log10_p = -np.log10(pvals + 1e-300)\n\n\n# ──────────────────────────────────────────────\n# HELPER: panel label\n# ──────────────────────────────────────────────\ndef panel_label(ax, label, x=-0.28, y=1.08):\n    \"\"\"Add bold panel label above the subplot.\"\"\"\n    ax.text(x, y, label, transform=ax.transAxes,\n            fontsize=9, fontweight='bold', va='bottom', ha='left')\n\n\n# ──────────────────────────────────────────────\n# BUILD FIGURE\n# ──────────────────────────────────────────────\n# Science full width = 183 mm = 7.2 inches\nfig = plt.figure(figsize=(7.2, 6.0))\n\n# Layout: 2x2 grid with custom width ratios\n# Panel (a) PCA — left top, Panel (b) Tumor curve — right top\n# Panel (c) Boxplot — left bottom, Panel (d) Volcano — right bottom\ngs = fig.add_gridspec(2, 2, hspace=0.30, wspace=0.32,\n                      left=0.10, right=0.97, bottom=0.08, top=0.96,\n                      width_ratios=[1, 1.3])\n\n# ════════════════════════════════════════════\n# PANEL (a): PCA Score Plot\n# ═══════════════════��════════════════════════\nax_a = fig.add_subplot(gs[0, 0])\npanel_label(ax_a, '(a)')\n\n# Map group to color\ngroup_color_map = {g: COLORS[g] for g in GROUP_ORDER}\nmarker_map = {g: m for g, m in zip(GROUP_ORDER, MARKERS)}\n\nfor g in GROUP_ORDER:\n    idx = [i for i, y in enumerate(y_pca) if y == g]\n    ax_a.scatter(X_pcs[idx, 0], X_pcs[idx, 1],\n                 c=COLORS[g], marker=marker_map[g],\n                 s=22, edgecolors='white', linewidth=0.4,\n                 alpha=0.85, zorder=5, label=GROUP_LABELS[GROUP_ORDER.index(g)])\n\n# Draw 95% confidence ellipses\nfor g in GROUP_ORDER:\n    idx = [i for i, y in enumerate(y_pca) if y == g]\n    xc, yc = X_pcs[idx].mean(axis=0)\n    cov_m = np.cov(X_pcs[idx].T)\n    if cov_m.size == 0:\n        continue\n    # Eigendecomposition for ellipse\n    eigvals, eigvecs = np.linalg.eigh(cov_m)\n    order = eigvals.argsort()[::-1]\n    eigvals, eigvecs = eigvals[order], eigvecs[:, order]\n    angle = np.degrees(np.arctan2(eigvecs[1, 0], eigvecs[0, 0]))\n    width, height = 2 * np.sqrt(5.991 * eigvals)  # 95% confidence (chi2, df=2)\n    ellipse = mpatches.Ellipse(xy=(xc, yc), width=width, height=height,\n                               angle=angle, fill=False,\n                               edgecolor=COLORS[g], linewidth=0.9,\n                               linestyle='--', alpha=0.7)\n    ax_a.add_patch(ellipse)\n\nax_a.set_xlabel(f'PC1 ({pca_var[0]:.1f}%)')\nax_a.set_ylabel(f'PC2 ({pca_var[1]:.1f}%)')\n\n# Legend\nlegend_elements = [\n    Line2D([0], [0], marker='o', color='w', markerfacecolor=COLORS['Ctrl'],\n           markersize=5, label='Control', markeredgecolor='white', markeredgewidth=0.4),\n    Line2D([0], [0], marker='s', color='w', markerfacecolor=COLORS['TrtA'],\n           markersize=5, label='Treatment A', markeredgecolor='white', markeredgewidth=0.4),\n    Line2D([0], [0], marker='D', color='w', markerfacecolor=COLORS['TrtB'],\n           markersize=5, label='Treatment B', markeredgecolor='white', markeredgewidth=0.4),\n]\nax_a.legend(handles=legend_elements, loc='lower right', frameon=False,\n            handletextpad=0.5, borderpad=0.3)\n\nax_a.set_aspect('equal', adjustable='datalim')\nax_a.set_box_aspect(1)\n\n# ════════════════════════════════════════════\n# PANEL (b): Tumor Volume Curves\n# ════════════════════════════════════════════\nax_b = fig.add_subplot(gs[0, 1])\npanel_label(ax_b, '(b)')\n\nfor g_idx, g in enumerate(GROUP_ORDER):\n    data = tumor_data[g]\n    mean = data.mean(axis=0)\n    sem = data.std(axis=0, ddof=1) / np.sqrt(N_SAMPLES[g])\n\n    ax_b.plot(TIME_POINTS, mean, color=COLORS[g], linewidth=1.5,\n              marker=MARKERS[g_idx], markersize=4.5,\n              markerfacecolor=COLORS[g], markeredgewidth=0.4,\n              markeredgecolor='white', label=GROUP_LABELS[g_idx],\n              zorder=5)\n    ax_b.fill_between(TIME_POINTS, mean - sem, mean + sem,\n                       color=COLORS[g], alpha=0.12, edgecolor='none')\n\n# Statistical annotation — example: TrtA vs Ctrl at day 28\n# (In real figure, you'd compute from actual data)\nax_b.text(27.5, tumor_data['Ctrl'][:, -1].mean() + 120,\n          '*', fontsize=10, fontweight='bold', ha='center', va='bottom',\n          color='#333333')\n# line for the bracket\nax_b.plot([26, 27.5, 27.5, 29],\n          [tumor_data['Ctrl'][:, -1].mean() + 80] * 2 +\n          [tumor_data['TrtA'][:, -1].mean() + 80] * 2,\n          color='#555555', linewidth=0.5, clip_on=False)\nax_b.text(28.25, (tumor_data['Ctrl'][:, -1].mean() +\n                  tumor_data['TrtA'][:, -1].mean()) / 2 + 80,\n          '*', fontsize=10, fontweight='bold', ha='center', va='bottom',\n          color='#333333')\n\nax_b.set_xlabel('Days after treatment')\nax_b.set_ylabel('Tumor volume (mm³)')\nax_b.set_xticks(TIME_POINTS)\nax_b.set_xlim(-1, 30)\nax_b.legend(loc='upper left', frameon=False, handletextpad=0.5, borderpad=0.3)\nax_b.set_box_aspect(0.85)\n\n# ════════════════════════════════════════════\n# PANEL (c): Day 28 Box Plot with strip\n# ════════════════════════════════════════════\nax_c = fig.add_subplot(gs[1, 0])\npanel_label(ax_c, '(c)')\n\nbox_data = [day28_data[g] for g in GROUP_ORDER]\npositions = [1, 2, 3]\n\n# Boxplot\nbp = ax_c.boxplot(box_data, positions=positions, widths=0.55,\n                  patch_artist=True, showmeans=True,\n                  meanline=False, showfliers=False,\n                  medianprops={'color': 'black', 'linewidth': 1.2},\n                  meanprops={'marker': 'D', 'markerfacecolor': 'white',\n                             'markeredgecolor': 'black', 'markersize': 3.5},\n                  whiskerprops={'linewidth': 0.8},\n                  capprops={'linewidth': 0.8},\n                  boxprops={'linewidth': 0.7},\n                  flierprops={'markersize': 3})\n\n# Color boxes\nfor i, patch in enumerate(bp['boxes']):\n    patch.set_facecolor(COLORS[GROUP_ORDER[i]])\n    patch.set_alpha(0.75)\n    patch.set_edgecolor('black')\n\n# Add strip plot (individual data points)\nfor i, g in enumerate(GROUP_ORDER):\n    data = day28_data[g]\n    # Add jitter\n    jitter = np.random.normal(0, 0.06, len(data))\n    x = positions[i] + jitter\n    ax_c.scatter(x, data, alpha=0.7, s=14, color=COLORS[g],\n                 edgecolors='white', linewidth=0.4, zorder=6)\n\n# Statistical annotation\nfrom scipy import stats\n# Ctrl vs TrtA\n_, p1 = stats.ttest_ind(day28_data['Ctrl'], day28_data['TrtA'])\n# Ctrl vs TrtB\n_, p2 = stats.ttest_ind(day28_data['Ctrl'], day28_data['TrtB'])\n\n# Annotate significance\ndef annotate_significance(ax, x1, x2, y, p_val):\n    h = max(data.max() for data in box_data) * 0.03\n    if p_val < 0.001:\n        symbol = '***'\n    elif p_val < 0.01:\n        symbol = '**'\n    elif p_val < 0.05:\n        symbol = '*'\n    else:\n        symbol = 'n.s.'\n    ax.plot([x1, x1, x2, x2], [y, y+h, y+h, y], color='#333333', linewidth=0.6, clip_on=False)\n    ax.text((x1+x2)/2, y+h, symbol, fontsize=7.5, fontweight='bold',\n            ha='center', va='bottom', color='#333333')\n\nmax_val = max(max(d) for d in box_data)\nannotate_significance(ax_c, 1, 2, max_val * 1.03, p1)\nannotate_significance(ax_c, 1, 3, max_val * 1.12, p2)\n\nax_c.set_xticklabels(GROUP_LABELS, fontsize=6.5)\nax_c.set_ylabel('Tumor volume (mm³)')\nax_c.set_ylim(0, max_val * 1.25)\nax_c.set_box_aspect(1)\n\n# ════════════════════════════════════════════\n# PANEL (d): Volcano Plot\n# ════════════════════════════════════════════\nax_d = fig.add_subplot(gs[1, 1])\npanel_label(ax_d, '(d)')\n\n# Thresholds\nlfc_thresh = 1.0\np_thresh = 0.05\nneg_log10_p_thresh = -np.log10(p_thresh)\n\n# Categorize genes\nup = (lfc >= lfc_thresh) & (neg_log10_p >= neg_log10_p_thresh)\ndown = (lfc <= -lfc_thresh) & (neg_log10_p >= neg_log10_p_thresh)\nns = ~(up | down)\n\nn_up = up.sum()\nn_down = down.sum()\n\n# Plot non-significant\nax_d.scatter(lfc[ns], neg_log10_p[ns], c='#B0B0B0', s=2.5, alpha=0.5,\n             edgecolors='none', rasterized=True, zorder=1)\n\n# Plot upregulated\nax_d.scatter(lfc[up], neg_log10_p[up], c='#C44D4D', s=4, alpha=0.6,\n             edgecolors='none', rasterized=True, zorder=2)\n\n# Plot downregulated\nax_d.scatter(lfc[down], neg_log10_p[down], c='#3B7DD8', s=4, alpha=0.6,\n             edgecolors='none', rasterized=True, zorder=2)\n\n# Threshold lines\nax_d.axhline(neg_log10_p_thresh, color='grey', linestyle='--', linewidth=0.5, alpha=0.5)\nax_d.axvline(lfc_thresh, color='grey', linestyle='--', linewidth=0.5, alpha=0.5)\nax_d.axvline(-lfc_thresh, color='grey', linestyle='--', linewidth=0.5, alpha=0.5)\n\nax_d.set_xlabel('log$_2$ (Fold Change)')\nax_d.set_ylabel('−log$_{10}$ ($P$-value)')\n\n# Annotate top genes\n# Pick a few top DE genes to label\ntop_up_idx = np.where(up)[0][np.argsort(-lfc[up])[:5]]\ntop_down_idx = np.where(down)[0][np.argsort(lfc[down])[:5]]\n\ngene_names_pool_up = ['Ccl2', 'Il6', 'Mmp9', 'Tnf', 'Vegfa', 'Cxcl1', 'Mki67']\ngene_names_pool_down = ['Cdkn1a', 'Bax', 'Fas', 'Gadd45a', 'Rb1', 'Tp53', 'Bcl2l1']\n\nfor i, idx in enumerate(top_up_idx):\n    if i < len(gene_names_pool_up):\n        ax_d.annotate(gene_names_pool_up[i], (lfc[idx], neg_log10_p[idx]),\n                      fontsize=5.5, color='#C44D4D', ha='left', va='bottom',\n                      xytext=(4, 2), textcoords='offset points',\n                      arrowprops=dict(arrowstyle='-', color='#C44D4D', lw=0.3))\n\nfor i, idx in enumerate(top_down_idx):\n    if i < len(gene_names_pool_down):\n        ax_d.annotate(gene_names_pool_down[i], (lfc[idx], neg_log10_p[idx]),\n                      fontsize=5.5, color='#3B7DD8', ha='right', va='bottom',\n                      xytext=(-4, 2), textcoords='offset points',\n                      arrowprops=dict(arrowstyle='-', color='#3B7DD8', lw=0.3))\n\n# Legend\nlegend_d = [\n    Line2D([0], [0], marker='o', color='w', markerfacecolor='#C44D4D',\n           markersize=4, label=f'Up ({n_up})'),\n    Line2D([0], [0], marker='o', color='w', markerfacecolor='#3B7DD8',\n           markersize=4, label=f'Down ({n_down})'),\n    Line2D([0], [0], marker='o', color='w', markerfacecolor='#B0B0B0',\n           markersize=4, label=f'NS ({ns.sum()})'),\n]\nax_d.legend(handles=legend_d, loc='upper right', frameon=False,\n            handletextpad=0.3, borderpad=0.3, fontsize=6)\n\n# Set a reasonable y-limit\nymax = np.percentile(neg_log10_p[neg_log10_p > 0], 99.5) * 1.1\nax_d.set_ylim(0, min(ymax, 10))\nx_max = max(abs(lfc).max(), 3.5)\nax_d.set_xlim(-x_max, x_max)\nax_d.set_box_aspect(0.85)\n\n# ──────────────────────────────────────────────\n# SAVE\n# ──────────────────────────────────────────────\noutput_path = '/home/joe/Documents/repo/skill/sci-draw/figure1_science.png'\nfig.savefig(output_path, dpi=600, facecolor='white', edgecolor='none')\nprint(f'Figure saved to: {output_path}')\nprint(f'Dimensions: {fig.get_size_inches()[0]:.1f} x {fig.get_size_inches()[1]:.1f} inches')\nprint(f'PCA variance explained: PC1={pca_var[0]:.1f}%, PC2={pca_var[1]:.1f}%')\nprint(f'Volcano: {n_up} up, {n_down} down, {ns.sum()} NS')\nprint(f'T-test Ctrl vs TrtA: p={p1:.2e}')\nprint(f'T-test Ctrl vs TrtB: p={p2:.2e}')\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure1_science.py", "content": "#!/usr/bin/env python3\n\"\"\"\nScience Figure 1 — Multi-panel figure for publication\nPanels: (a) PCA, (b) Tumor volume curve, (c) Day 28 box plot, (d) Volcano plot\nTarget: Science double-column layout (183 mm full width)\n\"\"\"\n\nimport numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.lines import Line2D\nfrom matplotlib.font_manager import FontProperties\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ──────────────────────────────────────────────\n# GLOBAL SETTINGS — Science journal style\n# ──────────────────────────────────────────────\nplt.rcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': 7,\n    'axes.linewidth': 0.8,\n    'axes.labelsize': 7.5,\n    'axes.titlesize': 8,\n    'xtick.labelsize': 6.5,\n    'ytick.labelsize': 6.5,\n    'xtick.major.width': 0.6,\n    'ytick.major.width': 0.6,\n    'xtick.major.size': 3,\n    'ytick.major.size': 3,\n    'xtick.direction': 'in',\n    'ytick.direction': 'in',\n    'legend.fontsize': 6.5,\n    'legend.frameon': False,\n    'figure.dpi': 300,\n    'savefig.dpi': 600,\n    'savefig.bbox': 'tight',\n    'savefig.pad_inches': 0.05,\n})\n\n# ──────────────────────────────────────────────\n# COLOR PALETTE — colorblind-safe\n# ──────────────────────────────────────────────\nCOLORS = {\n    'Ctrl':   '#3B7DD8',   # steel blue\n    'TrtA':   '#E8834A',   # burnt orange\n    'TrtB':   '#4DAF7A',   # emerald green\n}\n\nGROUP_ORDER = ['Ctrl', 'TrtA', 'TrtB']\nGROUP_LABELS = ['Control', 'Treatment A', 'Treatment B']\n\n# Marker styles for curves\nMARKERS = ['o', 's', 'D']\n# Fill styles for boxplot\nBOX_FILL = [True, True, True]\n\n# ──────────────────────────────────────────────\n# SEED for reproducibility\n# ──────────────────────────────────────────────\nnp.random.seed(42)\n\n# ──────────────────────────────────────────────\n# DATA GENERATION\n# ──────────────────────────────────────────────\nN_SAMPLES = {'Ctrl': 8, 'TrtA': 8, 'TrtB': 8}\n# Time points (days)\nTIME_POINTS = np.array([0, 4, 8, 12, 16, 20, 24, 28])\n\n# --- Tumor volume simulation (exponential growth with treatment effect) ---\ndef simulate_tumor_volumes(group, n, time_pts):\n    \"\"\"Simulate realistic tumor growth curves.\"\"\"\n    base = np.zeros((n, len(time_pts)))\n    for i in range(n):\n        # V(t) = V0 * exp(k * t) with per-mouse noise\n        V0 = 60 + np.random.uniform(-15, 15)   # initial volume ~60 mm³\n        noise_level = np.random.uniform(0.85, 1.15)\n\n        if group == 'Ctrl':\n            k = 0.12 + np.random.normal(0, 0.015)     # fast growth\n        elif group == 'TrtA':\n            k = 0.07 + np.random.normal(0, 0.012)     # moderate inhibition\n        else:  # TrtB\n            k = 0.03 + np.random.normal(0, 0.010)     # strong inhibition\n\n        # Ensure positive growth\n        k = max(0.01, k)\n\n        raw = V0 * np.exp(k * time_pts)\n        # Add autocorrelated noise\n        noise = np.random.normal(1, 0.06, len(time_pts))\n        noise = np.cumsum(noise - 1) * 0.03 + 1\n        raw = raw * noise\n        raw = np.clip(raw, 20, 3500)\n        base[i] = raw\n    return base\n\ntumor_data = {}\nfor g in GROUP_ORDER:\n    tumor_data[g] = simulate_tumor_volumes(g, N_SAMPLES[g], TIME_POINTS)\n\n# --- PCA data simulation (multivariate with group separation) ---\ndef simulate_pca_data():\n    \"\"\"Simulate gene expression data (50 features) with group structure.\"\"\"\n    n_features = 50\n    X_list, y_list = [], []\n    for idx, g in enumerate(GROUP_ORDER):\n        n = N_SAMPLES[g]\n        # Base expression with group-specific shift on first few PCs\n        mu = np.zeros(n_features)\n        mu[:3] = [idx * 3.0, idx * 2.0, -idx * 1.5]\n        cov = np.eye(n_features) * 0.8\n        # Add some correlation structure\n        for j in range(n_features):\n            for k in range(j+1, min(j+3, n_features)):\n                cov[j,k] = cov[k,j] = 0.2\n        X_g = np.random.multivariate_normal(mu, cov, size=n)\n        X_list.append(X_g)\n        y_list.extend([g] * n)\n    return np.vstack(X_list), y_list\n\nX_pca, y_pca = simulate_pca_data()\n\nfrom sklearn.preprocessing import StandardScaler\nfrom sklearn.decomposition import PCA\nX_scaled = StandardScaler().fit_transform(X_pca)\npca = PCA(n_components=2)\nX_pcs = pca.fit_transform(X_scaled)\npca_var = pca.explained_variance_ratio_ * 100\n\n# --- Day 28 data for boxplot ---\nday28_data = {g: tumor_data[g][:, -1] for g in GROUP_ORDER}\n\n# --- Volcano plot data ---\ndef simulate_volcano():\n    \"\"\"Simulate differential expression results (Ctrl vs TrtB).\"\"\"\n    n_genes = 4000\n    # log2 fold changes\n    lfc = np.random.normal(0, 0.6, n_genes)\n    # Add some truly DE genes\n    de_indices = np.random.choice(n_genes, size=180, replace=False)\n    lfc[de_indices[:90]] = np.random.choice([-1]*45 + [-1.5]*25 + [-2]*12 + [-3]*8, 90)\n    lfc[de_indices[90:]] = np.random.choice([1]*45 + [1.5]*25 + [2]*12 + [3]*8, 90)\n\n    # p-values\n    pvals = np.random.uniform(0.01, 1.0, n_genes)\n    for idx in de_indices:\n        # DE genes get small p-values\n        pvals[idx] = 10 ** np.random.uniform(-8, -1.5)\n\n    # Adjust direction: DE in one direction only for TrtB\n    # TrtB is effective, so many downregulated genes (negative LFC = lower in TrtB)\n    # And some upregulated (positive LFC = higher in TrtB)\n\n    return lfc, pvals\n\nlfc, pvals = simulate_volcano()\n# Calculate -log10 p-value\nneg_log10_p = -np.log10(pvals + 1e-300)\n\n\n# ──────────────────────────────────────────────\n# HELPER: panel label\n# ──────────────────────────────────────────────\ndef panel_label(ax, label, x=-0.28, y=1.08):\n    \"\"\"Add bold panel label above the subplot.\"\"\"\n    ax.text(x, y, label, transform=ax.transAxes,\n            fontsize=9, fontweight='bold', va='bottom', ha='left')\n\n\n# ──────────────────────────────────────────────\n# BUILD FIGURE\n# ──────────────────────────────────────────────\n# Science full width = 183 mm = 7.2 inches\nfig = plt.figure(figsize=(7.2, 6.0))\n\n# Layout: 2x2 grid with custom width ratios\n# Panel (a) PCA — left top, Panel (b) Tumor curve — right top\n# Panel (c) Boxplot — left bottom, Panel (d) Volcano — right bottom\ngs = fig.add_gridspec(2, 2, hspace=0.30, wspace=0.32,\n                      left=0.10, right=0.97, bottom=0.08, top=0.96,\n                      width_ratios=[1, 1.3])\n\n# ════════════════════════════════════════════\n# PANEL (a): PCA Score Plot\n# ════════════════════════════════════════════\nax_a = fig.add_subplot(gs[0, 0])\npanel_label(ax_a, '(a)')\n\n# Map group to color\ngroup_color_map = {g: COLORS[g] for g in GROUP_ORDER}\nmarker_map = {g: m for g, m in zip(GROUP_ORDER, MARKERS)}\n\nfor g in GROUP_ORDER:\n    idx = [i for i, y in enumerate(y_pca) if y == g]\n    ax_a.scatter(X_pcs[idx, 0], X_pcs[idx, 1],\n                 c=COLORS[g], marker=marker_map[g],\n                 s=22, edgecolors='white', linewidth=0.4,\n                 alpha=0.85, zorder=5, label=GROUP_LABELS[GROUP_ORDER.index(g)])\n\n# Draw 95% confidence ellipses\nfor g in GROUP_ORDER:\n    idx = [i for i, y in enumerate(y_pca) if y == g]\n    xc, yc = X_pcs[idx].mean(axis=0)\n    cov_m = np.cov(X_pcs[idx].T)\n    if cov_m.size == 0:\n        continue\n    # Eigendecomposition for ellipse\n    eigvals, eigvecs = np.linalg.eigh(cov_m)\n    order = eigvals.argsort()[::-1]\n    eigvals, eigvecs = eigvals[order], eigvecs[:, order]\n    angle = np.degrees(np.arctan2(eigvecs[1, 0], eigvecs[0, 0]))\n    width, height = 2 * np.sqrt(5.991 * eigvals)  # 95% confidence (chi2, df=2)\n    ellipse = mpatches.Ellipse(xy=(xc, yc), width=width, height=height,\n                               angle=angle, fill=False,\n                               edgecolor=COLORS[g], linewidth=0.9,\n                               linestyle='--', alpha=0.7)\n    ax_a.add_patch(ellipse)\n\nax_a.set_xlabel(f'PC1 ({pca_var[0]:.1f}%)')\nax_a.set_ylabel(f'PC2 ({pca_var[1]:.1f}%)')\n\n# Legend\nlegend_elements = [\n    Line2D([0], [0], marker='o', color='w', markerfacecolor=COLORS['Ctrl'],\n           markersize=5, label='Control', markeredgecolor='white', markeredgewidth=0.4),\n    Line2D([0], [0], marker='s', color='w', markerfacecolor=COLORS['TrtA'],\n           markersize=5, label='Treatment A', markeredgecolor='white', markeredgewidth=0.4),\n    Line2D([0], [0], marker='D', color='w', markerfacecolor=COLORS['TrtB'],\n           markersize=5, label='Treatment B', markeredgecolor='white', markeredgewidth=0.4),\n]\nax_a.legend(handles=legend_elements, loc='lower right', frameon=False,\n            handletextpad=0.5, borderpad=0.3)\n\nax_a.set_aspect('equal', adjustable='datalim')\nax_a.set_box_aspect(1)\n\n# ════════════════════════════════════════════\n# PANEL (b): Tumor Volume Curves\n# ════════════════════════════════════════════\nax_b = fig.add_subplot(gs[0, 1])\npanel_label(ax_b, '(b)')\n\nfor g_idx, g in enumerate(GROUP_ORDER):\n    data = tumor_data[g]\n    mean = data.mean(axis=0)\n    sem = data.std(axis=0, ddof=1) / np.sqrt(N_SAMPLES[g])\n\n    ax_b.plot(TIME_POINTS, mean, color=COLORS[g], linewidth=1.5,\n              marker=MARKERS[g_idx], markersize=4.5,\n              markerfacecolor=COLORS[g], markeredgewidth=0.4,\n              markeredgecolor='white', label=GROUP_LABELS[g_idx],\n              zorder=5)\n    ax_b.fill_between(TIME_POINTS, mean - sem, mean + sem,\n                       color=COLORS[g], alpha=0.12, edgecolor='none')\n\n# Statistical annotation — example: TrtA vs Ctrl at day 28\n# (In real figure, you'd compute from actual data)\nax_b.text(27.5, tumor_data['Ctrl'][:, -1].mean() + 120,\n          '*', fontsize=10, fontweight='bold', ha='center', va='bottom',\n          color='#333333')\n# line for the bracket\nax_b.plot([26, 27.5, 27.5, 29],\n          [tumor_data['Ctrl'][:, -1].mean() + 80] * 2 +\n          [tumor_data['TrtA'][:, -1].mean() + 80] * 2,\n          color='#555555', linewidth=0.5, clip_on=False)\nax_b.text(28.25, (tumor_data['Ctrl'][:, -1].mean() +\n                  tumor_data['TrtA'][:, -1].mean()) / 2 + 80,\n          '*', fontsize=10, fontweight='bold', ha='center', va='bottom',\n          color='#333333')\n\nax_b.set_xlabel('Days after treatment')\nax_b.set_ylabel('Tumor volume (mm³)')\nax_b.set_xticks(TIME_POINTS)\nax_b.set_xlim(-1, 30)\nax_b.legend(loc='upper left', frameon=False, handletextpad=0.5, borderpad=0.3)\nax_b.set_box_aspect(0.85)\n\n# ════════════════════════════════════════════\n# PANEL (c): Day 28 Box Plot with strip\n# ════════════════════════════════════════════\nax_c = fig.add_subplot(gs[1, 0])\npanel_label(ax_c, '(c)')\n\nbox_data = [day28_data[g] for g in GROUP_ORDER]\npositions = [1, 2, 3]\n\n# Boxplot\nbp = ax_c.boxplot(box_data, positions=positions, widths=0.55,\n                  patch_artist=True, showmeans=True,\n                  meanline=False, showfliers=False,\n                  medianprops={'color': 'black', 'linewidth': 1.2},\n                  meanprops={'marker': 'D', 'markerfacecolor': 'white',\n                             'markeredgecolor': 'black', 'markersize': 3.5},\n                  whiskerprops={'linewidth': 0.8},\n                  capprops={'linewidth': 0.8},\n                  boxprops={'linewidth': 0.7},\n                  flierprops={'markersize': 3})\n\n# Color boxes\nfor i, patch in enumerate(bp['boxes']):\n    patch.set_facecolor(COLORS[GROUP_ORDER[i]])\n    patch.set_alpha(0.75)\n    patch.set_edgecolor('black')\n\n# Add strip plot (individual data points)\nfor i, g in enumerate(GROUP_ORDER):\n    data = day28_data[g]\n    # Add jitter\n    jitter = np.random.normal(0, 0.06, len(data))\n    x = positions[i] + jitter\n    ax_c.scatter(x, data, alpha=0.7, s=14, color=COLORS[g],\n                 edgecolors='white', linewidth=0.4, zorder=6)\n\n# Statistical annotation\nfrom scipy import stats\n# Ctrl vs TrtA\n_, p1 = stats.ttest_ind(day28_data['Ctrl'], day28_data['TrtA'])\n# Ctrl vs TrtB\n_, p2 = stats.ttest_ind(day28_data['Ctrl'], day28_data['TrtB'])\n\n# Annotate significance\ndef annotate_significance(ax, x1, x2, y, p_val):\n    h = max(data.max() for data in box_data) * 0.03\n    if p_val < 0.001:\n        symbol = '***'\n    elif p_val < 0.01:\n        symbol = '**'\n    elif p_val < 0.05:\n        symbol = '*'\n    else:\n        symbol = 'n.s.'\n    ax.plot([x1, x1, x2, x2], [y, y+h, y+h, y], color='#333333', linewidth=0.6, clip_on=False)\n    ax.text((x1+x2)/2, y+h, symbol, fontsize=7.5, fontweight='bold',\n            ha='center', va='bottom', color='#333333')\n\nmax_val = max(max(d) for d in box_data)\nannotate_significance(ax_c, 1, 2, max_val * 1.03, p1)\nannotate_significance(ax_c, 1, 3, max_val * 1.12, p2)\n\nax_c.set_xticklabels(GROUP_LABELS, fontsize=6.5)\nax_c.set_ylabel('Tumor volume (mm³)')\nax_c.set_ylim(0, max_val * 1.25)\nax_c.set_box_aspect(1)\n\n# ════════════════════════════════════════════\n# PANEL (d): Volcano Plot\n# ════════════════════════════════════════════\nax_d = fig.add_subplot(gs[1, 1])\npanel_label(ax_d, '(d)')\n\n# Thresholds\nlfc_thresh = 1.0\np_thresh = 0.05\nneg_log10_p_thresh = -np.log10(p_thresh)\n\n# Categorize genes\nup = (lfc >= lfc_thresh) & (neg_log10_p >= neg_log10_p_thresh)\ndown = (lfc <= -lfc_thresh) & (neg_log10_p >= neg_log10_p_thresh)\nns = ~(up | down)\n\nn_up = up.sum()\nn_down = down.sum()\n\n# Plot non-significant\nax_d.scatter(lfc[ns], neg_log10_p[ns], c='#B0B0B0', s=2.5, alpha=0.5,\n             edgecolors='none', rasterized=True, zorder=1)\n\n# Plot upregulated\nax_d.scatter(lfc[up], neg_log10_p[up], c='#C44D4D', s=4, alpha=0.6,\n             edgecolors='none', rasterized=True, zorder=2)\n\n# Plot downregulated\nax_d.scatter(lfc[down], neg_log10_p[down], c='#3B7DD8', s=4, alpha=0.6,\n             edgecolors='none', rasterized=True, zorder=2)\n\n# Threshold lines\nax_d.axhline(neg_log10_p_thresh, color='grey', linestyle='--', linewidth=0.5, alpha=0.5)\nax_d.axvline(lfc_thresh, color='grey', linestyle='--', linewidth=0.5, alpha=0.5)\nax_d.axvline(-lfc_thresh, color='grey', linestyle='--', linewidth=0.5, alpha=0.5)\n\nax_d.set_xlabel('log$_2$ (Fold Change)')\nax_d.set_ylabel('−log$_{10}$ ($P$-value)')\n\n# Annotate top genes\n# Pick a few top DE genes to label\ntop_up_idx = np.where(up)[0][np.argsort(-lfc[up])[:5]]\ntop_down_idx = np.where(down)[0][np.argsort(lfc[down])[:5]]\n\ngene_names_pool_up = ['Ccl2', 'Il6', 'Mmp9', 'Tnf', 'Vegfa', 'Cxcl1', 'Mki67']\ngene_names_pool_down = ['Cdkn1a', 'Bax', 'Fas', 'Gadd45a', 'Rb1', 'Tp53', 'Bcl2l1']\n\nfor i, idx in enumerate(top_up_idx):\n    if i < len(gene_names_pool_up):\n        ax_d.annotate(gene_names_pool_up[i], (lfc[idx], neg_log10_p[idx]),\n                      fontsize=5.5, color='#C44D4D', ha='left', va='bottom',\n                      xytext=(4, 2), textcoords='offset points',\n                      arrowprops=dict(arrowstyle='-', color='#C44D4D', lw=0.3))\n\nfor i, idx in enumerate(top_down_idx):\n    if i < len(gene_names_pool_down):\n        ax_d.annotate(gene_names_pool_down[i], (lfc[idx], neg_log10_p[idx]),\n                      fontsize=5.5, color='#3B7DD8', ha='right', va='bottom',\n                      xytext=(-4, 2), textcoords='offset points',\n                      arrowprops=dict(arrowstyle='-', color='#3B7DD8', lw=0.3))\n\n# Legend\nlegend_d = [\n    Line2D([0], [0], marker='o', color='w', markerfacecolor='#C44D4D',\n           markersize=4, label=f'Up ({n_up})'),\n    Line2D([0], [0], marker='o', color='w', markerfacecolor='#3B7DD8',\n           markersize=4, label=f'Down ({n_down})'),\n    Line2D([0], [0], marker='o', color='w', markerfacecolor='#B0B0B0',\n           markersize=4, label=f'NS ({ns.sum()})'),\n]\nax_d.legend(handles=legend_d, loc='upper right', frameon=False,\n            handletextpad=0.3, borderpad=0.3, fontsize=6)\n\n# Set a reasonable y-limit\nymax = np.percentile(neg_log10_p[neg_log10_p > 0], 99.5) * 1.1\nax_d.set_ylim(0, min(ymax, 10))\nx_max = max(abs(lfc).max(), 3.5)\nax_d.set_xlim(-x_max, x_max)\nax_d.set_box_aspect(0.85)\n\n# ──────────────────────────────────────────────\n# SAVE\n# ──────────────────────────────────────────────\noutput_path = '/home/joe/Documents/repo/skill/sci-draw/figure1_science.png'\nfig.savefig(output_path, dpi=600, facecolor='white', edgecolor='none')\nprint(f'Figure saved to: {output_path}')\nprint(f'Dimensions: {fig.get_size_inches()[0]:.1f} x {fig.get_size_inches()[1]:.1f} inches')\nprint(f'PCA variance explained: PC1={pca_var[0]:.1f}%, PC2={pca_var[1]:.1f}%')\nprint(f'Volcano: {n_up} up, {n_down} down, {ns.sum()} NS')\nprint(f'T-test Ctrl vs TrtA: p={p1:.2e}')\nprint(f'T-test Ctrl vs TrtB: p={p2:.2e}')\n"})
