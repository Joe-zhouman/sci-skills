TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/scrnaseq_umap_generator.py", "content": "#!/usr/bin/env python3\n\"\"\"\nInteractive scRNA-seq UMAP viewer — generates a standalone HTML file.\n\nProduces a Plotly-based interactive scatter plot of UMAP coordinates with:\n  - Colour by cell type (default) or by any gene via dropdown\n  - Hover tooltips: cell barcode, cell type, UMAP coords, top gene expression, metadata\n  - Legend, zoom/pan, and export as a self-contained HTML file\n\nUsage\n-----\n  # With synthetic demo data:\n  python scrnaseq_umap_generator.py --demo\n\n  # With real data (CSV format):\n  python scrnaseq_umap_generator.py \\\n      --umap_csv umap_coords.csv \\\n      --metadata_csv metadata.csv \\\n      --expression_csv expression.csv \\\n      --output interactive_umap.html\n\nCSV file formats (column names are flexible; the script auto-detects):\n  umap_coords.csv:  columns like \"barcode\" (or first column as index),\n                    \"UMAP_1\" / \"UMAP_2\" or \"x\" / \"y\"\n  metadata.csv:     columns like \"barcode\" (join key), \"cell_type\",\n                    plus any extra columns → shown in hover\n  expression.csv:   columns like \"barcode\" (join key),\n                    then one column per gene with numeric values (log-normalised)\n\"\"\"\n\nimport argparse\nimport csv\nimport itertools\nimport sys\nimport textwrap\nfrom pathlib import Path\n\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n#  Synthetic data generation (used when --demo is passed)\n# ---------------------------------------------------------------------------\n\nN_CELLS_DEMO = 3000\nN_GENES_DEMO = 8\n\n# Realistic marker genes per lineage\nMARKER_GENES = [\n    \"CD3D\",   # T cells\n    \"CD14\",   # Monocytes\n    \"CD19\",   # B cells\n    \"NKG7\",   # NK cells\n    \"FCGR3A\", # CD16+ Monocytes\n    \"CD8A\",   # CD8 T cells\n    \"CD4\",    # CD4 T cells\n    \"GZMB\",   # cytotoxic / NK\n    \"MS4A1\",  # B cells (CD20)\n    \"CST3\",   # Myeloid\n    \"GNLY\",   # NK / cytotoxic\n    \"CD79A\",  # B cells\n    \"LYZ\",    # Myeloid\n    \"IL7R\",   # CD4 T cells\n    \"FCER1A\", # DCs\n    \"PPBP\",   # Platelets\n]\n\nCELL_TYPES = [\n    \"CD4 T cell\",\n    \"CD8 T cell\",\n    \"NK cell\",\n    \"B cell\",\n    \"Monocyte (CD14+)\",\n    \"Monocyte (CD16+)\",\n    \"Dendritic cell\",\n    \"Platelet\",\n]\n\nCONDITIONS = [\"Control\", \"Treatment_A\", \"Treatment_B\"]\nPATIENTS = [f\"P{i:03d}\" for i in range(1, 13)]\nBATCHES = [\"B001\", \"B002\", \"B003\"]\n\n\ndef _make_blobs(centers, n_per_cluster, noise=0.6, seed=42):\n    \"\"\"Generate 2-D Gaussian blobs around *centers*.\"\"\"\n    rng = np.random.default_rng(seed)\n    n_clusters = len(centers)\n    pts_per = [n_per_cluster] * n_clusters\n    xs, ys = [], []\n    for (cx, cy), n in zip(centers, pts_per):\n        xs.append(rng.normal(cx, noise, n))\n        ys.append(rng.normal(cy, noise, n))\n    return np.concatenate(xs), np.concatenate(ys)\n\n\ndef _mk_demo_data():\n    \"\"\"\n    Return (umap_df, metadata_df, expression_df) as lists-of-dicts\n    representing a realistic scRNA-seq dataset.\n    \"\"\"\n    # ---- UMAP coords with some cluster separation ----\n    centers = [\n        (-4, 5),   # CD4 T\n        (-2, 6),   # CD8 T\n        (2, 6),    # NK\n        (5, 2),    # B\n        (-5, -2),  # CD14+ Mono\n        (-2, -4),  # CD16+ Mono\n        (3, -4),   # DC\n        (0, 0),    # Platelet\n    ]\n    n_ct = len(CELL_TYPES)\n    n_per = N_CELLS_DEMO // n_ct\n    extra = N_CELLS_DEMO - n_per * n_ct\n\n    xs, ys = _make_blobs(centers, n_per, noise=0.6, seed=42)\n\n    # Handle remainder\n    if extra > 0:\n        rng_extra = np.random.default_rng(42)\n        for i in range(extra):\n            cx, cy = centers[i % n_ct]\n            xs = np.append(xs, rng_extra.normal(cx, 0.6))\n            ys = np.append(ys, rng_extra.normal(cy, 0.6))\n\n    barcodes = [f\"AAACCCAAGCTCGCTA-{i}\" for i in range(len(xs))]\n\n    umap = [\n        {\"barcode\": bc, \"UMAP_1\": round(x, 4), \"UMAP_2\": round(y, 4)}\n        for bc, x, y in zip(barcodes, xs, ys)\n    ]\n\n    # ---- Metadata ----\n    rng_m = np.random.default_rng(123)\n    cell_type_list = []\n    ct_idx = 0\n    for i in range(len(barcodes)):\n        cell_type_list.append(CELL_TYPES[ct_idx])\n        if ct_idx < n_ct - 1 and (i + 1) % n_per == 0:\n            ct_idx += 1\n\n    metadata = [\n        {\n            \"barcode\": bc,\n            \"cell_type\": ct,\n            \"condition\": rng_m.choice(CONDITIONS),\n            \"patient\": rng_m.choice(PATIENTS),\n            \"batch\": rng_m.choice(BATCHES),\n            \"nCount_RNA\": int(rng_m.lognormal(3.5, 0.4)),\n            \"nFeature_RNA\": int(rng_m.lognormal(3.0, 0.3)),\n            \"percent_mito\": round(abs(rng_m.normal(5, 2)), 2),\n            \"S_score\": round(rng_m.normal(0, 0.5), 3),\n            \"G2M_score\": round(rng_m.normal(0, 0.5), 3),\n        }\n        for bc, ct in zip(barcodes, cell_type_list)\n    ]\n\n    # ---- Expression (log-normalised, realistic per cell type) ----\n    # build a mapping: cell_type -> list of highly-expressed genes and a\n    # background level for everything else\n    ct_gene_signal = {\n        \"CD4 T cell\":        {\"CD3D\": 4.2, \"CD4\": 3.8, \"IL7R\": 3.5, \"CD8A\": 0.5},\n        \"CD8 T cell\":        {\"CD3D\": 4.0, \"CD8A\": 4.5, \"GZMB\": 3.2, \"CD4\": 0.3},\n        \"NK cell\":           {\"NKG7\": 5.0, \"GNLY\": 4.8, \"GZMB\": 4.0, \"CD3D\": 1.2},\n        \"B cell\":            {\"CD19\": 4.5, \"MS4A1\": 4.3, \"CD79A\": 4.0, \"CD3D\": 0.2},\n        \"Monocyte (CD14+)\":  {\"CD14\": 5.0, \"CST3\": 3.8, \"LYZ\": 4.5, \"FCGR3A\": 0.5},\n        \"Monocyte (CD16+)\":  {\"FCGR3A\": 4.8, \"CST3\": 3.5, \"LYZ\": 4.0, \"CD14\": 0.8},\n        \"Dendritic cell\":    {\"FCER1A\": 4.5, \"CST3\": 4.2, \"CD14\": 1.5, \"FCGR3A\": 2.0},\n        \"Platelet\":          {\"PPBP\": 5.5, \"CD3D\": 0.3, \"CD14\": 0.2},\n    }\n\n    # All genes that appear in any cell type\n    all_genes_set = set()\n    for v in ct_gene_signal.values():\n        all_genes_set.update(v.keys())\n    # Pick 8 of the most informative genes for the default view, keep the rest\n    # for the dropdown\n    DISPLAY_GENES = sorted(all_genes_set)\n\n    rng_e = np.random.default_rng(456)\n    expression = []\n    for bc, ct in zip(barcodes, cell_type_list):\n        row = {\"barcode\": bc}\n        sig = ct_gene_signal.get(ct, {})\n        for gene in DISPLAY_GENES:\n            mean_expr = sig.get(gene, 0.0)\n            if mean_expr > 0:\n                # Positive expression with realistic variance\n                val = rng_e.gamma(mean_expr * 2, 0.4)\n                val = max(0, val)\n            else:\n                # Background / dropout\n                val = rng_e.exponential(0.2) if rng_e.random() > 0.6 else 0.0\n            row[gene] = round(val, 3)\n        expression.append(row)\n\n    return umap, metadata, expression\n\n\n# ---------------------------------------------------------------------------\n#  Load real data from CSVs\n# ---------------------------------------------------------------------------\n\ndef _load_csv(path):\n    \"\"\"Read a CSV and return a list of dicts (lowercased keys).\"\"\"\n    with open(path) as f:\n        reader = csv.DictReader(f)\n        rows = []\n        for row in reader:\n            rows.append({k.strip().lower(): v.strip() for k, v in row.items()})\n    if not rows:\n        print(f\"Warning: {path} is empty.\", file=sys.stderr)\n    return rows\n\n\ndef _detect_umap_cols(row):\n    \"\"\"Return (x_col, y_col) from a UMAP row dict.\"\"\"\n    keys = list(row.keys())\n    for xc in (\"umap_1\", \"x\", \"umap1\", \"umap-1\", \"umap1\"):\n        if xc in keys:\n            break\n    else:\n        print(f\"UMAP columns not found. Keys: {keys}\", file=sys.stderr)\n        sys.exit(1)\n    for yc in (\"umap_2\", \"y\", \"umap2\", \"umap-2\", \"umap2\"):\n        if yc in keys:\n            break\n    else:\n        print(f\"UMAP y-column not found. Keys: {keys}\", file=sys.stderr)\n        sys.exit(1)\n    return xc, yc\n\n\ndef _detect_barcode_col(rows, fallback=None):\n    \"\"\"Return the name of the barcode / cell-ID column.\"\"\"\n    keys = rows[0].keys()\n    for candidate in (\"barcode\", \"cell\", \"cell_id\", \"cellid\", \"index\"):\n        if candidate in keys:\n            return candidate\n    # first column that looks like a cell barcode (contains -)\n    if fallback:\n        return fallback\n    # just use the first column\n    return list(keys)[0]\n\n\ndef _detect_cell_type_col(rows):\n    \"\"\"Return the name of the cell-type column.\"\"\"\n    keys = rows[0].keys()\n    for candidate in (\"cell_type\", \"celltype\", \"cluster\", \"annotation\",\n                      \"label\", \"identity\"):\n        if candidate in keys:\n            return candidate\n    return None\n\n\n# ---------------------------------------------------------------------------\n#  Build the Plotly figure\n# ---------------------------------------------------------------------------\n\ntry:\n    import plotly.graph_objects as go\n    import plotly.express as px\n    from plotly.subplots import make_subplots\nexcept ImportError:\n    print(\"This script requires plotly. Install with: pip install plotly\", file=sys.stderr)\n    sys.exit(1)\n\n\n# A colourblind-friendly qualitative palette (Wong, 2011)\nCT_COLORS = {\n    \"CD4 T cell\":        \"#0072B2\",  # blue\n    \"CD8 T cell\":        \"#56B4E9\",  # sky blue\n    \"NK cell\":           \"#009E73\",  # green\n    \"B cell\":            \"#F0E442\",  # yellow\n    \"Monocyte (CD14+)\":  \"#D55E00\",  # vermillion\n    \"Monocyte (CD16+)\":  \"#E69F00\",  # orange\n    \"Dendritic cell\":    \"#CC79A7\",  # pink\n    \"Platelet\":          \"#000000\",  # black\n}\n\n# Fallback palette for unknown cell types\nFALLBACK_PALETTE = px.colors.qualitative.Set3\n\n\ndef _build_hover(colours, ct_col, meta_rows_by_bc):\n    \"\"\"Build rich hover text for each point.\"\"\"\n    hover_texts = []\n    for ct, bc in zip(colours[\"label\"], colours[\"barcodes\"]):\n        meta = meta_rows_by_bc.get(bc, {})\n        parts = [\n            f\"<b>{bc}</b>\",\n            f\"Cell type: {ct}\",\n        ]\n        for k, v in meta.items():\n            kf = k.replace(\"_\", \" \").title()\n            parts.append(f\"{kf}: {v}\")\n        hover_texts.append(\"<br>\".join(parts))\n    return hover_texts\n\n\ndef make_figure(umap_rows, metadata_rows, expression_rows, genes=None,\n                title=\"scRNA-seq UMAP\"):\n    \"\"\"\n    Build a Plotly figure from parsed data.\n\n    Parameters\n    ----------\n    umap_rows : list[dict]\n    metadata_rows : list[dict]\n    expression_rows : list[dict] | None\n    genes : list[str] | None — genes to include in hover and dropdown.\n            If None, auto-detect from expression data.\n    title : str\n    \"\"\"\n    # ---- Detect columns ----\n    bc_col_umap = _detect_barcode_col(umap_rows)\n    xc, yc = _detect_umap_cols(umap_rows)\n\n    bc_col_meta = _detect_barcode_col(metadata_rows, fallback=bc_col_umap)\n    ct_col = _detect_cell_type_col(metadata_rows)\n\n    if expression_rows:\n        bc_col_expr = _detect_barcode_col(expression_rows, fallback=bc_col_umap)\n    else:\n        bc_col_expr = None\n\n    # ---- Build lookup dicts ----\n    meta_by_bc = {r[bc_col_meta]: r for r in metadata_rows}\n    expr_by_bc = {r[bc_col_expr]: r for r in expression_rows} if expression_rows else {}\n\n    # ---- Determine the gene list ----\n    if genes is None and expression_rows:\n        # exclude the barcode column\n        keys = list(expression_rows[0].keys())\n        genes = [k for k in keys if k != bc_col_expr]\n        # limit to e.g. 20 genes to keep the dropdown manageable\n        if len(genes) > 20:\n            # pick the most variable (by variance across cells)\n            expr_vals = {g: [] for g in genes}\n            for row in expression_rows:\n                for g in genes:\n                    try:\n                        expr_vals[g].append(float(row[g]))\n                    except (ValueError, KeyError):\n                        expr_vals[g].append(0.0)\n            variances = [(g, np.var(expr_vals[g])) for g in genes]\n            variances.sort(key=lambda x: x[1], reverse=True)\n            genes = [g for g, _ in variances[:20]]\n    genes = genes or []\n\n    # ---- Build trace data ----\n    barcodes = [r[bc_col_umap] for r in umap_rows]\n    x_vals = [float(r[xc]) for r in umap_rows]\n    y_vals = [float(r[yc]) for r in umap_rows]\n\n    # Cell type labels\n    if ct_col:\n        labels = [meta_by_bc.get(bc, {}).get(ct_col, \"Unknown\") for bc in barcodes]\n    else:\n        labels = [\"Unknown\"] * len(barcodes)\n\n    # Colour mapping for cell types\n    unique_cts = sorted(set(labels))\n    palette = itertools.cycle(FALLBACK_PALETTE)\n    color_map = {}\n    for ct in unique_cts:\n        if ct in CT_COLORS:\n            color_map[ct] = CT_COLORS[ct]\n        else:\n            color_map[ct] = next(palette)\n\n    # ---- Build hover text ----\n    hover_texts = []\n    for bc, ct in zip(barcodes, labels):\n        meta = meta_by_bc.get(bc, {})\n        expr = expr_by_bc.get(bc, {})\n        parts = [\n            f\"<b>{bc}</b>\",\n            f\"<b>Cell type:</b> {ct}\",\n            f\"UMAP_1: {meta.get(xc, '')}\",\n            f\"UMAP_2: {meta.get(yc, '')}\",\n        ]\n        # Show metadata fields (skip barcode, umap coords, cell type)\n        skip_keys = {bc_col_meta, bc_col_umap, xc, yc, ct_col, \"barcode\"}\n        for k, v in meta.items():\n            if k in skip_keys:\n                continue\n            kf = k.replace(\"_\", \" \").title()\n            parts.append(f\"<b>{kf}:</b> {v}\")\n        # Show a few top-expressed genes\n        if expr:\n            top_genes = sorted(\n                [(g, float(expr.get(g, 0))) for g in genes],\n                key=lambda x: x[1], reverse=True\n            )[:5]\n            top_genes = [(g, v) for g, v in top_genes if v > 0]\n            if top_genes:\n                parts.append(\"<b>── Top genes ──</b>\")\n                for g, v in top_genes:\n                    parts.append(f\"{g}: {v:.2f}\")\n        hover_texts.append(\"<br>\".join(parts))\n\n    # Build the numeric array for the expression colour dimension (default = first gene)\n    if genes:\n        default_expr = [float(expr_by_bc.get(bc, {}).get(genes[0], 0)) for bc in barcodes]\n    else:\n        default_expr = None\n\n    # ---- Colour by cell type (default) ----\n    colours = [color_map[ct] for ct in labels]\n\n    # ---- Build figure ----\n    hoverlabel = dict(bgcolor=\"rgba(255,255,255,0.92)\",\n                      bordercolor=\"#ccc\",\n                      font=dict(size=11, family=\"sans-serif\"))\n\n    fig = go.Figure()\n\n    # Add the primary scatter trace\n    trace = go.Scattergl(\n        x=x_vals,\n        y=y_vals,\n        mode=\"markers\",\n        marker=dict(\n            color=colours,\n            size=3,\n            line=dict(width=0.3, color=\"rgba(0,0,0,0.3)\"),\n        ),\n        text=hover_texts,\n        hoverinfo=\"text\",\n        hoverlabel=hoverlabel,\n        name=\"\",\n        showlegend=False,\n    )\n    fig.add_trace(trace)\n\n    # ---- Legend entries for cell types (invisible traces) ----\n    for ct in unique_cts:\n        fig.add_trace(go.Scattergl(\n            x=[None], y=[None],\n            mode=\"markers\",\n            marker=dict(size=8, color=color_map[ct]),\n            name=ct,\n            showlegend=True,\n            hoverinfo=\"none\",\n        ))\n\n    # ---- Layout ----\n    fig.update_layout(\n        title=dict(\n            text=title,\n            x=0.02,\n            font=dict(size=18, family=\"Arial, sans-serif\"),\n        ),\n        xaxis=dict(\n            title=dict(text=\"UMAP 1\", font=dict(size=14)),\n            zeroline=False,\n            showgrid=True,\n            gridcolor=\"#eee\",\n            showspikes=True,\n            spikethickness=1,\n        ),\n        yaxis=dict(\n            title=dict(text=\"UMAP 2\", font=dict(size=14)),\n            zeroline=False,\n            showgrid=True,\n            gridcolor=\"#eee\",\n            showspikes=True,\n            spikethickness=1,\n        ),\n        hovermode=\"closest\",\n        dragmode=\"zoom\",\n        template=\"plotly_white\",\n        width=None,   # responsive\n        height=None,\n        margin=dict(l=60, r=30, t=60, b=60),\n        legend=dict(\n            title=dict(text=\"Cell Type\", font=dict(size=12)),\n            font=dict(size=10),\n            itemsizing=\"constant\",\n            x=1.02,\n            y=1,\n            xanchor=\"left\",\n            yanchor=\"top\",\n            bgcolor=\"rgba(255,255,255,0.7)\",\n        ),\n        updatemenus=[],\n    )\n\n    # ---- Dropdown menu: switch colour dimension ----\n    if genes:\n        buttons = [\n            dict(\n                label=\"Cell Type\",\n                method=\"restyle\",\n                args=[{\"marker.color\": [colours],\n                       \"marker.colorscale\": None,\n                       \"marker.cmin\": None,\n                       \"marker.cmax\": None,\n                       \"marker.colorbar\": None,\n                       \"marker.showscale\": False}],\n            )\n        ]\n\n        # Build a continuous colour scale\n        colorscale = \"Viridis\"\n\n        for gene in genes:\n            expr_vals_g = [\n                float(expr_by_bc.get(bc, {}).get(gene, 0)) for bc in barcodes\n            ]\n            vmin, vmax = min(expr_vals_g), max(expr_vals_g)\n            buttons.append(dict(\n                label=gene,\n                method=\"restyle\",\n                args=[{\n                    \"marker.color\": [expr_vals_g],\n                    \"marker.colorscale\": colorscale,\n                    \"marker.cmin\": vmin,\n                    \"marker.cmax\": vmax,\n                    \"marker.colorbar\": dict(\n                        title=dict(text=gene, font=dict(size=11)),\n                        thickness=15,\n                        len=0.5,\n                        x=1.0,\n                    ),\n                    \"marker.showscale\": True,\n                }],\n            ))\n\n        fig.update_layout(\n            updatemenus=[\n                dict(\n                    buttons=buttons,\n                    direction=\"down\",\n                    showactive=True,\n                    x=1.02,\n                    y=0.3,\n                    xanchor=\"left\",\n                    yanchor=\"top\",\n                    bgcolor=\"#f8f8f8\",\n                    bordercolor=\"#ccc\",\n                    font=dict(size=11),\n                )\n            ],\n            annotations=[\n                dict(\n                    text=\"Colour by:\",\n                    x=1.02,\n                    y=0.36,\n                    xanchor=\"left\",\n                    yanchor=\"bottom\",\n                    showarrow=False,\n                    font=dict(size=12),\n                ),\n                # attribution: how many cells shown\n                dict(\n                    text=f\"<i>{len(barcodes):,} cells</i>\",\n                    x=0.02,\n                    y=-0.04,\n                    xanchor=\"left\",\n                    yanchor=\"top\",\n                    showarrow=False,\n                    font=dict(size=11, color=\"#999\"),\n                    xref=\"paper\",\n                    yref=\"paper\",\n                ),\n            ],\n        )\n\n    return fig\n\n\n# ---------------------------------------------------------------------------\n#  CLI\n# ---------------------------------------------------------------------------\n\ndef parse_args(argv=None):\n    p = argparse.ArgumentParser(\n        description=\"Generate an interactive scRNA-seq UMAP HTML file.\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=textwrap.dedent(\"\"\"\\\n            Examples:\n              # Generate standalone HTML with synthetic demo data\n              %(prog)s --demo\n\n              # Use your own data\n              %(prog)s --umap_csv umap.csv --metadata_csv meta.csv --expression_csv expr.csv\n        \"\"\"),\n    )\n    p.add_argument(\"--demo\", action=\"store_true\",\n                   help=\"Use synthetic demo data instead of real CSVs\")\n    p.add_argument(\"--umap_csv\", help=\"CSV with UMAP coordinates\")\n    p.add_argument(\"--metadata_csv\", help=\"CSV with cell metadata (cell_type, condition, etc.)\")\n    p.add_argument(\"--expression_csv\", help=\"CSV with gene expression values (cells × genes)\")\n    p.add_argument(\"--genes\", nargs=\"*\", default=None,\n                   help=\"Specific genes to include (default: auto-detect from expression CSV)\")\n    p.add_argument(\"-o\", \"--output\", default=\"scrnaseq_umap.html\",\n                   help=\"Output HTML file path (default: scrnaseq_umap.html)\")\n    p.add_argument(\"--title\", default=\"scRNA-seq UMAP\",\n                   help=\"Plot title (default: scRNA-seq UMAP)\")\n    return p.parse_args(argv)\n\n\ndef main():\n    args = parse_args()\n\n    if args.demo:\n        print(\"Generating synthetic scRNA-seq data...\", file=sys.stderr)\n        umap_rows, meta_rows, expr_rows = _mk_demo_data()\n    else:\n        # Load from CSV files\n        if not args.umap_csv or not args.metadata_csv:\n            print(\"Error: --umap_csv and --metadata_csv are required (or use --demo).\",\n                  file=sys.stderr)\n            sys.exit(1)\n        print(\"Loading data...\", file=sys.stderr)\n        umap_rows = _load_csv(args.umap_csv)\n        meta_rows = _load_csv(args.metadata_csv)\n        expr_rows = _load_csv(args.expression_csv) if args.expression_csv else None\n\n    genes = args.genes\n    print(\"Building figure...\", file=sys.stderr)\n    fig = make_figure(umap_rows, meta_rows, expr_rows, genes=genes, title=args.title)\n\n    print(f\"Writing {args.output} ...\", file=sys.stderr)\n    fig.write_html(\n        args.output,\n        include_plotlyjs=\"cdn\",    # smaller file; needs internet on first load\n        # To embed plotly.js fully:  include_plotlyjs=True\n        full_html=True,\n        config={\n            \"displayModeBar\": True,\n            \"modeBarButtonsToAdd\": [\"hoverclosest\", \"hovercompare\"],\n            \"modeBarButtonsToRemove\": [\"sendDataToCloud\"],\n            \"displaylogo\": False,\n            \"responsive\": True,\n            \"scrollZoom\": True,\n        },\n        div_id=\"scrnaseq-umap\",\n        auto_open=False,\n    )\n    print(f\"✅ Done — open {args.output} in a browser.\", file=sys.stderr)\n\n\nif __name__ == \"__main__\":\n    main()\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/scrnaseq_umap_generator.py", "content": "#!/usr/bin/env python3\n\"\"\"\nInteractive scRNA-seq UMAP viewer — generates a standalone HTML file.\n\nProduces a Plotly-based interactive scatter plot of UMAP coordinates with:\n  - Colour by cell type (default) or by any gene via dropdown\n  - Hover tooltips: cell barcode, cell type, UMAP coords, top gene expression, metadata\n  - Legend, zoom/pan, and export as a self-contained HTML file\n\nUsage\n-----\n  # With synthetic demo data:\n  python scrnaseq_umap_generator.py --demo\n\n  # With real data (CSV format):\n  python scrnaseq_umap_generator.py \\\n      --umap_csv umap_coords.csv \\\n      --metadata_csv metadata.csv \\\n      --expression_csv expression.csv \\\n      --output interactive_umap.html\n\nCSV file formats (column names are flexible; the script auto-detects):\n  umap_coords.csv:  columns like \"barcode\" (or first column as index),\n                    \"UMAP_1\" / \"UMAP_2\" or \"x\" / \"y\"\n  metadata.csv:     columns like \"barcode\" (join key), \"cell_type\",\n                    plus any extra columns → shown in hover\n  expression.csv:   columns like \"barcode\" (join key),\n                    then one column per gene with numeric values (log-normalised)\n\"\"\"\n\nimport argparse\nimport csv\nimport itertools\nimport sys\nimport textwrap\nfrom pathlib import Path\n\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n#  Synthetic data generation (used when --demo is passed)\n# ---------------------------------------------------------------------------\n\nN_CELLS_DEMO = 3000\nN_GENES_DEMO = 8\n\n# Realistic marker genes per lineage\nMARKER_GENES = [\n    \"CD3D\",   # T cells\n    \"CD14\",   # Monocytes\n    \"CD19\",   # B cells\n    \"NKG7\",   # NK cells\n    \"FCGR3A\", # CD16+ Monocytes\n    \"CD8A\",   # CD8 T cells\n    \"CD4\",    # CD4 T cells\n    \"GZMB\",   # cytotoxic / NK\n    \"MS4A1\",  # B cells (CD20)\n    \"CST3\",   # Myeloid\n    \"GNLY\",   # NK / cytotoxic\n    \"CD79A\",  # B cells\n    \"LYZ\",    # Myeloid\n    \"IL7R\",   # CD4 T cells\n    \"FCER1A\", # DCs\n    \"PPBP\",   # Platelets\n]\n\nCELL_TYPES = [\n    \"CD4 T cell\",\n    \"CD8 T cell\",\n    \"NK cell\",\n    \"B cell\",\n    \"Monocyte (CD14+)\",\n    \"Monocyte (CD16+)\",\n    \"Dendritic cell\",\n    \"Platelet\",\n]\n\nCONDITIONS = [\"Control\", \"Treatment_A\", \"Treatment_B\"]\nPATIENTS = [f\"P{i:03d}\" for i in range(1, 13)]\nBATCHES = [\"B001\", \"B002\", \"B003\"]\n\n\ndef _make_blobs(centers, n_per_cluster, noise=0.6, seed=42):\n    \"\"\"Generate 2-D Gaussian blobs around *centers*.\"\"\"\n    rng = np.random.default_rng(seed)\n    n_clusters = len(centers)\n    pts_per = [n_per_cluster] * n_clusters\n    xs, ys = [], []\n    for (cx, cy), n in zip(centers, pts_per):\n        xs.append(rng.normal(cx, noise, n))\n        ys.append(rng.normal(cy, noise, n))\n    return np.concatenate(xs), np.concatenate(ys)\n\n\ndef _mk_demo_data():\n    \"\"\"\n    Return (umap_df, metadata_df, expression_df) as lists-of-dicts\n    representing a realistic scRNA-seq dataset.\n    \"\"\"\n    # ---- UMAP coords with some cluster separation ----\n    centers = [\n        (-4, 5),   # CD4 T\n        (-2, 6),   # CD8 T\n        (2, 6),    # NK\n        (5, 2),    # B\n        (-5, -2),  # CD14+ Mono\n        (-2, -4),  # CD16+ Mono\n        (3, -4),   # DC\n        (0, 0),    # Platelet\n    ]\n    n_ct = len(CELL_TYPES)\n    n_per = N_CELLS_DEMO // n_ct\n    extra = N_CELLS_DEMO - n_per * n_ct\n\n    xs, ys = _make_blobs(centers, n_per, noise=0.6, seed=42)\n\n    # Handle remainder\n    if extra > 0:\n        rng_extra = np.random.default_rng(42)\n        for i in range(extra):\n            cx, cy = centers[i % n_ct]\n            xs = np.append(xs, rng_extra.normal(cx, 0.6))\n            ys = np.append(ys, rng_extra.normal(cy, 0.6))\n\n    barcodes = [f\"AAACCCAAGCTCGCTA-{i}\" for i in range(len(xs))]\n\n    umap = [\n        {\"barcode\": bc, \"UMAP_1\": round(x, 4), \"UMAP_2\": round(y, 4)}\n        for bc, x, y in zip(barcodes, xs, ys)\n    ]\n\n    # ---- Metadata ----\n    rng_m = np.random.default_rng(123)\n    cell_type_list = []\n    ct_idx = 0\n    for i in range(len(barcodes)):\n        cell_type_list.append(CELL_TYPES[ct_idx])\n        if ct_idx < n_ct - 1 and (i + 1) % n_per == 0:\n            ct_idx += 1\n\n    metadata = [\n        {\n            \"barcode\": bc,\n            \"cell_type\": ct,\n            \"condition\": rng_m.choice(CONDITIONS),\n            \"patient\": rng_m.choice(PATIENTS),\n            \"batch\": rng_m.choice(BATCHES),\n            \"nCount_RNA\": int(rng_m.lognormal(3.5, 0.4)),\n            \"nFeature_RNA\": int(rng_m.lognormal(3.0, 0.3)),\n            \"percent_mito\": round(abs(rng_m.normal(5, 2)), 2),\n            \"S_score\": round(rng_m.normal(0, 0.5), 3),\n            \"G2M_score\": round(rng_m.normal(0, 0.5), 3),\n        }\n        for bc, ct in zip(barcodes, cell_type_list)\n    ]\n\n    # ---- Expression (log-normalised, realistic per cell type) ----\n    # build a mapping: cell_type -> list of highly-expressed genes and a\n    # background level for everything else\n    ct_gene_signal = {\n        \"CD4 T cell\":        {\"CD3D\": 4.2, \"CD4\": 3.8, \"IL7R\": 3.5, \"CD8A\": 0.5},\n        \"CD8 T cell\":        {\"CD3D\": 4.0, \"CD8A\": 4.5, \"GZMB\": 3.2, \"CD4\": 0.3},\n        \"NK cell\":           {\"NKG7\": 5.0, \"GNLY\": 4.8, \"GZMB\": 4.0, \"CD3D\": 1.2},\n        \"B cell\":            {\"CD19\": 4.5, \"MS4A1\": 4.3, \"CD79A\": 4.0, \"CD3D\": 0.2},\n        \"Monocyte (CD14+)\":  {\"CD14\": 5.0, \"CST3\": 3.8, \"LYZ\": 4.5, \"FCGR3A\": 0.5},\n        \"Monocyte (CD16+)\":  {\"FCGR3A\": 4.8, \"CST3\": 3.5, \"LYZ\": 4.0, \"CD14\": 0.8},\n        \"Dendritic cell\":    {\"FCER1A\": 4.5, \"CST3\": 4.2, \"CD14\": 1.5, \"FCGR3A\": 2.0},\n        \"Platelet\":          {\"PPBP\": 5.5, \"CD3D\": 0.3, \"CD14\": 0.2},\n    }\n\n    # All genes that appear in any cell type\n    all_genes_set = set()\n    for v in ct_gene_signal.values():\n        all_genes_set.update(v.keys())\n    # Pick 8 of the most informative genes for the default view, keep the rest\n    # for the dropdown\n    DISPLAY_GENES = sorted(all_genes_set)\n\n    rng_e = np.random.default_rng(456)\n    expression = []\n    for bc, ct in zip(barcodes, cell_type_list):\n        row = {\"barcode\": bc}\n        sig = ct_gene_signal.get(ct, {})\n        for gene in DISPLAY_GENES:\n            mean_expr = sig.get(gene, 0.0)\n            if mean_expr > 0:\n                # Positive expression with realistic variance\n                val = rng_e.gamma(mean_expr * 2, 0.4)\n                val = max(0, val)\n            else:\n                # Background / dropout\n                val = rng_e.exponential(0.2) if rng_e.random() > 0.6 else 0.0\n            row[gene] = round(val, 3)\n        expression.append(row)\n\n    return umap, metadata, expression\n\n\n# ---------------------------------------------------------------------------\n#  Load real data from CSVs\n# ---------------------------------------------------------------------------\n\ndef _load_csv(path):\n    \"\"\"Read a CSV and return a list of dicts (lowercased keys).\"\"\"\n    with open(path) as f:\n        reader = csv.DictReader(f)\n        rows = []\n        for row in reader:\n            rows.append({k.strip().lower(): v.strip() for k, v in row.items()})\n    if not rows:\n        print(f\"Warning: {path} is empty.\", file=sys.stderr)\n    return rows\n\n\ndef _detect_umap_cols(row):\n    \"\"\"Return (x_col, y_col) from a UMAP row dict.\"\"\"\n    keys = list(row.keys())\n    for xc in (\"umap_1\", \"x\", \"umap1\", \"umap-1\", \"umap1\"):\n        if xc in keys:\n            break\n    else:\n        print(f\"UMAP columns not found. Keys: {keys}\", file=sys.stderr)\n        sys.exit(1)\n    for yc in (\"umap_2\", \"y\", \"umap2\", \"umap-2\", \"umap2\"):\n        if yc in keys:\n            break\n    else:\n        print(f\"UMAP y-column not found. Keys: {keys}\", file=sys.stderr)\n        sys.exit(1)\n    return xc, yc\n\n\ndef _detect_barcode_col(rows, fallback=None):\n    \"\"\"Return the name of the barcode / cell-ID column.\"\"\"\n    keys = rows[0].keys()\n    for candidate in (\"barcode\", \"cell\", \"cell_id\", \"cellid\", \"index\"):\n        if candidate in keys:\n            return candidate\n    # first column that looks like a cell barcode (contains -)\n    if fallback:\n        return fallback\n    # just use the first column\n    return list(keys)[0]\n\n\ndef _detect_cell_type_col(rows):\n    \"\"\"Return the name of the cell-type column.\"\"\"\n    keys = rows[0].keys()\n    for candidate in (\"cell_type\", \"celltype\", \"cluster\", \"annotation\",\n                      \"label\", \"identity\"):\n        if candidate in keys:\n            return candidate\n    return None\n\n\n# ---------------------------------------------------------------------------\n#  Build the Plotly figure\n# ---------------------------------------------------------------------------\n\ntry:\n    import plotly.graph_objects as go\n    import plotly.express as px\n    from plotly.subplots import make_subplots\nexcept ImportError:\n    print(\"This script requires plotly. Install with: pip install plotly\", file=sys.stderr)\n    sys.exit(1)\n\n\n# A colourblind-friendly qualitative palette (Wong, 2011)\nCT_COLORS = {\n    \"CD4 T cell\":        \"#0072B2\",  # blue\n    \"CD8 T cell\":        \"#56B4E9\",  # sky blue\n    \"NK cell\":           \"#009E73\",  # green\n    \"B cell\":            \"#F0E442\",  # yellow\n    \"Monocyte (CD14+)\":  \"#D55E00\",  # vermillion\n    \"Monocyte (CD16+)\":  \"#E69F00\",  # orange\n    \"Dendritic cell\":    \"#CC79A7\",  # pink\n    \"Platelet\":          \"#000000\",  # black\n}\n\n# Fallback palette for unknown cell types\nFALLBACK_PALETTE = px.colors.qualitative.Set3\n\n\ndef _build_hover(colours, ct_col, meta_rows_by_bc):\n    \"\"\"Build rich hover text for each point.\"\"\"\n    hover_texts = []\n    for ct, bc in zip(colours[\"label\"], colours[\"barcodes\"]):\n        meta = meta_rows_by_bc.get(bc, {})\n        parts = [\n            f\"<b>{bc}</b>\",\n            f\"Cell type: {ct}\",\n        ]\n        for k, v in meta.items():\n            kf = k.replace(\"_\", \" \").title()\n            parts.append(f\"{kf}: {v}\")\n        hover_texts.append(\"<br>\".join(parts))\n    return hover_texts\n\n\ndef make_figure(umap_rows, metadata_rows, expression_rows, genes=None,\n                title=\"scRNA-seq UMAP\"):\n    \"\"\"\n    Build a Plotly figure from parsed data.\n\n    Parameters\n    ----------\n    umap_rows : list[dict]\n    metadata_rows : list[dict]\n    expression_rows : list[dict] | None\n    genes : list[str] | None — genes to include in hover and dropdown.\n            If None, auto-detect from expression data.\n    title : str\n    \"\"\"\n    # ---- Detect columns ----\n    bc_col_umap = _detect_barcode_col(umap_rows)\n    xc, yc = _detect_umap_cols(umap_rows)\n\n    bc_col_meta = _detect_barcode_col(metadata_rows, fallback=bc_col_umap)\n    ct_col = _detect_cell_type_col(metadata_rows)\n\n    if expression_rows:\n        bc_col_expr = _detect_barcode_col(expression_rows, fallback=bc_col_umap)\n    else:\n        bc_col_expr = None\n\n    # ---- Build lookup dicts ----\n    meta_by_bc = {r[bc_col_meta]: r for r in metadata_rows}\n    expr_by_bc = {r[bc_col_expr]: r for r in expression_rows} if expression_rows else {}\n\n    # ---- Determine the gene list ----\n    if genes is None and expression_rows:\n        # exclude the barcode column\n        keys = list(expression_rows[0].keys())\n        genes = [k for k in keys if k != bc_col_expr]\n        # limit to e.g. 20 genes to keep the dropdown manageable\n        if len(genes) > 20:\n            # pick the most variable (by variance across cells)\n            expr_vals = {g: [] for g in genes}\n            for row in expression_rows:\n                for g in genes:\n                    try:\n                        expr_vals[g].append(float(row[g]))\n                    except (ValueError, KeyError):\n                        expr_vals[g].append(0.0)\n            variances = [(g, np.var(expr_vals[g])) for g in genes]\n            variances.sort(key=lambda x: x[1], reverse=True)\n            genes = [g for g, _ in variances[:20]]\n    genes = genes or []\n\n    # ---- Build trace data ----\n    barcodes = [r[bc_col_umap] for r in umap_rows]\n    x_vals = [float(r[xc]) for r in umap_rows]\n    y_vals = [float(r[yc]) for r in umap_rows]\n\n    # Cell type labels\n    if ct_col:\n        labels = [meta_by_bc.get(bc, {}).get(ct_col, \"Unknown\") for bc in barcodes]\n    else:\n        labels = [\"Unknown\"] * len(barcodes)\n\n    # Colour mapping for cell types\n    unique_cts = sorted(set(labels))\n    palette = itertools.cycle(FALLBACK_PALETTE)\n    color_map = {}\n    for ct in unique_cts:\n        if ct in CT_COLORS:\n            color_map[ct] = CT_COLORS[ct]\n        else:\n            color_map[ct] = next(palette)\n\n    # ---- Build hover text ----\n    hover_texts = []\n    for bc, ct in zip(barcodes, labels):\n        meta = meta_by_bc.get(bc, {})\n        expr = expr_by_bc.get(bc, {})\n        parts = [\n            f\"<b>{bc}</b>\",\n            f\"<b>Cell type:</b> {ct}\",\n            f\"UMAP_1: {meta.get(xc, '')}\",\n            f\"UMAP_2: {meta.get(yc, '')}\",\n        ]\n        # Show metadata fields (skip barcode, umap coords, cell type)\n        skip_keys = {bc_col_meta, bc_col_umap, xc, yc, ct_col, \"barcode\"}\n        for k, v in meta.items():\n            if k in skip_keys:\n                continue\n            kf = k.replace(\"_\", \" \").title()\n            parts.append(f\"<b>{kf}:</b> {v}\")\n        # Show a few top-expressed genes\n        if expr:\n            top_genes = sorted(\n                [(g, float(expr.get(g, 0))) for g in genes],\n                key=lambda x: x[1], reverse=True\n            )[:5]\n            top_genes = [(g, v) for g, v in top_genes if v > 0]\n            if top_genes:\n                parts.append(\"<b>── Top genes ──</b>\")\n                for g, v in top_genes:\n                    parts.append(f\"{g}: {v:.2f}\")\n        hover_texts.append(\"<br>\".join(parts))\n\n    # Build the numeric array for the expression colour dimension (default = first gene)\n    if genes:\n        default_expr = [float(expr_by_bc.get(bc, {}).get(genes[0], 0)) for bc in barcodes]\n    else:\n        default_expr = None\n\n    # ---- Colour by cell type (default) ----\n    colours = [color_map[ct] for ct in labels]\n\n    # ---- Build figure ----\n    hoverlabel = dict(bgcolor=\"rgba(255,255,255,0.92)\",\n                      bordercolor=\"#ccc\",\n                      font=dict(size=11, family=\"sans-serif\"))\n\n    fig = go.Figure()\n\n    # Add the primary scatter trace\n    trace = go.Scattergl(\n        x=x_vals,\n        y=y_vals,\n        mode=\"markers\",\n        marker=dict(\n            color=colours,\n            size=3,\n            line=dict(width=0.3, color=\"rgba(0,0,0,0.3)\"),\n        ),\n        text=hover_texts,\n        hoverinfo=\"text\",\n        hoverlabel=hoverlabel,\n        name=\"\",\n        showlegend=False,\n    )\n    fig.add_trace(trace)\n\n    # ---- Legend entries for cell types (invisible traces) ----\n    for ct in unique_cts:\n        fig.add_trace(go.Scattergl(\n            x=[None], y=[None],\n            mode=\"markers\",\n            marker=dict(size=8, color=color_map[ct]),\n            name=ct,\n            showlegend=True,\n            hoverinfo=\"none\",\n        ))\n\n    # ---- Layout ----\n    fig.update_layout(\n        title=dict(\n            text=title,\n            x=0.02,\n            font=dict(size=18, family=\"Arial, sans-serif\"),\n        ),\n        xaxis=dict(\n            title=dict(text=\"UMAP 1\", font=dict(size=14)),\n            zeroline=False,\n            showgrid=True,\n            gridcolor=\"#eee\",\n            showspikes=True,\n            spikethickness=1,\n        ),\n        yaxis=dict(\n            title=dict(text=\"UMAP 2\", font=dict(size=14)),\n            zeroline=False,\n            showgrid=True,\n            gridcolor=\"#eee\",\n            showspikes=True,\n            spikethickness=1,\n        ),\n        hovermode=\"closest\",\n        dragmode=\"zoom\",\n        template=\"plotly_white\",\n        width=None,   # responsive\n        height=None,\n        margin=dict(l=60, r=30, t=60, b=60),\n        legend=dict(\n            title=dict(text=\"Cell Type\", font=dict(size=12)),\n            font=dict(size=10),\n            itemsizing=\"constant\",\n            x=1.02,\n            y=1,\n            xanchor=\"left\",\n            yanchor=\"top\",\n            bgcolor=\"rgba(255,255,255,0.7)\",\n        ),\n        updatemenus=[],\n    )\n\n    # ---- Dropdown menu: switch colour dimension ----\n    if genes:\n        buttons = [\n            dict(\n                label=\"Cell Type\",\n                method=\"restyle\",\n                args=[{\"marker.color\": [colours],\n                       \"marker.colorscale\": None,\n                       \"marker.cmin\": None,\n                       \"marker.cmax\": None,\n                       \"marker.colorbar\": None,\n                       \"marker.showscale\": False}],\n            )\n        ]\n\n        # Build a continuous colour scale\n        colorscale = \"Viridis\"\n\n        for gene in genes:\n            expr_vals_g = [\n                float(expr_by_bc.get(bc, {}).get(gene, 0)) for bc in barcodes\n            ]\n            vmin, vmax = min(expr_vals_g), max(expr_vals_g)\n            buttons.append(dict(\n                label=gene,\n                method=\"restyle\",\n                args=[{\n                    \"marker.color\": [expr_vals_g],\n                    \"marker.colorscale\": colorscale,\n                    \"marker.cmin\": vmin,\n                    \"marker.cmax\": vmax,\n                    \"marker.colorbar\": dict(\n                        title=dict(text=gene, font=dict(size=11)),\n                        thickness=15,\n                        len=0.5,\n                        x=1.0,\n                    ),\n                    \"marker.showscale\": True,\n                }],\n            ))\n\n        fig.update_layout(\n            updatemenus=[\n                dict(\n                    buttons=buttons,\n                    direction=\"down\",\n                    showactive=True,\n                    x=1.02,\n                    y=0.3,\n                    xanchor=\"left\",\n                    yanchor=\"top\",\n                    bgcolor=\"#f8f8f8\",\n                    bordercolor=\"#ccc\",\n                    font=dict(size=11),\n                )\n            ],\n            annotations=[\n                dict(\n                    text=\"Colour by:\",\n                    x=1.02,\n                    y=0.36,\n                    xanchor=\"left\",\n                    yanchor=\"bottom\",\n                    showarrow=False,\n                    font=dict(size=12),\n                ),\n                # attribution: how many cells shown\n                dict(\n                    text=f\"<i>{len(barcodes):,} cells</i>\",\n                    x=0.02,\n                    y=-0.04,\n                    xanchor=\"left\",\n                    yanchor=\"top\",\n                    showarrow=False,\n                    font=dict(size=11, color=\"#999\"),\n                    xref=\"paper\",\n                    yref=\"paper\",\n                ),\n            ],\n        )\n\n    return fig\n\n\n# ---------------------------------------------------------------------------\n#  CLI\n# ---------------------------------------------------------------------------\n\ndef parse_args(argv=None):\n    p = argparse.ArgumentParser(\n        description=\"Generate an interactive scRNA-seq UMAP HTML file.\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=textwrap.dedent(\"\"\"\\\n            Examples:\n              # Generate standalone HTML with synthetic demo data\n              %(prog)s --demo\n\n              # Use your own data\n              %(prog)s --umap_csv umap.csv --metadata_csv meta.csv --expression_csv expr.csv\n        \"\"\"),\n    )\n    p.add_argument(\"--demo\", action=\"store_true\",\n                   help=\"Use synthetic demo data instead of real CSVs\")\n    p.add_argument(\"--umap_csv\", help=\"CSV with UMAP coordinates\")\n    p.add_argument(\"--metadata_csv\", help=\"CSV with cell metadata (cell_type, condition, etc.)\")\n    p.add_argument(\"--expression_csv\", help=\"CSV with gene expression values (cells × genes)\")\n    p.add_argument(\"--genes\", nargs=\"*\", default=None,\n                   help=\"Specific genes to include (default: auto-detect from expression CSV)\")\n    p.add_argument(\"-o\", \"--output\", default=\"scrnaseq_umap.html\",\n                   help=\"Output HTML file path (default: scrnaseq_umap.html)\")\n    p.add_argument(\"--title\", default=\"scRNA-seq UMAP\",\n                   help=\"Plot title (default: scRNA-seq UMAP)\")\n    return p.parse_args(argv)\n\n\ndef main():\n    args = parse_args()\n\n    if args.demo:\n        print(\"Generating synthetic scRNA-seq data...\", file=sys.stderr)\n        umap_rows, meta_rows, expr_rows = _mk_demo_data()\n    else:\n        # Load from CSV files\n        if not args.umap_csv or not args.metadata_csv:\n            print(\"Error: --umap_csv and --metadata_csv are required (or use --demo).\",\n                  file=sys.stderr)\n            sys.exit(1)\n        print(\"Loading data...\", file=sys.stderr)\n        umap_rows = _load_csv(args.umap_csv)\n        meta_rows = _load_csv(args.metadata_csv)\n        expr_rows = _load_csv(args.expression_csv) if args.expression_csv else None\n\n    genes = args.genes\n    print(\"Building figure...\", file=sys.stderr)\n    fig = make_figure(umap_rows, meta_rows, expr_rows, genes=genes, title=args.title)\n\n    print(f\"Writing {args.output} ...\", file=sys.stderr)\n    fig.write_html(\n        args.output,\n        include_plotlyjs=\"cdn\",    # smaller file; needs internet on first load\n        # To embed plotly.js fully:  include_plotlyjs=True\n        full_html=True,\n        config={\n            \"displayModeBar\": True,\n            \"modeBarButtonsToAdd\": [\"hoverclosest\", \"hovercompare\"],\n            \"modeBarButtonsToRemove\": [\"sendDataToCloud\"],\n            \"displaylogo\": False,\n            \"responsive\": True,\n            \"scrollZoom\": True,\n        },\n        div_id=\"scrnaseq-umap\",\n        auto_open=False,\n    )\n    print(f\"✅ Done — open {args.output} in a browser.\", file=sys.stderr)\n\n\nif __name__ == \"__main__\":\n    main()\n"})
