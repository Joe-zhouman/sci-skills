TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure2_scrnaseq.py", "content": "#!/usr/bin/env python3\n\"\"\"\nFigure 2: Single-cell RNA-seq analysis for Cell journal submission\n  - Panel a: 100% stacked bar chart – cluster proportions by condition (Control vs Treatment)\n  - Panel b: Volcano plot – differentially expressed genes\n\nUnified colorblind-safe palette. Cell journal formatting standards.\nOutput: figure2.pdf, figure2.png (300 dpi)\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.ticker as mticker\nfrom matplotlib.patches import FancyBboxPatch\nimport seaborn as sns\nimport warnings\nwarnings.filterwarnings('ignore', category=UserWarning)\n\n# =============================================================================\n# 0. GLOBAL STYLE — Cell journal standards\n# =============================================================================\n\n# Cell uses Arial as default; Helvetica is the closest Type-1 standard\nplt.rcParams.update({\n    'font.family':       'sans-serif',\n    'font.sans-serif':   ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size':         7,            # Cell figure text is 6-8 pt\n    'axes.titlesize':    8,\n    'axes.labelsize':    7,\n    'xtick.labelsize':   6.5,\n    'ytick.labelsize':   6.5,\n    'legend.fontsize':   6,\n    'figure.dpi':        300,\n    'savefig.dpi':       300,\n    'savefig.bbox':      'tight',\n    'axes.linewidth':    0.6,\n    'xtick.major.width': 0.5,\n    'ytick.major.width': 0.5,\n    'xtick.major.size':  2.5,\n    'ytick.major.size':  2.5,\n    'xtick.direction':   'out',\n    'ytick.direction':   'out',\n    'axes.spines.top':   False,\n    'axes.spines.right': False,\n})\n\n# ── Colorblind-safe qualitative palette (Wong, 2011) ────────────────────────\nCLUSTER_COLORS = [\n    '#0072B2',  # blue\n    '#E69F00',  # orange\n    '#009E73',  # green\n    '#CC79A7',  # pink\n    '#56B4E9',  # sky blue\n    '#F0E442',  # yellow\n    '#D55E00',  # vermillion\n    '#000000',  # black\n    '#999999',  # grey\n    '#882255',  # wine\n    '#44AA99',  # teal\n    '#AA4499',  # purple\n]\n\n# Volcano highlight colors\nVOLCANO_UP   = '#CC0000'   # up-regulated\nVOLCANO_DOWN = '#0072B2'   # down-regulated\nVOLCANO_NS   = '#999999'   # not significant\n\nOUTPUT_DIR  = '/home/joe/Documents/repo/skill/sci-draw'\n\n\n# =============================================================================\n# 1. DATA GENERATION (REPLACE with your real data)\n# =============================================================================\n\ndef generate_cluster_data(n_cells=5000, random_seed=42):\n    \"\"\"\n    Generate synthetic scRNA-seq cluster assignments and conditions.\n\n    Replace this function with:\n      metadata = pd.read_csv('path/to/metadata.csv')\n    Your metadata should have columns: ['cell_barcode', 'cluster', 'condition']\n    \"\"\"\n    rng = np.random.default_rng(random_seed)\n    n_clusters = 8\n    cluster_names = [f'C{i}' for i in range(n_clusters)]\n\n    # Create cell barcodes\n    barcodes = [f'cell_{i:06d}' for i in range(n_cells)]\n\n    # Assign cells evenly to conditions\n    conditions = ['Control'] * (n_cells // 2) + ['Treatment'] * (n_cells // 2)\n    rng.shuffle(conditions)\n\n    # Simulate condition-specific cluster abundance shifts\n    # Control: clusters are roughly equal\n    # Treatment: some clusters expand, some contract\n    control_probs = np.array([0.15, 0.12, 0.18, 0.10, 0.14, 0.13, 0.09, 0.09])\n    control_probs = control_probs / control_probs.sum()\n    treatment_probs = np.array([0.25, 0.05, 0.08, 0.22, 0.06, 0.18, 0.04, 0.12])\n    treatment_probs = treatment_probs / treatment_probs.sum()\n\n    clusters = []\n    for cond in conditions:\n        if cond == 'Control':\n            clusters.append(rng.choice(cluster_names, p=control_probs))\n        else:\n            clusters.append(rng.choice(cluster_names, p=treatment_probs))\n\n    metadata = pd.DataFrame({\n        'cell_barcode': barcodes,\n        'cluster':      clusters,\n        'condition':    conditions,\n    })\n    return metadata\n\n\ndef generate_degs_data(random_seed=42):\n    \"\"\"\n    Generate synthetic differential expression results.\n\n    Replace this function with:\n      degs = pd.read_csv('path/to/deseq2_results.csv')\n    Your DEG table should have columns:\n      ['gene', 'log2FoldChange', 'pvalue', 'padj']\n    \"\"\"\n    rng = np.random.default_rng(random_seed)\n    n_genes = 2000\n\n    gene_names = [f'GENE_{i}' for i in range(n_genes)]\n\n    # Background: mostly null distribution\n    # Add some truly DE genes\n    log2fc = rng.normal(0, 0.8, n_genes)\n\n    # Inject 80 differentially expressed genes\n    n_de = 80\n    de_idx = rng.choice(n_genes, n_de, replace=False)\n    half = n_de // 2\n\n    # Up-regulated\n    log2fc[de_idx[:half]] = rng.uniform(0.8, 3.5, half) * rng.choice([1, 1, 1, -1], half)\n    # Down-regulated\n    log2fc[de_idx[half:]] = rng.uniform(-3.5, -0.8, n_de - half)\n\n    # Compute p-values\n    pvalues = np.ones(n_genes)\n    for i in range(n_genes):\n        if abs(log2fc[i]) > 0.5:\n            # Make DE genes significant\n            z = abs(log2fc[i]) / 0.3 + rng.exponential(0.5)\n            pvalues[i] = 2 * (1 - rng.normal(0, 1).cdf(z))\n        else:\n            pvalues[i] = rng.uniform(0.05, 1.0)\n\n    # Actually compute p-values properly\n    from scipy.stats import norm\n    pvalues = np.array([\n        2 * (1 - norm.cdf(abs(log2fc[i]) / 0.3 + rng.exponential(0.5)))\n        if abs(log2fc[i]) > 0.5\n        else rng.uniform(0.05, 1.0)\n        for i in range(n_genes)\n    ])\n\n    # BH correction\n    from scipy.stats import false_discovery_control\n    padj = np.minimum(false_discovery_control(pvalues, method='bh'), 1.0)\n\n    degs = pd.DataFrame({\n        'gene':           gene_names,\n        'log2FoldChange': log2fc,\n        'pvalue':         pvalues,\n        'padj':           padj,\n    })\n\n    # Label some interesting genes for the volcano plot\n    top_up = degs[(degs['padj'] < 0.01) & (degs['log2FoldChange'] > 1)].head(8)\n    top_down = degs[(degs['padj'] < 0.01) & (degs['log2FoldChange'] < -1)].head(8)\n\n    # Name the top genes with real gene names for visual appeal\n    real_names = [\n        'CD8A', 'GZMB', 'PRF1', 'IFNG', 'CCL5', 'NKG7', 'GZMK', 'GZMH',\n        'IL7R', 'CCR7', 'TCF7', 'LEF1', 'SELL', 'FOXP3', 'CTLA4', 'TIGIT',\n    ]\n    for i, (idx, row) in enumerate(top_up.iterrows()):\n        degs.loc[idx, 'gene'] = real_names[i]\n    for i, (idx, row) in enumerate(top_down.iterrows()):\n        degs.loc[idx, 'gene'] = real_names[len(top_up) + i]\n\n    return degs\n\n\n# =============================================================================\n# 2. FIGURE 2a — STACKED BAR CHART\n# =============================================================================\n\ndef plot_stacked_bar(metadata, colors, ax):\n    \"\"\"100% stacked bar of cluster proportions per condition.\"\"\"\n\n    # ── Compute proportions ────────────────────────────────────────────\n    ct = pd.crosstab(metadata['cluster'], metadata['condition'],\n                     normalize='columns') * 100\n\n    # Sort clusters by Control proportion (descending)\n    ct = ct.sort_values('Control', ascending=False)\n\n    # ── Reformat to long format for seaborn barplot ────────────────────\n    plot_data = ct.reset_index().melt(id_vars='cluster',\n                                       var_name='condition',\n                                       value_name='proportion')\n\n    # ── Build the 100% stacked bar ──────────────────────────────��──────\n    conditions = ['Control', 'Treatment']\n    clusters   = ct.index.tolist()\n\n    bar_width = 0.50\n    x_pos = np.arange(len(conditions))\n\n    bottom = np.zeros(len(conditions))\n    bars = []\n\n    cluster_color_map = {c: colors[i % len(colors)]\n                         for i, c in enumerate(clusters)}\n\n    for cluster in clusters:\n        props = [ct.loc[cluster, cond] for cond in conditions]\n        b = ax.bar(x_pos, props, bar_width, bottom=bottom,\n                   color=cluster_color_map[cluster],\n                   linewidth=0.3, edgecolor='white', label=cluster)\n        bars.append(b)\n        bottom += props\n\n    # ── Labels & aesthetics ────────────────────────────────────────────\n    ax.set_xticks(x_pos)\n    ax.set_xticklabels(conditions, fontweight='bold')\n    ax.set_ylabel('Proportion of cells (%)', fontweight='bold')\n    ax.set_ylim(0, 105)\n    ax.yaxis.set_major_locator(mticker.MultipleLocator(20))\n\n    # ── Legend outside the plot ────────────────────────────────────────\n    legend = ax.legend(\n        loc='upper left', bbox_to_anchor=(1.02, 1),\n        frameon=True, framealpha=0.9, edgecolor='#CCCCCC',\n        title='Cluster', title_fontsize=6.5,\n        handlelength=0.7, handletextpad=0.5,\n        borderpad=0.3, columnspacing=0.6,\n    )\n    legend.get_frame().set_linewidth(0.4)\n\n    # ── Panel label ────────────────────────────────────────────────────\n    ax.text(-0.18, 1.05, 'A', transform=ax.transAxes,\n            fontsize=9, fontweight='bold',\n            va='bottom', ha='left')\n\n    return ax\n\n\n# =============================================================================\n# 3. FIGURE 2b — VOLCANO PLOT\n# =============================================================================\n\ndef plot_volcano(degs, colors, ax):\n    \"\"\"Volcano plot with highlighted DE genes and top gene labels.\"\"\"\n\n    # ── Classify genes ─────────────────────────────────────────────────\n    log2fc_cutoff  = 0.585   # 1.5-fold\n    pval_cutoff    = 0.01    # -log10 ≈ 2\n\n    degs = degs.copy()\n    degs['-log10_padj'] = -np.log10(degs['padj'].clip(lower=1e-300))\n\n    conditions = []\n    for _, row in degs.iterrows():\n        if row['padj'] < pval_cutoff and row['log2FoldChange'] > log2fc_cutoff:\n            conditions.append('Up')\n        elif row['padj'] < pval_cutoff and row['log2FoldChange'] < -log2fc_cutoff:\n            conditions.append('Down')\n        else:\n            conditions.append('NS')\n    degs['regulation'] = conditions\n\n    # Counts for annotation\n    n_up   = (degs['regulation'] == 'Up').sum()\n    n_down = (degs['regulation'] == 'Down').sum()\n\n    # ── Scatter ────────────────────────────────────────────────────────\n    color_map = {'Up': VOLCANO_UP, 'Down': VOLCANO_DOWN, 'NS': VOLCANO_NS}\n\n    for reg_type in ['NS', 'Up', 'Down']:\n        subset = degs[degs['regulation'] == reg_type]\n        ax.scatter(\n            subset['log2FoldChange'], subset['-log10_padj'],\n            c=color_map[reg_type], s=4 if reg_type == 'NS' else 8,\n            alpha=0.6 if reg_type == 'NS' else 0.85,\n            edgecolors='none', rasterized=True,\n            label=f'{reg_type} (n={n_up if reg_type==\"Up\" else n_down if reg_type==\"Down\" else \"\"})',\n        )\n\n    # ── Threshold lines ────────────────────────────────────────────────\n    ax.axhline(-np.log10(pval_cutoff), ls='--', lw=0.4, color='#888888')\n    ax.axvline(-log2fc_cutoff, ls='--', lw=0.4, color='#888888')\n    ax.axvline(log2fc_cutoff,  ls='--', lw=0.4, color='#888888')\n\n    # ── Label top DE genes ─────────────────────────────────────────────\n    top_genes = pd.concat([\n        degs[degs['regulation'] == 'Up'].nsmallest(6, 'padj'),\n        degs[degs['regulation'] == 'Down'].nsmallest(6, 'padj'),\n    ])\n\n    # Offset label positions to avoid overlaps\n    offsets_x = {\n        'CD8A': 0.25, 'GZMB': 0.25, 'PRF1': 0.25, 'IFNG': 0.35,\n        'IL7R': -0.35, 'CCR7': -0.35, 'TCF7': -0.35, 'LEF1': -0.35,\n    }\n    offsets_y = {\n        'CD8A': 2, 'GZMB': -2, 'PRF1': 2, 'IFNG': -2,\n        'IL7R': 2, 'CCR7': -2, 'TCF7': 2, 'LEF1': -2,\n    }\n\n    for _, gene in top_genes.iterrows():\n        off_x = offsets_x.get(gene['gene'], 0.2)\n        off_y = offsets_y.get(gene['gene'], 1)\n        ax.annotate(\n            gene['gene'],\n            xy=(gene['log2FoldChange'], gene['-log10_padj']),\n            xytext=(off_x, off_y), textcoords='offset points',\n            fontsize=6, fontweight='bold',\n            color='#333333',\n            arrowprops=dict(arrowstyle='-', color='#AAAAAA', lw=0.3),\n            va='bottom', ha='left' if gene['log2FoldChange'] > 0 else 'right',\n        )\n\n    # ── Labels & axes ──────────────────────────────────────────────────\n    ax.set_xlabel(r'log$_2$(Fold Change)', fontweight='bold')\n    ax.set_ylabel(r'$-$log$_{10}$(adjusted $p$)', fontweight='bold')\n\n    # Symmetric x-axis\n    max_lfc = max(abs(degs['log2FoldChange'].quantile(0.99)),\n                  abs(degs['log2FoldChange'].quantile(0.01))) + 0.5\n    ax.set_xlim(-max_lfc, max_lfc)\n\n    # ── Legend ─────────────────────────────────────────────────────────\n    legend = ax.legend(\n        loc='upper right', frameon=True, framealpha=0.9,\n        edgecolor='#CCCCCC', fontsize=6,\n        handlelength=0.7, handletextpad=0.4,\n        borderpad=0.3,\n    )\n    legend.get_frame().set_linewidth(0.4)\n\n    # ── Panel label ────────────────────────────────────────────────────\n    ax.text(-0.18, 1.05, 'B', transform=ax.transAxes,\n            fontsize=9, fontweight='bold',\n            va='bottom', ha='left')\n\n    return ax\n\n\n# =============================================================================\n# 4. ASSEMBLE FIGURE 2\n# =============================================================================\n\ndef main():\n    print(\"→ Generating synthetic scRNA-seq data...\")\n    metadata = generate_cluster_data(n_cells=5000, random_seed=42)\n    degs     = generate_degs_data(random_seed=42)\n\n    print(f\"   Cells: {len(metadata)} | Clusters: {metadata['cluster'].nunique()} | \"\n          f\"Genes tested: {len(degs)} | DE genes: {(degs['padj'] < 0.01).sum()}\")\n\n    # ── Create figure — Cell journal: single-column ~85 mm wide ──────\n    # Cell full page is ~174 mm. Single column ~85 mm.\n    panel_width  = 85 / 25.4   # inches   ? 85 mm -> inches\n    panel_height = 70 / 25.4   # inches\n\n    fig, (ax_bar, ax_volc) = plt.subplots(\n        1, 2, figsize=(panel_width * 2 + 0.3, panel_height),\n        gridspec_kw={'width_ratios': [1, 1.15], 'wspace': 0.50},\n    )\n\n    # ── Plot ───────────────────────────────────────────────────────────\n    print(\"→ Panel A: Stacked bar chart – cluster proportions...\")\n    plot_stacked_bar(metadata, CLUSTER_COLORS, ax_bar)\n\n    print(\"→ Panel B: Volcano plot – differential expression...\")\n    plot_volcano(degs, CLUSTER_COLORS, ax_volc)\n\n    # ── Export ─────────────────────────────────────────────────────────\n    pdf_path = f'{OUTPUT_DIR}/figure2.pdf'\n    png_path = f'{OUTPUT_DIR}/figure2.png'\n\n    fig.savefig(pdf_path, dpi=300, bbox_inches='tight',\n                transparent=False, facecolor='white')\n    fig.savefig(png_path, dpi=300, bbox_inches='tight',\n                transparent=False, facecolor='white')\n\n    plt.close(fig)\n    print(f\"\\n✓ Figure 2 saved to:\")\n    print(f\"  {pdf_path}\")\n    print(f\"  {png_path}\")\n\n\nif __name__ == '__main__':\n    main()\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure2_scrnaseq.py", "content": "#!/usr/bin/env python3\n\"\"\"\nFigure 2: Single-cell RNA-seq analysis for Cell journal submission\n  - Panel a: 100% stacked bar chart – cluster proportions by condition (Control vs Treatment)\n  - Panel b: Volcano plot – differentially expressed genes\n\nUnified colorblind-safe palette. Cell journal formatting standards.\nOutput: figure2.pdf, figure2.png (300 dpi)\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.ticker as mticker\nfrom matplotlib.patches import FancyBboxPatch\nimport seaborn as sns\nimport warnings\nwarnings.filterwarnings('ignore', category=UserWarning)\n\n# =============================================================================\n# 0. GLOBAL STYLE — Cell journal standards\n# =============================================================================\n\n# Cell uses Arial as default; Helvetica is the closest Type-1 standard\nplt.rcParams.update({\n    'font.family':       'sans-serif',\n    'font.sans-serif':   ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size':         7,            # Cell figure text is 6-8 pt\n    'axes.titlesize':    8,\n    'axes.labelsize':    7,\n    'xtick.labelsize':   6.5,\n    'ytick.labelsize':   6.5,\n    'legend.fontsize':   6,\n    'figure.dpi':        300,\n    'savefig.dpi':       300,\n    'savefig.bbox':      'tight',\n    'axes.linewidth':    0.6,\n    'xtick.major.width': 0.5,\n    'ytick.major.width': 0.5,\n    'xtick.major.size':  2.5,\n    'ytick.major.size':  2.5,\n    'xtick.direction':   'out',\n    'ytick.direction':   'out',\n    'axes.spines.top':   False,\n    'axes.spines.right': False,\n})\n\n# ── Colorblind-safe qualitative palette (Wong, 2011) ────────────────────────\nCLUSTER_COLORS = [\n    '#0072B2',  # blue\n    '#E69F00',  # orange\n    '#009E73',  # green\n    '#CC79A7',  # pink\n    '#56B4E9',  # sky blue\n    '#F0E442',  # yellow\n    '#D55E00',  # vermillion\n    '#000000',  # black\n    '#999999',  # grey\n    '#882255',  # wine\n    '#44AA99',  # teal\n    '#AA4499',  # purple\n]\n\n# Volcano highlight colors\nVOLCANO_UP   = '#CC0000'   # up-regulated\nVOLCANO_DOWN = '#0072B2'   # down-regulated\nVOLCANO_NS   = '#999999'   # not significant\n\nOUTPUT_DIR  = '/home/joe/Documents/repo/skill/sci-draw'\n\n\n# =============================================================================\n# 1. DATA GENERATION (REPLACE with your real data)\n# =============================================================================\n\ndef generate_cluster_data(n_cells=5000, random_seed=42):\n    \"\"\"\n    Generate synthetic scRNA-seq cluster assignments and conditions.\n    \n    Replace this function with:\n      metadata = pd.read_csv('path/to/metadata.csv')\n    Your metadata should have columns: ['cell_barcode', 'cluster', 'condition']\n    \"\"\"\n    rng = np.random.default_rng(random_seed)\n    n_clusters = 8\n    cluster_names = [f'C{i}' for i in range(n_clusters)]\n    \n    # Create cell barcodes\n    barcodes = [f'cell_{i:06d}' for i in range(n_cells)]\n    \n    # Assign cells evenly to conditions\n    conditions = ['Control'] * (n_cells // 2) + ['Treatment'] * (n_cells // 2)\n    rng.shuffle(conditions)\n    \n    # Simulate condition-specific cluster abundance shifts\n    # Control: clusters are roughly equal\n    # Treatment: some clusters expand, some contract\n    control_probs = np.array([0.15, 0.12, 0.18, 0.10, 0.14, 0.13, 0.09, 0.09])\n    control_probs = control_probs / control_probs.sum()\n    treatment_probs = np.array([0.25, 0.05, 0.08, 0.22, 0.06, 0.18, 0.04, 0.12])\n    treatment_probs = treatment_probs / treatment_probs.sum()\n    \n    clusters = []\n    for cond in conditions:\n        if cond == 'Control':\n            clusters.append(rng.choice(cluster_names, p=control_probs))\n        else:\n            clusters.append(rng.choice(cluster_names, p=treatment_probs))\n    \n    metadata = pd.DataFrame({\n        'cell_barcode': barcodes,\n        'cluster':      clusters,\n        'condition':    conditions,\n    })\n    return metadata\n\n\ndef generate_degs_data(random_seed=42):\n    \"\"\"\n    Generate synthetic differential expression results.\n    \n    Replace this function with:\n      degs = pd.read_csv('path/to/deseq2_results.csv')\n    Your DEG table should have columns:\n      ['gene', 'log2FoldChange', 'pvalue', 'padj']\n    \"\"\"\n    rng = np.random.default_rng(random_seed)\n    n_genes = 2000\n    \n    gene_names = [f'GENE_{i}' for i in range(n_genes)]\n    \n    # Background: mostly null distribution\n    # Add some truly DE genes\n    log2fc = rng.normal(0, 0.8, n_genes)\n    \n    # Inject 80 differentially expressed genes\n    n_de = 80\n    de_idx = rng.choice(n_genes, n_de, replace=False)\n    half = n_de // 2\n    \n    # Up-regulated\n    log2fc[de_idx[:half]] = rng.uniform(0.8, 3.5, half) * rng.choice([1, 1, 1, -1], half)\n    # Down-regulated\n    log2fc[de_idx[half:]] = rng.uniform(-3.5, -0.8, n_de - half)\n    \n    # Compute p-values\n    pvalues = np.ones(n_genes)\n    for i in range(n_genes):\n        if abs(log2fc[i]) > 0.5:\n            # Make DE genes significant\n            z = abs(log2fc[i]) / 0.3 + rng.exponential(0.5)\n            pvalues[i] = 2 * (1 - rng.normal(0, 1).cdf(z))\n        else:\n            pvalues[i] = rng.uniform(0.05, 1.0)\n    \n    # Actually compute p-values properly\n    from scipy.stats import norm\n    pvalues = np.array([\n        2 * (1 - norm.cdf(abs(log2fc[i]) / 0.3 + rng.exponential(0.5)))\n        if abs(log2fc[i]) > 0.5\n        else rng.uniform(0.05, 1.0)\n        for i in range(n_genes)\n    ])\n    \n    # BH correction\n    from scipy.stats import false_discovery_control\n    padj = np.minimum(false_discovery_control(pvalues, method='bh'), 1.0)\n    \n    degs = pd.DataFrame({\n        'gene':           gene_names,\n        'log2FoldChange': log2fc,\n        'pvalue':         pvalues,\n        'padj':           padj,\n    })\n    \n    # Label some interesting genes for the volcano plot\n    top_up = degs[(degs['padj'] < 0.01) & (degs['log2FoldChange'] > 1)].head(8)\n    top_down = degs[(degs['padj'] < 0.01) & (degs['log2FoldChange'] < -1)].head(8)\n    \n    # Name the top genes with real gene names for visual appeal\n    real_names = [\n        'CD8A', 'GZMB', 'PRF1', 'IFNG', 'CCL5', 'NKG7', 'GZMK', 'GZMH',\n        'IL7R', 'CCR7', 'TCF7', 'LEF1', 'SELL', 'FOXP3', 'CTLA4', 'TIGIT',\n    ]\n    for i, (idx, row) in enumerate(top_up.iterrows()):\n        degs.loc[idx, 'gene'] = real_names[i]\n    for i, (idx, row) in enumerate(top_down.iterrows()):\n        degs.loc[idx, 'gene'] = real_names[len(top_up) + i]\n    \n    return degs\n\n\n# =============================================================================\n# 2. FIGURE 2a — STACKED BAR CHART\n# =============================================================================\n\ndef plot_stacked_bar(metadata, colors, ax):\n    \"\"\"100% stacked bar of cluster proportions per condition.\"\"\"\n    \n    # ── Compute proportions ────────────────────────────────────────────\n    ct = pd.crosstab(metadata['cluster'], metadata['condition'],\n                     normalize='columns') * 100\n    \n    # Sort clusters by Control proportion (descending)\n    ct = ct.sort_values('Control', ascending=False)\n    \n    # ── Reformat to long format for seaborn barplot ────────────────────\n    plot_data = ct.reset_index().melt(id_vars='cluster',\n                                       var_name='condition',\n                                       value_name='proportion')\n    \n    # ── Build the 100% stacked bar ─────────────────────────────────────\n    conditions = ['Control', 'Treatment']\n    clusters   = ct.index.tolist()\n    \n    bar_width = 0.50\n    x_pos = np.arange(len(conditions))\n    \n    bottom = np.zeros(len(conditions))\n    bars = []\n    \n    cluster_color_map = {c: colors[i % len(colors)]\n                         for i, c in enumerate(clusters)}\n    \n    for cluster in clusters:\n        props = [ct.loc[cluster, cond] for cond in conditions]\n        b = ax.bar(x_pos, props, bar_width, bottom=bottom,\n                   color=cluster_color_map[cluster],\n                   linewidth=0.3, edgecolor='white', label=cluster)\n        bars.append(b)\n        bottom += props\n    \n    # ── Labels & aesthetics ────────────────────────────────────────────\n    ax.set_xticks(x_pos)\n    ax.set_xticklabels(conditions, fontweight='bold')\n    ax.set_ylabel('Proportion of cells (%)', fontweight='bold')\n    ax.set_ylim(0, 105)\n    ax.yaxis.set_major_locator(mticker.MultipleLocator(20))\n    \n    # ── Legend outside the plot ────────────────────────────────────────\n    legend = ax.legend(\n        loc='upper left', bbox_to_anchor=(1.02, 1),\n        frameon=True, framealpha=0.9, edgecolor='#CCCCCC',\n        title='Cluster', title_fontsize=6.5,\n        handlelength=0.7, handletextpad=0.5,\n        borderpad=0.3, columnspacing=0.6,\n    )\n    legend.get_frame().set_linewidth(0.4)\n    \n    # ── Panel label ────────────────────────────────────────────────────\n    ax.text(-0.18, 1.05, 'A', transform=ax.transAxes,\n            fontsize=9, fontweight='bold',\n            va='bottom', ha='left')\n    \n    return ax\n\n\n# =============================================================================\n# 3. FIGURE 2b — VOLCANO PLOT\n# =============================================================================\n\ndef plot_volcano(degs, colors, ax):\n    \"\"\"Volcano plot with highlighted DE genes and top gene labels.\"\"\"\n    \n    # ── Classify genes ─────────────────────────────────────────────────\n    log2fc_cutoff  = 0.585   # 1.5-fold\n    pval_cutoff    = 0.01    # -log10 ≈ 2\n    \n    degs = degs.copy()\n    degs['-log10_padj'] = -np.log10(degs['padj'].clip(lower=1e-300))\n    \n    conditions = []\n    for _, row in degs.iterrows():\n        if row['padj'] < pval_cutoff and row['log2FoldChange'] > log2fc_cutoff:\n            conditions.append('Up')\n        elif row['padj'] < pval_cutoff and row['log2FoldChange'] < -log2fc_cutoff:\n            conditions.append('Down')\n        else:\n            conditions.append('NS')\n    degs['regulation'] = conditions\n    \n    # Counts for annotation\n    n_up   = (degs['regulation'] == 'Up').sum()\n    n_down = (degs['regulation'] == 'Down').sum()\n    \n    # ── Scatter ────────────────────────────────────────────────────────\n    color_map = {'Up': VOLCANO_UP, 'Down': VOLCANO_DOWN, 'NS': VOLCANO_NS}\n    \n    for reg_type in ['NS', 'Up', 'Down']:\n        subset = degs[degs['regulation'] == reg_type]\n        ax.scatter(\n            subset['log2FoldChange'], subset['-log10_padj'],\n            c=color_map[reg_type], s=4 if reg_type == 'NS' else 8,\n            alpha=0.6 if reg_type == 'NS' else 0.85,\n            edgecolors='none', rasterized=True,\n            label=f'{reg_type} (n={n_up if reg_type==\"Up\" else n_down if reg_type==\"Down\" else \"\"})',\n        )\n    \n    # ── Threshold lines ────────────────────────────────────────────────\n    ax.axhline(-np.log10(pval_cutoff), ls='--', lw=0.4, color='#888888')\n    ax.axvline(-log2fc_cutoff, ls='--', lw=0.4, color='#888888')\n    ax.axvline(log2fc_cutoff,  ls='--', lw=0.4, color='#888888')\n    \n    # ── Label top DE genes ─────────────────────────────────────────────\n    top_genes = pd.concat([\n        degs[degs['regulation'] == 'Up'].nsmallest(6, 'padj'),\n        degs[degs['regulation'] == 'Down'].nsmallest(6, 'padj'),\n    ])\n    \n    # Offset label positions to avoid overlaps\n    offsets_x = {\n        'CD8A': 0.25, 'GZMB': 0.25, 'PRF1': 0.25, 'IFNG': 0.35,\n        'IL7R': -0.35, 'CCR7': -0.35, 'TCF7': -0.35, 'LEF1': -0.35,\n    }\n    offsets_y = {\n        'CD8A': 2, 'GZMB': -2, 'PRF1': 2, 'IFNG': -2,\n        'IL7R': 2, 'CCR7': -2, 'TCF7': 2, 'LEF1': -2,\n    }\n    \n    for _, gene in top_genes.iterrows():\n        off_x = offsets_x.get(gene['gene'], 0.2)\n        off_y = offsets_y.get(gene['gene'], 1)\n        ax.annotate(\n            gene['gene'],\n            xy=(gene['log2FoldChange'], gene['-log10_padj']),\n            xytext=(off_x, off_y), textcoords='offset points',\n            fontsize=6, fontweight='bold',\n            color='#333333',\n            arrowprops=dict(arrowstyle='-', color='#AAAAAA', lw=0.3),\n            va='bottom', ha='left' if gene['log2FoldChange'] > 0 else 'right',\n        )\n    \n    # ── Labels & axes ──────────────────────────────────────────────────\n    ax.set_xlabel(r'log$_2$(Fold Change)', fontweight='bold')\n    ax.set_ylabel(r'$-$log$_{10}$(adjusted $p$)', fontweight='bold')\n    \n    # Symmetric x-axis\n    max_lfc = max(abs(degs['log2FoldChange'].quantile(0.99)),\n                  abs(degs['log2FoldChange'].quantile(0.01))) + 0.5\n    ax.set_xlim(-max_lfc, max_lfc)\n    \n    # ── Legend ─────────────────────────────────────────────────────────\n    legend = ax.legend(\n        loc='upper right', frameon=True, framealpha=0.9,\n        edgecolor='#CCCCCC', fontsize=6,\n        handlelength=0.7, handletextpad=0.4,\n        borderpad=0.3,\n    )\n    legend.get_frame().set_linewidth(0.4)\n    \n    # ── Panel label ────────────────────────────────────────────────────\n    ax.text(-0.18, 1.05, 'B', transform=ax.transAxes,\n            fontsize=9, fontweight='bold',\n            va='bottom', ha='left')\n    \n    return ax\n\n\n# =============================================================================\n# 4. ASSEMBLE FIGURE 2\n# =============================================================================\n\ndef main():\n    print(\"→ Generating synthetic scRNA-seq data...\")\n    metadata = generate_cluster_data(n_cells=5000, random_seed=42)\n    degs     = generate_degs_data(random_seed=42)\n    \n    print(f\"   Cells: {len(metadata)} | Clusters: {metadata['cluster'].nunique()} | \"\n          f\"Genes tested: {len(degs)} | DE genes: {(degs['padj'] < 0.01).sum()}\")\n    \n    # ── Create figure — Cell journal: single-column ~85 mm wide ──────\n    # Cell full page is ~174 mm. Single column ~85 mm.\n    panel_width  = 85 / 25.4   # inches   ? 85 mm -> inches\n    panel_height = 70 / 25.4   # inches\n    \n    fig, (ax_bar, ax_volc) = plt.subplots(\n        1, 2, figsize=(panel_width * 2 + 0.3, panel_height),\n        gridspec_kw={'width_ratios': [1, 1.15], 'wspace': 0.50},\n    )\n    \n    # ── Plot ───────────────────────────────────────────────────────────\n    print(\"→ Panel A: Stacked bar chart – cluster proportions...\")\n    plot_stacked_bar(metadata, CLUSTER_COLORS, ax_bar)\n    \n    print(\"→ Panel B: Volcano plot – differential expression...\")\n    plot_volcano(degs, CLUSTER_COLORS, ax_volc)\n    \n    # ── Export ─────────────────────────────────────────────────────────\n    pdf_path = f'{OUTPUT_DIR}/figure2.pdf'\n    png_path = f'{OUTPUT_DIR}/figure2.png'\n    \n    fig.savefig(pdf_path, dpi=300, bbox_inches='tight',\n                transparent=False, facecolor='white')\n    fig.savefig(png_path, dpi=300, bbox_inches='tight',\n                transparent=False, facecolor='white')\n    \n    plt.close(fig)\n    print(f\"\\n✓ Figure 2 saved to:\")\n    print(f\"  {pdf_path}\")\n    print(f\"  {png_path}\")\n\n\nif __name__ == '__main__':\n    main()\n"})
