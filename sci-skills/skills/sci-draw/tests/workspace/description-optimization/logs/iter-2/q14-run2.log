TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.py", "content": "#!/usr/bin/env python3\n\"\"\"\nGraphical Abstract: Nanomedicine targeting tumor via EPR effect\nand pH-responsive drug release in the acidic tumor microenvironment.\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.patches import FancyBboxPatch, FancyArrowPatch, Circle, Ellipse\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# Setup\n# ---------------------------------------------------------------------------\nfig, ax = plt.subplots(1, 1, figsize=(14, 7))\n\nax.set_xlim(0, 14)\nax.set_ylim(0, 7)\nax.set_aspect('equal')\nax.axis('off')\n\n# =========================== HELPER FUNCTIONS ===========================\n\ndef blood_vessel(ax):\n    \"\"\"Draw a blood vessel (horizontal tube) across the left region.\"\"\"\n    y_top = 3.8\n    y_bot = 2.2\n    x_left = 0.5\n    x_right = 5.5\n\n    # Vessel lumen (light red fill)\n    lumen = mpatches.Rectangle((x_left, y_bot), x_right - x_left, y_top - y_bot,\n                                facecolor='#fce4e4', edgecolor='none', zorder=0)\n    ax.add_patch(lumen)\n\n    # Top wall\n    top_wall = mpatches.Rectangle((x_left, y_top - 0.15), x_right - x_left, 0.15,\n                                   facecolor='#d6727a', edgecolor='none', zorder=1)\n    ax.add_patch(top_wall)\n\n    # Bottom wall\n    bot_wall = mpatches.Rectangle((x_left, y_bot), x_right - x_left, 0.15,\n                                   facecolor='#d6727a', edgecolor='none', zorder=1)\n    ax.add_patch(bot_wall)\n\n    # Gaps in endothelium (leaky vasculature – EPR effect)\n    gaps = [(1.2, 0.30), (2.5, 0.35), (4.0, 0.30)]\n    for gx, gw in gaps:\n        gap_top = mpatches.Rectangle((gx, y_top - 0.15), gw, 0.15,\n                                      facecolor='#fce4e4', edgecolor='none', zorder=2)\n        ax.add_patch(gap_top)\n        # Indicate gap with a small bracket\n        ax.plot([gx, gx + gw], [y_top + 0.05, y_top + 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n        ax.plot([gx, gx], [y_top - 0.05, y_top + 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n        ax.plot([gx + gw, gx + gw], [y_top - 0.05, y_top + 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n\n        # Also bottom wall gaps\n        gap_bot = mpatches.Rectangle((gx + 1.5, y_bot), gw, 0.15,\n                                      facecolor='#fce4e4', edgecolor='none', zorder=2)\n        ax.add_patch(gap_bot)\n        ax.plot([gx + 1.5, gx + 1.5 + gw], [y_bot - 0.05, y_bot - 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n        ax.plot([gx + 1.5, gx + 1.5], [y_bot + 0.05, y_bot - 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n        ax.plot([gx + 1.5 + gw, gx + 1.5 + gw], [y_bot + 0.05, y_bot - 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n\n    # Endothelial cell nuclei\n    for nx in [1.0, 3.0, 5.0]:\n        for y_base in [y_top - 0.07, y_bot + 0.07]:\n            nucleus = Ellipse((nx, y_base), 0.4, 0.10,\n                              facecolor='#a9444e', edgecolor='none', zorder=4)\n            ax.add_patch(nucleus)\n\n    # Label\n    ax.text((x_left + x_right) / 2, y_top + 0.5, 'Blood Vessel',\n            ha='center', va='center', fontsize=12, fontweight='bold',\n            color='#8b3a3a')\n    ax.text((x_left + x_right) / 2, y_top + 0.2, '(Leaky Endothelium)',\n            ha='center', va='center', fontsize=9, fontstyle='italic',\n            color='#8b3a3a')\n    ax.text((x_left + x_right) / 2, (y_top + y_bot) / 2, 'Blood Flow',\n            ha='center', va='center', fontsize=10, color='#c0392b', alpha=0.5)\n\n    # Blood cells (RBCs simplified)\n    for bx in [1.5, 2.8, 4.2]:\n        rbc = Ellipse((bx, 3.0), 0.5, 0.25, facecolor='#d6727a', alpha=0.6, zorder=2)\n        ax.add_patch(rbc)\n\n    return x_right, y_top, y_bot\n\n\ndef draw_nanoparticle(ax, x, y, radius=0.25, color='#2e86de'):\n    \"\"\"Draw a nanoparticle as a circle with a core-shell look.\"\"\"\n    # Outer shell (slightly larger, semi-transparent)\n    shell = Circle((x, y), radius * 1.3, facecolor=color, alpha=0.25,\n                   edgecolor=color, lw=1.5, zorder=5)\n    ax.add_patch(shell)\n    # Core\n    core = Circle((x, y), radius, facecolor=color, alpha=0.7,\n                  edgecolor='none', zorder=6)\n    ax.add_patch(core)\n    # Highlight\n    hl = Circle((x - radius * 0.25, y + radius * 0.25), radius * 0.3,\n                facecolor='white', alpha=0.4, edgecolor='none', zorder=7)\n    ax.add_patch(hl)\n    # Drug payload dots inside\n    for angle in [0, 72, 144, 216, 288]:\n        rad = np.deg2rad(angle)\n        dx = np.cos(rad) * radius * 0.45\n        dy = np.sin(rad) * radius * 0.45\n        dot = Circle((x + dx, y + dy), 0.035, facecolor='#f1c40f',\n                     edgecolor='none', zorder=8)\n        ax.add_patch(dot)\n\n\ndef draw_drug_molecule(ax, x, y, size=0.08):\n    \"\"\"Draw a small drug molecule (star/dot).\"\"\"\n    mol = Circle((x, y), size, facecolor='#e67e22', edgecolor='#d35400',\n                 lw=0.5, zorder=9)\n    ax.add_patch(mol)\n    # Tiny \"rays\"\n    for angle in [0, 60, 120, 180, 240, 300]:\n        rad = np.deg2rad(angle)\n        dx = np.cos(rad) * size * 1.8\n        dy = np.sin(rad) * size * 1.8\n        ax.plot([x, x + dx], [y, y + dy], color='#e67e22',\n                lw=0.8, alpha=0.6, zorder=8)\n\n\ndef draw_tumor_cell(ax, x, y, scale=1.0):\n    \"\"\"Draw a tumor cell as an irregular shape.\"\"\"\n    r = 0.45 * scale\n    cell = Ellipse((x, y), r * 2.2, r * 1.8, angle=np.random.uniform(-15, 15),\n                   facecolor='#a29bfe', alpha=0.35, edgecolor='#6c5ce7',\n                   lw=1.5, zorder=3)\n    ax.add_patch(cell)\n    # Nucleus (large, irregular – characteristic of cancer cells)\n    nucleus = Ellipse((x + 0.05, y + 0.03), r * 1.0, r * 0.8,\n                      angle=np.random.uniform(-10, 10),\n                      facecolor='#6c5ce7', alpha=0.5, edgecolor='#4834d4',\n                      lw=1.0, zorder=4)\n    ax.add_patch(nucleus)\n    # Nucleolus\n    nucleolus = Circle((x + 0.08, y + 0.05), r * 0.2,\n                       facecolor='#4834d4', alpha=0.6, edgecolor='none', zorder=5)\n    ax.add_patch(nucleolus)\n    return cell\n\n\ndef draw_ph_indicator(ax, x, y):\n    \"\"\"Draw a pH meter icon.\"\"\"\n    beaker = FancyBboxPatch((x - 0.3, y - 0.5), 0.6, 0.7,\n                             boxstyle=\"round,pad=0.05\",\n                             facecolor='#dfe6e9', edgecolor='#636e72', lw=1.5, zorder=10)\n    ax.add_patch(beaker)\n    ax.text(x, y - 0.15, 'pH↓', ha='center', va='center', fontsize=11,\n            fontweight='bold', color='#d63031', zorder=11)\n    for hx, hy in [(x - 0.15, y + 0.15), (x + 0.12, y + 0.22), (x, y + 0.05)]:\n        ax.text(hx, hy, 'H⁺', ha='center', va='center', fontsize=7,\n                color='#d63031', zorder=11)\n\n\n# =========================== BUILD THE SCENE ===========================\n\n# 1. Blood vessel\nvessel_right, v_top, v_bot = blood_vessel(ax)\n\n# 2. Nanoparticles in blood\nnp_positions = [(1.8, 3.3), (3.5, 2.8), (2.5, 2.5), (4.8, 3.2), (1.0, 2.6)]\nfor nx, ny in np_positions:\n    draw_nanoparticle(ax, nx, ny)\n\n# 3. Tumor tissue region (right side) – dashed background\ntumor_region = FancyBboxPatch((5.8, 0.8), 7.5, 5.2,\n                               boxstyle=\"round,pad=0.1\",\n                               facecolor='#ffeaa7', alpha=0.08,\n                               edgecolor='#fdcb6e', lw=1.5, ls='--', zorder=0)\nax.add_patch(tumor_region)\n\n# 4. Extravasating nanoparticles (through gaps, moving outward)\nextrav_paths = [\n    ((1.35, v_top - 0.05), (2.0, v_top - 0.6)),\n    ((2.65, v_top - 0.05), (3.2, v_top - 0.8)),\n    ((4.15, v_top - 0.05), (4.8, v_top - 0.5)),\n    ((3.0, v_bot + 0.15), (3.8, v_bot + 0.7)),\n    ((4.5, v_bot + 0.15), (5.2, v_bot + 0.6)),\n]\nfor start, end in extrav_paths:\n    arrow = FancyArrowPatch(start, end,\n                            arrowstyle='->,head_width=0.12,head_length=0.15',\n                            color='#2e86de', lw=1.5, alpha=0.6,\n                            connectionstyle='arc3,rad=0.0', zorder=4)\n    ax.add_patch(arrow)\n    draw_nanoparticle(ax, end[0], end[1], radius=0.18, color='#2e86de')\n\n# 5. Nanoparticles in tumor interstitium\ntumor_np_positions = [(6.5, 3.8), (8.0, 4.5), (9.5, 3.0), (7.2, 2.0),\n                       (11.0, 4.2), (10.0, 1.5), (6.8, 5.5)]\nfor nx, ny in tumor_np_positions:\n    draw_nanoparticle(ax, nx, ny, radius=0.2, color='#2e86de')\n\n# 6. Tumor cells\ntumor_cells = [(8.5, 1.8), (10.5, 2.5), (12.0, 1.2), (11.5, 4.0),\n               (9.0, 5.0), (7.0, 1.2), (12.8, 3.5), (6.5, 4.2)]\nfor cx, cy in tumor_cells:\n    draw_tumor_cell(ax, cx, cy, scale=0.9)\n\n# 7. pH indicators near some nanoparticles\nph_locations = [(6.5, 3.5), (8.0, 4.0), (10.0, 1.0)]\nfor px, py in ph_locations:\n    draw_ph_indicator(ax, px, py)\n\n# 8. Drug release arrows from nanoparticles\nrelease_pairs = [\n    ((6.5, 3.3), (7.2, 2.8)),\n    ((8.0, 4.2), (9.0, 4.8)),\n    ((10.0, 1.3), (10.8, 1.8)),\n    ((11.0, 3.9), (11.8, 3.5)),\n    ((7.2, 1.8), (7.5, 1.3)),\n]\nfor start, end in release_pairs:\n    arrow = FancyArrowPatch(start, end,\n                            arrowstyle='->,head_width=0.08,head_length=0.10',\n                            color='#e67e22', lw=1.2, alpha=0.7,\n                            connectionstyle='arc3,rad=0.2',\n                            linestyle='dashed', zorder=8)\n    ax.add_patch(arrow)\n    for _ in range(4):\n        dx = np.random.uniform(-0.3, 0.3)\n        dy = np.random.uniform(-0.3, 0.3)\n        draw_drug_molecule(ax, end[0] + dx, end[1] + dy)\n\n# 9. Apoptotic tumor cells (showing damage)\napop_cells = [(12.5, 1.8), (10.5, 4.5)]\nfor cx, cy in apop_cells:\n    for i in range(3):\n        fx = cx + np.random.uniform(-0.3, 0.3)\n        fy = cy + np.random.uniform(-0.3, 0.3)\n        frag = Circle((fx, fy), 0.15, facecolor='#ff7675', alpha=0.5,\n                      edgecolor='#d63031', lw=0.8, zorder=3)\n        ax.add_patch(frag)\n\n# =========================== ANNOTATIONS & LABELS ===========================\n\n# Big arrows between phases\narrow_epr = FancyArrowPatch((5.5, 5.5), (6.5, 5.5),\n                             arrowstyle='->,head_width=0.25,head_length=0.3',\n                             color='#636e72', lw=2.5, zorder=10)\nax.add_patch(arrow_epr)\n\nax.text(6.0, 5.8, 'EPR Effect\\n(Passive Targeting)',\n        ha='center', va='center', fontsize=11, fontweight='bold',\n        color='#2d3436', bbox=dict(boxstyle='round,pad=0.3',\n                                   facecolor='white', alpha=0.85, edgecolor='#636e72'))\n\narrow_ph = FancyArrowPatch((9.0, 5.5), (10.0, 5.5),\n                            arrowstyle='->,head_width=0.25,head_length=0.3',\n                            color='#d63031', lw=2.5, zorder=10)\nax.add_patch(arrow_ph)\n\nax.text(9.5, 5.8, 'Acidic TME\\n(pH 6.5–6.8)',\n        ha='center', va='center', fontsize=11, fontweight='bold',\n        color='#d63031', bbox=dict(boxstyle='round,pad=0.3',\n                                   facecolor='white', alpha=0.85, edgecolor='#d63031'))\n\n# Section labels\nax.text(3.0, 6.6, '① Intravenous Injection',\n        ha='center', va='center', fontsize=13, fontweight='bold', color='#2d3436')\nax.text(8.5, 6.6, '② Tumor Accumulation via EPR',\n        ha='center', va='center', fontsize=13, fontweight='bold', color='#2d3436')\nax.text(12.0, 6.6, '③ pH-Responsive Drug Release',\n        ha='center', va='center', fontsize=13, fontweight='bold', color='#d63031')\n\n# Legend box\nlegend_elements = [\n    mpatches.Patch(facecolor='#2e86de', alpha=0.7, label='Nanoparticle'),\n    mpatches.Patch(facecolor='#e67e22', alpha=0.8, label='Free Drug'),\n    mpatches.Patch(facecolor='#a29bfe', alpha=0.35, edgecolor='#6c5ce7', label='Tumor Cell'),\n    mpatches.Patch(facecolor='#ff7675', alpha=0.5, label='Apoptotic Cell'),\n]\nlegend = ax.legend(handles=legend_elements, loc='lower center',\n                    framealpha=0.9, edgecolor='#b2bec3',\n                    fontsize=9, ncol=4,\n                    bbox_to_anchor=(0.5, -0.05))\nlegend.get_frame().set_linewidth(1.0)\n\n# Title\nax.text(7.0, 6.95,\n        'Graphical Abstract: EPR-Mediated Tumor Targeting & pH-Responsive Drug Release',\n        ha='center', va='center', fontsize=15, fontweight='bold', color='#2d3436')\n\n# Annotation: EPR gaps\nax.annotate('Leaky vasculature\\n(fenestrations ~100–600 nm)',\n            xy=(1.35, 4.0), xytext=(0.2, 5.0),\n            ha='left', fontsize=8, color='#c0392b',\n            arrowprops=dict(arrowstyle='->', color='#c0392b', lw=1.0),\n            bbox=dict(boxstyle='round,pad=0.2', facecolor='white',\n                      alpha=0.8, edgecolor='#c0392b'))\n\n# Annotation: Tumor microenvironment\nax.annotate('Acidic TME\\n(pH ~6.5)\\nTriggers drug release',\n            xy=(10.5, 1.2), xytext=(11.2, 0.5),\n            ha='left', fontsize=8, color='#d63031',\n            arrowprops=dict(arrowstyle='->', color='#d63031', lw=1.0),\n            bbox=dict(boxstyle='round,pad=0.2', facecolor='white',\n                      alpha=0.8, edgecolor='#d63031'))\n\n# Annotation: EPR effect label\nax.annotate('Enhanced Permeability\\n& Retention (EPR) Effect',\n            xy=(4.5, 3.0), xytext=(4.5, 0.5),\n            ha='center', fontsize=9, fontweight='bold', color='#2e86de',\n            arrowprops=dict(arrowstyle='->', color='#2e86de', lw=1.5,\n                            connectionstyle='arc3,rad=0.3'),\n            bbox=dict(boxstyle='round,pad=0.3', facecolor='white',\n                      alpha=0.85, edgecolor='#2e86de'))\n\n# pH-responsive linker cleavage annotation\nax.annotate('pH-responsive\\nlinker cleavage',\n            xy=(8.0, 4.5), xytext=(7.0, 6.2),\n            ha='center', fontsize=8, color='#d63031',\n            arrowprops=dict(arrowstyle='->', color='#d63031', lw=1.0),\n            bbox=dict(boxstyle='round,pad=0.15', facecolor='#ffeaa7',\n                      alpha=0.7, edgecolor='#d63031'))\n\n# =========================== SAVE ===========================\nplt.tight_layout()\nplt.savefig('/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.png',\n            dpi=300, bbox_inches='tight', facecolor='white')\nplt.savefig('/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.pdf',\n            bbox_inches='tight', facecolor='white')\nplt.close()\n\nprint(\"Done! Saved:\")\nprint(\"  - graphical_abstract.png (300 DPI)\")\nprint(\"  - graphical_abstract.pdf\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.py", "content": "#!/usr/bin/env python3\n\"\"\"\nGraphical Abstract: Nanomedicine targeting tumor via EPR effect\nand pH-responsive drug release in the acidic tumor microenvironment.\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.patches import FancyBboxPatch, FancyArrowPatch, Circle, Ellipse\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# Setup\n# ---------------------------------------------------------------------------\nfig, ax = plt.subplots(1, 1, figsize=(14, 7))\n\nax.set_xlim(0, 14)\nax.set_ylim(0, 7)\nax.set_aspect('equal')\nax.axis('off')\n\n# =========================== HELPER FUNCTIONS ===========================\n\ndef blood_vessel(ax):\n    \"\"\"Draw a blood vessel (horizontal tube) across the left region.\"\"\"\n    y_top = 3.8\n    y_bot = 2.2\n    x_left = 0.5\n    x_right = 5.5\n\n    # Vessel lumen (light red fill)\n    lumen = mpatches.Rectangle((x_left, y_bot), x_right - x_left, y_top - y_bot,\n                                facecolor='#fce4e4', edgecolor='none', zorder=0)\n    ax.add_patch(lumen)\n\n    # Top wall\n    top_wall = mpatches.Rectangle((x_left, y_top - 0.15), x_right - x_left, 0.15,\n                                   facecolor='#d6727a', edgecolor='none', zorder=1)\n    ax.add_patch(top_wall)\n\n    # Bottom wall\n    bot_wall = mpatches.Rectangle((x_left, y_bot), x_right - x_left, 0.15,\n                                   facecolor='#d6727a', edgecolor='none', zorder=1)\n    ax.add_patch(bot_wall)\n\n    # Gaps in endothelium (leaky vasculature – EPR effect)\n    gaps = [(1.2, 0.30), (2.5, 0.35), (4.0, 0.30)]\n    for gx, gw in gaps:\n        gap_top = mpatches.Rectangle((gx, y_top - 0.15), gw, 0.15,\n                                      facecolor='#fce4e4', edgecolor='none', zorder=2)\n        ax.add_patch(gap_top)\n        # Indicate gap with a small bracket\n        ax.plot([gx, gx + gw], [y_top + 0.05, y_top + 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n        ax.plot([gx, gx], [y_top - 0.05, y_top + 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n        ax.plot([gx + gw, gx + gw], [y_top - 0.05, y_top + 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n\n        # Also bottom wall gaps\n        gap_bot = mpatches.Rectangle((gx + 1.5, y_bot), gw, 0.15,\n                                      facecolor='#fce4e4', edgecolor='none', zorder=2)\n        ax.add_patch(gap_bot)\n        ax.plot([gx + 1.5, gx + 1.5 + gw], [y_bot - 0.05, y_bot - 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n        ax.plot([gx + 1.5, gx + 1.5], [y_bot + 0.05, y_bot - 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n        ax.plot([gx + 1.5 + gw, gx + 1.5 + gw], [y_bot + 0.05, y_bot - 0.05],\n                color='#c0392b', lw=1.5, zorder=3)\n\n    # Endothelial cell nuclei\n    for nx in [1.0, 3.0, 5.0]:\n        for y_base in [y_top - 0.07, y_bot + 0.07]:\n            nucleus = Ellipse((nx, y_base), 0.4, 0.10,\n                              facecolor='#a9444e', edgecolor='none', zorder=4)\n            ax.add_patch(nucleus)\n\n    # Label\n    ax.text((x_left + x_right) / 2, y_top + 0.5, 'Blood Vessel',\n            ha='center', va='center', fontsize=12, fontweight='bold',\n            color='#8b3a3a')\n    ax.text((x_left + x_right) / 2, y_top + 0.2, '(Leaky Endothelium)',\n            ha='center', va='center', fontsize=9, fontstyle='italic',\n            color='#8b3a3a')\n    ax.text((x_left + x_right) / 2, (y_top + y_bot) / 2, 'Blood Flow',\n            ha='center', va='center', fontsize=10, color='#c0392b', alpha=0.5)\n\n    # Blood cells (RBCs simplified)\n    for bx in [1.5, 2.8, 4.2]:\n        rbc = Ellipse((bx, 3.0), 0.5, 0.25, facecolor='#d6727a', alpha=0.6, zorder=2)\n        ax.add_patch(rbc)\n\n    return x_right, y_top, y_bot\n\n\ndef draw_nanoparticle(ax, x, y, radius=0.25, color='#2e86de'):\n    \"\"\"Draw a nanoparticle as a circle with a core-shell look.\"\"\"\n    # Outer shell (slightly larger, semi-transparent)\n    shell = Circle((x, y), radius * 1.3, facecolor=color, alpha=0.25,\n                   edgecolor=color, lw=1.5, zorder=5)\n    ax.add_patch(shell)\n    # Core\n    core = Circle((x, y), radius, facecolor=color, alpha=0.7,\n                  edgecolor='none', zorder=6)\n    ax.add_patch(core)\n    # Highlight\n    hl = Circle((x - radius * 0.25, y + radius * 0.25), radius * 0.3,\n                facecolor='white', alpha=0.4, edgecolor='none', zorder=7)\n    ax.add_patch(hl)\n    # Drug payload dots inside\n    for angle in [0, 72, 144, 216, 288]:\n        rad = np.deg2rad(angle)\n        dx = np.cos(rad) * radius * 0.45\n        dy = np.sin(rad) * radius * 0.45\n        dot = Circle((x + dx, y + dy), 0.035, facecolor='#f1c40f',\n                     edgecolor='none', zorder=8)\n        ax.add_patch(dot)\n\n\ndef draw_drug_molecule(ax, x, y, size=0.08):\n    \"\"\"Draw a small drug molecule (star/dot).\"\"\"\n    mol = Circle((x, y), size, facecolor='#e67e22', edgecolor='#d35400',\n                 lw=0.5, zorder=9)\n    ax.add_patch(mol)\n    # Tiny \"rays\"\n    for angle in [0, 60, 120, 180, 240, 300]:\n        rad = np.deg2rad(angle)\n        dx = np.cos(rad) * size * 1.8\n        dy = np.sin(rad) * size * 1.8\n        ax.plot([x, x + dx], [y, y + dy], color='#e67e22',\n                lw=0.8, alpha=0.6, zorder=8)\n\n\ndef draw_tumor_cell(ax, x, y, scale=1.0):\n    \"\"\"Draw a tumor cell as an irregular shape.\"\"\"\n    r = 0.45 * scale\n    cell = Ellipse((x, y), r * 2.2, r * 1.8, angle=np.random.uniform(-15, 15),\n                   facecolor='#a29bfe', alpha=0.35, edgecolor='#6c5ce7',\n                   lw=1.5, zorder=3)\n    ax.add_patch(cell)\n    # Nucleus (large, irregular – characteristic of cancer cells)\n    nucleus = Ellipse((x + 0.05, y + 0.03), r * 1.0, r * 0.8,\n                      angle=np.random.uniform(-10, 10),\n                      facecolor='#6c5ce7', alpha=0.5, edgecolor='#4834d4',\n                      lw=1.0, zorder=4)\n    ax.add_patch(nucleus)\n    # Nucleolus\n    nucleolus = Circle((x + 0.08, y + 0.05), r * 0.2,\n                       facecolor='#4834d4', alpha=0.6, edgecolor='none', zorder=5)\n    ax.add_patch(nucleolus)\n    return cell\n\n\ndef draw_ph_indicator(ax, x, y):\n    \"\"\"Draw a pH meter icon.\"\"\"\n    beaker = FancyBboxPatch((x - 0.3, y - 0.5), 0.6, 0.7,\n                             boxstyle=\"round,pad=0.05\",\n                             facecolor='#dfe6e9', edgecolor='#636e72', lw=1.5, zorder=10)\n    ax.add_patch(beaker)\n    ax.text(x, y - 0.15, 'pH\\u2193', ha='center', va='center', fontsize=11,\n            fontweight='bold', color='#d63031', zorder=11)\n    for hx, hy in [(x - 0.15, y + 0.15), (x + 0.12, y + 0.22), (x, y + 0.05)]:\n        ax.text(hx, hy, 'H\\u207a', ha='center', va='center', fontsize=7,\n                color='#d63031', zorder=11)\n\n\n# =========================== BUILD THE SCENE ===========================\n\n# 1. Blood vessel\nvessel_right, v_top, v_bot = blood_vessel(ax)\n\n# 2. Nanoparticles in blood\nnp_positions = [(1.8, 3.3), (3.5, 2.8), (2.5, 2.5), (4.8, 3.2), (1.0, 2.6)]\nfor nx, ny in np_positions:\n    draw_nanoparticle(ax, nx, ny)\n\n# 3. Tumor tissue region (right side) – dashed background\ntumor_region = FancyBboxPatch((5.8, 0.8), 7.5, 5.2,\n                               boxstyle=\"round,pad=0.1\",\n                               facecolor='#ffeaa7', alpha=0.08,\n                               edgecolor='#fdcb6e', lw=1.5, ls='--', zorder=0)\nax.add_patch(tumor_region)\n\n# 4. Extravasating nanoparticles (through gaps, moving outward)\nextrav_paths = [\n    ((1.35, v_top - 0.05), (2.0, v_top - 0.6)),\n    ((2.65, v_top - 0.05), (3.2, v_top - 0.8)),\n    ((4.15, v_top - 0.05), (4.8, v_top - 0.5)),\n    ((3.0, v_bot + 0.15), (3.8, v_bot + 0.7)),\n    ((4.5, v_bot + 0.15), (5.2, v_bot + 0.6)),\n]\nfor start, end in extrav_paths:\n    arrow = FancyArrowPatch(start, end,\n                            arrowstyle='->,head_width=0.12,head_length=0.15',\n                            color='#2e86de', lw=1.5, alpha=0.6,\n                            connectionstyle='arc3,rad=0.0', zorder=4)\n    ax.add_patch(arrow)\n    draw_nanoparticle(ax, end[0], end[1], radius=0.18, color='#2e86de')\n\n# 5. Nanoparticles in tumor interstitium\ntumor_np_positions = [(6.5, 3.8), (8.0, 4.5), (9.5, 3.0), (7.2, 2.0),\n                       (11.0, 4.2), (10.0, 1.5), (6.8, 5.5)]\nfor nx, ny in tumor_np_positions:\n    draw_nanoparticle(ax, nx, ny, radius=0.2, color='#2e86de')\n\n# 6. Tumor cells\ntumor_cells = [(8.5, 1.8), (10.5, 2.5), (12.0, 1.2), (11.5, 4.0),\n               (9.0, 5.0), (7.0, 1.2), (12.8, 3.5), (6.5, 4.2)]\nfor cx, cy in tumor_cells:\n    draw_tumor_cell(ax, cx, cy, scale=0.9)\n\n# 7. pH indicators near some nanoparticles\nph_locations = [(6.5, 3.5), (8.0, 4.0), (10.0, 1.0)]\nfor px, py in ph_locations:\n    draw_ph_indicator(ax, px, py)\n\n# 8. Drug release arrows from nanoparticles\nrelease_pairs = [\n    ((6.5, 3.3), (7.2, 2.8)),\n    ((8.0, 4.2), (9.0, 4.8)),\n    ((10.0, 1.3), (10.8, 1.8)),\n    ((11.0, 3.9), (11.8, 3.5)),\n    ((7.2, 1.8), (7.5, 1.3)),\n]\nfor start, end in release_pairs:\n    arrow = FancyArrowPatch(start, end,\n                            arrowstyle='->,head_width=0.08,head_length=0.10',\n                            color='#e67e22', lw=1.2, alpha=0.7,\n                            connectionstyle='arc3,rad=0.2',\n                            linestyle='dashed', zorder=8)\n    ax.add_patch(arrow)\n    for _ in range(4):\n        dx = np.random.uniform(-0.3, 0.3)\n        dy = np.random.uniform(-0.3, 0.3)\n        draw_drug_molecule(ax, end[0] + dx, end[1] + dy)\n\n# 9. Apoptotic tumor cells (showing damage)\napop_cells = [(12.5, 1.8), (10.5, 4.5)]\nfor cx, cy in apop_cells:\n    for i in range(3):\n        fx = cx + np.random.uniform(-0.3, 0.3)\n        fy = cy + np.random.uniform(-0.3, 0.3)\n        frag = Circle((fx, fy), 0.15, facecolor='#ff7675', alpha=0.5,\n                      edgecolor='#d63031', lw=0.8, zorder=3)\n        ax.add_patch(frag)\n\n# =========================== ANNOTATIONS & LABELS ===========================\n\n# Big arrows between phases\narrow_epr = FancyArrowPatch((5.5, 5.5), (6.5, 5.5),\n                             arrowstyle='->,head_width=0.25,head_length=0.3',\n                             color='#636e72', lw=2.5, zorder=10)\nax.add_patch(arrow_epr)\n\nax.text(6.0, 5.8, 'EPR Effect\\n(Passive Targeting)',\n        ha='center', va='center', fontsize=11, fontweight='bold',\n        color='#2d3436', bbox=dict(boxstyle='round,pad=0.3',\n                                   facecolor='white', alpha=0.85, edgecolor='#636e72'))\n\narrow_ph = FancyArrowPatch((9.0, 5.5), (10.0, 5.5),\n                            arrowstyle='->,head_width=0.25,head_length=0.3',\n                            color='#d63031', lw=2.5, zorder=10)\nax.add_patch(arrow_ph)\n\nax.text(9.5, 5.8, 'Acidic TME\\n(pH 6.5\\u20136.8)',\n        ha='center', va='center', fontsize=11, fontweight='bold',\n        color='#d63031', bbox=dict(boxstyle='round,pad=0.3',\n                                   facecolor='white', alpha=0.85, edgecolor='#d63031'))\n\n# Section labels\nax.text(3.0, 6.6, '\\u2460 Intravenous Injection',\n        ha='center', va='center', fontsize=13, fontweight='bold', color='#2d3436')\nax.text(8.5, 6.6, '\\u2461 Tumor Accumulation via EPR',\n        ha='center', va='center', fontsize=13, fontweight='bold', color='#2d3436')\nax.text(12.0, 6.6, '\\u2462 pH-Responsive Drug Release',\n        ha='center', va='center', fontsize=13, fontweight='bold', color='#d63031')\n\n# Legend box\nlegend_elements = [\n    mpatches.Patch(facecolor='#2e86de', alpha=0.7, label='Nanoparticle'),\n    mpatches.Patch(facecolor='#e67e22', alpha=0.8, label='Free Drug'),\n    mpatches.Patch(facecolor='#a29bfe', alpha=0.35, edgecolor='#6c5ce7', label='Tumor Cell'),\n    mpatches.Patch(facecolor='#ff7675', alpha=0.5, label='Apoptotic Cell'),\n]\nlegend = ax.legend(handles=legend_elements, loc='lower center',\n                    framealpha=0.9, edgecolor='#b2bec3',\n                    fontsize=9, ncol=4,\n                    bbox_to_anchor=(0.5, -0.05))\nlegend.get_frame().set_linewidth(1.0)\n\n# Title\nax.text(7.0, 6.95,\n        'Graphical Abstract: EPR-Mediated Tumor Targeting & pH-Responsive Drug Release',\n        ha='center', va='center', fontsize=15, fontweight='bold', color='#2d3436')\n\n# Annotation: EPR gaps\nax.annotate('Leaky vasculature\\n(fenestrations ~100\\u2013600 nm)',\n            xy=(1.35, 4.0), xytext=(0.2, 5.0),\n            ha='left', fontsize=8, color='#c0392b',\n            arrowprops=dict(arrowstyle='->', color='#c0392b', lw=1.0),\n            bbox=dict(boxstyle='round,pad=0.2', facecolor='white',\n                      alpha=0.8, edgecolor='#c0392b'))\n\n# Annotation: Tumor microenvironment\nax.annotate('Acidic TME\\n(pH ~6.5)\\nTriggers drug release',\n            xy=(10.5, 1.2), xytext=(11.2, 0.5),\n            ha='left', fontsize=8, color='#d63031',\n            arrowprops=dict(arrowstyle='->', color='#d63031', lw=1.0),\n            bbox=dict(boxstyle='round,pad=0.2', facecolor='white',\n                      alpha=0.8, edgecolor='#d63031'))\n\n# Annotation: EPR effect label\nax.annotate('Enhanced Permeability\\n& Retention (EPR) Effect',\n            xy=(4.5, 3.0), xytext=(4.5, 0.5),\n            ha='center', fontsize=9, fontweight='bold', color='#2e86de',\n            arrowprops=dict(arrowstyle='->', color='#2e86de', lw=1.5,\n                            connectionstyle='arc3,rad=0.3'),\n            bbox=dict(boxstyle='round,pad=0.3', facecolor='white',\n                      alpha=0.85, edgecolor='#2e86de'))\n\n# pH-responsive linker cleavage annotation\nax.annotate('pH-responsive\\nlinker cleavage',\n            xy=(8.0, 4.5), xytext=(7.0, 6.2),\n            ha='center', fontsize=8, color='#d63031',\n            arrowprops=dict(arrowstyle='->', color='#d63031', lw=1.0),\n            bbox=dict(boxstyle='round,pad=0.15', facecolor='#ffeaa7',\n                      alpha=0.7, edgecolor='#d63031'))\n\n# =========================== SAVE ===========================\nplt.tight_layout()\nplt.savefig('/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.png',\n            dpi=300, bbox_inches='tight', facecolor='white')\nplt.savefig('/home/joe/Documents/repo/skill/sci-draw/graphical_abstract.pdf',\n            bbox_inches='tight', facecolor='white')\nplt.close()\n\nprint(\"Done! Saved:\")\nprint(\"  - graphical_abstract.png (300 DPI)\")\nprint(\"  - graphical_abstract.pdf\")\n"})
