TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/sci-draw/assets/figures4papers/figure_scRNAseq_Cell/plot_figure2.py", "content": "\"\"\"\nFigure 2: scRNA-seq cluster proportion + DEG volcano plot\n=========================================================\nFor Cell journal submission.\n\nPanel (a): Stacked bar chart — cell cluster proportions in Control vs Treatment\nPanel (b): Volcano plot — differentially expressed genes (log2FC vs -log10 padj)\n\nUsage:\n    python plot_figure2.py                          # PNG preview\n    python plot_figure2.py --export                 # PDF + PNG for submission\n    python plot_figure2.py --real-data path/to/csv  # use your own data\n\nDesign:\n    - Cell-style formatting (Nature-level preset from setup_style.py)\n    - Unified colorblind-safe palette across both panels\n    - Proper panel labels a/b aligned via layout_tools\n\nAuthor: sci-draw\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport os\nimport sys\n\nimport numpy as np\nimport pandas as pd\nfrom matplotlib import pyplot as plt\nfrom matplotlib.patches import FancyBboxPatch\n\n# ── sci-draw utilities ──────────────────────────────────────────────────────\nsys.path.insert(0, os.path.join(os.path.dirname(__file__), \"..\", \"..\", \"..\", \"scripts\"))\nfrom setup_style import setup_style\nfrom layout_tools import add_panel_labels, finalize_figure\nfrom export_figure import export_figure\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  CONFIGURATION\n# ══════════════════════════════════════════════════════════════════════════════\n\n# Cell journal: similar to Nature — sans-serif, compact, clean\nJOURNAL = \"nature\"\n# Figure width: double-column Cell figure ~ 6.85 in (174 mm)\nFIG_W, FIG_H = 7.0, 3.2\n\n# Colorblind-safe palette for 10 cell clusters (Tableau 10 + ColorBrewer extension)\nCLUSTER_COLORS = [\n    \"#3B7DD8\",  # Cluster 0 — blue\n    \"#E85D4A\",  # Cluster 1 — red\n    \"#4DAF4A\",  # Cluster 2 — green\n    \"#984EA3\",  # Cluster 3 — purple\n    \"#FF7F00\",  # Cluster 4 — orange\n    \"#A65628\",  # Cluster 5 — brown\n    \"#F781BF\",  # Cluster 6 — pink\n    \"#66C2A5\",  # Cluster 7 — teal\n    \"#E6AB02\",  # Cluster 8 — gold\n    \"#999999\",  # Cluster 9 — gray\n]\n\n# Volcano plot colors (match the accent tones from the cluster palette)\nVOLCANO_UP = \"#CC3344\"      # up-regulated — red accent\nVOLCANO_DOWN = \"#3B7DD8\"    # down-regulated — blue accent\nVOLCANO_NS = \"#BBBBBB\"      # not significant — light gray\nVOLCANO_TOP = \"#881122\"     # top marker gene — dark red (for labeling)\n\n# Significance thresholds\nLOG2FC_THRESH = 0.5   # |log2FC| >= 0.5\nPADJ_THRESH = 0.05    # adjusted p-value <= 0.05\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  DATA — synthetic example (replace with real data when available)\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef generate_example_data(random_seed: int = 42) -> dict:\n    \"\"\"\n    Generate realistic scRNA-seq example data.\n\n    Returns a dict with:\n        - cluster_props: DataFrame [cluster, control_prop, treatment_prop]\n        - deg: DataFrame [gene, log2FC, pvalue, padj, cluster_marker]\n    \"\"\"\n    rng = np.random.default_rng(random_seed)\n\n    n_clusters = 10\n    cluster_names = [f\"Cluster {i}\" for i in range(n_clusters)]\n\n    # ── Cluster proportions ──────────────────────────────────────────────────\n    # Simulate a shift: some clusters expand in treatment, some contract\n    props_ctrl = rng.dirichlet(np.ones(n_clusters) * 2.0)   # even-ish\n    # Shift weights: clusters 0,3,7 expand; 1,5,8 contract\n    shift = np.ones(n_clusters) * 2.0\n    shift[0] = 4.0   # expands\n    shift[3] = 3.5\n    shift[7] = 3.0\n    shift[1] = 1.0   # contracts\n    shift[5] = 1.2\n    shift[8] = 1.0\n    props_tx = rng.dirichlet(shift)\n\n    cluster_props = pd.DataFrame({\n        \"cluster\": cluster_names,\n        \"Control\": props_ctrl,\n        \"Treatment\": props_tx,\n    })\n\n    # ── DEG data ────────────────────────────────────────────────────────────\n    n_genes = 2000\n    # Simulate log2FC: mostly centered at 0, some shifted\n    log2fc = rng.normal(0, 0.8, n_genes)\n\n    # Assign a subset as truly differentially expressed\n    n_up = 80\n    n_down = 60\n    up_idx = rng.choice(n_genes, n_up, replace=False)\n    down_idx = rng.choice(\n        [i for i in range(n_genes) if i not in up_idx], n_down, replace=False\n    )\n    log2fc[up_idx] = np.abs(log2fc[up_idx]) + rng.uniform(0.3, 1.0, n_up)\n    log2fc[down_idx] = -np.abs(log2fc[down_idx]) - rng.uniform(0.3, 1.0, n_down)\n\n    # p-values: small for DEGs, large for non-DEGs\n    pvalue = np.ones(n_genes)\n    # Non-DEGs: uniform p-values\n    nondeg_mask = np.ones(n_genes, dtype=bool)\n    nondeg_mask[up_idx] = False\n    nondeg_mask[down_idx] = False\n    pvalue[nondeg_mask] = rng.uniform(0.1, 1.0, nondeg_mask.sum())\n\n    # DEGs: small p-values\n    n_deg = len(np.concatenate([up_idx, down_idx]))\n    pvalue[up_idx] = 10 ** -rng.uniform(2, 12, n_up)\n    pvalue[down_idx] = 10 ** -rng.uniform(2, 10, n_down)\n\n    # Adjust p-values (Benjamini-Hochberg via scipy)\n    from scipy.stats import false_discovery_control\n    padj = false_discovery_control(pvalue)\n\n    # Gene names\n    genes = [f\"Gene{i}\" for i in range(n_genes)]\n    # Label a few top marker genes\n    top_genes = {\n        \"CXCL10\": up_idx[0], \"CCL5\": up_idx[1], \"ISG15\": up_idx[2],\n        \"CD74\": up_idx[3], \"B2M\": up_idx[4],\n        \"GAPDH\": down_idx[0], \"ACTB\": down_idx[1], \"EEF1A1\": down_idx[2],\n    }\n    for name, idx in top_genes.items():\n        if idx < n_genes:\n            genes[idx] = name\n\n    deg = pd.DataFrame({\n        \"gene\": genes,\n        \"log2FC\": log2fc,\n        \"pvalue\": pvalue,\n        \"padj\": padj,\n    })\n\n    # Mark cluster-marker status (for visual distinction on volcano)\n    is_up = (deg[\"log2FC\"] >= LOG2FC_THRESH) & (deg[\"padj\"] <= PADJ_THRESH)\n    is_down = (deg[\"log2FC\"] <= -LOG2FC_THRESH) & (deg[\"padj\"] <= PADJ_THRESH)\n    deg[\"significant\"] = \"NS\"\n    deg.loc[is_up, \"significant\"] = \"Up\"\n    deg.loc[is_down, \"significant\"] = \"Down\"\n    deg[\"-log10_padj\"] = -np.log10(deg[\"padj\"].clip(lower=1e-300))\n\n    return {\"cluster_props\": cluster_props, \"deg\": deg}\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  PLOTTING FUNCTIONS\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef panel_a_stacked_bar(ax, data: pd.DataFrame) -> None:\n    \"\"\"\n    Stacked bar chart — cell cluster proportion comparison.\n\n    Data expected columns: cluster, Control, Treatment\n    Control and Treatment should be fractions that sum to ~1.0 each.\n    \"\"\"\n    clusters = data[\"cluster\"].values\n    n = len(clusters)\n    colors = CLUSTER_COLORS[:n]\n\n    # Bar positions\n    categories = [\"Control\", \"Treatment\"]\n    x = np.arange(len(categories))\n    bar_width = 0.55\n\n    # Plot stacked bars\n    bottom_ctrl = np.zeros(len(categories))\n    for i in range(n):\n        vals = [data.loc[i, \"Control\"], data.loc[i, \"Treatment\"]]\n        ax.bar(\n            x, vals, bar_width,\n            bottom=bottom_ctrl,\n            color=colors[i],\n            edgecolor=\"white\",\n            linewidth=0.4,\n            label=clusters[i],\n        )\n        bottom_ctrl += vals\n\n    # Styling\n    ax.set_xticks(x)\n    ax.set_xticklabels(categories, fontsize=7)\n    ax.set_ylabel(\"Cell proportion\", fontsize=7)\n    ax.set_ylim(0, 1.02)\n    ax.set_yticks([0, 0.25, 0.50, 0.75, 1.00])\n    ax.set_yticklabels([\"0.00\", \"0.25\", \"0.50\", \"0.75\", \"1.00\"])\n\n    # Legend: place outside right, smaller font\n    ax.legend(\n        loc=\"upper left\",\n        bbox_to_anchor=(1.01, 1.0),\n        frameon=False,\n        fontsize=6,\n        title=\"Cluster\",\n        title_fontsize=6.5,\n        handlelength=1.0,\n        handletextpad=0.4,\n    )\n\n\ndef panel_b_volcano(ax, data: pd.DataFrame) -> None:\n    \"\"\"\n    Volcano plot — log2(Fold Change) vs -log10(adjusted p-value).\n\n    Highlights up/down regulated genes and labels key markers.\n    \"\"\"\n    # Categorize points\n    up = data[data[\"significant\"] == \"Up\"]\n    down = data[data[\"significant\"] == \"Down\"]\n    ns = data[data[\"significant\"] == \"NS\"]\n\n    # Plot non-significant first (background layer)\n    ax.scatter(\n        ns[\"log2FC\"], ns[\"-log10_padj\"],\n        c=VOLCANO_NS, s=3, alpha=0.4, rasterized=True, label=\"NS\",\n    )\n\n    # Down-regulated\n    ax.scatter(\n        down[\"log2FC\"], down[\"-log10_padj\"],\n        c=VOLCANO_DOWN, s=8, alpha=0.7, rasterized=True, label=\"Down\",\n    )\n\n    # Up-regulated\n    ax.scatter(\n        up[\"log2FC\"], up[\"-log10_padj\"],\n        c=VOLCANO_UP, s=8, alpha=0.7, rasterized=True, label=\"Up\",\n    )\n\n    # Threshold lines\n    ax.axvline(-LOG2FC_THRESH, color=\"grey\", linestyle=\"--\", linewidth=0.4, alpha=0.6)\n    ax.axvline(LOG2FC_THRESH, color=\"grey\", linestyle=\"--\", linewidth=0.4, alpha=0.6)\n    ax.axhline(-np.log10(PADJ_THRESH), color=\"grey\", linestyle=\"--\", linewidth=0.4, alpha=0.6)\n\n    # Label top marker genes\n    top_markers = [\n        \"CXCL10\", \"CCL5\", \"ISG15\", \"CD74\", \"B2M\",\n        \"GAPDH\", \"ACTB\", \"EEF1A1\",\n    ]\n    for gene_name in top_markers:\n        row = data[data[\"gene\"] == gene_name]\n        if row.empty:\n            continue\n        r = row.iloc[0]\n        # Use different color for labeled points\n        color = VOLCANO_TOP if r[\"significant\"] == \"Up\" else VOLCANO_DOWN\n        ax.plot(\n            r[\"log2FC\"], r[\"-log10_padj\"],\n            marker=\"o\", markersize=5, markeredgecolor=\"black\",\n            markerfacecolor=color, markeredgewidth=0.5, linestyle=\"None\",\n        )\n        # Offset label to avoid overlap\n        offset_x = 0.08\n        offset_y = 0.08\n        ax.annotate(\n            gene_name,\n            xy=(r[\"log2FC\"], r[\"-log10_padj\"]),\n            xytext=(r[\"log2FC\"] + offset_x, r[\"-log10_padj\"] + offset_y),\n            fontsize=5.5,\n            fontweight=\"bold\",\n            color=color,\n            arrowprops=dict(\n                arrowstyle=\"-\", color=\"grey\", lw=0.3, alpha=0.5,\n            ),\n        )\n\n    # Styling\n    ax.set_xlabel(\"$\\log_2$(Fold Change)\", fontsize=7)\n    ax.set_ylabel(\"$-\\log_{10}$(adjusted $p$)\", fontsize=7)\n\n    # Legend\n    ax.legend(\n        loc=\"upper right\", frameon=False, fontsize=6,\n        markerscale=1.2, handletextpad=0.3,\n    )\n\n    # Count summary annotation\n    n_up = len(up)\n    n_down = len(down)\n    ax.text(\n        0.98, 0.02,\n        f\"↑ {n_up}  ↓ {n_down}\",\n        transform=ax.transAxes,\n        fontsize=6,\n        ha=\"right\", va=\"bottom\",\n        color=\"#333333\",\n    )\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  MAIN\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef main(export: bool = False, real_data_path: str | None = None) -> None:\n    # ── Setup Cell journal style ─────────────────────────────────────────────\n    info = setup_style(journal=JOURNAL, lang=\"en\", use_sciplots=False)\n    print(f\"[setup] journal={info['journal']}, sciplots={info['sciplots_used']}\")\n\n    # ── Load / generate data ────────────────────────────────────────────────\n    if real_data_path and os.path.exists(real_data_path):\n        # User-provided data: CSV with cluster proportions + DEG\n        # Expects two sheets / files: cluster_props.csv and deg.csv\n        base = os.path.splitext(real_data_path)[0]\n        props_path = f\"{base}_cluster_props.csv\"\n        deg_path = f\"{base}_deg.csv\"\n        if os.path.exists(props_path) and os.path.exists(deg_path):\n            cluster_props = pd.read_csv(props_path)\n            deg = pd.read_csv(deg_path)\n            print(f\"[data] loaded real data from {props_path} and {deg_path}\")\n        else:\n            print(f\"[data] expected {props_path} and {deg_path} not found; using example data\")\n            data = generate_example_data()\n            cluster_props, deg = data[\"cluster_props\"], data[\"deg\"]\n    else:\n        data = generate_example_data()\n        cluster_props, deg = data[\"cluster_props\"], data[\"deg\"]\n        print(\"[data] using synthetic example data (replace with --real-data)\")\n\n    # ── Build figure ────────────────────────────────────────────────────────\n    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(FIG_W, FIG_H))\n\n    # Expand left panel slightly for legend room\n    fig.subplots_adjust(wspace=0.35, left=0.07, right=0.92, bottom=0.15, top=0.92)\n\n    # Panel (a): Stacked bar\n    panel_a_stacked_bar(ax1, cluster_props)\n\n    # Panel (b): Volcano\n    panel_b_volcano(ax2, deg)\n\n    # ── Finalize layout and add panel labels ────────────────────────────────\n    # Use constrained-layout within each panel area\n    finalize_figure(fig, prefer=\"tight\", verbose=True)\n    add_panel_labels(fig, style=\"nature\", fontsize=8, fontweight=\"bold\")\n\n    # ── Export ──────────────────────────────────────────────────────────────\n    output_dir = os.path.join(os.path.dirname(__file__), \"figures\")\n    os.makedirs(output_dir, exist_ok=True)\n    basename = os.path.join(output_dir, \"figure2_scRNAseq\")\n\n    if export:\n        paths = export_figure(\n            fig,\n            basename=basename,\n            formats=[\"pdf\", \"png\"],\n            size_inches=(FIG_W, FIG_H),\n            dpi=300,\n            grayscale_preview=True,\n        )\n        print(f\"[export] wrote {len(paths)} file(s)\")\n        for p in paths:\n            print(f\"  {p}\")\n    else:\n        # Just save a PNG preview\n        png_path = f\"{basename}_preview.png\"\n        fig.savefig(png_path, dpi=200, bbox_inches=\"tight\")\n        print(f\"[preview] wrote {png_path}\")\n\n    plt.close(fig)\n    print(\"[done] Figure 2 complete.\")\n\n\nif __name__ == \"__main__\":\n    p = argparse.ArgumentParser(description=\"Figure 2: scRNA-seq cluster bar + volcano\")\n    p.add_argument(\"--export\", action=\"store_true\", help=\"Export PDF+PNG for submission\")\n    p.add_argument(\n        \"--real-data\", type=str, default=None,\n        help=(\n            \"Path to data prefix (e.g. path/to/my_data)\\n\"\n            \"  Expects: my_data_cluster_props.csv  — columns: cluster, Control, Treatment\\n\"\n            \"           my_data_deg.csv             — columns: gene, log2FC, pvalue, padj\"\n        ),\n    )\n    args = p.parse_args()\n\n    main(export=args.export, real_data_path=args.real_data)\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/sci-draw/assets/figures4papers/figure_scRNAseq_Cell/plot_figure2.py", "content": "\"\"\"\nFigure 2: scRNA-seq cluster proportion + DEG volcano plot\n=========================================================\nFor Cell journal submission.\n\nPanel (a): Stacked bar chart — cell cluster proportions in Control vs Treatment\nPanel (b): Volcano plot — differentially expressed genes (log2FC vs -log10 padj)\n\nUsage:\n    python plot_figure2.py                          # PNG preview\n    python plot_figure2.py --export                 # PDF + PNG for submission\n    python plot_figure2.py --real-data path/to/csv  # use your own data\n\nDesign:\n    - Cell-style formatting (Nature-level preset from setup_style.py)\n    - Unified colorblind-safe palette across both panels\n    - Proper panel labels a/b aligned via layout_tools\n\nAuthor: sci-draw\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport os\nimport sys\n\nimport numpy as np\nimport pandas as pd\nfrom matplotlib import pyplot as plt\nfrom matplotlib.patches import FancyBboxPatch\n\n# ── sci-draw utilities ──────────────────────────────────────────────────────\nsys.path.insert(0, os.path.join(os.path.dirname(__file__), \"..\", \"..\", \"..\", \"scripts\"))\nfrom setup_style import setup_style\nfrom layout_tools import add_panel_labels, finalize_figure\nfrom export_figure import export_figure\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  CONFIGURATION\n# ══════════════════════════════════════════════════════════════════════════════\n\n# Cell journal: similar to Nature — sans-serif, compact, clean\nJOURNAL = \"nature\"\n# Figure width: double-column Cell figure ~ 6.85 in (174 mm)\nFIG_W, FIG_H = 7.0, 3.2\n\n# Colorblind-safe palette for 10 cell clusters (Tableau 10 + ColorBrewer extension)\nCLUSTER_COLORS = [\n    \"#3B7DD8\",  # Cluster 0 — blue\n    \"#E85D4A\",  # Cluster 1 — red\n    \"#4DAF4A\",  # Cluster 2 — green\n    \"#984EA3\",  # Cluster 3 — purple\n    \"#FF7F00\",  # Cluster 4 — orange\n    \"#A65628\",  # Cluster 5 — brown\n    \"#F781BF\",  # Cluster 6 — pink\n    \"#66C2A5\",  # Cluster 7 — teal\n    \"#E6AB02\",  # Cluster 8 — gold\n    \"#999999\",  # Cluster 9 — gray\n]\n\n# Volcano plot colors (match the accent tones from the cluster palette)\nVOLCANO_UP = \"#CC3344\"      # up-regulated — red accent\nVOLCANO_DOWN = \"#3B7DD8\"    # down-regulated — blue accent\nVOLCANO_NS = \"#BBBBBB\"      # not significant — light gray\nVOLCANO_TOP = \"#881122\"     # top marker gene — dark red (for labeling)\n\n# Significance thresholds\nLOG2FC_THRESH = 0.5   # |log2FC| >= 0.5\nPADJ_THRESH = 0.05    # adjusted p-value <= 0.05\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  DATA — synthetic example (replace with real data when available)\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef generate_example_data(random_seed: int = 42) -> dict:\n    \"\"\"\n    Generate realistic scRNA-seq example data.\n\n    Returns a dict with:\n        - cluster_props: DataFrame [cluster, control_prop, treatment_prop]\n        - deg: DataFrame [gene, log2FC, pvalue, padj, cluster_marker]\n    \"\"\"\n    rng = np.random.default_rng(random_seed)\n\n    n_clusters = 10\n    cluster_names = [f\"Cluster {i}\" for i in range(n_clusters)]\n\n    # ── Cluster proportions ──────────────────────────────────────────────────\n    # Simulate a shift: some clusters expand in treatment, some contract\n    props_ctrl = rng.dirichlet(np.ones(n_clusters) * 2.0)   # even-ish\n    # Shift weights: clusters 0,3,7 expand; 1,5,8 contract\n    shift = np.ones(n_clusters) * 2.0\n    shift[0] = 4.0   # expands\n    shift[3] = 3.5\n    shift[7] = 3.0\n    shift[1] = 1.0   # contracts\n    shift[5] = 1.2\n    shift[8] = 1.0\n    props_tx = rng.dirichlet(shift)\n\n    cluster_props = pd.DataFrame({\n        \"cluster\": cluster_names,\n        \"Control\": props_ctrl,\n        \"Treatment\": props_tx,\n    })\n\n    # ── DEG data ────────────────────────────────────────────────────────────\n    n_genes = 2000\n    # Simulate log2FC: mostly centered at 0, some shifted\n    log2fc = rng.normal(0, 0.8, n_genes)\n\n    # Assign a subset as truly differentially expressed\n    n_up = 80\n    n_down = 60\n    up_idx = rng.choice(n_genes, n_up, replace=False)\n    down_idx = rng.choice(\n        [i for i in range(n_genes) if i not in up_idx], n_down, replace=False\n    )\n    log2fc[up_idx] = np.abs(log2fc[up_idx]) + rng.uniform(0.3, 1.0, n_up)\n    log2fc[down_idx] = -np.abs(log2fc[down_idx]) - rng.uniform(0.3, 1.0, n_down)\n\n    # p-values: small for DEGs, large for non-DEGs\n    pvalue = np.ones(n_genes)\n    # Non-DEGs: uniform p-values\n    nondeg_mask = np.ones(n_genes, dtype=bool)\n    nondeg_mask[up_idx] = False\n    nondeg_mask[down_idx] = False\n    pvalue[nondeg_mask] = rng.uniform(0.1, 1.0, nondeg_mask.sum())\n\n    # DEGs: small p-values\n    n_deg = len(np.concatenate([up_idx, down_idx]))\n    pvalue[up_idx] = 10 ** -rng.uniform(2, 12, n_up)\n    pvalue[down_idx] = 10 ** -rng.uniform(2, 10, n_down)\n\n    # Adjust p-values (Benjamini-Hochberg via scipy)\n    from scipy.stats import false_discovery_control\n    padj = false_discovery_control(pvalue)\n\n    # Gene names\n    genes = [f\"Gene{i}\" for i in range(n_genes)]\n    # Label a few top marker genes\n    top_genes = {\n        \"CXCL10\": up_idx[0], \"CCL5\": up_idx[1], \"ISG15\": up_idx[2],\n        \"CD74\": up_idx[3], \"B2M\": up_idx[4],\n        \"GAPDH\": down_idx[0], \"ACTB\": down_idx[1], \"EEF1A1\": down_idx[2],\n    }\n    for name, idx in top_genes.items():\n        if idx < n_genes:\n            genes[idx] = name\n\n    deg = pd.DataFrame({\n        \"gene\": genes,\n        \"log2FC\": log2fc,\n        \"pvalue\": pvalue,\n        \"padj\": padj,\n    })\n\n    # Mark cluster-marker status (for visual distinction on volcano)\n    is_up = (deg[\"log2FC\"] >= LOG2FC_THRESH) & (deg[\"padj\"] <= PADJ_THRESH)\n    is_down = (deg[\"log2FC\"] <= -LOG2FC_THRESH) & (deg[\"padj\"] <= PADJ_THRESH)\n    deg[\"significant\"] = \"NS\"\n    deg.loc[is_up, \"significant\"] = \"Up\"\n    deg.loc[is_down, \"significant\"] = \"Down\"\n    deg[\"-log10_padj\"] = -np.log10(deg[\"padj\"].clip(lower=1e-300))\n\n    return {\"cluster_props\": cluster_props, \"deg\": deg}\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  PLOTTING FUNCTIONS\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef panel_a_stacked_bar(ax, data: pd.DataFrame) -> None:\n    \"\"\"\n    Stacked bar chart — cell cluster proportion comparison.\n\n    Data expected columns: cluster, Control, Treatment\n    Control and Treatment should be fractions that sum to ~1.0 each.\n    \"\"\"\n    clusters = data[\"cluster\"].values\n    n = len(clusters)\n    colors = CLUSTER_COLORS[:n]\n\n    # Bar positions\n    categories = [\"Control\", \"Treatment\"]\n    x = np.arange(len(categories))\n    bar_width = 0.55\n\n    # Plot stacked bars\n    bottom_ctrl = np.zeros(len(categories))\n    for i in range(n):\n        vals = [data.loc[i, \"Control\"], data.loc[i, \"Treatment\"]]\n        ax.bar(\n            x, vals, bar_width,\n            bottom=bottom_ctrl,\n            color=colors[i],\n            edgecolor=\"white\",\n            linewidth=0.4,\n            label=clusters[i],\n        )\n        bottom_ctrl += vals\n\n    # Styling\n    ax.set_xticks(x)\n    ax.set_xticklabels(categories, fontsize=7)\n    ax.set_ylabel(\"Cell proportion\", fontsize=7)\n    ax.set_ylim(0, 1.02)\n    ax.set_yticks([0, 0.25, 0.50, 0.75, 1.00])\n    ax.set_yticklabels([\"0.00\", \"0.25\", \"0.50\", \"0.75\", \"1.00\"])\n\n    # Legend: place outside right, smaller font\n    ax.legend(\n        loc=\"upper left\",\n        bbox_to_anchor=(1.01, 1.0),\n        frameon=False,\n        fontsize=6,\n        title=\"Cluster\",\n        title_fontsize=6.5,\n        handlelength=1.0,\n        handletextpad=0.4,\n    )\n\n\ndef panel_b_volcano(ax, data: pd.DataFrame) -> None:\n    \"\"\"\n    Volcano plot — log2(Fold Change) vs -log10(adjusted p-value).\n\n    Highlights up/down regulated genes and labels key markers.\n    \"\"\"\n    # Categorize points\n    up = data[data[\"significant\"] == \"Up\"]\n    down = data[data[\"significant\"] == \"Down\"]\n    ns = data[data[\"significant\"] == \"NS\"]\n\n    # Plot non-significant first (background layer)\n    ax.scatter(\n        ns[\"log2FC\"], ns[\"-log10_padj\"],\n        c=VOLCANO_NS, s=3, alpha=0.4, rasterized=True, label=\"NS\",\n    )\n\n    # Down-regulated\n    ax.scatter(\n        down[\"log2FC\"], down[\"-log10_padj\"],\n        c=VOLCANO_DOWN, s=8, alpha=0.7, rasterized=True, label=\"Down\",\n    )\n\n    # Up-regulated\n    ax.scatter(\n        up[\"log2FC\"], up[\"-log10_padj\"],\n        c=VOLCANO_UP, s=8, alpha=0.7, rasterized=True, label=\"Up\",\n    )\n\n    # Threshold lines\n    ax.axvline(-LOG2FC_THRESH, color=\"grey\", linestyle=\"--\", linewidth=0.4, alpha=0.6)\n    ax.axvline(LOG2FC_THRESH, color=\"grey\", linestyle=\"--\", linewidth=0.4, alpha=0.6)\n    ax.axhline(-np.log10(PADJ_THRESH), color=\"grey\", linestyle=\"--\", linewidth=0.4, alpha=0.6)\n\n    # Label top marker genes\n    top_markers = [\n        \"CXCL10\", \"CCL5\", \"ISG15\", \"CD74\", \"B2M\",\n        \"GAPDH\", \"ACTB\", \"EEF1A1\",\n    ]\n    for gene_name in top_markers:\n        row = data[data[\"gene\"] == gene_name]\n        if row.empty:\n            continue\n        r = row.iloc[0]\n        # Use different color for labeled points\n        color = VOLCANO_TOP if r[\"significant\"] == \"Up\" else VOLCANO_DOWN\n        ax.plot(\n            r[\"log2FC\"], r[\"-log10_padj\"],\n            marker=\"o\", markersize=5, markeredgecolor=\"black\",\n            markerfacecolor=color, markeredgewidth=0.5, linestyle=\"None\",\n        )\n        # Offset label to avoid overlap\n        offset_x = 0.08\n        offset_y = 0.08\n        ax.annotate(\n            gene_name,\n            xy=(r[\"log2FC\"], r[\"-log10_padj\"]),\n            xytext=(r[\"log2FC\"] + offset_x, r[\"-log10_padj\"] + offset_y),\n            fontsize=5.5,\n            fontweight=\"bold\",\n            color=color,\n            arrowprops=dict(\n                arrowstyle=\"-\", color=\"grey\", lw=0.3, alpha=0.5,\n            ),\n        )\n\n    # Styling\n    ax.set_xlabel(\"$\\log_2$(Fold Change)\", fontsize=7)\n    ax.set_ylabel(\"$-\\log_{10}$(adjusted $p$)\", fontsize=7)\n\n    # Legend\n    ax.legend(\n        loc=\"upper right\", frameon=False, fontsize=6,\n        markerscale=1.2, handletextpad=0.3,\n    )\n\n    # Count summary annotation\n    n_up = len(up)\n    n_down = len(down)\n    ax.text(\n        0.98, 0.02,\n        f\"↑ {n_up}  ↓ {n_down}\",\n        transform=ax.transAxes,\n        fontsize=6,\n        ha=\"right\", va=\"bottom\",\n        color=\"#333333\",\n    )\n\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  MAIN\n# ══════════════════════════════════════════════════════════════════════════════\n\ndef main(export: bool = False, real_data_path: str | None = None) -> None:\n    # ── Setup Cell journal style ─────────────────────────────────────────────\n    info = setup_style(journal=JOURNAL, lang=\"en\", use_sciplots=False)\n    print(f\"[setup] journal={info['journal']}, sciplots={info['sciplots_used']}\")\n\n    # ── Load / generate data ────────────────────────────────────────────────\n    if real_data_path and os.path.exists(real_data_path):\n        # User-provided data: CSV with cluster proportions + DEG\n        # Expects two sheets / files: cluster_props.csv and deg.csv\n        base = os.path.splitext(real_data_path)[0]\n        props_path = f\"{base}_cluster_props.csv\"\n        deg_path = f\"{base}_deg.csv\"\n        if os.path.exists(props_path) and os.path.exists(deg_path):\n            cluster_props = pd.read_csv(props_path)\n            deg = pd.read_csv(deg_path)\n            print(f\"[data] loaded real data from {props_path} and {deg_path}\")\n        else:\n            print(f\"[data] expected {props_path} and {deg_path} not found; using example data\")\n            data = generate_example_data()\n            cluster_props, deg = data[\"cluster_props\"], data[\"deg\"]\n    else:\n        data = generate_example_data()\n        cluster_props, deg = data[\"cluster_props\"], data[\"deg\"]\n        print(\"[data] using synthetic example data (replace with --real-data)\")\n\n    # ── Build figure ────────────────────────────────────────────────────────\n    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(FIG_W, FIG_H))\n\n    # Expand left panel slightly for legend room\n    fig.subplots_adjust(wspace=0.35, left=0.07, right=0.92, bottom=0.15, top=0.92)\n\n    # Panel (a): Stacked bar\n    panel_a_stacked_bar(ax1, cluster_props)\n\n    # Panel (b): Volcano\n    panel_b_volcano(ax2, deg)\n\n    # ── Finalize layout and add panel labels ────────────────────────────────\n    # Use constrained-layout within each panel area\n    finalize_figure(fig, prefer=\"tight\", verbose=True)\n    add_panel_labels(fig, style=\"nature\", fontsize=8, fontweight=\"bold\")\n\n    # ── Export ──────────────────────────────────────────────────────────────\n    output_dir = os.path.join(os.path.dirname(__file__), \"figures\")\n    os.makedirs(output_dir, exist_ok=True)\n    basename = os.path.join(output_dir, \"figure2_scRNAseq\")\n\n    if export:\n        paths = export_figure(\n            fig,\n            basename=basename,\n            formats=[\"pdf\", \"png\"],\n            size_inches=(FIG_W, FIG_H),\n            dpi=300,\n            grayscale_preview=True,\n        )\n        print(f\"[export] wrote {len(paths)} file(s)\")\n        for p in paths:\n            print(f\"  {p}\")\n    else:\n        # Just save a PNG preview\n        png_path = f\"{basename}_preview.png\"\n        fig.savefig(png_path, dpi=200, bbox_inches=\"tight\")\n        print(f\"[preview] wrote {png_path}\")\n\n    plt.close(fig)\n    print(\"[done] Figure 2 complete.\")\n\n\nif __name__ == \"__main__\":\n    p = argparse.ArgumentParser(description=\"Figure 2: scRNA-seq cluster bar + volcano\")\n    p.add_argument(\"--export\", action=\"store_true\", help=\"Export PDF+PNG for submission\")\n    p.add_argument(\n        \"--real-data\", type=str, default=None,\n        help=(\n            \"Path to data prefix (e.g. path/to/my_data)\\n\"\n            \"  Expects: my_data_cluster_props.csv  — columns: cluster, Control, Treatment\\n\"\n            \"           my_data_deg.csv             — columns: gene, log2FC, pvalue, padj\"\n        ),\n    )\n    args = p.parse_args()\n\n    main(export=args.export, real_data_path=args.real_data)\n"})
