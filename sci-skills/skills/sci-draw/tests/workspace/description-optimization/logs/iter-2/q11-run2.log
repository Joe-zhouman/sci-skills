    # Subtitle (small, italic, below title)\n    if sub:\n        ax.text(x + w / 2, y + 0.08, sub,\n                ha='center', va='bottom', fontsize=7.5,\n                fontstyle='italic', color=MED_GRAY, zorder=3)\n\n    # Side text (e.g., \"n = XXX\") — right-aligned\n    if side_text:\n        ax.text(x + w - 0.15, y + h / 2, side_text,\n                ha='right', va='center', fontsize=8.5,\n                fontweight='bold', color=DARK_GRAY, zorder=3)\n\n    return (x + w / 2, y + h)  # top-center connection point\n\n\ndef arrow(ax, x1, y1, x2, y2, style='->', lw=1.0, shrink=2):\n    \"\"\"Draw a clean arrow between two points (data coords).\"\"\"\n    ax.annotate('', xy=(x2, y2), xytext=(x1, y1),\n                arrowprops=dict(\n                    arrowstyle=style,\n                    color=ARROW_COLOR,\n                    lw=lw,\n                    shrinkA=shrink, shrinkB=shrink\n                ),\n                zorder=1)\n\n\ndef downward_arrow(ax, cx, top_y, bot_y, lw=1.0):\n    \"\"\"Shortcut: vertical arrow from top_y to bot_y at x=cx.\"\"\"\n    arrow(ax, cx, top_y, cx, bot_y, lw=lw)\n\n\n# ── Build Figure ─────────────────────────────────────────────────────\n\ndef build_flowchart(params=None):\n    \"\"\"\n    params : dict with optional keys:\n        n_screened, n_excluded, n_randomized,\n        n_arm_a, n_arm_b, n_fu_loss_a, n_fu_loss_b,\n        n_analyzed_a, n_analyzed_b\n    \"\"\"\n    if params is None:\n        params = {}\n\n    fig, ax = plt.subplots(1, 1, figsize=(7.5, 10.5))\n    ax.set_xlim(0, 10)\n    ax.set_ylim(0, 15)\n    ax.axis('off')\n\n    # ── Layout constants ─────────────────────────────────────────\n    CX = 5.0            # pre-split center column\n    LX = 2.8            # left arm center\n    RX = 7.2            # right arm center\n    BW = 3.8            # wide box (pre-split)\n    SW = 3.0            # narrow box (post-split)\n    BH = 0.70           # box height\n    GAP = 1.05          # vertical gap between rows\n\n    def row_y(r):\n        \"\"\"Return bottom y of row r (row 0 = top).\"\"\"\n        return 14.0 - r * GAP - BH\n\n    # ── Row 0: Recruitment ──────────────────────────────────────\n    y0 = row_y(0)\n    box(ax, CX - BW / 2, y0, BW, BH,\n        'Patient Recruitment',\n        sub='Screening and enrollment')\n    downward_arrow(ax, CX, y0 + BH, row_y(1))\n\n    # ── Row 1: Eligibility ──────────────────────────────────────\n    y1 = row_y(1)\n    box(ax, CX - BW / 2, y1, BW, BH,\n        'Assessed for Eligibility',\n        sub='Inclusion / exclusion criteria',\n        side_text=f\"n = {params.get('n_screened', 'XXX')}\")\n\n    # Exclusion side-box\n    exc_w, exc_h = 2.2, 0.85\n    exc_x, exc_y = 8.0, y1 - 0.10\n    bbox = FancyBboxPatch(\n        (exc_x, exc_y), exc_w, exc_h,\n        boxstyle=\"round,pad=0.04\",\n        facecolor='#fafafa', edgecolor=LIGHT_GRAY,\n        linewidth=1.0, zorder=2\n    )\n    ax.add_patch(bbox)\n    ax.text(exc_x + exc_w / 2, exc_y + exc_h - 0.12, 'Excluded',\n            ha='center', va='top', fontsize=8.5, fontweight='bold',\n            color=MED_GRAY, zorder=3)\n    ax.text(exc_x + exc_w / 2, exc_y + 0.10,\n            f\"n = {params.get('n_excluded', 'XX')}\",\n            ha='center', va='bottom', fontsize=8,\n            color=MED_GRAY, zorder=3)\n    # Arrow from eligibility → exclusion\n    arrow(ax, CX + BW / 2, y1 + BH / 2, exc_x, exc_y + exc_h / 2,\n          lw=0.9)\n\n    # Arrow down to enrollment (skip rows unless excluded)\n    downward_arrow(ax, CX, y1 + BH, row_y(2), lw=1.0)\n\n    # ── Row 2: Enrollment / Consent ─────────────────────────────\n    y2 = row_y(2)\n    box(ax, CX - BW / 2, y2, BW, BH,\n        'Informed Consent',\n        sub='Enrolled',\n        side_text=f\"n = {params.get('n_randomized', 'XXX')}\")\n    downward_arrow(ax, CX, y2 + BH, row_y(3))\n\n    # ── Row 3: Randomization ────────────────────────────────────\n    y3 = row_y(3)\n    box(ax, CX - BW / 2, y3, BW, BH,\n        'Randomization',\n        sub='1:1 allocation',\n        side_text=f\"n = {params.get('n_randomized', 'XXX')}\")\n\n    # Split arrows\n    split_y = y3 + BH + 0.10\n    arrow(ax, CX, split_y, LX, split_y + 0.3, lw=1.0)\n    arrow(ax, CX, split_y, RX, split_y + 0.3, lw=1.0)\n\n    # ── Row 4: Allocation ───────────────────────────────────────\n    y4 = row_y(4)\n    # Arm A (left)\n    box(ax, LX - SW / 2, y4, SW, BH,\n        params.get('label_a', 'Treatment A'),\n        sub='Active / Experimental',\n        side_text=f\"n = {params.get('n_arm_a', 'XXX')}\")\n    # Arm B (right)\n    box(ax, RX - SW / 2, y4, SW, BH,\n        params.get('label_b', 'Treatment B'),\n        sub='Control / Placebo',\n        side_text=f\"n = {params.get('n_arm_b', 'XXX')}\")\n\n    # ── Row 5: Treatment Phase ──────────────────────────────────\n    y5 = row_y(5)\n    tx_w = 7.2\n    # Draw a wider \"phase\" box spanning both arms\n    span_box = FancyBboxPatch(\n        (CX - tx_w / 2, y5), tx_w, BH + 0.40,\n        boxstyle=\"round,pad=0.04\",\n        facecolor='#f9f9f9', edgecolor='#aaaaaa',\n        linewidth=0.8, zorder=2, linestyle='--'\n    )\n    ax.add_patch(span_box)\n    ax.text(CX, y5 + BH / 2 + 0.15, 'Treatment Phase',\n            ha='center', va='center', fontsize=9.5,\n            fontweight='bold', color=DARK_GRAY, zorder=3)\n\n    # Timeline ticks inside the phase box\n    visits = ['Wk 0', 'Wk 4', 'Wk 8', 'Wk 12', 'Wk 16', 'Wk 20']\n    n_v = len(visits)\n    visit_y = y5 + 0.22\n    for i, v in enumerate(visits):\n        vx = CX - tx_w / 2 + tx_w * (i + 0.5) / n_v\n        ax.plot(vx, visit_y, 'o', color='#888888', markersize=4, zorder=3)\n        ax.text(vx, visit_y - 0.18, v,\n                ha='center', va='top', fontsize=6.5,\n                color=MED_GRAY, zorder=3)\n\n    # Vertical arrows into treatment phase (from each arm)\n    arrow(ax, LX, y4 + BH, LX, y5 + BH + 0.40, lw=0.9)\n    arrow(ax, RX, y4 + BH, RX, y5 + BH + 0.40, lw=0.9)\n\n    # ── Row 6: Follow-Up ────────────────────────────────────────\n    y6 = row_y(6)\n    fu_w = 7.2\n    fu_box = FancyBboxPatch(\n        (CX - fu_w / 2, y6), fu_w, BH + 0.35,\n        boxstyle=\"round,pad=0.04\",\n        facecolor='#f9f9f9', edgecolor='#aaaaaa',\n        linewidth=0.8, zorder=2, linestyle='--'\n    )\n    ax.add_patch(fu_box)\n    ax.text(CX, y6 + BH / 2 + 0.10, 'Follow-Up Period',\n            ha='center', va='center', fontsize=9.5,\n            fontweight='bold', color=DARK_GRAY, zorder=3)\n\n    # FU visit ticks\n    fu_visits = ['Mo 3', 'Mo 6', 'Mo 9', 'Mo 12', 'Mo 18', 'Mo 24']\n    n_fv = len(fu_visits)\n    fv_y = y6 + 0.18\n    for i, v in enumerate(fu_visits):\n        vx = CX - fu_w / 2 + fu_w * (i + 0.5) / n_fv\n        ax.plot(vx, fv_y, '^', color='#888888', markersize=4, zorder=3)\n        ax.text(vx, fv_y - 0.18, v,\n                ha='center', va='top', fontsize=6.5,\n                color=MED_GRAY, zorder=3)\n\n    # Arrow: treatment → follow-up\n    arrow(ax, CX, y5 + BH + 0.40, CX, y6 + BH + 0.35, lw=1.0)\n\n    # ── Row 7: Completion Status ────────────────────────────────\n    y7 = row_y(7)\n    sub_w = 2.6\n    # Completed (left)\n    box(ax, CX - sub_w - 0.30, y7, sub_w, BH,\n        'Completed Protocol',\n        side_text=f\"n = {params.get('n_completed', 'XXX')}\")\n    arrow(ax, CX, y6 + BH + 0.35, CX - sub_w / 2 - 0.15, y7 + BH,\n          lw=0.9)\n\n    # Discontinued (right)\n    box(ax, CX + 0.30, y7, sub_w, BH,\n        'Discontinued',\n        sub='Adverse event / Withdrawal',\n        side_text=f\"n = {params.get('n_discontinued', 'XX')}\")\n    arrow(ax, CX, y6 + BH + 0.35, CX + 0.30 + sub_w / 2, y7 + BH,\n          lw=0.9)\n\n    # ── Row 8: Analysis ─────────────────────────────────────────\n    y8 = row_y(8)\n    box(ax, CX - BW / 2, y8, BW, BH,\n        'Intention-to-Treat Analysis',\n        sub='Primary and secondary outcomes',\n        side_text=f\"n = {params.get('n_analyzed', 'XXX')}\")\n\n    # Merge arrows\n    arrow(ax, CX - sub_w / 2 - 0.15, y7 + BH, CX, y8 + BH, lw=0.9)\n    arrow(ax, CX + 0.30 + sub_w / 2, y7 + BH, CX, y8 + BH, lw=0.9)\n\n    # ── Footer ─────────────────────────────────────────────────\n    fig.text(0.5, 0.01,\n             'Figure 1. Study Flow Diagram',\n             ha='center', fontsize=10, fontweight='bold',\n             color=DARK_GRAY)\n\n    fig.subplots_adjust(left=0.05, right=0.95, top=0.98, bottom=0.04)\n    return fig\n\n\n# ── CLI ──────────────────────────────────────────────────────────────\n\nif __name__ == '__main__':\n    # Customize patient numbers here\n    data = {\n        'n_screened':     1250,\n        'n_excluded':      312,\n        'n_randomized':    938,\n        'label_a':        'Dapagliflozin',\n        'n_arm_a':         469,\n        'label_b':        'Placebo',\n        'n_arm_b':         469,\n        'n_completed':     856,\n        'n_discontinued':   82,\n        'n_analyzed':      938,\n    }\n\n    fig = build_flowchart(data)\n\n    flags = set(sys.argv[1:]) if len(sys.argv) > 1 else {'both'}\n\n    if '--pdf' in flags or 'both' in flags:\n        fig.savefig('clinical_trial_flowchart.pdf', dpi=300,\n                    format='pdf', bbox_inches='tight')\n        print('✓ Saved  clinical_trial_flowchart.pdf')\n\n    if '--png' in flags or 'both' in flags:\n        fig.savefig('clinical_trial_flowchart.png', dpi=300,\n                    format='png', bbox_inches='tight')\n        print('✓ Saved  clinical_trial_flowchart.png')\n\n    if '--preview' in flags:\n        plt.show()\n    else:\n        plt.close(fig)\n        print('Done.')\n"})
