TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure1_science.py", "content": "#!/usr/bin/env python3\n\"\"\"\nFigure 1: Multi-panel figure for Science journal.\nPanels:\n  (a) PCA scatter plot showing separation of 3 groups\n  (b) Tumor volume time-course curves\n  (c) Day 28 boxplot comparison\n  (d) Volcano plot of differentially expressed genes\n\nTarget: Science, double-column width (183 mm full page)\nColor scheme: Wong colorblind-safe palette\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.patches import Ellipse\nfrom sklearn.decomposition import PCA\nfrom sklearn.preprocessing import StandardScaler\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# =============================================================================\n# 1.  CONFIGURATION – Science journal specs + colorblind-safe palette\n# =============================================================================\n\nSCIENCE_WIDTH_MM = 183\nSCIENCE_WIDTH_IN = SCIENCE_WIDTH_MM / 25.4          # 7.20 in\nSCIENCE_HEIGHT_IN = SCIENCE_WIDTH_IN * 0.82          # ≈ 5.91 in (2×2 grid)\n\n# Wong colorblind-safe palette\nCTRL_COLOR  = '#0072B2'   # blue\nTRTA_COLOR  = '#E69F00'   # orange\nTRTB_COLOR  = '#009E73'   # green\nGROUP_COLORS = [CTRL_COLOR, TRTA_COLOR, TRTB_COLOR]\nGROUP_NAMES  = ['Control', 'Treatment_A', 'Treatment_B']\nGROUP_LABELS = ['Control', 'Treatment A', 'Treatment B']\n\n# Global matplotlib style – clean, minimal, Science-ready\nplt.rcParams.update({\n    'font.family':        'sans-serif',\n    'font.sans-serif':    ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size':          7,\n    'axes.titlesize':     7,\n    'axes.labelsize':     7,\n    'xtick.labelsize':    6.5,\n    'ytick.labelsize':    6.5,\n    'legend.fontsize':    6.5,\n    'figure.dpi':         300,\n    'savefig.dpi':        600,\n    'savefig.bbox':       'tight',\n    'axes.linewidth':     0.8,\n    'xtick.major.width':  0.6,\n    'ytick.major.width':  0.6,\n    'xtick.major.size':   3,\n    'ytick.major.size':   3,\n    'lines.linewidth':    1.5,\n    'lines.markersize':   4,\n    'axes.spines.top':    False,\n    'axes.spines.right':  False,\n})\n\nnp.random.seed(42)\n\n# =============================================================================\n# 2.  SYNTHETIC DATA GENERATION\n# =============================================================================\n\n# -----------------------------------------------------------------------------\n# 2a. PCA data – 24 samples × 100 features, 3 groups of 8\n# -----------------------------------------------------------------------------\nN_PER_GROUP = 8\nN_FEATURES  = 100\nN_TOTAL     = N_PER_GROUP * 3\n\nX = np.random.randn(N_TOTAL, N_FEATURES) * 0.5\n\n# Group-specific mean shifts to create PCA separation\nshift_map = {\n    'Control':      np.zeros(N_FEATURES),\n    'Treatment_A':  np.random.randn(N_FEATURES) * 0.3 + 0.2,\n    'Treatment_B':  np.random.randn(N_FEATURES) * 0.3 - 0.2,\n}\nfor i, grp in enumerate(GROUP_NAMES):\n    sl = slice(i * N_PER_GROUP, (i + 1) * N_PER_GROUP)\n    X[sl, :] += shift_map[grp]\n\n# Enrich top 10 features with group-specific structure\nfor feat_idx in range(10):\n    for i in range(3):\n        X[i::3, feat_idx] += np.random.randn(N_PER_GROUP) * 0.5 + [0.8, -0.3, -0.5][i]\n\nscaler = StandardScaler()\nX_scaled = scaler.fit_transform(X)\npca = PCA(n_components=2)\nX_pca = pca.fit_transform(X_scaled)\nexpl_var = pca.explained_variance_ratio_ * 100\n\npca_labels = np.repeat(GROUP_NAMES, N_PER_GROUP)\n\n# -----------------------------------------------------------------------------\n# 2b. Tumor volume time course – 3 groups × 6 animals, 9 time points\n# -----------------------------------------------------------------------------\nDAYS = np.array([0, 3, 7, 10, 14, 17, 21, 24, 28])\nN_ANIMALS = 6\n\ndef make_curve(intercept, rate, regress_start_idx, regress_magnitudes, noise_scale=5, seed=0):\n    \"\"\"Generate a realistic tumor growth curve with regression.\"\"\"\n    rng = np.random.RandomState(seed)\n    curve = intercept * np.exp(rate * DAYS)\n    if regress_start_idx is not None:\n        for j, mag in enumerate(regress_magnitudes):\n            if regress_start_idx + j < len(curve):\n                curve[regress_start_idx + j] -= mag\n    curve = np.maximum(curve, 0) + rng.randn(len(DAYS)) * noise_scale\n    return np.maximum(curve, 0)\n\nctrl_ref  = make_curve(80, 0.065, None, [], seed=10)\ntrta_ref  = make_curve(80, 0.035, 4, [5, 15, 30, 50, 70], seed=20)\ntrtb_ref  = make_curve(80, 0.020, 3, [15, 35, 55, 80, 100, 120], seed=30)\n\nrefs = [ctrl_ref, trta_ref, trtb_ref]\n\nrecords = []\nfor gi, grp in enumerate(GROUP_NAMES):\n    for a in range(N_ANIMALS):\n        rng = np.random.RandomState(gi * 100 + a * 10)\n        baseline_shift = rng.randn() * 15\n        noise = rng.randn(len(DAYS)) * 8\n        values = refs[gi] + noise + baseline_shift * 0.3\n        values = np.maximum(values, 0)\n        for d, v in zip(DAYS, values):\n            records.append({'Group': grp, 'Animal': f'{grp}_A{a+1}',\n                            'Day': d, 'Tumor_Volume': round(v, 1)})\n\ntumor_df = pd.DataFrame(records)\ntumor_summary = (tumor_df.groupby(['Group', 'Day'])\n                 .agg(Mean=('Tumor_Volume', 'mean'),\n                      SEM=('Tumor_Volume', 'sem'))\n                 .reset_index())\n\n# -----------------------------------------------------------------------------\n# 2c. Day 28 data – subset from tumor_df for boxplot\n# -----------------------------------------------------------------------------\nday28_df = tumor_df[tumor_df['Day'] == 28].copy()\n\n# -----------------------------------------------------------------------------\n# 2d. Volcano plot – 2 000 genes with ~45 up / ~38 down\n# -----------------------------------------------------------------------------\nN_GENES = 2000\nrng_fc  = np.random.RandomState(100)\nrng_pv  = np.random.RandomState(101)\nrng_up  = np.random.RandomState(102)\nrng_dn  = np.random.RandomState(105)\n\nlog2fc  = rng_fc.randn(N_GENES) * 0.3\nneg_logp = -np.log10(np.clip(rng_pv.rand(N_GENES), 0.01, 1)) + 0.3\n\n# Upregulated\nn_up = 45\nup_idx = rng_up.choice(N_GENES, n_up, replace=False)\nlog2fc[up_idx]   = rng_up.rand(n_up) * 2.0 + 1.2\nneg_logp[up_idx] = rng_up.rand(n_up) * 3.0 + 2.0\n\n# Downregulated\nn_down = 38\navail = np.setdiff1d(np.arange(N_GENES), up_idx)\ndown_idx = rng_dn.choice(avail, n_down, replace=False)\nlog2fc[down_idx]   = -(rng_dn.rand(n_down) * 2.0 + 1.0)\nneg_logp[down_idx] = rng_dn.rand(n_down) * 3.0 + 2.0\n\nvolcano_df = pd.DataFrame({\n    'Gene':        [f'GENE_{i+1}' for i in range(N_GENES)],\n    'log2FC':      log2fc,\n    'neg_log10_p': neg_logp,\n})\nvolcano_df['regulation'] = 'NS'\nvolcano_df.loc[(volcano_df['log2FC'] > 1) & (volcano_df['neg_log10_p'] > -np.log10(0.05)),\n               'regulation'] = 'Up'\nvolcano_df.loc[(volcano_df['log2FC'] < -1) & (volcano_df['neg_log10_p'] > -np.log10(0.05)),\n               'regulation'] = 'Down'\n\n# Label top 5 per direction\ntop_up   = volcano_df[volcano_df['regulation'] == 'Up'].nlargest(5, 'neg_log10_p')\ntop_down = volcano_df[volcano_df['regulation'] == 'Down'].nlargest(5, 'neg_log10_p')\nlabel_genes = pd.concat([top_up, top_down])\n\nN_UP      = (volcano_df['regulation'] == 'Up').sum()\nN_DOWN    = (volcano_df['regulation'] == 'Down').sum()\nN_NS      = (volcano_df['regulation'] == 'NS').sum()\n\nprint(f'Volcano stats – Up: {N_UP}, Down: {N_DOWN}, NS: {N_NS}')\n\n# =============================================================================\n# 3.  BUILD THE FIGURE\n# =============================================================================\n\nfig = plt.figure(figsize=(SCIENCE_WIDTH_IN, SCIENCE_HEIGHT_IN))\ngs = gridspec.GridSpec(2, 2, figure=fig, hspace=0.32, wspace=0.28,\n                       left=0.08, right=0.97, bottom=0.09, top=0.95)\n\naxes = [fig.add_subplot(gs[0, 0]), fig.add_subplot(gs[0, 1]),\n        fig.add_subplot(gs[1, 0]), fig.add_subplot(gs[1, 1])]\n\n# ---------------------------------------------------------------------------\n# Panel (a) – PCA\n# ---------------------------------------------------------------------------\nax = axes[0]\nfor i, grp in enumerate(GROUP_NAMES):\n    mask = np.array(pca_labels) == grp\n    x, y = X_pca[mask, 0], X_pca[mask, 1]\n    ax.scatter(x, y, c=GROUP_COLORS[i], label=GROUP_LABELS[i],\n               s=22, edgecolors='white', linewidth=0.4, zorder=5)\n\n    # 95 % confidence ellipse\n    cov = np.cov(x, y)\n    centre = (x.mean(), y.mean())\n    evals, evecs = np.linalg.eig(cov)\n    angle = np.degrees(np.arctan2(evecs[1, 0], evecs[0, 0]))\n    w = 2 * np.sqrt(5.991 * evals[0])\n    h = 2 * np.sqrt(5.991 * evals[1])\n    ell = Ellipse(xy=centre, width=w, height=h, angle=angle,\n                  edgecolor=GROUP_COLORS[i], facecolor=GROUP_COLORS[i],\n                  alpha=0.10, zorder=1)\n    ax.add_patch(ell)\n\nax.set_xlabel(f'PC1 ({expl_var[0]:.1f}%)')\nax.set_ylabel(f'PC2 ({expl_var[1]:.1f}%)')\nax.legend(frameon=False, loc='best', handletextpad=0.5)\nax.text(-0.10, 1.08, '(a)', transform=ax.transAxes,\n        fontsize=8, fontweight='bold', va='bottom', ha='left')\n\n# ---------------------------------------------------------------------------\n# Panel (b) – Tumor volume curves\n# ---------------------------------------------------------------------------\nax = axes[1]\nfor i, grp in enumerate(GROUP_NAMES):\n    grp_dat = tumor_summary[tumor_summary['Group'] == grp]\n    ax.errorbar(grp_dat['Day'], grp_dat['Mean'], yerr=grp_dat['SEM'],\n                color=GROUP_COLORS[i], label=GROUP_LABELS[i],\n                linewidth=1.8, capsize=2.5, capthick=0.8,\n                marker='o', markersize=4.5,\n                markerfacecolor=GROUP_COLORS[i],\n                markeredgecolor='white', markeredgewidth=0.3)\n\nax.set_xlabel('Days')\nax.set_ylabel('Tumor Volume (mm³)')\nax.set_xlim(-1, 30)\nax.set_ylim(0, ax.get_ylim()[1] * 1.05)\nax.legend(frameon=False, loc='upper left', handletextpad=0.5)\nax.text(-0.10, 1.08, '(b)', transform=ax.transAxes,\n        fontsize=8, fontweight='bold', va='bottom', ha='left')\n\n# ---------------------------------------------------------------------------\n# Panel (c) – Day 28 boxplot + individual points\n# ---------------------------------------------------------------------------\nax = axes[2]\n\nboxes_data = [day28_df[day28_df['Group'] == g]['Tumor_Volume'].values for g in GROUP_NAMES]\n\nbp = ax.boxplot(boxes_data, patch_artist=True, widths=0.5,\n                showmeans=True, meanline=True,\n                medianprops=dict(color='black', linewidth=1.2),\n                meanprops=dict(color='black', linewidth=0.8, linestyle='--'),\n                flierprops=dict(marker='o', markersize=3, alpha=0.4),\n                whis=1.5)\n\nfor patch, color in zip(bp['boxes'], GROUP_COLORS):\n    patch.set_facecolor(color)\n    patch.set_alpha(0.60)\n    patch.set_edgecolor('black')\n    patch.set_linewidth(0.8)\n\nfor i, grp in enumerate(GROUP_NAMES):\n    vals = day28_df[day28_df['Group'] == grp]['Tumor_Volume'].values\n    jit = np.random.RandomState(i * 50).randn(len(vals)) * 0.06 + (i + 1)\n    ax.scatter(jit, vals, color=GROUP_COLORS[i], s=14,\n               edgecolors='black', linewidth=0.3, zorder=5, alpha=0.75)\n\nax.set_xticklabels(GROUP_LABELS, fontsize=6.5)\nax.set_ylabel('Tumor Volume (mm³)')\n\n# Significance brackets\nmax_per_grp = [boxes_data[i].max() for i in range(3)]\ny_lim = ax.get_ylim()\ny_ceil = y_lim[1]\n\n# Control vs Treatment A\nx1, x2 = 1, 2\ny_bar = max(max_per_grp[0], max_per_grp[1]) * 1.08 + 15\nax.plot([x1, x1, x2, x2],\n        [y_bar, y_bar + 4, y_bar + 4, y_bar],\n        lw=0.6, c='black')\nax.text((x1 + x2) / 2, y_bar + 8, '*', ha='center', va='bottom',\n        fontsize=10, fontweight='bold')\n\n# Control vs Treatment B\nx1, x2 = 1, 3\ny_bar = max(max_per_grp) * 1.15 + 10\nax.plot([x1, x1, x2, x2],\n        [y_bar, y_bar + 4, y_bar + 4, y_bar],\n        lw=0.6, c='black')\nax.text((x1 + x2) / 2, y_bar + 8, '**', ha='center', va='bottom',\n        fontsize=10, fontweight='bold')\n\n# Adjust y-limit to fit annotations\nax.set_ylim(0, y_bar + 30)\n\nax.text(-0.10, 1.08, '(c)', transform=ax.transAxes,\n        fontsize=8, fontweight='bold', va='bottom', ha='left')\n\n# ---------------------------------------------------------------------------\n# Panel (d) – Volcano plot\n# ---------------------------------------------------------------------------\nax = axes[3]\n\nvolc_styles = {\n    'NS':   dict(c='#BBBBBB', s=5,  alpha=0.25, lbl=None),\n    'Up':   dict(c='#CC3333', s=14, alpha=0.75, lbl='Up'),\n    'Down': dict(c='#3366CC', s=14, alpha=0.75, lbl='Down'),\n}\n\nfor reg in ['NS', 'Up', 'Down']:\n    sty = volc_styles[reg]\n    mask = volcano_df['regulation'] == reg\n    ax.scatter(volcano_df.loc[mask, 'log2FC'],\n               volcano_df.loc[mask, 'neg_log10_p'],\n               c=sty['c'], s=sty['s'], alpha=sty['alpha'],\n               edgecolors='none', label=sty['lbl'])\n\n# Threshold lines\nfor val in [1, -1]:\n    ax.axvline(val, ls='--', c='grey', alpha=0.4, lw=0.6)\nax.axhline(-np.log10(0.05), ls='--', c='grey', alpha=0.4, lw=0.6)\n\n# Label top genes\nfor _, gene in label_genes.iterrows():\n    ax.annotate(gene['Gene'],\n                (gene['log2FC'], gene['neg_log10_p']),\n                fontsize=4.8, xytext=(4, 3),\n                textcoords='offset points',\n                arrowprops=dict(arrowstyle='-', color='grey', lw=0.3))\n\nax.set_xlabel('log₂(Fold Change)')\nax.set_ylabel('−log₁₀(p-value)')\nax.legend(frameon=False, loc='upper right', fontsize=6)\n\n# Count box\nax.text(0.97, 0.96, f'↑ {N_UP}   ↓ {N_DOWN}',\n        transform=ax.transAxes, fontsize=6.5, ha='right', va='top',\n        bbox=dict(boxstyle='round,pad=0.3',\n                  facecolor='white', edgecolor='#CCCCCC', lw=0.5))\n\nax.text(-0.10, 1.08, '(d)', transform=ax.transAxes,\n        fontsize=8, fontweight='bold', va='bottom', ha='left')\n\n# =============================================================================\n# 4.  SAVE\n# =============================================================================\n\nout_pdf = 'figure1_science.pdf'\nout_png = 'figure1_science.png'\n\nfig.savefig(out_pdf, dpi=600, bbox_inches='tight', pad_inches=0.02)\nfig.savefig(out_png, dpi=600, bbox_inches='tight', pad_inches=0.02)\n\nprint(f'✅  Saved  →  {out_pdf}')\nprint(f'✅  Saved  →  {out_png}')\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure1_science.py", "content": "#!/usr/bin/env python3\n\"\"\"\nFigure 1: Multi-panel figure for Science journal.\nPanels:\n  (a) PCA scatter plot showing separation of 3 groups\n  (b) Tumor volume time-course curves\n  (c) Day 28 boxplot comparison\n  (d) Volcano plot of differentially expressed genes\n\nTarget: Science, double-column width (183 mm full page)\nColor scheme: Wong colorblind-safe palette\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.gridspec as gridspec\nfrom matplotlib.patches import Ellipse\nfrom sklearn.decomposition import PCA\nfrom sklearn.preprocessing import StandardScaler\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# =============================================================================\n# 1.  CONFIGURATION – Science journal specs + colorblind-safe palette\n# =============================================================================\n\nSCIENCE_WIDTH_MM = 183\nSCIENCE_WIDTH_IN = SCIENCE_WIDTH_MM / 25.4          # 7.20 in\nSCIENCE_HEIGHT_IN = SCIENCE_WIDTH_IN * 0.82          # ≈ 5.91 in (2×2 grid)\n\n# Wong colorblind-safe palette\nCTRL_COLOR  = '#0072B2'   # blue\nTRTA_COLOR  = '#E69F00'   # orange\nTRTB_COLOR  = '#009E73'   # green\nGROUP_COLORS = [CTRL_COLOR, TRTA_COLOR, TRTB_COLOR]\nGROUP_NAMES  = ['Control', 'Treatment_A', 'Treatment_B']\nGROUP_LABELS = ['Control', 'Treatment A', 'Treatment B']\n\n# Global matplotlib style – clean, minimal, Science-ready\nplt.rcParams.update({\n    'font.family':        'sans-serif',\n    'font.sans-serif':    ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size':          7,\n    'axes.titlesize':     7,\n    'axes.labelsize':     7,\n    'xtick.labelsize':    6.5,\n    'ytick.labelsize':    6.5,\n    'legend.fontsize':    6.5,\n    'figure.dpi':         300,\n    'savefig.dpi':        600,\n    'savefig.bbox':       'tight',\n    'axes.linewidth':     0.8,\n    'xtick.major.width':  0.6,\n    'ytick.major.width':  0.6,\n    'xtick.major.size':   3,\n    'ytick.major.size':   3,\n    'lines.linewidth':    1.5,\n    'lines.markersize':   4,\n    'axes.spines.top':    False,\n    'axes.spines.right':  False,\n})\n\nnp.random.seed(42)\n\n# =============================================================================\n# 2.  SYNTHETIC DATA GENERATION\n# =============================================================================\n\n# -----------------------------------------------------------------------------\n# 2a. PCA data – 24 samples × 100 features, 3 groups of 8\n# -----------------------------------------------------------------------------\nN_PER_GROUP = 8\nN_FEATURES  = 100\nN_TOTAL     = N_PER_GROUP * 3\n\nX = np.random.randn(N_TOTAL, N_FEATURES) * 0.5\n\n# Group-specific mean shifts to create PCA separation\nshift_map = {\n    'Control':      np.zeros(N_FEATURES),\n    'Treatment_A':  np.random.randn(N_FEATURES) * 0.3 + 0.2,\n    'Treatment_B':  np.random.randn(N_FEATURES) * 0.3 - 0.2,\n}\nfor i, grp in enumerate(GROUP_NAMES):\n    sl = slice(i * N_PER_GROUP, (i + 1) * N_PER_GROUP)\n    X[sl, :] += shift_map[grp]\n\n# Enrich top 10 features with group-specific structure\nfor feat_idx in range(10):\n    for i in range(3):\n        X[i::3, feat_idx] += np.random.randn(N_PER_GROUP) * 0.5 + [0.8, -0.3, -0.5][i]\n\nscaler = StandardScaler()\nX_scaled = scaler.fit_transform(X)\npca = PCA(n_components=2)\nX_pca = pca.fit_transform(X_scaled)\nexpl_var = pca.explained_variance_ratio_ * 100\n\npca_labels = np.repeat(GROUP_NAMES, N_PER_GROUP)\n\n# -----------------------------------------------------------------------------\n# 2b. Tumor volume time course – 3 groups × 6 animals, 9 time points\n# -----------------------------------------------------------------------------\nDAYS = np.array([0, 3, 7, 10, 14, 17, 21, 24, 28])\nN_ANIMALS = 6\n\ndef make_curve(intercept, rate, regress_start_idx, regress_magnitudes, noise_scale=5, seed=0):\n    \"\"\"Generate a realistic tumor growth curve with regression.\"\"\"\n    rng = np.random.RandomState(seed)\n    curve = intercept * np.exp(rate * DAYS)\n    if regress_start_idx is not None:\n        for j, mag in enumerate(regress_magnitudes):\n            if regress_start_idx + j < len(curve):\n                curve[regress_start_idx + j] -= mag\n    curve = np.maximum(curve, 0) + rng.randn(len(DAYS)) * noise_scale\n    return np.maximum(curve, 0)\n\nctrl_ref  = make_curve(80, 0.065, None, [], seed=10)\ntrta_ref  = make_curve(80, 0.035, 4, [5, 15, 30, 50, 70], seed=20)\ntrtb_ref  = make_curve(80, 0.020, 3, [15, 35, 55, 80, 100, 120], seed=30)\n\nrefs = [ctrl_ref, trta_ref, trtb_ref]\n\nrecords = []\nfor gi, grp in enumerate(GROUP_NAMES):\n    for a in range(N_ANIMALS):\n        rng = np.random.RandomState(gi * 100 + a * 10)\n        baseline_shift = rng.randn() * 15\n        noise = rng.randn(len(DAYS)) * 8\n        values = refs[gi] + noise + baseline_shift * 0.3\n        values = np.maximum(values, 0)\n        for d, v in zip(DAYS, values):\n            records.append({'Group': grp, 'Animal': f'{grp}_A{a+1}',\n                            'Day': d, 'Tumor_Volume': round(v, 1)})\n\ntumor_df = pd.DataFrame(records)\ntumor_summary = (tumor_df.groupby(['Group', 'Day'])\n                 .agg(Mean=('Tumor_Volume', 'mean'),\n                      SEM=('Tumor_Volume', 'sem'))\n                 .reset_index())\n\n# -----------------------------------------------------------------------------\n# 2c. Day 28 data – subset from tumor_df for boxplot\n# -----------------------------------------------------------------------------\nday28_df = tumor_df[tumor_df['Day'] == 28].copy()\n\n# -----------------------------------------------------------------------------\n# 2d. Volcano plot – 2 000 genes with ~45 up / ~38 down\n# -----------------------------------------------------------------------------\nN_GENES = 2000\nrng_fc  = np.random.RandomState(100)\nrng_pv  = np.random.RandomState(101)\nrng_up  = np.random.RandomState(102)\nrng_dn  = np.random.RandomState(105)\n\nlog2fc  = rng_fc.randn(N_GENES) * 0.3\nneg_logp = -np.log10(np.clip(rng_pv.rand(N_GENES), 0.01, 1)) + 0.3\n\n# Upregulated\nn_up = 45\nup_idx = rng_up.choice(N_GENES, n_up, replace=False)\nlog2fc[up_idx]   = rng_up.rand(n_up) * 2.0 + 1.2\nneg_logp[up_idx] = rng_up.rand(n_up) * 3.0 + 2.0\n\n# Downregulated\nn_down = 38\navail = np.setdiff1d(np.arange(N_GENES), up_idx)\ndown_idx = rng_dn.choice(avail, n_down, replace=False)\nlog2fc[down_idx]   = -(rng_dn.rand(n_down) * 2.0 + 1.0)\nneg_logp[down_idx] = rng_dn.rand(n_down) * 3.0 + 2.0\n\nvolcano_df = pd.DataFrame({\n    'Gene':        [f'GENE_{i+1}' for i in range(N_GENES)],\n    'log2FC':      log2fc,\n    'neg_log10_p': neg_logp,\n})\nvolcano_df['regulation'] = 'NS'\nvolcano_df.loc[(volcano_df['log2FC'] > 1) & (volcano_df['neg_log10_p'] > -np.log10(0.05)),\n               'regulation'] = 'Up'\nvolcano_df.loc[(volcano_df['log2FC'] < -1) & (volcano_df['neg_log10_p'] > -np.log10(0.05)),\n               'regulation'] = 'Down'\n\n# Label top 5 per direction\ntop_up   = volcano_df[volcano_df['regulation'] == 'Up'].nlargest(5, 'neg_log10_p')\ntop_down = volcano_df[volcano_df['regulation'] == 'Down'].nlargest(5, 'neg_log10_p')\nlabel_genes = pd.concat([top_up, top_down])\n\nN_UP      = (volcano_df['regulation'] == 'Up').sum()\nN_DOWN    = (volcano_df['regulation'] == 'Down').sum()\nN_NS      = (volcano_df['regulation'] == 'NS').sum()\n\nprint(f'Volcano stats – Up: {N_UP}, Down: {N_DOWN}, NS: {N_NS}')\n\n# =============================================================================\n# 3.  BUILD THE FIGURE\n# =============================================================================\n\nfig = plt.figure(figsize=(SCIENCE_WIDTH_IN, SCIENCE_HEIGHT_IN))\ngs = gridspec.GridSpec(2, 2, figure=fig, hspace=0.32, wspace=0.28,\n                       left=0.08, right=0.97, bottom=0.09, top=0.95)\n\naxes = [fig.add_subplot(gs[0, 0]), fig.add_subplot(gs[0, 1]),\n        fig.add_subplot(gs[1, 0]), fig.add_subplot(gs[1, 1])]\n\n# ---------------------------------------------------------------------------\n# Panel (a) – PCA\n# ---------------------------------------------------------------------------\nax = axes[0]\nfor i, grp in enumerate(GROUP_NAMES):\n    mask = np.array(pca_labels) == grp\n    x, y = X_pca[mask, 0], X_pca[mask, 1]\n    ax.scatter(x, y, c=GROUP_COLORS[i], label=GROUP_LABELS[i],\n               s=22, edgecolors='white', linewidth=0.4, zorder=5)\n\n    # 95 % confidence ellipse\n    cov = np.cov(x, y)\n    centre = (x.mean(), y.mean())\n    evals, evecs = np.linalg.eig(cov)\n    angle = np.degrees(np.arctan2(evecs[1, 0], evecs[0, 0]))\n    w = 2 * np.sqrt(5.991 * evals[0])\n    h = 2 * np.sqrt(5.991 * evals[1])\n    ell = Ellipse(xy=centre, width=w, height=h, angle=angle,\n                  edgecolor=GROUP_COLORS[i], facecolor=GROUP_COLORS[i],\n                  alpha=0.10, zorder=1)\n    ax.add_patch(ell)\n\nax.set_xlabel(f'PC1 ({expl_var[0]:.1f}%)')\nax.set_ylabel(f'PC2 ({expl_var[1]:.1f}%)')\nax.legend(frameon=False, loc='best', handletextpad=0.5)\nax.text(-0.10, 1.08, '(a)', transform=ax.transAxes,\n        fontsize=8, fontweight='bold', va='bottom', ha='left')\n\n# ---------------------------------------------------------------------------\n# Panel (b) – Tumor volume curves\n# ---------------------------------------------------------------------------\nax = axes[1]\nfor i, grp in enumerate(GROUP_NAMES):\n    grp_dat = tumor_summary[tumor_summary['Group'] == grp]\n    ax.errorbar(grp_dat['Day'], grp_dat['Mean'], yerr=grp_dat['SEM'],\n                color=GROUP_COLORS[i], label=GROUP_LABELS[i],\n                linewidth=1.8, capsize=2.5, capthick=0.8,\n                marker='o', markersize=4.5,\n                markerfacecolor=GROUP_COLORS[i],\n                markeredgecolor='white', markeredgewidth=0.3)\n\nax.set_xlabel('Days')\nax.set_ylabel('Tumor Volume (mm³)')\nax.set_xlim(-1, 30)\nax.set_ylim(0, ax.get_ylim()[1] * 1.05)\nax.legend(frameon=False, loc='upper left', handletextpad=0.5)\nax.text(-0.10, 1.08, '(b)', transform=ax.transAxes,\n        fontsize=8, fontweight='bold', va='bottom', ha='left')\n\n# ---------------------------------------------------------------------------\n# Panel (c) – Day 28 boxplot + individual points\n# ---------------------------------------------------------------------------\nax = axes[2]\n\nboxes_data = [day28_df[day28_df['Group'] == g]['Tumor_Volume'].values for g in GROUP_NAMES]\n\nbp = ax.boxplot(boxes_data, patch_artist=True, widths=0.5,\n                showmeans=True, meanline=True,\n                medianprops=dict(color='black', linewidth=1.2),\n                meanprops=dict(color='black', linewidth=0.8, linestyle='--'),\n                flierprops=dict(marker='o', markersize=3, alpha=0.4),\n                whis=1.5)\n\nfor patch, color in zip(bp['boxes'], GROUP_COLORS):\n    patch.set_facecolor(color)\n    patch.set_alpha(0.60)\n    patch.set_edgecolor('black')\n    patch.set_linewidth(0.8)\n\nfor i, grp in enumerate(GROUP_NAMES):\n    vals = day28_df[day28_df['Group'] == grp]['Tumor_Volume'].values\n    jit = np.random.RandomState(i * 50).randn(len(vals)) * 0.06 + (i + 1)\n    ax.scatter(jit, vals, color=GROUP_COLORS[i], s=14,\n               edgecolors='black', linewidth=0.3, zorder=5, alpha=0.75)\n\nax.set_xticklabels(GROUP_LABELS, fontsize=6.5)\nax.set_ylabel('Tumor Volume (mm³)')\n\n# Significance brackets\nmax_per_grp = [boxes_data[i].max() for i in range(3)]\ny_lim = ax.get_ylim()\ny_ceil = y_lim[1]\n\n# Control vs Treatment A\nx1, x2 = 1, 2\ny_bar = max(max_per_grp[0], max_per_grp[1]) * 1.08 + 15\nax.plot([x1, x1, x2, x2],\n        [y_bar, y_bar + 4, y_bar + 4, y_bar],\n        lw=0.6, c='black')\nax.text((x1 + x2) / 2, y_bar + 8, '*', ha='center', va='bottom',\n        fontsize=10, fontweight='bold')\n\n# Control vs Treatment B\nx1, x2 = 1, 3\ny_bar = max(max_per_grp) * 1.15 + 10\nax.plot([x1, x1, x2, x2],\n        [y_bar, y_bar + 4, y_bar + 4, y_bar],\n        lw=0.6, c='black')\nax.text((x1 + x2) / 2, y_bar + 8, '**', ha='center', va='bottom',\n        fontsize=10, fontweight='bold')\n\n# Adjust y-limit to fit annotations\nax.set_ylim(0, y_bar + 30)\n\nax.text(-0.10, 1.08, '(c)', transform=ax.transAxes,\n        fontsize=8, fontweight='bold', va='bottom', ha='left')\n\n# ---------------------------------------------------------------------------\n# Panel (d) – Volcano plot\n# ---------------------------------------------------------------------------\nax = axes[3]\n\nvolc_styles = {\n    'NS':   dict(c='#BBBBBB', s=5,  alpha=0.25, lbl=None),\n    'Up':   dict(c='#CC3333', s=14, alpha=0.75, lbl='Up'),\n    'Down': dict(c='#3366CC', s=14, alpha=0.75, lbl='Down'),\n}\n\nfor reg in ['NS', 'Up', 'Down']:\n    sty = volc_styles[reg]\n    mask = volcano_df['regulation'] == reg\n    ax.scatter(volcano_df.loc[mask, 'log2FC'],\n               volcano_df.loc[mask, 'neg_log10_p'],\n               c=sty['c'], s=sty['s'], alpha=sty['alpha'],\n               edgecolors='none', label=sty['lbl'])\n\n# Threshold lines\nfor val in [1, -1]:\n    ax.axvline(val, ls='--', c='grey', alpha=0.4, lw=0.6)\nax.axhline(-np.log10(0.05), ls='--', c='grey', alpha=0.4, lw=0.6)\n\n# Label top genes\nfor _, gene in label_genes.iterrows():\n    ax.annotate(gene['Gene'],\n                (gene['log2FC'], gene['neg_log10_p']),\n                fontsize=4.8, xytext=(4, 3),\n                textcoords='offset points',\n                arrowprops=dict(arrowstyle='-', color='grey', lw=0.3))\n\nax.set_xlabel('log₂(Fold Change)')\nax.set_ylabel('−log₁₀(p-value)')\nax.legend(frameon=False, loc='upper right', fontsize=6)\n\n# Count box\nax.text(0.97, 0.96, f'↑ {N_UP}   ↓ {N_DOWN}',\n        transform=ax.transAxes, fontsize=6.5, ha='right', va='top',\n        bbox=dict(boxstyle='round,pad=0.3',\n                  facecolor='white', edgecolor='#CCCCCC', lw=0.5))\n\nax.text(-0.10, 1.08, '(d)', transform=ax.transAxes,\n        fontsize=8, fontweight='bold', va='bottom', ha='left')\n\n# =============================================================================\n# 4.  SAVE\n# =============================================================================\n\nout_pdf = 'figure1_science.pdf'\nout_png = 'figure1_science.png'\n\nfig.savefig(out_pdf, dpi=600, bbox_inches='tight', pad_inches=0.02)\nfig.savefig(out_png, dpi=600, bbox_inches='tight', pad_inches=0.02)\n\nprint(f'✅  Saved  →  {out_pdf}')\nprint(f'✅  Saved  →  {out_png}')\n"})
