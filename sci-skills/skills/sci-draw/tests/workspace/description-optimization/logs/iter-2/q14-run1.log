TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/epr_graphical_abstract.py", "content": "#!/usr/bin/env python3\n\"\"\"\nGraphical Abstract: Nanomedicine targeting tumor via EPR effect\nand pH-responsive drug release in the acidic microenvironment.\n\"\"\"\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.path import Path\nimport numpy as np\n\n# ============================================================\n#  Style setup\n# ============================================================\nplt.rcParams.update({\n    \"font.family\": \"sans-serif\",\n    \"font.sans-serif\": [\"Arial\", \"Helvetica\", \"DejaVu Sans\"],\n    \"font.size\": 12,\n})\n\nfig, ax = plt.subplots(figsize=(10, 7))\nax.set_xlim(0, 10)\nax.set_ylim(0, 10)\nax.set_aspect(\"equal\")\nax.axis(\"off\")\n\n# ============================================================\n#  Colors\n# ============================================================\nCOLOR_BLOOD = \"#EF5350\"          # red for blood\nCOLOR_VESSEL_WALL = \"#E57373\"\nCOLOR_NP_CORE = \"#42A5F5\"         # nanoparticle core\nCOLOR_NP_SHELL = \"#90CAF9\"        # nanoparticle shell (polymer)\nCOLOR_DRUG = \"#FFB74D\"            # drug molecules\nCOLOR_TUMOR = \"#7E57C2\"           # tumor cell\nCOLOR_TUMOR_NUCLEUS = \"#5C6BC0\"\nCOLOR_ECM = \"#BDBDBD\"             # extracellular matrix\nCOLOR_PH_LOW = \"#FF8A65\"\nCOLOR_PH_NEUTRAL = \"#81C784\"\nCOLOR_ARROW = \"#546E7A\"\nCOLOR_BG_SHIELD = \"#FFF3E0\"       # pH annotation background\nCOLOR_VESSEL_LUMEN = \"#FFCDD2\"    # light red lumen\n\n\n# ============================================================\n#  1. Blood Vessel (top)\n# ============================================================\n# Vessel lumen (upper region)\nvessel_top = 8.5\nvessel_bottom = 7.0\nax.fill_between([0.5, 9.5], vessel_top, vessel_bottom,\n                color=COLOR_VESSEL_LUMEN, alpha=0.3, zorder=0)\n\n# Vessel wall - bottom line (endothelium)\nwall_y = 7.0\nax.plot([0.5, 9.5], [wall_y, wall_y], color=COLOR_VESSEL_WALL,\n        linewidth=3, solid_capstyle=\"round\", zorder=2)\n\n# Vessel wall - top line\nax.plot([0.5, 9.5], [vessel_top, vessel_top], color=COLOR_VESSEL_WALL,\n        linewidth=3, solid_capstyle=\"round\", zorder=2)\n\n# Endothelial cells (nuclei)\nfor x in np.linspace(1.0, 7.0, 7):\n    ax.plot(x, wall_y - 0.15, \"o\", color=\"#C62828\", markersize=4, zorder=3)\n# Endothelial cells on right side\nfor x in np.linspace(8.0, 9.0, 3):\n    ax.plot(x, wall_y - 0.15, \"o\", color=\"#C62828\", markersize=4, zorder=3)\n\n# Leaky gap in endothelium (tumor vasculature - EPR effect)\ngap_center = 7.5\ngap_width = 0.7\n# Draw gap as a break in the wall — we just leave a section empty\n# and add small \"tear\" marks\ngap_left = gap_center - gap_width / 2\ngap_right = gap_center + gap_width / 2\nax.plot([gap_left, gap_right], [wall_y, wall_y], \"w\", linewidth=4, zorder=3)\n# Tear markers\nax.annotate(\"\", xy=(gap_left, wall_y), xytext=(gap_left - 0.08, wall_y + 0.15),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_VESSEL_WALL, lw=1.5))\nax.annotate(\"\", xy=(gap_right, wall_y), xytext=(gap_right + 0.08, wall_y + 0.15),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_VESSEL_WALL, lw=1.5))\n\n# \"Leaky vasculature\" label above gap\nax.annotate(\"Leaky vasculature\\n(EPR effect)\", xy=(gap_center, vessel_top + 0.4),\n            fontsize=9, ha=\"center\", va=\"bottom\", color=\"#C62828\",\n            fontweight=\"bold\",\n            bbox=dict(boxstyle=\"round,pad=0.3\", facecolor=\"white\",\n                      edgecolor=COLOR_VESSEL_WALL, alpha=0.85))\n\n\n# ============================================================\n#  2. Red blood cells & Nanoparticles in bloodstream\n# ============================================================\n# Red blood cells (small red discs)\nrbc_positions = [(1.5, 7.8), (3.0, 7.5), (4.5, 8.0), (6.0, 7.7),\n                 (2.0, 8.2), (5.0, 8.3), (8.5, 7.9)]\nfor x, y in rbc_positions:\n    circle = mpatches.Circle((x, y), 0.25, color=COLOR_BLOOD, alpha=0.7,\n                             ec=\"#C62828\", lw=1, zorder=4)\n    ax.add_patch(circle)\n\n# Nanoparticles (core-shell structure) in blood\nnp_positions_blood = [(2.5, 7.6), (4.0, 7.8), (5.5, 7.5), (7.0, 7.7),\n                      (1.0, 7.9), (8.0, 7.6), (9.0, 7.8)]\nfor x, y in np_positions_blood:\n    # Shell (polymer)\n    shell = mpatches.Circle((x, y), 0.20, color=COLOR_NP_SHELL, alpha=0.8,\n                            ec=\"#1E88E5\", lw=0.5, zorder=5)\n    ax.add_patch(shell)\n    # Core (drug payload)\n    core = mpatches.Circle((x, y), 0.10, color=COLOR_NP_CORE, alpha=0.9,\n                           ec=\"#1565C0\", lw=0.5, zorder=6)\n    ax.add_patch(core)\n\n# Direction of blood flow (arrow)\nax.annotate(\"\", xy=(8.8, 7.75), xytext=(1.2, 7.75),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_BLOOD,\n                            lw=2.5, linestyle=\"dashed\"), zorder=1)\nax.text(1.2, 7.4, \"Blood flow\", fontsize=9, color=\"#C62828\", fontstyle=\"italic\")\n\n\n# ============================================================\n#  3. Nanoparticle extravasation through leaky gap (EPR)\n# ============================================================\n# NPs passing through the gap\nnp_extra = [(7.5, 7.0), (7.5, 6.6), (7.55, 6.2), (7.45, 5.8)]\nfor i, (x, y) in enumerate(np_extra):\n    shell = mpatches.Circle((x, y), 0.18, color=COLOR_NP_SHELL, alpha=0.85,\n                            ec=\"#1E88E5\", lw=0.5, zorder=7)\n    ax.add_patch(shell)\n    core = mpatches.Circle((x, y), 0.09, color=COLOR_NP_CORE, alpha=0.9,\n                           ec=\"#1565C0\", lw=0.5, zorder=8)\n    ax.add_patch(core)\n\n# Arrow showing extravasation direction\nax.annotate(\"\", xy=(7.5, 5.4), xytext=(7.5, 7.3),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_ARROW,\n                            lw=2.5), zorder=6)\nax.text(7.8, 6.3, \"Extravasation\", fontsize=9, color=COLOR_ARROW,\n        fontweight=\"bold\", rotation=90, va=\"center\")\n\n\n# ============================================================\n#  4. Tumor interstitium / ECM\n# ============================================================\n# ECM represented by a dotted/fibrous background\nfor i in range(15):\n    x = np.random.uniform(0.8, 9.2)\n    y = np.random.uniform(3.5, 6.5)\n    if not ((3.0 < x < 7.0) and (3.0 < y < 6.0)):  # avoid clustering over cells\n        ax.plot(x, y, \".\", color=COLOR_ECM, alpha=0.4, markersize=3, zorder=0)\n\n# Collagen fibers (wavy lines)\nfor _ in range(8):\n    x_start = np.random.uniform(0.5, 9.0)\n    y_start = np.random.uniform(4.0, 6.5)\n    x_vals = np.linspace(x_start, x_start + np.random.uniform(0.5, 1.5), 30)\n    y_vals = y_start + 0.08 * np.sin(5 * x_vals) + np.random.uniform(-0.05, 0.05)\n    ax.plot(x_vals, y_vals, color=COLOR_ECM, alpha=0.3, lw=0.8, zorder=0)\n\n\n# ============================================================\n#  5. Tumor cells\n# ============================================================\ndef draw_tumor_cell(cx, cy, scale=1.0, label=\"\"):\n    \"\"\"Draw an irregular tumor cell with nucleus.\"\"\"\n    # Cell body - slightly irregular shape\n    angles = np.linspace(0, 2 * np.pi, 50)\n    r = 0.45 * scale\n    radii = r + 0.10 * scale * np.sin(3 * angles) + 0.05 * scale * np.sin(5 * angles)\n    x_verts = cx + radii * np.cos(angles)\n    y_verts = cy + radii * np.sin(angles)\n    verts = list(zip(x_verts, y_verts))\n    codes = [Path.MOVETO] + [Path.LINETO] * (len(verts) - 2) + [Path.CLOSEPOLY]\n    path = Path(verts[:-1], codes)\n    patch = mpatches.PathPatch(path, facecolor=COLOR_TUMOR, alpha=0.7,\n                               ec=\"#4527A0\", lw=1.5, zorder=5)\n    ax.add_patch(patch)\n\n    # Nucleus\n    nucleus = mpatches.Circle((cx + 0.05 * scale, cy + 0.05 * scale),\n                              0.18 * scale, color=COLOR_TUMOR_NUCLEUS,\n                              alpha=0.8, ec=\"#283593\", lw=1, zorder=6)\n    ax.add_patch(nucleus)\n\n    # Surface receptors (small bumps)\n    for angle in np.linspace(0, 2 * np.pi, 8, endpoint=False):\n        rx = cx + (r + 0.08) * np.cos(angle)\n        ry = cy + (r + 0.08) * np.sin(angle)\n        rec = mpatches.Circle((rx, ry), 0.04 * scale, color=\"#D1C4E9\",\n                              alpha=0.8, zorder=7)\n        ax.add_patch(rec)\n\n    if label:\n        ax.text(cx, cy - 0.65 * scale, label, fontsize=9, ha=\"center\",\n                va=\"top\", color=\"#4527A0\", fontweight=\"bold\")\n\n# Tumor cells positions\ntumor_positions = [\n    (1.5, 4.5, 1.0, \"Tumor cell\"),\n    (3.5, 5.0, 0.9, \"\"),\n    (4.0, 3.8, 1.1, \"Tumor cell\"),\n    (5.5, 5.2, 0.85, \"\"),\n    (6.0, 4.0, 1.0, \"\"),\n    (2.0, 3.0, 0.8, \"\"),\n    (7.5, 3.5, 0.9, \"\"),\n]\nfor cx, cy, scale, label in tumor_positions:\n    draw_tumor_cell(cx, cy, scale, label)\n\n\n# ============================================================\n#  6. Nanoparticles in tumor interstitium (accumulated via EPR)\n# ============================================================\nnp_tumor_positions = [\n    (2.2, 5.5), (3.8, 6.0), (4.5, 5.5),\n    (1.8, 3.8), (3.0, 4.2), (5.8, 4.8),\n    (6.5, 5.5), (7.2, 4.8), (6.8, 3.2),\n]\nfor x, y in np_tumor_positions:\n    shell = mpatches.Circle((x, y), 0.16, color=COLOR_NP_SHELL, alpha=0.7,\n                            ec=\"#1E88E5\", lw=0.5, zorder=6)\n    ax.add_patch(shell)\n    core = mpatches.Circle((x, y), 0.08, color=COLOR_NP_CORE, alpha=0.8,\n                           ec=\"#1565C0\", lw=0.5, zorder=7)\n    ax.add_patch(core)\n\n\n# ============================================================\n#  7. pH-responsive drug release (bottom)\n# ============================================================\n# Nanoparticles releasing drug (core disintegrating)\nrelease_positions = [\n    (1.0, 1.8), (3.0, 1.5), (5.0, 2.0), (7.0, 1.5), (8.5, 1.8)\n]\nfor x, y in release_positions:\n    # Shell (cracked/weakened - shown as a dashed outline)\n    shell = mpatches.Circle((x, y), 0.18, color=COLOR_NP_SHELL, alpha=0.4,\n                            ec=\"#1E88E5\", lw=0.8, linestyle=\"dotted\", zorder=5)\n    ax.add_patch(shell)\n    # Drug molecules being released\n    for dx, dy in [(0.15, 0.15), (-0.15, 0.1), (0.2, -0.1),\n                   (-0.1, -0.18), (0.1, -0.05)]:\n        drug = mpatches.Circle((x + dx, y + dy), 0.04, color=COLOR_DRUG,\n                               alpha=0.9, ec=\"#E65100\", lw=0.3, zorder=6)\n        ax.add_patch(drug)\n    # More drug molecules diffusing away\n    for dx, dy in [(0.3, 0.2), (-0.3, 0.25), (0.35, -0.25),\n                   (-0.25, -0.3), (0.0, 0.3)]:\n        drug = mpatches.Circle((x + dx, y + dy), 0.03, color=COLOR_DRUG,\n                               alpha=0.5, ec=\"#E65100\", lw=0.2, zorder=5)\n        ax.add_patch(drug)\n\n# Arrow from intact NP in tumor to disintegrating NP\nax.annotate(\"\", xy=(1.0, 2.2), xytext=(2.0, 5.0),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_ARROW,\n                            lw=2, connectionstyle=\"arc3,rad=-0.2\"), zorder=4)\nax.text(0.6, 3.6, \"pH-triggered\\ndrug release\", fontsize=9, color=COLOR_ARROW,\n        fontweight=\"bold\", ha=\"left\", va=\"center\",\n        bbox=dict(boxstyle=\"round,pad=0.3\", facecolor=\"white\",\n                  edgecolor=\"gray\", alpha=0.85))\n\n\n# ============================================================\n#  8. pH gradient annotation\n# ============================================================\n# pH scale bar on the right side\nph_x = 9.3\n# Neutral pH (blood) - green bar\nax.plot([ph_x, ph_x], [7.2, 8.2], color=COLOR_PH_NEUTRAL, lw=8, solid_capstyle=\"round\", zorder=2)\nax.text(ph_x + 0.3, 7.7, \"pH 7.4\", fontsize=9, color=\"#2E7D32\",\n        fontweight=\"bold\", va=\"center\")\n\n# Acidic pH (tumor) - orange bar\nax.plot([ph_x, ph_x], [1.5, 3.5], color=COLOR_PH_LOW, lw=8, solid_capstyle=\"round\", zorder=2)\nax.text(ph_x + 0.3, 2.5, \"pH 6.5\", fontsize=9, color=\"#D84315\",\n        fontweight=\"bold\", va=\"center\")\n\n# Gradient between (fade)\nfor y in np.linspace(3.5, 7.2, 20):\n    t = (y - 3.5) / (7.2 - 3.5)\n    c = (1 - t) * np.array([1.0, 0.4, 0.15]) + t * np.array([0.3, 0.7, 0.3])\n    ax.plot([ph_x, ph_x], [y, y + 0.18], color=c, lw=8, solid_capstyle=\"butt\", zorder=1)\n\n# pH label\nax.text(ph_x + 0.3, 5.4, \"pH\\ngradient\", fontsize=8, color=\"gray\",\n        ha=\"center\", va=\"center\", fontstyle=\"italic\")\n\n# Acidic microenvironment bracket\nax.annotate(\"Acidic tumor\\nmicroenvironment\", xy=(1.5, 2.5),\n            fontsize=9, ha=\"left\", va=\"center\", color=\"#D84315\",\n            fontweight=\"bold\",\n            bbox=dict(boxstyle=\"round,pad=0.3\", facecolor=COLOR_BG_SHIELD,\n                      edgecolor=COLOR_PH_LOW, alpha=0.85))\n\n\n# ============================================================\n#  9. Title / Legend\n# ============================================================\nax.set_title(\"Nanomedicine Tumor Targeting via EPR Effect\\n\"\n             \"and pH-Responsive Drug Release\",\n             fontsize=14, fontweight=\"bold\", pad=15)\n\n# Legend items\nlegend_elements = [\n    mpatches.Patch(facecolor=COLOR_NP_SHELL, edgecolor=\"#1E88E5\",\n                   label=\"Nanoparticle (polymer shell)\"),\n    mpatches.Patch(facecolor=COLOR_DRUG, edgecolor=\"#E65100\",\n                   label=\"Drug molecule\"),\n    mpatches.Patch(facecolor=COLOR_TUMOR, edgecolor=\"#4527A0\",\n                   label=\"Tumor cell\"),\n    mpatches.Patch(facecolor=COLOR_VESSEL_LUMEN, edgecolor=COLOR_VESSEL_WALL,\n                   label=\"Blood vessel\"),\n]\nlegend = ax.legend(handles=legend_elements, loc=\"lower center\",\n                   ncol=4, fontsize=8.5, framealpha=0.9,\n                   bbox_to_anchor=(0.5, -0.05), handlelength=1.5)\nlegend.get_frame().set_edgecolor(\"gray\")\n\n# ============================================================\n#  Save\n# ============================================================\noutput_path = \"/home/joe/Documents/repo/skill/sci-draw/epr_graphical_abstract.png\"\nfig.savefig(output_path, dpi=300, bbox_inches=\"tight\",\n            facecolor=\"white\", edgecolor=\"none\")\nprint(f\"Saved to: {output_path}\")\n\n# Also save as PDF for publication\npdf_path = \"/home/joe/Documents/repo/skill/sci-draw/epr_graphical_abstract.pdf\"\nfig.savefig(pdf_path, bbox_inches=\"tight\", facecolor=\"white\", edgecolor=\"none\")\nprint(f\"Saved to: {pdf_path}\")\n\nplt.close()\nprint(\"Done!\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/epr_graphical_abstract.py", "content": "#!/usr/bin/env python3\n\"\"\"\nGraphical Abstract: Nanomedicine targeting tumor via EPR effect\nand pH-responsive drug release in the acidic microenvironment.\n\"\"\"\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.path import Path\nimport numpy as np\n\n# ============================================================\n#  Style setup\n# ============================================================\nplt.rcParams.update({\n    \"font.family\": \"sans-serif\",\n    \"font.sans-serif\": [\"Arial\", \"Helvetica\", \"DejaVu Sans\"],\n    \"font.size\": 12,\n})\n\nfig, ax = plt.subplots(figsize=(10, 7))\nax.set_xlim(0, 10)\nax.set_ylim(0, 10)\nax.set_aspect(\"equal\")\nax.axis(\"off\")\n\n# ============================================================\n#  Colors\n# ============================================================\nCOLOR_BLOOD = \"#EF5350\"          # red for blood\nCOLOR_VESSEL_WALL = \"#E57373\"\nCOLOR_NP_CORE = \"#42A5F5\"         # nanoparticle core\nCOLOR_NP_SHELL = \"#90CAF9\"        # nanoparticle shell (polymer)\nCOLOR_DRUG = \"#FFB74D\"            # drug molecules\nCOLOR_TUMOR = \"#7E57C2\"           # tumor cell\nCOLOR_TUMOR_NUCLEUS = \"#5C6BC0\"\nCOLOR_ECM = \"#BDBDBD\"             # extracellular matrix\nCOLOR_PH_LOW = \"#FF8A65\"\nCOLOR_PH_NEUTRAL = \"#81C784\"\nCOLOR_ARROW = \"#546E7A\"\nCOLOR_BG_SHIELD = \"#FFF3E0\"       # pH annotation background\nCOLOR_VESSEL_LUMEN = \"#FFCDD2\"    # light red lumen\n\n\n# ============================================================\n#  1. Blood Vessel (top)\n# ============================================================\n# Vessel lumen (upper region)\nvessel_top = 8.5\nvessel_bottom = 7.0\nax.fill_between([0.5, 9.5], vessel_top, vessel_bottom,\n                color=COLOR_VESSEL_LUMEN, alpha=0.3, zorder=0)\n\n# Vessel wall - bottom line (endothelium)\nwall_y = 7.0\nax.plot([0.5, 9.5], [wall_y, wall_y], color=COLOR_VESSEL_WALL,\n        linewidth=3, solid_capstyle=\"round\", zorder=2)\n\n# Vessel wall - top line\nax.plot([0.5, 9.5], [vessel_top, vessel_top], color=COLOR_VESSEL_WALL,\n        linewidth=3, solid_capstyle=\"round\", zorder=2)\n\n# Endothelial cells (nuclei)\nfor x in np.linspace(1.0, 7.0, 7):\n    ax.plot(x, wall_y - 0.15, \"o\", color=\"#C62828\", markersize=4, zorder=3)\n# Endothelial cells on right side\nfor x in np.linspace(8.0, 9.0, 3):\n    ax.plot(x, wall_y - 0.15, \"o\", color=\"#C62828\", markersize=4, zorder=3)\n\n# Leaky gap in endothelium (tumor vasculature - EPR effect)\ngap_center = 7.5\ngap_width = 0.7\n# Draw gap as a break in the wall — we just leave a section empty\n# and add small \"tear\" marks\ngap_left = gap_center - gap_width / 2\ngap_right = gap_center + gap_width / 2\nax.plot([gap_left, gap_right], [wall_y, wall_y], \"w\", linewidth=4, zorder=3)\n# Tear markers\nax.annotate(\"\", xy=(gap_left, wall_y), xytext=(gap_left - 0.08, wall_y + 0.15),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_VESSEL_WALL, lw=1.5))\nax.annotate(\"\", xy=(gap_right, wall_y), xytext=(gap_right + 0.08, wall_y + 0.15),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_VESSEL_WALL, lw=1.5))\n\n# \"Leaky vasculature\" label above gap\nax.annotate(\"Leaky vasculature\\n(EPR effect)\", xy=(gap_center, vessel_top + 0.4),\n            fontsize=9, ha=\"center\", va=\"bottom\", color=\"#C62828\",\n            fontweight=\"bold\",\n            bbox=dict(boxstyle=\"round,pad=0.3\", facecolor=\"white\",\n                      edgecolor=COLOR_VESSEL_WALL, alpha=0.85))\n\n\n# ============================================================\n#  2. Red blood cells & Nanoparticles in bloodstream\n# ============================================================\n# Red blood cells (small red discs)\nrbc_positions = [(1.5, 7.8), (3.0, 7.5), (4.5, 8.0), (6.0, 7.7),\n                 (2.0, 8.2), (5.0, 8.3), (8.5, 7.9)]\nfor x, y in rbc_positions:\n    circle = mpatches.Circle((x, y), 0.25, color=COLOR_BLOOD, alpha=0.7,\n                             ec=\"#C62828\", lw=1, zorder=4)\n    ax.add_patch(circle)\n\n# Nanoparticles (core-shell structure) in blood\nnp_positions_blood = [(2.5, 7.6), (4.0, 7.8), (5.5, 7.5), (7.0, 7.7),\n                      (1.0, 7.9), (8.0, 7.6), (9.0, 7.8)]\nfor x, y in np_positions_blood:\n    # Shell (polymer)\n    shell = mpatches.Circle((x, y), 0.20, color=COLOR_NP_SHELL, alpha=0.8,\n                            ec=\"#1E88E5\", lw=0.5, zorder=5)\n    ax.add_patch(shell)\n    # Core (drug payload)\n    core = mpatches.Circle((x, y), 0.10, color=COLOR_NP_CORE, alpha=0.9,\n                           ec=\"#1565C0\", lw=0.5, zorder=6)\n    ax.add_patch(core)\n\n# Direction of blood flow (arrow)\nax.annotate(\"\", xy=(8.8, 7.75), xytext=(1.2, 7.75),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_BLOOD,\n                            lw=2.5, linestyle=\"dashed\"), zorder=1)\nax.text(1.2, 7.4, \"Blood flow\", fontsize=9, color=\"#C62828\", fontstyle=\"italic\")\n\n\n# ============================================================\n#  3. Nanoparticle extravasation through leaky gap (EPR)\n# ============================================================\n# NPs passing through the gap\nnp_extra = [(7.5, 7.0), (7.5, 6.6), (7.55, 6.2), (7.45, 5.8)]\nfor i, (x, y) in enumerate(np_extra):\n    shell = mpatches.Circle((x, y), 0.18, color=COLOR_NP_SHELL, alpha=0.85,\n                            ec=\"#1E88E5\", lw=0.5, zorder=7)\n    ax.add_patch(shell)\n    core = mpatches.Circle((x, y), 0.09, color=COLOR_NP_CORE, alpha=0.9,\n                           ec=\"#1565C0\", lw=0.5, zorder=8)\n    ax.add_patch(core)\n\n# Arrow showing extravasation direction\nax.annotate(\"\", xy=(7.5, 5.4), xytext=(7.5, 7.3),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_ARROW,\n                            lw=2.5), zorder=6)\nax.text(7.8, 6.3, \"Extravasation\", fontsize=9, color=COLOR_ARROW,\n        fontweight=\"bold\", rotation=90, va=\"center\")\n\n\n# ============================================================\n#  4. Tumor interstitium / ECM\n# ============================================================\n# ECM represented by a dotted/fibrous background\nfor i in range(15):\n    x = np.random.uniform(0.8, 9.2)\n    y = np.random.uniform(3.5, 6.5)\n    if not ((3.0 < x < 7.0) and (3.0 < y < 6.0)):  # avoid clustering over cells\n        ax.plot(x, y, \".\", color=COLOR_ECM, alpha=0.4, markersize=3, zorder=0)\n\n# Collagen fibers (wavy lines)\nfor _ in range(8):\n    x_start = np.random.uniform(0.5, 9.0)\n    y_start = np.random.uniform(4.0, 6.5)\n    x_vals = np.linspace(x_start, x_start + np.random.uniform(0.5, 1.5), 30)\n    y_vals = y_start + 0.08 * np.sin(5 * x_vals) + np.random.uniform(-0.05, 0.05)\n    ax.plot(x_vals, y_vals, color=COLOR_ECM, alpha=0.3, lw=0.8, zorder=0)\n\n\n# ============================================================\n#  5. Tumor cells\n# ============================================================\ndef draw_tumor_cell(cx, cy, scale=1.0, label=\"\"):\n    \"\"\"Draw an irregular tumor cell with nucleus.\"\"\"\n    # Cell body - slightly irregular shape\n    angles = np.linspace(0, 2 * np.pi, 50)\n    r = 0.45 * scale\n    radii = r + 0.10 * scale * np.sin(3 * angles) + 0.05 * scale * np.sin(5 * angles)\n    x_verts = cx + radii * np.cos(angles)\n    y_verts = cy + radii * np.sin(angles)\n    verts = list(zip(x_verts, y_verts))\n    codes = [Path.MOVETO] + [Path.LINETO] * (len(verts) - 2) + [Path.CLOSEPOLY]\n    path = Path(verts[:-1], codes)\n    patch = mpatches.PathPatch(path, facecolor=COLOR_TUMOR, alpha=0.7,\n                               ec=\"#4527A0\", lw=1.5, zorder=5)\n    ax.add_patch(patch)\n\n    # Nucleus\n    nucleus = mpatches.Circle((cx + 0.05 * scale, cy + 0.05 * scale),\n                              0.18 * scale, color=COLOR_TUMOR_NUCLEUS,\n                              alpha=0.8, ec=\"#283593\", lw=1, zorder=6)\n    ax.add_patch(nucleus)\n\n    # Surface receptors (small bumps)\n    for angle in np.linspace(0, 2 * np.pi, 8, endpoint=False):\n        rx = cx + (r + 0.08) * np.cos(angle)\n        ry = cy + (r + 0.08) * np.sin(angle)\n        rec = mpatches.Circle((rx, ry), 0.04 * scale, color=\"#D1C4E9\",\n                              alpha=0.8, zorder=7)\n        ax.add_patch(rec)\n\n    if label:\n        ax.text(cx, cy - 0.65 * scale, label, fontsize=9, ha=\"center\",\n                va=\"top\", color=\"#4527A0\", fontweight=\"bold\")\n\n# Tumor cells positions\ntumor_positions = [\n    (1.5, 4.5, 1.0, \"Tumor cell\"),\n    (3.5, 5.0, 0.9, \"\"),\n    (4.0, 3.8, 1.1, \"Tumor cell\"),\n    (5.5, 5.2, 0.85, \"\"),\n    (6.0, 4.0, 1.0, \"\"),\n    (2.0, 3.0, 0.8, \"\"),\n    (7.5, 3.5, 0.9, \"\"),\n]\nfor cx, cy, scale, label in tumor_positions:\n    draw_tumor_cell(cx, cy, scale, label)\n\n\n# ============================================================\n#  6. Nanoparticles in tumor interstitium (accumulated via EPR)\n# ============================================================\nnp_tumor_positions = [\n    (2.2, 5.5), (3.8, 6.0), (4.5, 5.5),\n    (1.8, 3.8), (3.0, 4.2), (5.8, 4.8),\n    (6.5, 5.5), (7.2, 4.8), (6.8, 3.2),\n]\nfor x, y in np_tumor_positions:\n    shell = mpatches.Circle((x, y), 0.16, color=COLOR_NP_SHELL, alpha=0.7,\n                            ec=\"#1E88E5\", lw=0.5, zorder=6)\n    ax.add_patch(shell)\n    core = mpatches.Circle((x, y), 0.08, color=COLOR_NP_CORE, alpha=0.8,\n                           ec=\"#1565C0\", lw=0.5, zorder=7)\n    ax.add_patch(core)\n\n\n# ============================================================\n#  7. pH-responsive drug release (bottom)\n# ============================================================\n# Nanoparticles releasing drug (core disintegrating)\nrelease_positions = [\n    (1.0, 1.8), (3.0, 1.5), (5.0, 2.0), (7.0, 1.5), (8.5, 1.8)\n]\nfor x, y in release_positions:\n    # Shell (cracked/weakened - shown as a dashed outline)\n    shell = mpatches.Circle((x, y), 0.18, color=COLOR_NP_SHELL, alpha=0.4,\n                            ec=\"#1E88E5\", lw=0.8, linestyle=\"dotted\", zorder=5)\n    ax.add_patch(shell)\n    # Drug molecules being released\n    for dx, dy in [(0.15, 0.15), (-0.15, 0.1), (0.2, -0.1),\n                   (-0.1, -0.18), (0.1, -0.05)]:\n        drug = mpatches.Circle((x + dx, y + dy), 0.04, color=COLOR_DRUG,\n                               alpha=0.9, ec=\"#E65100\", lw=0.3, zorder=6)\n        ax.add_patch(drug)\n    # More drug molecules diffusing away\n    for dx, dy in [(0.3, 0.2), (-0.3, 0.25), (0.35, -0.25),\n                   (-0.25, -0.3), (0.0, 0.3)]:\n        drug = mpatches.Circle((x + dx, y + dy), 0.03, color=COLOR_DRUG,\n                               alpha=0.5, ec=\"#E65100\", lw=0.2, zorder=5)\n        ax.add_patch(drug)\n\n# Arrow from intact NP in tumor to disintegrating NP\nax.annotate(\"\", xy=(1.0, 2.2), xytext=(2.0, 5.0),\n            arrowprops=dict(arrowstyle=\"->\", color=COLOR_ARROW,\n                            lw=2, connectionstyle=\"arc3,rad=-0.2\"), zorder=4)\nax.text(0.6, 3.6, \"pH-triggered\\ndrug release\", fontsize=9, color=COLOR_ARROW,\n        fontweight=\"bold\", ha=\"left\", va=\"center\",\n        bbox=dict(boxstyle=\"round,pad=0.3\", facecolor=\"white\",\n                  edgecolor=\"gray\", alpha=0.85))\n\n\n# ============================================================\n#  8. pH gradient annotation\n# ============================================================\n# pH scale bar on the right side\nph_x = 9.3\n# Neutral pH (blood) - green bar\nax.plot([ph_x, ph_x], [7.2, 8.2], color=COLOR_PH_NEUTRAL, lw=8, solid_capstyle=\"round\", zorder=2)\nax.text(ph_x + 0.3, 7.7, \"pH 7.4\", fontsize=9, color=\"#2E7D32\",\n        fontweight=\"bold\", va=\"center\")\n\n# Acidic pH (tumor) - orange bar\nax.plot([ph_x, ph_x], [1.5, 3.5], color=COLOR_PH_LOW, lw=8, solid_capstyle=\"round\", zorder=2)\nax.text(ph_x + 0.3, 2.5, \"pH 6.5\", fontsize=9, color=\"#D84315\",\n        fontweight=\"bold\", va=\"center\")\n\n# Gradient between (fade)\nfor y in np.linspace(3.5, 7.2, 20):\n    t = (y - 3.5) / (7.2 - 3.5)\n    c = (1 - t) * np.array([1.0, 0.4, 0.15]) + t * np.array([0.3, 0.7, 0.3])\n    ax.plot([ph_x, ph_x], [y, y + 0.18], color=c, lw=8, solid_capstyle=\"butt\", zorder=1)\n\n# pH label\nax.text(ph_x + 0.3, 5.4, \"pH\\ngradient\", fontsize=8, color=\"gray\",\n        ha=\"center\", va=\"center\", fontstyle=\"italic\")\n\n# Acidic microenvironment bracket\nax.annotate(\"Acidic tumor\\nmicroenvironment\", xy=(1.5, 2.5),\n            fontsize=9, ha=\"left\", va=\"center\", color=\"#D84315\",\n            fontweight=\"bold\",\n            bbox=dict(boxstyle=\"round,pad=0.3\", facecolor=COLOR_BG_SHIELD,\n                      edgecolor=COLOR_PH_LOW, alpha=0.85))\n\n\n# ============================================================\n#  9. Title / Legend\n# ============================================================\nax.set_title(\"Nanomedicine Tumor Targeting via EPR Effect\\n\"\n             \"and pH-Responsive Drug Release\",\n             fontsize=14, fontweight=\"bold\", pad=15)\n\n# Legend items\nlegend_elements = [\n    mpatches.Patch(facecolor=COLOR_NP_SHELL, edgecolor=\"#1E88E5\",\n                   label=\"Nanoparticle (polymer shell)\"),\n    mpatches.Patch(facecolor=COLOR_DRUG, edgecolor=\"#E65100\",\n                   label=\"Drug molecule\"),\n    mpatches.Patch(facecolor=COLOR_TUMOR, edgecolor=\"#4527A0\",\n                   label=\"Tumor cell\"),\n    mpatches.Patch(facecolor=COLOR_VESSEL_LUMEN, edgecolor=COLOR_VESSEL_WALL,\n                   label=\"Blood vessel\"),\n]\nlegend = ax.legend(handles=legend_elements, loc=\"lower center\",\n                   ncol=4, fontsize=8.5, framealpha=0.9,\n                   bbox_to_anchor=(0.5, -0.05), handlelength=1.5)\nlegend.get_frame().set_edgecolor(\"gray\")\n\n# ============================================================\n#  Save\n# ============================================================\noutput_path = \"/home/joe/Documents/repo/skill/sci-draw/epr_graphical_abstract.png\"\nfig.savefig(output_path, dpi=300, bbox_inches=\"tight\",\n            facecolor=\"white\", edgecolor=\"none\")\nprint(f\"Saved to: {output_path}\")\n\n# Also save as PDF for publication\npdf_path = \"/home/joe/Documents/repo/skill/sci-draw/epr_graphical_abstract.pdf\"\nfig.savefig(pdf_path, bbox_inches=\"tight\", facecolor=\"white\", edgecolor=\"none\")\nprint(f\"Saved to: {pdf_path}\")\n\nplt.close()\nprint(\"Done!\")\n"})
