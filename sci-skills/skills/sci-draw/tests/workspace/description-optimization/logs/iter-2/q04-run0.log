TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/neuroscience_stripplot.py", "content": "\"\"\"\nNeuroscience Publication-Quality Figure\n=========================================\nStrip plot + mean ± SEM with Mann-Whitney U significance annotations.\nIEEE single-column format, colorblind-safe palette.\nSmall-sample friendly alternative to bar charts (n = 6 per group).\n\nHOW TO ADAPT TO YOUR DATA:\n  1. Replace the mock data in the \"DATA\" section with your actual values.\n  2. Adjust group_names and ylabel/ylim as needed.\n  3. Run:  python neuroscience_stripplot.py\n  4. Output: neuroscience_figure.png (300 dpi) + .svg + .pdf\n\"\"\"\n\nimport numpy as np\nimport matplotlib\nmatplotlib.use(\"Agg\")\nimport matplotlib.pyplot as plt\nimport matplotlib.ticker as ticker\nfrom scipy.stats import mannwhitneyu\nfrom itertools import combinations\n\n# ── IEEE single-column formatting ────────────────────────────────────────────\nmatplotlib.rcParams.update({\n    \"font.family\": \"sans-serif\",\n    \"font.sans-serif\": [\"Arial\", \"Helvetica\"],\n    \"font.size\": 7,\n    \"axes.titlesize\": 8,\n    \"axes.labelsize\": 8,\n    \"xtick.labelsize\": 7,\n    \"ytick.labelsize\": 7,\n    \"legend.fontsize\": 7,\n    \"figure.dpi\": 300,\n    \"savefig.dpi\": 300,\n    \"savefig.bbox\": \"tight\",\n    \"axes.linewidth\": 0.8,\n    \"xtick.major.width\": 0.6,\n    \"ytick.major.width\": 0.6,\n    \"xtick.major.size\": 3,\n    \"ytick.major.size\": 3,\n    \"lines.linewidth\": 1.0,\n})\n\n# ── COLORBLIND-SAFE PALETTE (Wong 2011, Nature Methods) ─────────────────────\nCBPALETTE = {\n    \"black\":  (0.00, 0.00, 0.00),\n    \"orange\": (0.90, 0.45, 0.13),\n    \"blue\":   (0.00, 0.45, 0.70),\n    \"green\":  (0.00, 0.60, 0.50),\n    \"yellow\": (0.95, 0.70, 0.13),\n    \"red\":    (0.84, 0.15, 0.16),\n    \"purple\": (0.60, 0.35, 0.70),\n    \"cyan\":   (0.37, 0.63, 0.67),\n}\nGROUP_COLORS = [CBPALETTE[\"blue\"], CBPALETTE[\"orange\"], CBPALETTE[\"green\"],\n                CBPALETTE[\"red\"], CBPALETTE[\"purple\"]]\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  DATA  —  Replace with your actual values\n# ══════════════════════════════════════════════════════════════════════════════\n\ngroup_names = [\"Sham\", \"Lesion\", \"Treatment A\", \"Treatment B\", \"Treatment C\"]\n\n# Mock data: replace these lists with your 6 values per group\ngroups_data = [\n    [9.8, 11.2, 10.5, 8.9, 11.8, 10.1],   # Sham\n    [18.2, 16.8, 19.5, 17.1, 20.0, 18.9],  # Lesion\n    [13.5, 12.1, 14.2, 11.8, 15.0, 13.0],  # Treatment A\n    [6.5,  7.8,  8.2,  6.0,  7.1,  8.8],   # Treatment B\n    [15.5, 17.2, 16.0, 18.5, 14.9, 16.8],  # Treatment C\n]\n\nylabel = \"Neural Firing Rate (Hz)\"\nylim = (0, 26)        # set y-axis limits\n\n# ── Optional: control group for comparisons (index in group_names) ──────────\n# Set to None for ALL pairwise comparisons, or an int for vs-control only.\nCONTROL_INDEX = 0      # compare all groups against Sham\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  STATISTICS  —  Mann-Whitney U with Bonferroni correction\n# ══════════════════════════════════════════════════════════════════════════════\n\n# Determine which comparisons to run\nif CONTROL_INDEX is not None:\n    comparisons = [(CONTROL_INDEX, j) for j in range(len(groups_data)) if j != CONTROL_INDEX]\n    comparison_label = f\"vs {group_names[CONTROL_INDEX]}\"\nelse:\n    comparisons = list(combinations(range(len(groups_data)), 2))\n    comparison_label = \"all pairwise\"\n\n# Run Mann-Whitney U tests (two-sided)\np_values_raw = {}\nfor i, j in comparisons:\n    stat, p = mannwhitneyu(groups_data[i], groups_data[j], alternative=\"two-sided\")\n    p_values_raw[(i, j)] = p\n\n# Bonferroni correction\nn_comparisons = len(comparisons)\nalpha = 0.05\nalpha_corrected = alpha / n_comparisons\n\ndef significance_symbol(p, n_tests=n_comparisons):\n    \"\"\"Return significance symbol after Bonferroni correction.\"\"\"\n    p_adj = p * n_tests  # Bonferroni-adjusted p-value\n    if p_adj > 0.05:\n        return \"ns\"\n    elif p_adj <= 0.001:\n        return \"***\"\n    elif p_adj <= 0.01:\n        return \"**\"\n    else:\n        return \"*\"\n\n# Build lookup of significance info for each pair\nsig_info = {}\nfor (i, j), p in p_values_raw.items():\n    sig_info[(i, j)] = {\n        \"p_raw\": p,\n        \"p_adjusted\": p * n_comparisons,\n        \"symbol\": significance_symbol(p, n_comparisons),\n        \"significant\": (p * n_comparisons) <= 0.05,\n    }\n\n# Print stats summary\nprint(f\"Statistics: Mann-Whitney U ({comparison_label}), Bonferroni-corrected (×{n_comparisons})\")\nprint(f\"Critical α after correction = {alpha_corrected:.5f}\")\nprint(\"-\" * 60)\nfor (i, j), info in sorted(sig_info.items()):\n    flag = \"★\" if info[\"significant\"] else \" \"\n    print(f\"  {flag} {group_names[i]} vs {group_names[j]:12s}: \"\n          f\"U-stat = {mannwhitneyu(groups_data[i], groups_data[j], alternative='two-sided')[0]:5.1f}, \"\n          f\"p_raw = {info['p_raw']:.4f}, \"\n          f\"p_adj = {info['p_adjusted']:.4f}  {info['symbol']}\")\nprint(\"-\" * 60)\n\n# ══════════════════════════════════════════════════════════════════════════════\n#  FIGURE\n# ══════════════════════════════════════════════════════════════════════════════\n\nfig, ax = plt.subplots(figsize=(3.5, 2.8))  # IEEE single-column: 3.5\" wide\n\nn_groups = len(groups_data)\nx_positions = np.arange(n_groups)\n\n# ── Helper: draw significance bracket ───────────────────────────────────────\ndef draw_significance_bracket(ax, x1, x2, y_base, symbol, color=\"black\"):\n    \"\"\"Draw a horizontal bracket with significance symbol above two groups.\"\"\"\n    bracket_h = 0.8  # bracket arm height\n    text_offset = 0.3\n    y_bracket = y_base\n    y_text = y_bracket + text_offset\n\n    # Horizontal line connecting the two groups\n    ax.plot([x1, x2], [y_bracket, y_bracket],\n            color=color, lw=0.8, clip_on=False)\n    # Left tick\n    ax.plot([x1, x1], [y_bracket - bracket_h * 0.4, y_bracket],\n            color=color, lw=0.8, clip_on=False)\n    # Right tick\n    ax.plot([x2, x2], [y_bracket - bracket_h * 0.4, y_bracket],\n            color=color, lw=0.8, clip_on=False)\n\n    # Symbol or p-value text\n    symbol_fontsize = 7 if symbol in (\"ns\",) else 8\n    ax.text((x1 + x2) / 2, y_text, symbol,\n            ha=\"center\", va=\"bottom\", fontsize=symbol_fontsize,\n            fontweight=\"normal\", color=color)\n\ndef draw_strip_plot(ax, groups_data, x_positions, colors):\n    \"\"\"Draw individual data points (jittered strip plot).\"\"\"\n    for i, (group, x, color) in enumerate(zip(groups_data, x_positions, colors)):\n        # Horizontal jitter\n        jitter_width = 0.28\n        np.random.seed(42 + i)  # reproducible jitter\n        jitter = np.random.uniform(-jitter_width, jitter_width, size=len(group))\n        x_jittered = x + jitter\n\n        # Plot individual points\n        ax.scatter(x_jittered, group, s=22, c=[color], zorder=5,\n                   edgecolors=\"white\", linewidth=0.3, alpha=0.9)\n\n# ── Draw strip plot with individual data points ─────────────────────────────\ndraw_strip_plot(ax, groups_data, x_positions, GROUP_COLORS)\n\n# ── Overlay mean ± SEM markers ──────────────────────────────────────────────\nfor i, (group, x, color) in enumerate(zip(groups_data, x_positions, GROUP_COLORS)):\n    mean = np.mean(group)\n    sem = np.std(group, ddof=1) / np.sqrt(len(group))\n\n    # Mean marker (filled diamond) — this IS the \"mean bar\" the PI wants\n    ax.scatter(x, mean, s=64, marker=\"D\", c=[color], edgecolors=\"black\",\n               linewidth=0.6, zorder=10)\n\n    # SEM error bar\n    ax.errorbar(x, mean, yerr=sem, fmt=\"none\", ecolor=\"black\",\n                capsize=2.5, capthick=0.8, elinewidth=0.8, zorder=9)\n\n    # Optional: print summary statistics\n    print(f\"  {group_names[i]:12s}: mean={mean:.2f}, SEM={sem:.2f}\")\n\n# ── Significance annotations ────────────────────────────────────────────────\n# Collect significant pairs and calculate bracket Y positions\nmax_y = max(np.max(g) for g in groups_data)\nbracket_start = max_y + 1.2  # first bracket height\n\nsig_pairs = [(i, j, info) for (i, j), info in sig_info.items() if info[\"significant\"]]\n\n# Sort by the left group index for ordered brackets\nsig_pairs.sort(key=lambda x: (x[0], x[1]))\n\n# Bracket tiers: stack brackets that would overlap\ntier_height = 2.0\ntiers = []\n\nfor i, j, info in sig_pairs:\n    # Find which tier this bracket can go in (no x-overlap)\n    placed = False\n    for tier_idx, tier in enumerate(tiers):\n        # Check overlap with existing brackets in this tier\n        overlaps = any(not (j <= a or i >= b) for (a, b) in tier)\n        if not overlaps:\n            tier.append((i, j, info))\n            placed = True\n            break\n    if not placed:\n        tiers.append([(i, j, info)])\n\n# Draw brackets tier by tier\nfor tier_idx, tier in enumerate(tiers):\n    y_bracket = bracket_start + tier_idx * tier_height\n    for i, j, info in tier:\n        draw_significance_bracket(ax, x_positions[i], x_positions[j],\n                                  y_bracket, info[\"symbol\"])\n\n# ── Labels & formatting ─────────────────────────────────────────────────────\nax.set_xticks(x_positions)\nax.set_xticklabels(group_names, rotation=25, ha=\"right\")\nax.set_ylabel(ylabel)\nax.set_ylim(ylim)\n\n# Clean spines\nax.spines[\"top\"].set_visible(False)\nax.spines[\"right\"].set_visible(False)\nax.spines[\"left\"].set_linewidth(0.6)\nax.spines[\"bottom\"].set_linewidth(0.6)\n\n# Grid (horizontal only, muted)\nax.yaxis.set_major_locator(ticker.MultipleLocator(5))\nax.yaxis.set_minor_locator(ticker.MultipleLocator(1))\nax.grid(axis=\"y\", which=\"major\", alpha=0.15, lw=0.5)\nax.set_axisbelow(True)\n\n# ── Statistics summary box in corner ────────────────────────────────────────\nstats_text = (\n    f\"Mann-Whitney U\\n\"\n    f\"Bonferroni: ×{n_comparisons}\\n\"\n    f\"adj. α = {alpha_corrected:.4f}\\n\"\n    f\"n = {len(groups_data[0])} per group\"\n)\nax.text(0.98, 0.98, stats_text, transform=ax.transAxes,\n        fontsize=6, ha=\"right\", va=\"top\",\n        bbox=dict(boxstyle=\"round,pad=0.3\", facecolor=\"white\",\n                  edgecolor=\"gray\", alpha=0.85),\n        zorder=20)\n\n# ── Export ───────────────────────────────────────────────────────────────────\noutput_base = \"neuroscience_figure\"\nfor ext in [\"png\", \"svg\", \"pdf\"]:\n    fname = f\"{output_base}.{ext}\"\n    fig.savefig(fname, dpi=300, bbox_inches=\"tight\")\n    print(f\"  ✓ Saved {fname}\")\n\nplt.close(fig)\nprint(\"\\nDone — paste your data into `groups_data` and re-run.\")\n"})
