TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\nMulti-CSV Data Preprocessing Pipeline\n\nReads multiple CSV files → cleans missing values → standardizes numerical columns\n→ one-hot encodes categorical variables → merges into a single feature matrix.\n\nUsage:\n    python data_pipeline.py [--config config.yaml]\n    or run interactively with defaults:\n    python data_pipeline.py\n\"\"\"\n\nimport argparse\nimport logging\nimport sys\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional, Sequence, Tuple, Union\n\nimport numpy as np\nimport pandas as pd\nfrom sklearn.preprocessing import StandardScaler, MinMaxScaler, RobustScaler\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s | %(levelname)-8s | %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"data_pipeline\")\n\n\n# ---------------------------------------------------------------------------\n# Configuration\n# ---------------------------------------------------------------------------\n\nclass PipelineConfig:\n    \"\"\"Central configuration for the entire preprocessing pipeline.\n\n    Extend or override fields before calling ``run_pipeline(config)``.\n    \"\"\"\n\n    # ---- Data source ----\n    csv_paths: List[Union[str, Path]] = []\n    # Example: [\"./data/experiment_1.csv\", \"./data/experiment_2.csv\"]\n\n    # ---- Row identifier (used as index; None → auto integer index) ----\n    index_col: Optional[str] = None\n\n    # ---- Column type hints (overrides auto-detection) ----\n    categorical_cols: List[str] = []\n    numerical_cols: List[str] = []\n\n    # ---- Missing-value handling ----\n    # Strategy per type: \"drop\", \"mean\", \"median\", \"mode\", \"constant\"\n    # A single string applies to all columns of that type.\n    numeric_na_strategy: Union[str, Dict[str, str]] = \"mean\"\n    categorical_na_strategy: Union[str, Dict[str, str]] = \"mode\"\n    na_fill_value: float = -1.0  # used when strategy is \"constant\"\n\n    # ---- Numerical standardisation ----\n    # \"standard\" (z-score), \"minmax\", \"robust\", or None to skip\n    scaler_type: Optional[str] = \"standard\"\n\n    # ---- Categorical encoding ----\n    # \"onehot\" or \"dummy\" (pd.get_dummies); None to skip\n    # drop_first=False keeps all k levels (no collinearity removal)\n    categorical_encoding: str = \"onehot\"\n    drop_first: bool = False\n\n    # ---- Column filtering ----\n    # Explicit white-list / black-list (applied BEFORE merge)\n    keep_cols: Optional[List[str]] = None        # None → keep all\n    drop_cols: List[str] = []\n\n    # ---- Output ----\n    output_path: Optional[Union[str, Path]] = \"feature_matrix.csv\"\n\n    # ---- Verbose logging of column counts ----\n    verbose: bool = True\n\n\n# ---------------------------------------------------------------------------\n# Column type inference\n# ---------------------------------------------------------------------------\n\ndef _infer_column_types(\n    df: pd.DataFrame,\n    user_categorical: Sequence[str],\n    user_numerical: Sequence[str],\n) -> Tuple[List[str], List[str]]:\n    \"\"\"Infer categorical vs. numerical columns, respecting user overrides.\"\"\"\n    user_cat_set = set(user_categorical)\n    user_num_set = set(user_numerical)\n\n    cat_cols: List[str] = []\n    num_cols: List[str] = []\n\n    for col in df.columns:\n        if col in user_cat_set:\n            cat_cols.append(col)\n        elif col in user_num_set:\n            num_cols.append(col)\n        else:\n            # pandas dtype heuristics\n            dtype = df[col].dtype\n            if pd.api.types.is_numeric_dtype(dtype):\n                num_cols.append(col)\n            elif pd.api.types.is_object_dtype(dtype) or pd.api.types.is_categorical_dtype(dtype):\n                cat_cols.append(col)\n            elif pd.api.types.is_bool_dtype(dtype):\n                cat_cols.append(col)\n            else:\n                # Treat as categorical if unsure\n                cat_cols.append(col)\n\n    return cat_cols, num_cols\n\n\n# ---------------------------------------------------------------------------\n# Missing-value handling\n# ---------------------------------------------------------------------------\n\ndef _resolve_na_strategy(\n    strategy: Union[str, Dict[str, str]],\n    columns: List[str],\n) -> Dict[str, str]:\n    \"\"\"Normalise strategy to a per-column dict.\"\"\"\n    if isinstance(strategy, str):\n        return {col: strategy for col in columns}\n    # Already a dict — fill missing entries with default \"mean\" for numeric/\"mode\" for cat\n    return strategy\n\n\ndef _handle_missing_values(\n    df: pd.DataFrame,\n    cat_cols: List[str],\n    num_cols: List[str],\n    config: PipelineConfig,\n) -> pd.DataFrame:\n    \"\"\"Fill or drop missing values per configured strategy.\"\"\"\n    df = df.copy()\n\n    cat_strategies = _resolve_na_strategy(config.categorical_na_strategy, cat_cols)\n    num_strategies = _resolve_na_strategy(config.numeric_na_strategy, num_cols)\n\n    # ---- Categorical ----\n    for col in cat_cols:\n        if col not in df.columns:\n            continue\n        strategy = cat_strategies.get(col, \"mode\")\n        n_null = df[col].isna().sum()\n        if n_null == 0:\n            continue\n\n        if strategy == \"drop\":\n            df.dropna(subset=[col], inplace=True)\n        elif strategy == \"mode\":\n            mode_val = df[col].mode()\n            fill_val = mode_val.iloc[0] if not mode_val.empty else \"MISSING\"\n            df[col] = df[col].fillna(fill_val)\n        elif strategy == \"constant\":\n            df[col] = df[col].fillna(\"MISSING\")\n        else:\n            log.warning(\"Unsupported categorical NA strategy '%s' for '%s'; using 'mode'\", strategy, col)\n            df[col] = df[col].fillna(df[col].mode().iloc[0] if not df[col].mode().empty else \"MISSING\")\n\n        log.info(\"  %s: filled %d missing value(s) with strategy='%s'\", col, n_null, strategy)\n\n    # ---- Numerical ----\n    for col in num_cols:\n        if col not in df.columns:\n            continue\n        strategy = num_strategies.get(col, \"mean\")\n        n_null = df[col].isna().sum()\n        if n_null == 0:\n            continue\n\n        if strategy == \"drop\":\n            df.dropna(subset=[col], inplace=True)\n        elif strategy == \"mean\":\n            df[col] = df[col].fillna(df[col].mean())\n        elif strategy == \"median\":\n            df[col] = df[col].fillna(df[col].median())\n        elif strategy == \"constant\":\n            df[col] = df[col].fillna(config.na_fill_value)\n        else:\n            log.warning(\"Unsupported numeric NA strategy '%s' for '%s'; using 'mean'\", strategy, col)\n            df[col] = df[col].fillna(df[col].mean())\n\n        log.info(\"  %s: filled %d missing value(s) with strategy='%s'\", col, n_null, strategy)\n\n    # Drop any remaining rows that still have NA (should not happen above)\n    before = len(df)\n    df.dropna(inplace=True)\n    dropped = before - len(df)\n    if dropped:\n        log.info(\"  Dropped %d row(s) with remaining NA values.\", dropped)\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Scaling\n# ---------------------------------------------------------------------------\n\ndef _scale_numerical(\n    df: pd.DataFrame,\n    num_cols: List[str],\n    scaler_type: Optional[str],\n) -> Tuple[pd.DataFrame, Any]:\n    \"\"\"Apply chosen scaler; returns (df, fitted_scaler).\"\"\"\n    if not num_cols or scaler_type is None:\n        return df, None\n\n    present = [c for c in num_cols if c in df.columns]\n    if not present:\n        return df, None\n\n    scaler: Any\n    if scaler_type == \"standard\":\n        scaler = StandardScaler()\n    elif scaler_type == \"minmax\":\n        scaler = MinMaxScaler()\n    elif scaler_type == \"robust\":\n        scaler = RobustScaler()\n    else:\n        log.warning(\"Unknown scaler '%s'; skipping scaling.\", scaler_type)\n        return df, None\n\n    df = df.copy()\n    df[present] = scaler.fit_transform(df[present])\n    log.info(\n        \"  Scaled %d numerical column(s) using '%s' scaler.\",\n        len(present), scaler_type,\n    )\n    return df, scaler\n\n\n# ---------------------------------------------------------------------------\n# Categorical encoding\n# ---------------------------------------------------------------------------\n\ndef _encode_categorical(\n    df: pd.DataFrame,\n    cat_cols: List[str],\n    encoding: str,\n    drop_first: bool = False,\n) -> pd.DataFrame:\n    \"\"\"One-hot or dummy-encode categorical columns.\"\"\"\n    if not cat_cols or encoding is None:\n        return df\n\n    present = [c for c in cat_cols if c in df.columns]\n    if not present:\n        return df\n\n    if encoding == \"onehot\":\n        encoded = pd.get_dummies(\n            df[present],\n            prefix_sep=\"_\",\n            drop_first=drop_first,\n            dtype=float,  # ensures numeric output\n        )\n        df = df.drop(columns=present).join(encoded)\n        log.info(\n            \"  One-hot encoded %d categorical column(s), produced %d features.\",\n            len(present), encoded.shape[1],\n        )\n    elif encoding == \"dummy\":\n        # Same as onehot but with drop_first=True by convention\n        encoded = pd.get_dummies(\n            df[present],\n            prefix_sep=\"_\",\n            drop_first=True,\n            dtype=float,\n        )\n        df = df.drop(columns=present).join(encoded)\n        log.info(\n            \"  Dummy-encoded %d categorical column(s), produced %d features.\",\n            len(present), encoded.shape[1],\n        )\n    else:\n        log.warning(\"Unknown encoding '%s'; skip encoding.\", encoding)\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Column filtering\n# ---------------------------------------------------------------------------\n\ndef _filter_columns(df: pd.DataFrame, config: PipelineConfig) -> pd.DataFrame:\n    \"\"\"Apply keep/drop column filters.\"\"\"\n    if config.drop_cols:\n        existing = [c for c in config.drop_cols if c in df.columns]\n        if existing:\n            df = df.drop(columns=existing)\n            log.info(\"  Dropped %d user-specified column(s).\", len(existing))\n\n    if config.keep_cols is not None:\n        # Keep only those that exist\n        keep = [c for c in config.keep_cols if c in df.columns]\n        df = df[keep]\n        log.info(\"  Kept %d / %d user-specified column(s).\", len(keep), len(config.keep_cols))\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Single CSV loading & cleaning\n# ---------------------------------------------------------------------------\n\ndef load_and_clean_csv(\n    path: Union[str, Path],\n    config: PipelineConfig,\n    file_index: int,\n) -> pd.DataFrame:\n    \"\"\"Load a single CSV, clean, and return a processed DataFrame.\"\"\"\n    path = Path(path)\n    log.info(\"[%d] Loading %s\", file_index, path)\n\n    df = pd.read_csv(path, index_col=config.index_col)\n    log.info(\"  Shape: %d rows × %d columns\", *df.shape)\n\n    # ---- 1. Column filtering (before inference) ----\n    df = _filter_columns(df, config)\n\n    # ---- 2. Infer types ----\n    cat_cols, num_cols = _infer_column_types(df, config.categorical_cols, config.numerical_cols)\n\n    if config.verbose:\n        log.info(\"  Detected: %d categorical, %d numerical\", len(cat_cols), len(num_cols))\n\n    # ---- 3. Handle missing values ----\n    df = _handle_missing_values(df, cat_cols, num_cols, config)\n\n    # ---- 4. Scale numerical ----\n    df, _ = _scale_numerical(df, num_cols, config.scaler_type)\n\n    # ---- 5. Encode categorical ----\n    df = _encode_categorical(df, cat_cols, config.categorical_encoding, config.drop_first)\n\n    log.info(\"  Output shape: %d rows × %d columns\", *df.shape)\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Master merge\n# ---------------------------------------------------------------------------\n\ndef merge_dataframes(\n    dfs: List[pd.DataFrame],\n    how: str = \"outer\",\n) -> pd.DataFrame:\n    \"\"\"Merge all cleaned DataFrames into a single feature matrix.\n\n    ``how``:\n      - \"outer\" → union of all columns & rows (align by index). Missing cells\n        become NaN.\n      - \"inner\" → intersection of columns, keeping all rows.\n      - \"concat\" → vertical concatenation (requires matching columns).\n    \"\"\"\n    if len(dfs) == 0:\n        return pd.DataFrame()\n    if len(dfs) == 1:\n        return dfs[0]\n\n    if how == \"concat\":\n        merged = pd.concat(dfs, ignore_index=False)\n        log.info(\"Merged %d DataFrames via concat → %s\", len(dfs), str(merged.shape))\n    else:\n        # Align on index with outer/inner join\n        merged = dfs[0]\n        for i, other in enumerate(dfs[1:], start=2):\n            merged = pd.merge(\n                merged, other,\n                left_index=True, right_index=True,\n                how=how,\n                suffixes=(\"\", f\"_dup{i}\"),\n            )\n        log.info(\"Merged %d DataFrames via '%s' join → %s\", len(dfs), how, str(merged.shape))\n\n    return merged\n\n\n# ---------------------------------------------------------------------------\n# Entry point\n# ---------------------------------------------------------------------------\n\ndef run_pipeline(config: PipelineConfig) -> pd.DataFrame:\n    \"\"\"Execute the full pipeline and return the merged feature matrix.\n\n    Parameters\n    ----------\n    config : PipelineConfig\n        Pipeline configuration object.\n\n    Returns\n    -------\n    pd.DataFrame\n        Cleaned, merged feature matrix.\n    \"\"\"\n    if not config.csv_paths:\n        log.error(\"No CSV paths provided in config.csv_paths — nothing to do.\")\n        return pd.DataFrame()\n\n    log.info(\"=\" * 56)\n    log.info(\"Data Preprocessing Pipeline\")\n    log.info(\"=\" * 56)\n    log.info(\"Input files: %d\", len(config.csv_paths))\n    for p in config.csv_paths:\n        log.info(\"  • %s\", p)\n\n    # ---- Load & clean each CSV ----\n    cleaned_dfs: List[pd.DataFrame] = []\n    for i, path in enumerate(config.csv_paths):\n        df = load_and_clean_csv(path, config, file_index=i + 1)\n        cleaned_dfs.append(df)\n\n    # ---- Merge ----\n    merged = merge_dataframes(cleaned_dfs)\n\n    # ---- Post-merge NA drop (arise from outer join alignment) ----\n    if merged.isna().any().any():\n        before = len(merged)\n        merged.dropna(inplace=True)\n        dropped = before - len(merged)\n        if dropped:\n            log.info(\n                \"Dropped %d row(s) with NA from the merged matrix \"\n                \"(introduced by outer-join alignment).\",\n                dropped,\n            )\n\n    log.info(\"─\" * 56)\n    log.info(\"Final feature matrix: %d rows × %d columns\", *merged.shape)\n    log.info(\"Feature names: %s\", list(merged.columns))\n\n    # ---- Save ----\n    if config.output_path:\n        out = Path(config.output_path)\n        out.parent.mkdir(parents=True, exist_ok=True)\n        merged.to_csv(out, index=config.index_col is not None)\n        log.info(\"Saved to: %s\", out.resolve())\n\n    return merged\n\n\n# ---------------------------------------------------------------------------\n# CLI\n# ---------------------------------------------------------------------------\n\ndef main():\n    parser = argparse.ArgumentParser(\n        description=\"Multi-CSV data preprocessing pipeline.\",\n    )\n    parser.add_argument(\n        \"csv_paths\",\n        nargs=\"*\",\n        help=\"One or more CSV file paths (can also be set in config).\",\n    )\n    parser.add_argument(\n        \"--index-col\",\n        default=None,\n        help=\"Column name to use as row index.\",\n    )\n    parser.add_argument(\n        \"--numeric-na\",\n        default=\"mean\",\n        choices=[\"drop\", \"mean\", \"median\", \"constant\"],\n        help=\"Missing-value strategy for numerical columns.\",\n    )\n    parser.add_argument(\n        \"--categorical-na\",\n        default=\"mode\",\n        choices=[\"drop\", \"mode\", \"constant\"],\n        help=\"Missing-value strategy for categorical columns.\",\n    )\n    parser.add_argument(\n        \"--scaler\",\n        default=\"standard\",\n        choices=[\"standard\", \"minmax\", \"robust\", \"none\"],\n        help=\"Numerical scaler type.\",\n    )\n    parser.add_argument(\n        \"--encoding\",\n        default=\"onehot\",\n        choices=[\"onehot\", \"dummy\", \"none\"],\n        help=\"Categorical encoding method.\",\n    )\n    parser.add_argument(\n        \"--drop-first\",\n        action=\"store_true\",\n        help=\"Drop the first level of each one-hot encoded variable.\",\n    )\n    parser.add_argument(\n        \"--output\",\n        default=\"feature_matrix.csv\",\n        help=\"Output CSV path.\",\n    )\n    parser.add_argument(\n        \"--keep-cols\",\n        nargs=\"*\",\n        help=\"Only keep these columns (applied before processing).\",\n    )\n    parser.add_argument(\n        \"--drop-cols\",\n        nargs=\"*\",\n        help=\"Drop these columns (applied before processing).\",\n    )\n    parser.add_argument(\n        \"--quiet\",\n        action=\"store_true\",\n        help=\"Reduce logging verbosity.\",\n    )\n\n    args = parser.parse_args()\n\n    if args.quiet:\n        log.setLevel(logging.WARNING)\n\n    # Build config\n    config = PipelineConfig()\n    config.csv_paths = args.csv_paths or [\n        \"data/sample_1.csv\",\n        \"data/sample_2.csv\",\n    ]\n    config.index_col = args.index_col\n    config.numeric_na_strategy = args.numeric_na if args.numeric_na != \"none\" else None  # type: ignore\n    config.categorical_na_strategy = args.categorical_na\n    config.scaler_type = args.scaler if args.scaler != \"none\" else None\n    config.categorical_encoding = args.encoding if args.encoding != \"none\" else None\n    config.drop_first = args.drop_first\n    config.output_path = args.output\n    config.keep_cols = args.keep_cols\n    config.drop_cols = args.drop_cols or []\n\n    run_pipeline(config)\n\n\nif __name__ == \"__main__\":\n    main()\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\nMulti-CSV Data Preprocessing Pipeline\n\nReads multiple CSV files → cleans missing values → standardizes numerical columns\n→ one-hot encodes categorical variables → merges into a single feature matrix.\n\nUsage:\n    python data_pipeline.py [--config config.yaml]\n    or run interactively with defaults:\n    python data_pipeline.py\n\"\"\"\n\nimport argparse\nimport logging\nimport sys\nfrom pathlib import Path\nfrom typing import Any, Dict, List, Optional, Sequence, Tuple, Union\n\nimport numpy as np\nimport pandas as pd\nfrom sklearn.preprocessing import StandardScaler, MinMaxScaler, RobustScaler\n\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s | %(levelname)-8s | %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"data_pipeline\")\n\n\n# ---------------------------------------------------------------------------\n# Configuration\n# ---------------------------------------------------------------------------\n\nclass PipelineConfig:\n    \"\"\"Central configuration for the entire preprocessing pipeline.\n\n    Extend or override fields before calling ``run_pipeline(config)``.\n    \"\"\"\n\n    # ---- Data source ----\n    csv_paths: List[Union[str, Path]] = []\n    # Example: [\"./data/experiment_1.csv\", \"./data/experiment_2.csv\"]\n\n    # ---- Row identifier (used as index; None → auto integer index) ----\n    index_col: Optional[str] = None\n\n    # ---- Column type hints (overrides auto-detection) ----\n    categorical_cols: List[str] = []\n    numerical_cols: List[str] = []\n\n    # ---- Missing-value handling ----\n    # Strategy per type: \"drop\", \"mean\", \"median\", \"mode\", \"constant\"\n    # A single string applies to all columns of that type.\n    numeric_na_strategy: Union[str, Dict[str, str]] = \"mean\"\n    categorical_na_strategy: Union[str, Dict[str, str]] = \"mode\"\n    na_fill_value: float = -1.0  # used when strategy is \"constant\"\n\n    # ---- Numerical standardisation ----\n    # \"standard\" (z-score), \"minmax\", \"robust\", or None to skip\n    scaler_type: Optional[str] = \"standard\"\n\n    # ---- Categorical encoding ----\n    # \"onehot\" or \"dummy\" (pd.get_dummies); None to skip\n    # drop_first=False keeps all k levels (no collinearity removal)\n    categorical_encoding: str = \"onehot\"\n    drop_first: bool = False\n\n    # ---- Column filtering ----\n    # Explicit white-list / black-list (applied BEFORE merge)\n    keep_cols: Optional[List[str]] = None        # None → keep all\n    drop_cols: List[str] = []\n\n    # ---- Output ----\n    output_path: Optional[Union[str, Path]] = \"feature_matrix.csv\"\n\n    # ---- Verbose logging of column counts ----\n    verbose: bool = True\n\n\n# ---------------------------------------------------------------------------\n# Column type inference\n# ---------------------------------------------------------------------------\n\ndef _infer_column_types(\n    df: pd.DataFrame,\n    user_categorical: Sequence[str],\n    user_numerical: Sequence[str],\n) -> Tuple[List[str], List[str]]:\n    \"\"\"Infer categorical vs. numerical columns, respecting user overrides.\"\"\"\n    user_cat_set = set(user_categorical)\n    user_num_set = set(user_numerical)\n\n    cat_cols: List[str] = []\n    num_cols: List[str] = []\n\n    for col in df.columns:\n        if col in user_cat_set:\n            cat_cols.append(col)\n        elif col in user_num_set:\n            num_cols.append(col)\n        else:\n            # pandas dtype heuristics\n            dtype = df[col].dtype\n            if pd.api.types.is_numeric_dtype(dtype):\n                num_cols.append(col)\n            elif pd.api.types.is_object_dtype(dtype) or pd.api.types.is_categorical_dtype(dtype):\n                cat_cols.append(col)\n            elif pd.api.types.is_bool_dtype(dtype):\n                cat_cols.append(col)\n            else:\n                # Treat as categorical if unsure\n                cat_cols.append(col)\n\n    return cat_cols, num_cols\n\n\n# ---------------------------------------------------------------------------\n# Missing-value handling\n# ---------------------------------------------------------------------------\n\ndef _resolve_na_strategy(\n    strategy: Union[str, Dict[str, str]],\n    columns: List[str],\n) -> Dict[str, str]:\n    \"\"\"Normalise strategy to a per-column dict.\"\"\"\n    if isinstance(strategy, str):\n        return {col: strategy for col in columns}\n    # Already a dict — fill missing entries with default \"mean\" for numeric/\"mode\" for cat\n    return strategy\n\n\ndef _handle_missing_values(\n    df: pd.DataFrame,\n    cat_cols: List[str],\n    num_cols: List[str],\n    config: PipelineConfig,\n) -> pd.DataFrame:\n    \"\"\"Fill or drop missing values per configured strategy.\"\"\"\n    df = df.copy()\n\n    cat_strategies = _resolve_na_strategy(config.categorical_na_strategy, cat_cols)\n    num_strategies = _resolve_na_strategy(config.numeric_na_strategy, num_cols)\n\n    # ---- Categorical ----\n    for col in cat_cols:\n        if col not in df.columns:\n            continue\n        strategy = cat_strategies.get(col, \"mode\")\n        n_null = df[col].isna().sum()\n        if n_null == 0:\n            continue\n\n        if strategy == \"drop\":\n            df.dropna(subset=[col], inplace=True)\n        elif strategy == \"mode\":\n            mode_val = df[col].mode()\n            fill_val = mode_val.iloc[0] if not mode_val.empty else \"MISSING\"\n            df[col] = df[col].fillna(fill_val)\n        elif strategy == \"constant\":\n            df[col] = df[col].fillna(\"MISSING\")\n        else:\n            log.warning(\"Unsupported categorical NA strategy '%s' for '%s'; using 'mode'\", strategy, col)\n            df[col] = df[col].fillna(df[col].mode().iloc[0] if not df[col].mode().empty else \"MISSING\")\n\n        log.info(\"  %s: filled %d missing value(s) with strategy='%s'\", col, n_null, strategy)\n\n    # ---- Numerical ----\n    for col in num_cols:\n        if col not in df.columns:\n            continue\n        strategy = num_strategies.get(col, \"mean\")\n        n_null = df[col].isna().sum()\n        if n_null == 0:\n            continue\n\n        if strategy == \"drop\":\n            df.dropna(subset=[col], inplace=True)\n        elif strategy == \"mean\":\n            df[col] = df[col].fillna(df[col].mean())\n        elif strategy == \"median\":\n            df[col] = df[col].fillna(df[col].median())\n        elif strategy == \"constant\":\n            df[col] = df[col].fillna(config.na_fill_value)\n        else:\n            log.warning(\"Unsupported numeric NA strategy '%s' for '%s'; using 'mean'\", strategy, col)\n            df[col] = df[col].fillna(df[col].mean())\n\n        log.info(\"  %s: filled %d missing value(s) with strategy='%s'\", col, n_null, strategy)\n\n    # Drop any remaining rows that still have NA (should not happen above)\n    before = len(df)\n    df.dropna(inplace=True)\n    dropped = before - len(df)\n    if dropped:\n        log.info(\"  Dropped %d row(s) with remaining NA values.\", dropped)\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Scaling\n# ---------------------------------------------------------------------------\n\ndef _scale_numerical(\n    df: pd.DataFrame,\n    num_cols: List[str],\n    scaler_type: Optional[str],\n) -> Tuple[pd.DataFrame, Any]:\n    \"\"\"Apply chosen scaler; returns (df, fitted_scaler).\"\"\"\n    if not num_cols or scaler_type is None:\n        return df, None\n\n    present = [c for c in num_cols if c in df.columns]\n    if not present:\n        return df, None\n\n    scaler: Any\n    if scaler_type == \"standard\":\n        scaler = StandardScaler()\n    elif scaler_type == \"minmax\":\n        scaler = MinMaxScaler()\n    elif scaler_type == \"robust\":\n        scaler = RobustScaler()\n    else:\n        log.warning(\"Unknown scaler '%s'; skipping scaling.\", scaler_type)\n        return df, None\n\n    df = df.copy()\n    df[present] = scaler.fit_transform(df[present])\n    log.info(\n        \"  Scaled %d numerical column(s) using '%s' scaler.\",\n        len(present), scaler_type,\n    )\n    return df, scaler\n\n\n# ---------------------------------------------------------------------------\n# Categorical encoding\n# ---------------------------------------------------------------------------\n\ndef _encode_categorical(\n    df: pd.DataFrame,\n    cat_cols: List[str],\n    encoding: str,\n    drop_first: bool = False,\n) -> pd.DataFrame:\n    \"\"\"One-hot or dummy-encode categorical columns.\"\"\"\n    if not cat_cols or encoding is None:\n        return df\n\n    present = [c for c in cat_cols if c in df.columns]\n    if not present:\n        return df\n\n    if encoding == \"onehot\":\n        encoded = pd.get_dummies(\n            df[present],\n            prefix_sep=\"_\",\n            drop_first=drop_first,\n            dtype=float,  # ensures numeric output\n        )\n        df = df.drop(columns=present).join(encoded)\n        log.info(\n            \"  One-hot encoded %d categorical column(s), produced %d features.\",\n            len(present), encoded.shape[1],\n        )\n    elif encoding == \"dummy\":\n        # Same as onehot but with drop_first=True by convention\n        encoded = pd.get_dummies(\n            df[present],\n            prefix_sep=\"_\",\n            drop_first=True,\n            dtype=float,\n        )\n        df = df.drop(columns=present).join(encoded)\n        log.info(\n            \"  Dummy-encoded %d categorical column(s), produced %d features.\",\n            len(present), encoded.shape[1],\n        )\n    else:\n        log.warning(\"Unknown encoding '%s'; skip encoding.\", encoding)\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Column filtering\n# ---------------------------------------------------------------------------\n\ndef _filter_columns(df: pd.DataFrame, config: PipelineConfig) -> pd.DataFrame:\n    \"\"\"Apply keep/drop column filters.\"\"\"\n    if config.drop_cols:\n        existing = [c for c in config.drop_cols if c in df.columns]\n        if existing:\n            df = df.drop(columns=existing)\n            log.info(\"  Dropped %d user-specified column(s).\", len(existing))\n\n    if config.keep_cols is not None:\n        # Keep only those that exist\n        keep = [c for c in config.keep_cols if c in df.columns]\n        df = df[keep]\n        log.info(\"  Kept %d / %d user-specified column(s).\", len(keep), len(config.keep_cols))\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Single CSV loading & cleaning\n# ---------------------------------------------------------------------------\n\ndef load_and_clean_csv(\n    path: Union[str, Path],\n    config: PipelineConfig,\n    file_index: int,\n) -> pd.DataFrame:\n    \"\"\"Load a single CSV, clean, and return a processed DataFrame.\"\"\"\n    path = Path(path)\n    log.info(\"[%d] Loading %s\", file_index, path)\n\n    df = pd.read_csv(path, index_col=config.index_col)\n    log.info(\"  Shape: %d rows × %d columns\", *df.shape)\n\n    # ---- 1. Column filtering (before inference) ----\n    df = _filter_columns(df, config)\n\n    # ---- 2. Infer types ----\n    cat_cols, num_cols = _infer_column_types(df, config.categorical_cols, config.numerical_cols)\n\n    if config.verbose:\n        log.info(\"  Detected: %d categorical, %d numerical\", len(cat_cols), len(num_cols))\n\n    # ---- 3. Handle missing values ----\n    df = _handle_missing_values(df, cat_cols, num_cols, config)\n\n    # ---- 4. Scale numerical ----\n    df, _ = _scale_numerical(df, num_cols, config.scaler_type)\n\n    # ---- 5. Encode categorical ----\n    df = _encode_categorical(df, cat_cols, config.categorical_encoding, config.drop_first)\n\n    log.info(\"  Output shape: %d rows × %d columns\", *df.shape)\n    return df\n\n\n# ---------------------------------------------------------------------------\n# Master merge\n# ---------------------------------------------------------------------------\n\ndef merge_dataframes(\n    dfs: List[pd.DataFrame],\n    how: str = \"outer\",\n) -> pd.DataFrame:\n    \"\"\"Merge all cleaned DataFrames into a single feature matrix.\n\n    ``how``:\n      - \"outer\" → union of all columns & rows (align by index). Missing cells\n        become NaN.\n      - \"inner\" → intersection of columns, keeping all rows.\n      - \"concat\" → vertical concatenation (requires matching columns).\n    \"\"\"\n    if len(dfs) == 0:\n        return pd.DataFrame()\n    if len(dfs) == 1:\n        return dfs[0]\n\n    if how == \"concat\":\n        merged = pd.concat(dfs, ignore_index=False)\n        log.info(\"Merged %d DataFrames via concat → %s\", len(dfs), str(merged.shape))\n    else:\n        # Align on index with outer/inner join\n        merged = dfs[0]\n        for i, other in enumerate(dfs[1:], start=2):\n            merged = pd.merge(\n                merged, other,\n                left_index=True, right_index=True,\n                how=how,\n                suffixes=(\"\", f\"_dup{i}\"),\n            )\n        log.info(\"Merged %d DataFrames via '%s' join → %s\", len(dfs), how, str(merged.shape))\n\n    return merged\n\n\n# ---------------------------------------------------------------------------\n# Entry point\n# ---------------------------------------------------------------------------\n\ndef run_pipeline(config: PipelineConfig) -> pd.DataFrame:\n    \"\"\"Execute the full pipeline and return the merged feature matrix.\n\n    Parameters\n    ----------\n    config : PipelineConfig\n        Pipeline configuration object.\n\n    Returns\n    -------\n    pd.DataFrame\n        Cleaned, merged feature matrix.\n    \"\"\"\n    if not config.csv_paths:\n        log.error(\"No CSV paths provided in config.csv_paths — nothing to do.\")\n        return pd.DataFrame()\n\n    log.info(\"=\" * 56)\n    log.info(\"Data Preprocessing Pipeline\")\n    log.info(\"=\" * 56)\n    log.info(\"Input files: %d\", len(config.csv_paths))\n    for p in config.csv_paths:\n        log.info(\"  • %s\", p)\n\n    # ---- Load & clean each CSV ----\n    cleaned_dfs: List[pd.DataFrame] = []\n    for i, path in enumerate(config.csv_paths):\n        df = load_and_clean_csv(path, config, file_index=i + 1)\n        cleaned_dfs.append(df)\n\n    # ---- Merge ----\n    merged = merge_dataframes(cleaned_dfs)\n\n    # ---- Post-merge NA drop (arise from outer join alignment) ----\n    if merged.isna().any().any():\n        before = len(merged)\n        merged.dropna(inplace=True)\n        dropped = before - len(merged)\n        if dropped:\n            log.info(\n                \"Dropped %d row(s) with NA from the merged matrix \"\n                \"(introduced by outer-join alignment).\",\n                dropped,\n            )\n\n    log.info(\"─\" * 56)\n    log.info(\"Final feature matrix: %d rows × %d columns\", *merged.shape)\n    log.info(\"Feature names: %s\", list(merged.columns))\n\n    # ---- Save ----\n    if config.output_path:\n        out = Path(config.output_path)\n        out.parent.mkdir(parents=True, exist_ok=True)\n        merged.to_csv(out, index=config.index_col is not None)\n        log.info(\"Saved to: %s\", out.resolve())\n\n    return merged\n\n\n# ---------------------------------------------------------------------------\n# CLI\n# ---------------------------------------------------------------------------\n\ndef main():\n    parser = argparse.ArgumentParser(\n        description=\"Multi-CSV data preprocessing pipeline.\",\n    )\n    parser.add_argument(\n        \"csv_paths\",\n        nargs=\"*\",\n        help=\"One or more CSV file paths (can also be set in config).\",\n    )\n    parser.add_argument(\n        \"--index-col\",\n        default=None,\n        help=\"Column name to use as row index.\",\n    )\n    parser.add_argument(\n        \"--numeric-na\",\n        default=\"mean\",\n        choices=[\"drop\", \"mean\", \"median\", \"constant\"],\n        help=\"Missing-value strategy for numerical columns.\",\n    )\n    parser.add_argument(\n        \"--categorical-na\",\n        default=\"mode\",\n        choices=[\"drop\", \"mode\", \"constant\"],\n        help=\"Missing-value strategy for categorical columns.\",\n    )\n    parser.add_argument(\n        \"--scaler\",\n        default=\"standard\",\n        choices=[\"standard\", \"minmax\", \"robust\", \"none\"],\n        help=\"Numerical scaler type.\",\n    )\n    parser.add_argument(\n        \"--encoding\",\n        default=\"onehot\",\n        choices=[\"onehot\", \"dummy\", \"none\"],\n        help=\"Categorical encoding method.\",\n    )\n    parser.add_argument(\n        \"--drop-first\",\n        action=\"store_true\",\n        help=\"Drop the first level of each one-hot encoded variable.\",\n    )\n    parser.add_argument(\n        \"--output\",\n        default=\"feature_matrix.csv\",\n        help=\"Output CSV path.\",\n    )\n    parser.add_argument(\n        \"--keep-cols\",\n        nargs=\"*\",\n        help=\"Only keep these columns (applied before processing).\",\n    )\n    parser.add_argument(\n        \"--drop-cols\",\n        nargs=\"*\",\n        help=\"Drop these columns (applied before processing).\",\n    )\n    parser.add_argument(\n        \"--quiet\",\n        action=\"store_true\",\n        help=\"Reduce logging verbosity.\",\n    )\n\n    args = parser.parse_args()\n\n    if args.quiet:\n        log.setLevel(logging.WARNING)\n\n    # Build config\n    config = PipelineConfig()\n    config.csv_paths = args.csv_paths or [\n        \"data/sample_1.csv\",\n        \"data/sample_2.csv\",\n    ]\n    config.index_col = args.index_col\n    config.numeric_na_strategy = args.numeric_na if args.numeric_na != \"none\" else None  # type: ignore\n    config.categorical_na_strategy = args.categorical_na\n    config.scaler_type = args.scaler if args.scaler != \"none\" else None\n    config.categorical_encoding = args.encoding if args.encoding != \"none\" else None\n    config.drop_first = args.drop_first\n    config.output_path = args.output\n    config.keep_cols = args.keep_cols\n    config.drop_cols = args.drop_cols or []\n\n    run_pipeline(config)\n\n\nif __name__ == \"__main__\":\n    main()\n"})
