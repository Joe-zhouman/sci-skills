TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/clinical_trial_flowchart.py", "content": "#!/usr/bin/env python3\n\"\"\"\nClinical Trial Flowchart — NEJM CONSORT-style diagram\nClean, publication-quality figure for the Methods section.\n\"\"\"\n\nimport matplotlib\nmatplotlib.use(\"Agg\")\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.path import Path\nimport numpy as np\n\n# ── Style ────────────────────────────────────────────────────────────\n# NEJM uses clean sans-serif; fallback through common options\nplt.rcParams.update({\n    \"font.family\": \"sans-serif\",\n    \"font.sans-serif\": [\"Helvetica\", \"Arial\", \"DejaVu Sans\", \"Tahoma\"],\n    \"font.size\": 9,\n    \"axes.linewidth\": 0.5,\n})\n\nFIG_W, FIG_H = 7.5, 9.5   # inches — fits a half-page / column-width figure\nDPI = 350\n\nBOX_W, BOX_H = 0.48, 0.18   # normalized figure coordinates\nARROW_LEN = 0.09\n\n# ── Colour palette (greyscale + one accent for NEJM) ──────────────\nC_FILL    = \"#f5f5f5\"   # very light grey fill\nC_EDGE    = \"#222222\"   # near-black line\nC_BOLD    = \"#1a1a1a\"   # darker for emphasis boxes\nC_ACCENT  = \"#2c3e50\"   # muted navy for header boxes\nC_WHITE   = \"#ffffff\"\n\n# ── Helper functions ────────────────────────────────────────────────\n\ndef draw_box(ax, cx, cy, w=BOX_W, h=BOX_H, text=\"\", color=C_FILL,\n             edge=C_EDGE, lw=1.5, fontsize=8.5, bold=False, lines=None,\n             head_col=None):\n    \"\"\"\n    Draw a rounded rectangle centred at (cx, cy) with optional multi-line text.\n    `lines`: list of strings overrides `text` for vertical stacking.\n    \"\"\"\n    rect = mpatches.FancyBboxPatch(\n        (cx - w / 2, cy - h / 2), w, h,\n        boxstyle=\"round,pad=0.04\",\n        facecolor=color, edgecolor=edge, linewidth=lw,\n        zorder=3,\n    )\n    ax.add_patch(rect)\n\n    # Determine text lines\n    if lines is None:\n        lines = [text]\n    n = len(lines)\n\n    # Baseline for first line so block is vertically centred\n    total_h = n * 0.032\n    start_y = cy + total_h / 2 - 0.018\n\n    for i, line in enumerate(lines):\n        ax.text(\n            cx, start_y - i * 0.032, line,\n            ha=\"center\", va=\"top\",\n            fontsize=fontsize, color=C_BOLD,\n            fontweight=\"bold\" if bold else \"normal\",\n            zorder=4,\n        )\n\n\ndef draw_arrow(ax, x1, y1, x2, y2):\n    \"\"\"Shaft + triangle arrowhead.\"\"\"\n    dx, dy = x2 - x1, y2 - y1\n    d = np.hypot(dx, dy)\n    if d == 0:\n        return\n    # shorten shaft slightly from both ends\n    shrink = 0.025\n    s = shrink / d\n    ax.annotate(\n        \"\",\n        xy=(x2 - dx * s, y2 - dy * s),\n        xytext=(x1 + dx * s, y1 + dy * s),\n        arrowprops=dict(\n            arrowstyle=\"-|>\", color=C_EDGE, lw=0.9,\n            mutation_scale=10,\n        ),\n        zorder=2,\n    )\n\n\ndef draw_label(ax, x, y, text, fontsize=7.5, style=\"italic\"):\n    \"\"\"Small annotation beside an arrow or box.\"\"\"\n    ax.text(x, y, text, ha=\"center\", va=\"center\",\n            fontsize=fontsize, fontstyle=style, color=\"#555555\", zorder=5)\n\n\n# ── Build figure ────────────────────────────────────────────────────\nfig, ax = plt.subplots(figsize=(FIG_W, FIG_H))\nax.set_xlim(0, 1)\nax.set_ylim(0, 1)\nax.axis(\"off\")\n\n# Y levels (top → bottom)\nY0 = 0.94   # Title header\nY1 = 0.82   # Enrollment / Assessed\nY2 = 0.68   # Randomization\nY3 = 0.54   # Allocation (two arms)\nY4 = 0.40   # Treatment phase\nY5 = 0.26   # Follow-up\nY6 = 0.12   # Analysis\n\nCX = 0.50   # centre X\nW1 = 0.46   # box width for wide boxes\nW2 = 0.35   # narrower\n\n# ── 1. Title / Header band ──────────────────────────────────────────\ndraw_box(ax, CX, Y0, w=0.55, h=0.08,\n         text=\"Clinical Trial Flow Diagram\",\n         color=C_ACCENT, edge=C_ACCENT, fontsize=10, bold=True)\n# Underline accent\nax.plot([CX - 0.25, CX + 0.25], [Y0 - 0.045, Y0 - 0.045],\n        color=C_WHITE, lw=0.6, zorder=4)\n\n# ── 2. Enrollment ──────────────────────────────────────────────────\ndraw_box(ax, CX, Y1, w=W1, h=0.10,\n         lines=[\"Assessed for Eligibility\", \"(n = XXX screened)\"],\n         fontsize=9, color=C_FILL)\n\ndraw_arrow(ax, CX, Y1 - 0.10 / 2, CX, Y1 - 0.10 / 2 - ARROW_LEN)\n\n# Exclusion box (side)\nEXCL_X = 0.82\ndraw_box(ax, EXCL_X, Y1 - 0.04, w=0.28, h=0.08,\n         lines=[\"Excluded (n = XX)\", \"  • Not meeting criteria\", \"  • Declined to participate\"],\n         fontsize=6.5, color=\"#fafafa\", edge=\"#999999\", lw=1.0)\nax.plot([CX + W1 / 2, EXCL_X - 0.14], [Y1 - 0.04, Y1 - 0.04],\n        color=\"#999999\", lw=0.8, zorder=2)\n\n# ── 3. Randomisation ────────────────────────────────────────────────\ndraw_arrow(ax, CX, Y1 - 0.10 / 2 - ARROW_LEN, CX, Y1 - 0.10 / 2 - ARROW_LEN - 0.04)\ndraw_box(ax, CX, Y2, w=W1 * 0.65, h=0.08,\n         text=\"Randomization (n = XXX)\",\n         fontsize=9, color=C_FILL, bold=True)\n\ndraw_arrow(ax, CX, Y2 - 0.08 / 2, CX, Y2 - 0.08 / 2 - ARROW_LEN)\n\n# ── 4. Allocation – Two arms ────────────────────────────────────────\nARM_Y = Y3\ndraw_box(ax, 0.33, ARM_Y, w=W2, h=0.09,\n         lines=[\"Treatment Group A\", \"(n = XX)\", \"Intervention + SOC\"],\n         fontsize=7.5, color=C_FILL, bold=False)\n\ndraw_box(ax, 0.67, ARM_Y, w=W2, h=0.09,\n         lines=[\"Control Group B\", \"(n = XX)\", \"Standard of Care (SOC)\"],\n         fontsize=7.5, color=C_FILL)\n\n# Arrows from randomisation to arms\ndraw_arrow(ax, CX - 0.04, Y2 - 0.08 / 2 - ARROW_LEN / 2, 0.33, ARM_Y + 0.09 / 2 + 0.01)\ndraw_arrow(ax, CX + 0.04, Y2 - 0.08 / 2 - ARROW_LEN / 2, 0.67, ARM_Y + 0.09 / 2 + 0.01)\n\n# ── 5. Treatment Phase ──────────────────────────────────────────────\ndraw_arrow(ax, 0.33, ARM_Y - 0.09 / 2, 0.33, Y4 + 0.10 / 2)\ndraw_arrow(ax, 0.67, ARM_Y - 0.09 / 2, 0.67, Y4 + 0.10 / 2)\n\ndraw_box(ax, 0.33, Y4, w=W2, h=0.10,\n         lines=[\"Treatment Period\", \"(Week 0 – Week XX)\", \"Dosing, monitoring, AE tracking\"],\n         fontsize=7, color=C_FILL)\n\ndraw_box(ax, 0.67, Y4, w=W2, h=0.10,\n         lines=[\"Treatment Period\", \"(Week 0 – Week XX)\", \"Standard monitoring\"],\n         fontsize=7, color=C_FILL)\n\n# ── 6. Follow-up Visits ─────────────────────────────────────────────\ndraw_arrow(ax, 0.33, Y4 - 0.10 / 2, 0.33, Y5 + 0.08 / 2)\ndraw_arrow(ax, 0.67, Y4 - 0.10 / 2, 0.67, Y5 + 0.08 / 2)\n\n# Combined Follow-up box spanning both arms\nFU_W = 0.52\ndraw_box(ax, CX, Y5, w=FU_W, h=0.08,\n         lines=[\"Follow-Up Visits\", \"Month 3 · Month 6 · Month 12\"],\n         fontsize=8, color=C_FILL, bold=False)\n\n# Vertical connectors from each arm into the combined box\nax.plot([0.33, 0.33], [Y4 - 0.10 / 2, Y5 + 0.08 / 2], color=C_EDGE, lw=1.2, zorder=2)\nax.plot([0.67, 0.67], [Y4 - 0.10 / 2, Y5 + 0.08 / 2], color=C_EDGE, lw=1.2, zorder=2)\nax.plot([0.33, 0.67], [Y4 - 0.10 / 2, Y4 - 0.10 / 2], color=C_EDGE, lw=1.2, zorder=2)\n\n# Arrow from combined into FU box\ndraw_arrow(ax, CX, Y5 + 0.08 / 2 + 0.015, CX, Y5 + 0.08 / 2)\n\n# ── 7. Lost to follow-up (side label) ───────────────────────────────\ndraw_label(ax, 0.15, Y5,\n           \"Lost to follow-up / Discontinued\\n(n = XX each arm)  →\",\n           fontsize=6.5)\n\n# ── 8. Final Analysis ───────────────────────────────────────────────\ndraw_arrow(ax, CX, Y5 - 0.08 / 2, CX, Y6 + 0.10 / 2)\n\ndraw_box(ax, CX, Y6, w=W1 * 0.85, h=0.10,\n         lines=[\"Final Analysis\", \"Intention-to-Treat (ITT) · Per-Protocol (PP)\",\n                 \"↳ Primary endpoint · Key secondary endpoints\"],\n         fontsize=7.5, color=C_FILL, bold=False)\n\n# Underline accent for the title within the final box\nax.plot([CX - 0.15, CX + 0.15], [Y6 + 0.036, Y6 + 0.036],\n        color=C_ACCENT, lw=0.8, zorder=4)\n\n# ── Figure legend / footer ──────────────────────────────────────────\nax.text(CX, 0.02,\n        \"Figure 1. Clinical Trial Flow Diagram.\\n\"\n        \"Patients were screened, randomized in a 1:1 ratio, and followed per protocol.\",\n        ha=\"center\", va=\"bottom\", fontsize=7.5, color=\"#444444\",\n        transform=ax.transData)\n\n# ── Save ────────────────────────────────────────────────────────────\nOUT = \"clinical_trial_flowchart.png\"\nfig.savefig(OUT, dpi=DPI, bbox_inches=\"tight\", pad_inches=0.15,\n            facecolor=C_WHITE)\nplt.close(fig)\nprint(f\"✓ Saved → {OUT}  ({FIG_W}×{FIG_H}″ @ {DPI} dpi)\")\n"})
