TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_clean_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\n数据预处理 Pipeline：读取多个 CSV → 数据清洗 → 合并特征矩阵\n\n功能：\n  1. 读取多个 CSV 文件（glob 模式或列表）\n  2. 缺失值处理（删除 / 均值 / 中位数 / 众数 / 前向填充 / 常量填充）\n  3. 数值列标准化（Z‑score / Min‑Max）\n  4. 分类变量 One‑Hot 编码（自动识别 object / category 列）\n  5. 合并所有 CSV 为一个大特征矩阵，输出为单个 CSV 或 NumPy 矩阵\n\n用法示例：\n  python data_clean_pipeline.py --input data/*.csv --output cleaned_matrix.csv \\\\\n      --na_strategy mean --scale zscore --onehot\n\"\"\"\n\nimport argparse\nimport sys\nfrom pathlib import Path\nfrom typing import Dict, List, Literal, Optional, Union\n\nimport numpy as np\nimport pandas as pd\n\n# ---------------------------------------------------------------------------\n# 1. 读取模块\n# ---------------------------------------------------------------------------\n\ndef read_csv_files(\n    sources: List[Union[str, Path]],\n    sep: str = \",\",\n    encoding: str = \"utf-8\",\n    **kwargs,\n) -> Dict[str, pd.DataFrame]:\n    \"\"\"读取多个 CSV 文件，返回 {文件名: DataFrame} 字典。\n\n    Parameters\n    ----------\n    sources : 文件路径列表，支持 glob 通配符字符串\n    sep, encoding : 传给 pd.read_csv\n    **kwargs : 其他传给 pd.read_csv 的参数（如 header, index_col）\n\n    Returns\n    -------\n    { 文件名(不含后缀): DataFrame }\n    \"\"\"\n    # 展开 glob\n    expanded: List[Path] = []\n    for s in sources:\n        p = Path(s)\n        if \"*\" in s or \"?\" in s:\n            expanded.extend(sorted(p.parent.glob(p.name)))\n        elif p.exists():\n            expanded.append(p)\n        else:\n            print(f\"[WARN] 文件不存在，跳过: {s}\", file=sys.stderr)\n\n    if not expanded:\n        raise FileNotFoundError(\"没有找到任何 CSV 文件，请检查 --input 路径。\")\n\n    dataframes: Dict[str, pd.DataFrame] = {}\n    for fp in expanded:\n        try:\n            df = pd.read_csv(fp, sep=sep, encoding=encoding, **kwargs)\n            key = fp.stem  # 不含后缀的文件名\n            dataframes[key] = df\n            print(f\"  ✓ {fp.name}  →  {df.shape}\")\n        except Exception as e:\n            print(f\"  ✗ {fp.name} 读取失败: {e}\", file=sys.stderr)\n\n    return dataframes\n\n\n# ---------------------------------------------------------------------------\n# 2. 缺失值处理\n# ---------------------------------------------------------------------------\n\n# 支持的填充策略\nNaStrategy = Literal[\"drop\", \"mean\", \"median\", \"mode\", \"ffill\", \"bfill\", \"zero\", \"constant\"]\n\n\ndef handle_missing_values(\n    df: pd.DataFrame,\n    strategy: NaStrategy = \"drop\",\n    fill_value: Optional[Union[float, int, str]] = None,\n    na_cols: Optional[List[str]] = None,\n    thresh: Optional[int] = None,\n) -> pd.DataFrame:\n    \"\"\"处理 DataFrame 中的缺失值。\n\n    Parameters\n    ----------\n    df : 原始 DataFrame\n    strategy :\n        - \"drop\"      : 删除含缺失值的行\n        - \"mean\"      : 数值列用均值填充\n        - \"median\"    : 数值列用中位数填充\n        - \"mode\"      : 各列用众数填充\n        - \"ffill\"     : 前向填充\n        - \"bfill\"     : 后向填充\n        - \"zero\"      : 缺失值填 0\n        - \"constant\"  : 使用 fill_value 参数填充\n    fill_value : strategy=\"constant\" 时使用的填充值\n    na_cols : 指定要处理的列；None 表示所有列\n    thresh : strategy=\"drop\" 时，每行非 NA 值少于 thresh 才删除\n    \"\"\"\n    if df.empty:\n        return df\n\n    cols = na_cols if na_cols is not None else df.columns.tolist()\n    existing_cols = [c for c in cols if c in df.columns]\n    if not existing_cols:\n        return df\n\n    sub = df[existing_cols]\n\n    if strategy == \"drop\":\n        kwargs = {}\n        if thresh is not None:\n            kwargs[\"thresh\"] = thresh\n        df = df.dropna(subset=existing_cols, **kwargs)\n\n    elif strategy == \"mean\":\n        numeric_cols = sub.select_dtypes(include=[np.number]).columns.tolist()\n        for c in numeric_cols:\n            df[c] = df[c].fillna(df[c].mean())\n\n    elif strategy == \"median\":\n        numeric_cols = sub.select_dtypes(include=[np.number]).columns.tolist()\n        for c in numeric_cols:\n            df[c] = df[c].fillna(df[c].median())\n\n    elif strategy == \"mode\":\n        for c in existing_cols:\n            mode_vals = df[c].mode(dropna=True)\n            if not mode_vals.empty:\n                df[c] = df[c].fillna(mode_vals[0])\n\n    elif strategy == \"ffill\":\n        df[existing_cols] = df[existing_cols].ffill()\n\n    elif strategy == \"bfill\":\n        df[existing_cols] = df[existing_cols].bfill()\n\n    elif strategy == \"zero\":\n        df[existing_cols] = df[existing_cols].fillna(0)\n\n    elif strategy == \"constant\":\n        if fill_value is None:\n            raise ValueError(\"strategy='constant' 时需提供 fill_value\")\n        df[existing_cols] = df[existing_cols].fillna(fill_value)\n\n    else:\n        raise ValueError(f\"不支持的缺失值策略: {strategy}\")\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# 3. 数值列标准化\n# ---------------------------------------------------------------------------\n\nScaleMethod = Literal[\"zscore\", \"minmax\", \"maxabs\", \"robust\", \"none\"]\n\n\ndef scale_numeric(\n    df: pd.DataFrame,\n    method: ScaleMethod = \"zscore\",\n    scale_cols: Optional[List[str]] = None,\n    copy: bool = True,\n) -> pd.DataFrame:\n    \"\"\"标准化数值列。\n\n    Parameters\n    ----------\n    df : 输入 DataFrame\n    method :\n        - \"zscore\" : (x - μ) / σ\n        - \"minmax\" : (x - min) / (max - min)，缩放到 [0, 1]\n        - \"maxabs\" : x / max(|x|)，缩放到 [-1, 1]\n        - \"robust\" : (x - median) / IQR，对异常值更鲁棒\n        - \"none\"   : 不做处理\n    scale_cols : 指定要标准化的列；None 表示自动检测数值列\n    copy : 是否返回副本\n    \"\"\"\n    if method == \"none\":\n        return df.copy() if copy else df\n\n    result = df.copy() if copy else df\n\n    if scale_cols is None:\n        scale_cols = result.select_dtypes(include=[np.number]).columns.tolist()\n    else:\n        scale_cols = [c for c in scale_cols if c in result.columns]\n\n    for c in scale_cols:\n        col = result[c]\n        if col.nunique() <= 1:\n            # 常数列标准化无意义，直接填 0\n            result[c] = 0.0\n            continue\n\n        if method == \"zscore\":\n            mean, std = col.mean(), col.std(ddof=0)\n            result[c] = (col - mean) / std if std > 0 else 0.0\n\n        elif method == \"minmax\":\n            mn, mx = col.min(), col.max()\n            result[c] = (col - mn) / (mx - mn) if mx > mn else 0.0\n\n        elif method == \"maxabs\":\n            max_abs = col.abs().max()\n            result[c] = col / max_abs if max_abs > 0 else 0.0\n\n        elif method == \"robust\":\n            med, q1, q3 = col.median(), col.quantile(0.25), col.quantile(0.75)\n            iqr = q3 - q1\n            result[c] = (col - med) / iqr if iqr > 0 else 0.0\n\n        else:\n            raise ValueError(f\"不支持的标准化方法: {method}\")\n\n    return result\n\n\n# ---------------------------------------------------------------------------\n# 4. One‑Hot 编码\n# ---------------------------------------------------------------------------\n\ndef onehot_encode(\n    df: pd.DataFrame,\n    cat_cols: Optional[List[str]] = None,\n    drop_first: bool = False,\n    max_categories: Optional[int] = None,\n    dtype: type = float,\n) -> pd.DataFrame:\n    \"\"\"对分类变量进行 One‑Hot 编码。\n\n    Parameters\n    ----------\n    df : 输入 DataFrame\n    cat_cols :\n        - None : 自动选择 object / category 数据类型的列\n        - List : 指定列名\n    drop_first : 是否删除第一类（避免多重共线性）\n    max_categories : 类别数超过此值的列不做编码（避免维度爆炸）\n    dtype : 编码列的数据类型（默认 float，兼容 sklearn）\n    \"\"\"\n    result = df.copy()\n\n    if cat_cols is None:\n        cat_cols = result.select_dtypes(include=[\"object\", \"category\"]).columns.tolist()\n    else:\n        cat_cols = [c for c in cat_cols if c in result.columns]\n\n    if not cat_cols:\n        return result\n\n    skipped = []\n    to_encode = []\n    for c in cat_cols:\n        n_unique = result[c].nunique(dropna=True)\n        if max_categories is not None and n_unique > max_categories:\n            skipped.append(c)\n            continue\n        to_encode.append(c)\n\n    if skipped:\n        print(f\"  [INFO] 跳过列（类别数 > {max_categories}）: {skipped}\")\n\n    if not to_encode:\n        return result\n\n    # handle_nan 参数在旧版 pandas 不支持，用更兼容的方式处理缺失值\n    # 将 NaN 转为字符串占位符，保证 one-hot 不丢缺失信息\n    for c in to_encode:\n        if result[c].isna().any():\n            result[c] = result[c].fillna(\"__MISSING__\")\n\n    encoded = pd.get_dummies(\n        result[to_encode],\n        prefix=to_encode,\n        drop_first=drop_first,\n        dtype=dtype,\n    )\n\n    # 删除原始分类列，合并编码列\n    result = result.drop(columns=to_encode)\n    result = pd.concat([result, encoded], axis=1)\n\n    return result\n\n\n# ---------------------------------------------------------------------------\n# 5. 合并模块\n# ---------------------------------------------------------------------------\n\ndef merge_dataframes(\n    dfs: Dict[str, pd.DataFrame],\n    merge_key: Optional[str] = None,\n    how: str = \"outer\",\n) -> pd.DataFrame:\n    \"\"\"将多个 DataFrame 合并为一个特征矩阵。\n\n    Parameters\n    ----------\n    dfs : {name: DataFrame} 字典\n    merge_key :\n        - None       : 按行堆叠（假设列结构相同 / 不同则自动对齐）\n        - str / list : 按此列进行 SQL 式合并（适用于有关键列的异构表）\n    how : merge 方式: \"outer\" / \"inner\" / \"left\" / \"right\" / \"concat\"\n    \"\"\"\n    if not dfs:\n        raise ValueError(\"没有可合并的 DataFrame\")\n\n    names = list(dfs.keys())\n\n    if how == \"concat\" or merge_key is None:\n        # 行堆叠模式：列对齐，缺失列自动补 NaN\n        print(f\"  按行合并 {len(dfs)} 个文件…\")\n        combined = pd.concat(\n            [dfs[n] for n in names],\n            axis=0,\n            ignore_index=True,\n            join=\"outer\",\n            sort=False,\n        )\n        return combined\n\n    # SQL 式合并\n    print(f\"  按列 '{merge_key}' 合并 {len(dfs)} 个文件…\")\n    merged = dfs[names[0]]\n    for name in names[1:]:\n        merged = merged.merge(dfs[name], on=merge_key, how=how, suffixes=(\"\", f\"_{name}\"))\n\n    return merged\n\n\n# ---------------------------------------------------------------------------\n# 6. 完整 Pipeline\n# ---------------------------------------------------------------------------\n\ndef run_pipeline(\n    sources: List[Union[str, Path]],\n    output: Optional[Union[str, Path]] = None,\n    na_strategy: NaStrategy = \"drop\",\n    na_fill_value: Optional[Union[float, int, str]] = None,\n    scale_method: ScaleMethod = \"zscore\",\n    onehot: bool = False,\n    drop_first: bool = False,\n    max_categories: Optional[int] = None,\n    merge_key: Optional[str] = None,\n    merge_how: str = \"outer\",\n    csv_sep: str = \",\",\n    csv_encoding: str = \"utf-8\",\n    verbose: bool = True,\n    **csv_kwargs,\n) -> pd.DataFrame:\n    \"\"\"完整数据预处理 Pipeline。\n\n    Parameters\n    ----------\n    sources : CSV 文件路径列表（支持 glob 通配符）\n    output  : 输出 CSV 路径；None 则不保存\n    na_strategy, na_fill_value : 缺失值策略\n    scale_method : 标准化方法\n    onehot : 是否进行 One‑Hot 编码\n    drop_first : One‑Hot 是否 drop first\n    max_categories : One‑Hot 最大类别数\n    merge_key, merge_how : 合并参数\n    csv_sep, csv_encoding, csv_kwargs : 传给 pd.read_csv\n    verbose : 是否打印进度信息\n    \"\"\"\n    if verbose:\n        print(\"=\" * 55)\n        print(\"  数据预处理 Pipeline\")\n        print(\"=\" * 55)\n\n    # 1. 读取\n    if verbose:\n        print(\"\\n[1/4] 读取 CSV 文件…\")\n    dfs = read_csv_files(sources, sep=csv_sep, encoding=csv_encoding, **csv_kwargs)\n    if not dfs:\n        raise RuntimeError(\"没有成功读取任何 CSV 文件。\")\n\n    # 2. 逐文件清洗\n    if verbose:\n        print(f\"\\n[2/4] 缺失值处理（{na_strategy}）…\")\n    cleaned: Dict[str, pd.DataFrame] = {}\n    for name, df in dfs.items():\n        if verbose:\n            pre_shape = df.shape\n        df = handle_missing_values(df, strategy=na_strategy, fill_value=na_fill_value)\n        if verbose and df.shape != pre_shape:\n            print(f\"    {name}: {pre_shape} → {df.shape}\")\n        cleaned[name] = df\n\n    # 3. 标准化（在合并前做，避免跨文件信息泄露）\n    if scale_method != \"none\":\n        if verbose:\n            print(f\"\\n[3/4] 数值标准化（{scale_method}）…\")\n        for name, df in cleaned.items():\n            cleaned[name] = scale_numeric(df, method=scale_method)\n\n    # 4. 合并\n    if verbose:\n        print(f\"\\n[4/4] 合并数据…\")\n    final = merge_dataframes(cleaned, merge_key=merge_key, how=merge_how)\n\n    if verbose:\n        print(f\"\\n  合并后形状: {final.shape}\")\n\n    # 5. One‑Hot 编码（合并后统一做）\n    if onehot:\n        if verbose:\n            print(f\"\\n  执行 One‑Hot 编码…\")\n        final = onehot_encode(final, drop_first=drop_first, max_categories=max_categories)\n        if verbose:\n            print(f\"  One‑Hot 后形状: {final.shape}\")\n\n    # 6. 保存\n    if output:\n        final.to_csv(output, index=False)\n        if verbose:\n            print(f\"\\n  ✓ 已保存: {output}\")\n\n    if verbose:\n        print(\"=\" * 55)\n        print(\"  Pipeline 完成\")\n        print(\"=\" * 55)\n\n    return final\n\n\n# ---------------------------------------------------------------------------\n# 7. CLI 入口\n# ---------------------------------------------------------------------------\n\ndef parse_args(argv: Optional[List[str]] = None) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(\n        description=\"数据预处理 Pipeline：读取多个 CSV → 清洗 → 合并 → 特征矩阵\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=\"\"\"\n示例:\n  # 基本用法：读取所有 CSV，删除缺失行，Z‑score 标准化\n  python data_clean_pipeline.py -i \"data/*.csv\" -o cleaned.csv\n\n  # 均值填充缺失值 + Min‑Max 标准化 + One‑Hot 编码\n  python data_clean_pipeline.py -i \"data/train.csv\" \"data/test.csv\" \\\\\n      -o train_test.csv --na_strategy mean --scale minmax --onehot\n\n  # 按 ID 列合并多个异构表\n  python data_clean_pipeline.py -i \"tables/*.csv\" -o merged.csv \\\\\n      --na_strategy ffill --scale robust --merge_key sample_id --merge_how outer\n\n  # 保留原始 CSV 的 index 列\n  python data_clean_pipeline.py -i \"data/*.csv\" -o out.csv --index_col 0\n        \"\"\",\n    )\n\n    parser.add_argument(\n        \"-i\", \"--input\", nargs=\"+\", required=True,\n        help=\"CSV 文件路径（支持 glob，如 'data/*.csv'）\",\n    )\n    parser.add_argument(\n        \"-o\", \"--output\", default=None,\n        help=\"输出 CSV 路径（不指定则不保存）\",\n    )\n    parser.add_argument(\n        \"--na_strategy\",\n        choices=[\"drop\", \"mean\", \"median\", \"mode\", \"ffill\", \"bfill\", \"zero\", \"constant\"],\n        default=\"drop\",\n        help=\"缺失值处理策略 (default: drop)\",\n    )\n    parser.add_argument(\n        \"--na_fill_value\",\n        default=None,\n        help=\"constant 策略时的填充值\",\n    )\n    parser.add_argument(\n        \"--scale\",\n        choices=[\"zscore\", \"minmax\", \"maxabs\", \"robust\", \"none\"],\n        default=\"zscore\",\n        help=\"数值列标准化方法 (default: zscore)\",\n    )\n    parser.add_argument(\n        \"--onehot\", action=\"store_true\",\n        help=\"对分类变量进行 One‑Hot 编码\",\n    )\n    parser.add_argument(\n        \"--drop_first\", action=\"store_true\",\n        help=\"One‑Hot 时删除第一类（避免多重共线性）\",\n    )\n    parser.add_argument(\n        \"--max_categories\", type=int, default=None,\n        help=\"One‑Hot 最大类别数，超过此值则跳过该列\",\n    )\n    parser.add_argument(\n        \"--merge_key\", default=None,\n        help=\"按此列进行 SQL 式合并（不指定则行堆叠）\",\n    )\n    parser.add_argument(\n        \"--merge_how\",\n        choices=[\"outer\", \"inner\", \"left\", \"right\", \"concat\"],\n        default=\"concat\",\n        help=\"合并方式 (default: concat)\",\n    )\n    parser.add_argument(\n        \"--sep\", default=\",\",\n        help=\"CSV 分隔符 (default: ',')\",\n    )\n    parser.add_argument(\n        \"--encoding\", default=\"utf-8\",\n        help=\"CSV 编码 (default: utf-8)\",\n    )\n    # 透传给 pd.read_csv 的参数\n    parser.add_argument(\"--header\", type=int, default=\"infer\")\n    parser.add_argument(\"--index_col\", type=int, default=None)\n\n    return parser.parse_args(argv)\n\n\ndef main() -> None:\n    args = parse_args()\n\n    # 将 --na_fill_value 转为合适的类型\n    fill_val = args.na_fill_value\n    if fill_val is not None:\n        try:\n            fill_val = int(fill_val)\n        except ValueError:\n            try:\n                fill_val = float(fill_val)\n            except ValueError:\n                pass  # 保持字符串\n\n    csv_kwargs = {}\n    if args.header != \"infer\":\n        csv_kwargs[\"header\"] = args.header\n    if args.index_col is not None:\n        csv_kwargs[\"index_col\"] = args.index_col\n\n    run_pipeline(\n        sources=args.input,\n        output=args.output,\n        na_strategy=args.na_strategy,\n        na_fill_value=fill_val,\n        scale_method=args.scale,\n        onehot=args.onehot,\n        drop_first=args.drop_first,\n        max_categories=args.max_categories,\n        merge_key=args.merge_key,\n        merge_how=args.merge_how,\n        csv_sep=args.sep,\n        csv_encoding=args.encoding,\n        **csv_kwargs,\n    )\n\n\nif __name__ == \"__main__\":\n    main()\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_clean_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\n数据预处理 Pipeline：读取多个 CSV → 数据清洗 → 合并特征矩阵\n\n功能：\n  1. 读取多个 CSV 文件（glob 模式或列表）\n  2. 缺失值处理（删除 / 均值 / 中位数 / 众数 / 前向填充 / 常量填充）\n  3. 数值列标准化（Z‑score / Min‑Max）\n  4. 分类变量 One‑Hot 编码（自动识别 object / category 列）\n  5. 合并所有 CSV 为一个大特征矩阵，输出为单个 CSV 或 NumPy 矩阵\n\n用法示例：\n  python data_clean_pipeline.py --input data/*.csv --output cleaned_matrix.csv \\\\\n      --na_strategy mean --scale zscore --onehot\n\"\"\"\n\nimport argparse\nimport sys\nfrom pathlib import Path\nfrom typing import Dict, List, Literal, Optional, Union\n\nimport numpy as np\nimport pandas as pd\n\n# ---------------------------------------------------------------------------\n# 1. 读取模块\n# ---------------------------------------------------------------------------\n\ndef read_csv_files(\n    sources: List[Union[str, Path]],\n    sep: str = \",\",\n    encoding: str = \"utf-8\",\n    **kwargs,\n) -> Dict[str, pd.DataFrame]:\n    \"\"\"读取多个 CSV 文件，返回 {文件名: DataFrame} 字典。\n\n    Parameters\n    ----------\n    sources : 文件路径列表，支持 glob 通配符字符串\n    sep, encoding : 传给 pd.read_csv\n    **kwargs : 其他传给 pd.read_csv 的参数（如 header, index_col）\n\n    Returns\n    -------\n    { 文件名(不含后缀): DataFrame }\n    \"\"\"\n    # 展开 glob\n    expanded: List[Path] = []\n    for s in sources:\n        p = Path(s)\n        if \"*\" in s or \"?\" in s:\n            expanded.extend(sorted(p.parent.glob(p.name)))\n        elif p.exists():\n            expanded.append(p)\n        else:\n            print(f\"[WARN] 文件不存在，跳过: {s}\", file=sys.stderr)\n\n    if not expanded:\n        raise FileNotFoundError(\"没有找到任何 CSV 文件，请检查 --input 路径。\")\n\n    dataframes: Dict[str, pd.DataFrame] = {}\n    for fp in expanded:\n        try:\n            df = pd.read_csv(fp, sep=sep, encoding=encoding, **kwargs)\n            key = fp.stem  # 不含后缀的文件名\n            dataframes[key] = df\n            print(f\"  ✓ {fp.name}  →  {df.shape}\")\n        except Exception as e:\n            print(f\"  ✗ {fp.name} 读取失败: {e}\", file=sys.stderr)\n\n    return dataframes\n\n\n# ---------------------------------------------------------------------------\n# 2. 缺失值处理\n# ---------------------------------------------------------------------------\n\n# 支持的填充策略\nNaStrategy = Literal[\"drop\", \"mean\", \"median\", \"mode\", \"ffill\", \"bfill\", \"zero\", \"constant\"]\n\n\ndef handle_missing_values(\n    df: pd.DataFrame,\n    strategy: NaStrategy = \"drop\",\n    fill_value: Optional[Union[float, int, str]] = None,\n    na_cols: Optional[List[str]] = None,\n    thresh: Optional[int] = None,\n) -> pd.DataFrame:\n    \"\"\"处理 DataFrame 中的缺失值。\n\n    Parameters\n    ----------\n    df : 原始 DataFrame\n    strategy :\n        - \"drop\"      : 删除含缺失值的行\n        - \"mean\"      : 数值列用均值填充\n        - \"median\"    : 数值列用中位数填充\n        - \"mode\"      : 各列用众数填充\n        - \"ffill\"     : 前向填充\n        - \"bfill\"     : 后向填充\n        - \"zero\"      : 缺失值填 0\n        - \"constant\"  : 使用 fill_value 参数填充\n    fill_value : strategy=\"constant\" 时使用的填充值\n    na_cols : 指定要处理的列；None 表示所有列\n    thresh : strategy=\"drop\" 时，每行非 NA 值少于 thresh 才删除\n    \"\"\"\n    if df.empty:\n        return df\n\n    cols = na_cols if na_cols is not None else df.columns.tolist()\n    existing_cols = [c for c in cols if c in df.columns]\n    if not existing_cols:\n        return df\n\n    sub = df[existing_cols]\n\n    if strategy == \"drop\":\n        kwargs = {}\n        if thresh is not None:\n            kwargs[\"thresh\"] = thresh\n        df = df.dropna(subset=existing_cols, **kwargs)\n\n    elif strategy == \"mean\":\n        numeric_cols = sub.select_dtypes(include=[np.number]).columns.tolist()\n        for c in numeric_cols:\n            df[c] = df[c].fillna(df[c].mean())\n\n    elif strategy == \"median\":\n        numeric_cols = sub.select_dtypes(include=[np.number]).columns.tolist()\n        for c in numeric_cols:\n            df[c] = df[c].fillna(df[c].median())\n\n    elif strategy == \"mode\":\n        for c in existing_cols:\n            mode_vals = df[c].mode(dropna=True)\n            if not mode_vals.empty:\n                df[c] = df[c].fillna(mode_vals[0])\n\n    elif strategy == \"ffill\":\n        df[existing_cols] = df[existing_cols].ffill()\n\n    elif strategy == \"bfill\":\n        df[existing_cols] = df[existing_cols].bfill()\n\n    elif strategy == \"zero\":\n        df[existing_cols] = df[existing_cols].fillna(0)\n\n    elif strategy == \"constant\":\n        if fill_value is None:\n            raise ValueError(\"strategy='constant' 时需提供 fill_value\")\n        df[existing_cols] = df[existing_cols].fillna(fill_value)\n\n    else:\n        raise ValueError(f\"不支持的缺失值策略: {strategy}\")\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# 3. 数值列标准化\n# ---------------------------------------------------------------------------\n\nScaleMethod = Literal[\"zscore\", \"minmax\", \"maxabs\", \"robust\", \"none\"]\n\n\ndef scale_numeric(\n    df: pd.DataFrame,\n    method: ScaleMethod = \"zscore\",\n    scale_cols: Optional[List[str]] = None,\n    copy: bool = True,\n) -> pd.DataFrame:\n    \"\"\"标准化数值列。\n\n    Parameters\n    ----------\n    df : 输入 DataFrame\n    method :\n        - \"zscore\" : (x - μ) / σ\n        - \"minmax\" : (x - min) / (max - min)，缩放到 [0, 1]\n        - \"maxabs\" : x / max(|x|)，缩放到 [-1, 1]\n        - \"robust\" : (x - median) / IQR，对异常值更鲁棒\n        - \"none\"   : 不做处理\n    scale_cols : 指定要标准化的列；None 表示自动检测数值列\n    copy : 是否返回副本\n    \"\"\"\n    if method == \"none\":\n        return df.copy() if copy else df\n\n    result = df.copy() if copy else df\n\n    if scale_cols is None:\n        scale_cols = result.select_dtypes(include=[np.number]).columns.tolist()\n    else:\n        scale_cols = [c for c in scale_cols if c in result.columns]\n\n    for c in scale_cols:\n        col = result[c]\n        if col.nunique() <= 1:\n            # 常数列标准化无意义，直接填 0\n            result[c] = 0.0\n            continue\n\n        if method == \"zscore\":\n            mean, std = col.mean(), col.std(ddof=0)\n            result[c] = (col - mean) / std if std > 0 else 0.0\n\n        elif method == \"minmax\":\n            mn, mx = col.min(), col.max()\n            result[c] = (col - mn) / (mx - mn) if mx > mn else 0.0\n\n        elif method == \"maxabs\":\n            max_abs = col.abs().max()\n            result[c] = col / max_abs if max_abs > 0 else 0.0\n\n        elif method == \"robust\":\n            med, q1, q3 = col.median(), col.quantile(0.25), col.quantile(0.75)\n            iqr = q3 - q1\n            result[c] = (col - med) / iqr if iqr > 0 else 0.0\n\n        else:\n            raise ValueError(f\"不支持的标准化方法: {method}\")\n\n    return result\n\n\n# ---------------------------------------------------------------------------\n# 4. One‑Hot 编码\n# ---------------------------------------------------------------------------\n\ndef onehot_encode(\n    df: pd.DataFrame,\n    cat_cols: Optional[List[str]] = None,\n    drop_first: bool = False,\n    max_categories: Optional[int] = None,\n    dtype: type = float,\n) -> pd.DataFrame:\n    \"\"\"对分类变量进行 One‑Hot 编码。\n\n    Parameters\n    ----------\n    df : 输入 DataFrame\n    cat_cols :\n        - None : 自动选择 object / category 数据类型的列\n        - List : 指定列名\n    drop_first : 是否删除第一类（避免多重共线性）\n    max_categories : 类别数超过此值的列不做编码（避免维度爆炸）\n    dtype : 编码列的数据类型（默认 float，兼容 sklearn）\n    \"\"\"\n    result = df.copy()\n\n    if cat_cols is None:\n        cat_cols = result.select_dtypes(include=[\"object\", \"category\"]).columns.tolist()\n    else:\n        cat_cols = [c for c in cat_cols if c in result.columns]\n\n    if not cat_cols:\n        return result\n\n    skipped = []\n    to_encode = []\n    for c in cat_cols:\n        n_unique = result[c].nunique(dropna=True)\n        if max_categories is not None and n_unique > max_categories:\n            skipped.append(c)\n            continue\n        to_encode.append(c)\n\n    if skipped:\n        print(f\"  [INFO] 跳过列（类别数 > {max_categories}）: {skipped}\")\n\n    if not to_encode:\n        return result\n\n    # handle_nan 参数在旧版 pandas 不支持，用更兼容的方式处理缺失值\n    # 将 NaN 转为字符串占位符，保证 one-hot 不丢缺失信息\n    for c in to_encode:\n        if result[c].isna().any():\n            result[c] = result[c].fillna(\"__MISSING__\")\n\n    encoded = pd.get_dummies(\n        result[to_encode],\n        prefix=to_encode,\n        drop_first=drop_first,\n        dtype=dtype,\n    )\n\n    # 删除原始分类列，合并编码列\n    result = result.drop(columns=to_encode)\n    result = pd.concat([result, encoded], axis=1)\n\n    return result\n\n\n# ---------------------------------------------------------------------------\n# 5. 合并模块\n# ---------------------------------------------------------------------------\n\ndef merge_dataframes(\n    dfs: Dict[str, pd.DataFrame],\n    merge_key: Optional[str] = None,\n    how: str = \"outer\",\n) -> pd.DataFrame:\n    \"\"\"将多个 DataFrame 合并为一个特征矩阵。\n\n    Parameters\n    ----------\n    dfs : {name: DataFrame} 字典\n    merge_key :\n        - None       : 按行堆叠（假设列结构相同 / 不同则自动对齐）\n        - str / list : 按此列进行 SQL 式合并（适用于有关键列的异构表）\n    how : merge 方式: \"outer\" / \"inner\" / \"left\" / \"right\" / \"concat\"\n    \"\"\"\n    if not dfs:\n        raise ValueError(\"没有可合并的 DataFrame\")\n\n    names = list(dfs.keys())\n\n    if how == \"concat\" or merge_key is None:\n        # 行堆叠模式：列对齐，缺失列自动补 NaN\n        print(f\"  按行合并 {len(dfs)} 个文件…\")\n        combined = pd.concat(\n            [dfs[n] for n in names],\n            axis=0,\n            ignore_index=True,\n            join=\"outer\",\n            sort=False,\n        )\n        return combined\n\n    # SQL 式合并\n    print(f\"  按列 '{merge_key}' 合并 {len(dfs)} 个文件…\")\n    merged = dfs[names[0]]\n    for name in names[1:]:\n        merged = merged.merge(dfs[name], on=merge_key, how=how, suffixes=(\"\", f\"_{name}\"))\n\n    return merged\n\n\n# ---------------------------------------------------------------------------\n# 6. 完整 Pipeline\n# ---------------------------------------------------------------------------\n\ndef run_pipeline(\n    sources: List[Union[str, Path]],\n    output: Optional[Union[str, Path]] = None,\n    na_strategy: NaStrategy = \"drop\",\n    na_fill_value: Optional[Union[float, int, str]] = None,\n    scale_method: ScaleMethod = \"zscore\",\n    onehot: bool = False,\n    drop_first: bool = False,\n    max_categories: Optional[int] = None,\n    merge_key: Optional[str] = None,\n    merge_how: str = \"outer\",\n    csv_sep: str = \",\",\n    csv_encoding: str = \"utf-8\",\n    verbose: bool = True,\n    **csv_kwargs,\n) -> pd.DataFrame:\n    \"\"\"完整数据预处理 Pipeline。\n\n    Parameters\n    ----------\n    sources : CSV 文件路径列表（支持 glob 通配符）\n    output  : 输出 CSV 路径；None 则不保存\n    na_strategy, na_fill_value : 缺失值策略\n    scale_method : 标准化方法\n    onehot : 是否进行 One‑Hot 编码\n    drop_first : One‑Hot 是否 drop first\n    max_categories : One‑Hot 最大类别数\n    merge_key, merge_how : 合并参数\n    csv_sep, csv_encoding, csv_kwargs : 传给 pd.read_csv\n    verbose : 是否打印进度信息\n    \"\"\"\n    if verbose:\n        print(\"=\" * 55)\n        print(\"  数据预处理 Pipeline\")\n        print(\"=\" * 55)\n\n    # 1. 读取\n    if verbose:\n        print(\"\\n[1/4] 读取 CSV 文件…\")\n    dfs = read_csv_files(sources, sep=csv_sep, encoding=csv_encoding, **csv_kwargs)\n    if not dfs:\n        raise RuntimeError(\"没有成功读取任何 CSV 文件。\")\n\n    # 2. 逐文件清洗\n    if verbose:\n        print(f\"\\n[2/4] 缺失值处理（{na_strategy}）…\")\n    cleaned: Dict[str, pd.DataFrame] = {}\n    for name, df in dfs.items():\n        if verbose:\n            pre_shape = df.shape\n        df = handle_missing_values(df, strategy=na_strategy, fill_value=na_fill_value)\n        if verbose and df.shape != pre_shape:\n            print(f\"    {name}: {pre_shape} → {df.shape}\")\n        cleaned[name] = df\n\n    # 3. 标准化（在合并前做，避免跨文件信息泄露）\n    if scale_method != \"none\":\n        if verbose:\n            print(f\"\\n[3/4] 数值标准化（{scale_method}）…\")\n        for name, df in cleaned.items():\n            cleaned[name] = scale_numeric(df, method=scale_method)\n\n    # 4. 合并\n    if verbose:\n        print(f\"\\n[4/4] 合并数据…\")\n    final = merge_dataframes(cleaned, merge_key=merge_key, how=merge_how)\n\n    if verbose:\n        print(f\"\\n  合并后形状: {final.shape}\")\n\n    # 5. One‑Hot 编码（合并后统一做）\n    if onehot:\n        if verbose:\n            print(f\"\\n  执行 One‑Hot 编码…\")\n        final = onehot_encode(final, drop_first=drop_first, max_categories=max_categories)\n        if verbose:\n            print(f\"  One‑Hot 后形状: {final.shape}\")\n\n    # 6. 保存\n    if output:\n        final.to_csv(output, index=False)\n        if verbose:\n            print(f\"\\n  ✓ 已保存: {output}\")\n\n    if verbose:\n        print(\"=\" * 55)\n        print(\"  Pipeline 完成\")\n        print(\"=\" * 55)\n\n    return final\n\n\n# ---------------------------------------------------------------------------\n# 7. CLI 入口\n# ---------------------------------------------------------------------------\n\ndef parse_args(argv: Optional[List[str]] = None) -> argparse.Namespace:\n    parser = argparse.ArgumentParser(\n        description=\"数据预处理 Pipeline：读取多个 CSV → 清洗 → 合并 → 特征矩阵\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=\"\"\"\n示例:\n  # 基本用法：读取所有 CSV，删除缺失行，Z‑score 标准化\n  python data_clean_pipeline.py -i \"data/*.csv\" -o cleaned.csv\n\n  # 均值填充缺失值 + Min‑Max 标准化 + One‑Hot 编码\n  python data_clean_pipeline.py -i \"data/train.csv\" \"data/test.csv\" \\\\\n      -o train_test.csv --na_strategy mean --scale minmax --onehot\n\n  # 按 ID 列合并多个异构表\n  python data_clean_pipeline.py -i \"tables/*.csv\" -o merged.csv \\\\\n      --na_strategy ffill --scale robust --merge_key sample_id --merge_how outer\n\n  # 保留原始 CSV 的 index 列\n  python data_clean_pipeline.py -i \"data/*.csv\" -o out.csv --index_col 0\n        \"\"\",\n    )\n\n    parser.add_argument(\n        \"-i\", \"--input\", nargs=\"+\", required=True,\n        help=\"CSV 文件路径（支持 glob，如 'data/*.csv'）\",\n    )\n    parser.add_argument(\n        \"-o\", \"--output\", default=None,\n        help=\"输出 CSV 路径（不指定则不保存）\",\n    )\n    parser.add_argument(\n        \"--na_strategy\",\n        choices=[\"drop\", \"mean\", \"median\", \"mode\", \"ffill\", \"bfill\", \"zero\", \"constant\"],\n        default=\"drop\",\n        help=\"缺失值处理策略 (default: drop)\",\n    )\n    parser.add_argument(\n        \"--na_fill_value\",\n        default=None,\n        help=\"constant 策略时的填充值\",\n    )\n    parser.add_argument(\n        \"--scale\",\n        choices=[\"zscore\", \"minmax\", \"maxabs\", \"robust\", \"none\"],\n        default=\"zscore\",\n        help=\"数值列标准化方法 (default: zscore)\",\n    )\n    parser.add_argument(\n        \"--onehot\", action=\"store_true\",\n        help=\"对分类变量进行 One‑Hot 编码\",\n    )\n    parser.add_argument(\n        \"--drop_first\", action=\"store_true\",\n        help=\"One‑Hot 时删除第一类（避免多重共线性）\",\n    )\n    parser.add_argument(\n        \"--max_categories\", type=int, default=None,\n        help=\"One‑Hot 最大类别数，超过此值则跳过该列\",\n    )\n    parser.add_argument(\n        \"--merge_key\", default=None,\n        help=\"按此列进行 SQL 式合并（不指定则行堆叠）\",\n    )\n    parser.add_argument(\n        \"--merge_how\",\n        choices=[\"outer\", \"inner\", \"left\", \"right\", \"concat\"],\n        default=\"concat\",\n        help=\"合并方式 (default: concat)\",\n    )\n    parser.add_argument(\n        \"--sep\", default=\",\",\n        help=\"CSV 分隔符 (default: ',')\",\n    )\n    parser.add_argument(\n        \"--encoding\", default=\"utf-8\",\n        help=\"CSV 编码 (default: utf-8)\",\n    )\n    # 透传给 pd.read_csv 的参数\n    parser.add_argument(\"--header\", type=int, default=\"infer\")\n    parser.add_argument(\"--index_col\", type=int, default=None)\n\n    return parser.parse_args(argv)\n\n\ndef main() -> None:\n    args = parse_args()\n\n    # 将 --na_fill_value 转为合适的类型\n    fill_val = args.na_fill_value\n    if fill_val is not None:\n        try:\n            fill_val = int(fill_val)\n        except ValueError:\n            try:\n                fill_val = float(fill_val)\n            except ValueError:\n                pass  # 保持字符串\n\n    csv_kwargs = {}\n    if args.header != \"infer\":\n        csv_kwargs[\"header\"] = args.header\n    if args.index_col is not None:\n        csv_kwargs[\"index_col\"] = args.index_col\n\n    run_pipeline(\n        sources=args.input,\n        output=args.output,\n        na_strategy=args.na_strategy,\n        na_fill_value=fill_val,\n        scale_method=args.scale,\n        onehot=args.onehot,\n        drop_first=args.drop_first,\n        max_categories=args.max_categories,\n        merge_key=args.merge_key,\n        merge_how=args.merge_how,\n        csv_sep=args.sep,\n        csv_encoding=args.encoding,\n        **csv_kwargs,\n    )\n\n\nif __name__ == \"__main__\":\n    main()\n"})
