=dict(boxstyle='round,pad=0.2',\n                          facecolor='white', edgecolor=COLOR_DROPOUT,\n                          linewidth=0.8, alpha=0.85),\n                zorder=5)\n\n    # Dimension label above box\n    dim_labels = ['256', '128', '64', '32', '—']\n    ax.text(x[i], y_box + h_box/2 + 0.4, dim_labels[i],\n            ha='center', va='bottom',\n            fontsize=13, fontweight='bold', color=COLOR_EDGE, zorder=4)\n\n# ── Main forward arrows ──\nfor i in range(len(x) - 1):\n    ax.annotate('', xy=(x[i+1] - w_box/2, y_box),\n                xytext=(x[i] + w_box/2, y_box),\n                arrowprops=dict(\n                    arrowstyle='->', color=COLOR_EDGE,\n                    lw=3, connectionstyle='arc3,rad=0',\n                    shrinkA=2, shrinkB=2,\n                ), zorder=2)\n\n# ── Skip connection 1: Input → LSTM₂ ──\ny_skip_top = y_box + 2.6\nax.annotate('', xy=(x[2] - w_box/2, y_skip_top),\n            xytext=(x[0] + w_box/2, y_skip_top),\n            arrowprops=dict(\n                arrowstyle='->', color=COLOR_SKIP_A,\n                lw=2.5, linestyle='dashed',\n                connectionstyle='arc3,rad=0.15',\n            ), zorder=2)\n\n# Label for skip 1\nax.text((x[0] + x[2]) / 2, y_skip_top + 0.55,\n        'Skip Connection\\n(Input → LSTM₂)',\n        ha='center', va='bottom',\n        fontsize=9.5, fontweight='bold',\n        color=COLOR_SKIP_A, zorder=5)\n\n# ── Skip connection 2: LSTM₁ → LSTM₃ ──\ny_skip_bot = y_box - 2.6\nax.annotate('', xy=(x[3] - w_box/2, y_skip_bot),\n            xytext=(x[1] + w_box/2, y_skip_bot),\n            arrowprops=dict(\n                arrowstyle='->', color=COLOR_SKIP_B,\n                lw=2.5, linestyle='dashed',\n                connectionstyle='arc3,rad=-0.15',\n            ), zorder=2)\n\n# Label for skip 2\nax.text((x[1] + x[3]) / 2, y_skip_bot - 0.55,\n        'Skip Connection\\n(LSTM₁ → LSTM₃)',\n        ha='center', va='top',\n        fontsize=9.5, fontweight='bold',\n        color=COLOR_SKIP_B, zorder=5)\n\n# ── Data-flow label under main arrows ──\nax.text(np.mean(x), y_box - h_box/2 - 1.15,\n        'Data Flow ────►',\n        ha='center', va='top',\n        fontsize=10, color='#64748B',\n        fontstyle='italic', zorder=1)\n\n# ── Title ──\nax.text(9, 7.5, 'LSTM Neural Network Architecture with Skip Connections',\n        ha='center', va='top',\n        fontsize=16, fontweight='bold',\n        color=COLOR_EDGE, zorder=5)\n\nax.text(9, 7.0, 'Input: 256-dim embedding → 3 LSTM layers → Softmax output',\n        ha='center', va='top',\n        fontsize=11, color='#64748B',\n        fontstyle='italic', zorder=5)\n\n# ── Legend ──\nlegend_elements = [\n    mpatches.Patch(facecolor=COLOR_INPUT,  edgecolor=COLOR_EDGE, label='Input / Embedding'),\n    mpatches.Patch(facecolor=COLOR_LSTM,   edgecolor=COLOR_EDGE, label='LSTM Hidden Layer'),\n    mpatches.Patch(facecolor=COLOR_OUTPUT, edgecolor=COLOR_EDGE, label='Softmax Output'),\n    plt.Line2D([0], [0], color=COLOR_SKIP_A, lw=2.5, linestyle='--', label='Skip Connection'),\n    plt.Line2D([0], [0], color=COLOR_DROPOUT, lw=0, marker='s',\n               markerfacecolor='white', markeredgecolor=COLOR_DROPOUT,\n               markersize=10, label='Dropout Annotation'),\n]\nlegend = ax.legend(\n    handles=legend_elements, loc='lower center',\n    ncol=5, frameon=True, fancybox=True,\n    shadow=False, edgecolor='#CBD5E1',\n    fontsize=9.5,\n    bbox_to_anchor=(0.5, -0.02),\n)\nlegend.get_frame().set_facecolor('#FAFAFA')\nlegend.set_zorder(10)\n\nplt.tight_layout()\nplt.subplots_adjust(bottom=0.12)\nplt.savefig('lstm_architecture.png', dpi=250, bbox_inches='tight')\nplt.close()\nprint('✅ Saved to lstm_architecture.png')\n"})
