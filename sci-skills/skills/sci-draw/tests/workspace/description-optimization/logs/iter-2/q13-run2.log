TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/_diagrams/lstm_arch.py", "content": "#!/usr/bin/env python3\n\"\"\"\nNeural Network Architecture Diagram\n256-dim Embedding → 3× LSTM Hidden (128, 64, 32) → Softmax Output\nwith Skip Connections and Dropout Annotations\n\"\"\"\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# 1. Setup\n# ---------------------------------------------------------------------------\nfig, ax = plt.subplots(1, 1, figsize=(18, 7))\nax.set_xlim(-1, 17)\nax.set_ylim(-1, 7.5)\nax.axis(\"off\")\n\n# ---------------------------------------------------------------------------\n# 2. Layer definitions\n# ---------------------------------------------------------------------------\n# (x_center, y_center, name_top, name_bottom, dim, dropout, color)\nLAYER_SPECS = [\n    (1.5,  3.0, \"Input\",       \"Embedding\", 256, None,   \"#3498db\"),\n    (4.5,  3.0, \"LSTM 1\",      \"Hidden\",    128, 0.30,   \"#2ecc71\"),\n    (7.5,  3.0, \"LSTM 2\",      \"Hidden\",     64, 0.30,   \"#f39c12\"),\n    (10.5, 3.0, \"LSTM 3\",      \"Hidden\",     32, 0.20,   \"#e74c3c\"),\n    (13.5, 3.0, \"Softmax\",     \"Output\",    None, None,   \"#9b59b6\"),\n]\n\nW = 1.4                     # width  of each layer block\nH_INPUT = 2.8               # height of input  block\nH_LSTM  = [2.5, 2.0, 1.5]  # heights of LSTM blocks\nH_OUT   = 1.2               # height of output block\nHEIGHTS = [H_INPUT] + H_LSTM + [H_OUT]\n\n# ---------------------------------------------------------------------------\n# 3. Draw layer blocks\n# ---------------------------------------------------------------------------\nfor (cx, cy, name, sub, dim, do_rate, color), h in zip(LAYER_SPECS, HEIGHTS):\n    left = cx - W / 2\n    bot  = cy - h / 2\n\n    # --- rounded rectangle ---\n    rect = mpatches.FancyBboxPatch(\n        (left, bot), W, h,\n        boxstyle=\"round,pad=0.10\",\n        facecolor=color, edgecolor=\"white\", linewidth=2.5,\n        alpha=0.92,\n    )\n    ax.add_patch(rect)\n\n    # --- layer name (centred) ---\n    ax.text(\n        cx, cy, f\"{name}\\n{sub}\",\n        ha=\"center\", va=\"center\",\n        fontsize=11, fontweight=\"bold\", color=\"white\",\n        linespacing=1.3,\n    )\n\n    # --- dimension badge below ---\n    if dim is not None:\n        badge = mpatches.FancyBboxPatch(\n            (cx - 0.45, bot - 0.55), 0.9, 0.35,\n            boxstyle=\"round,pad=0.08\",\n            facecolor=\"white\", edgecolor=\"#bdc3c7\", linewidth=1.0,\n        )\n        ax.add_patch(badge)\n        ax.text(\n            cx, bot - 0.38, f\"dim={dim}\",\n            ha=\"center\", va=\"center\",\n            fontsize=8.5, fontweight=\"bold\", color=\"#2c3e50\",\n        )\n\n    # --- dropout label above ---\n    if do_rate is not None:\n        dobj = mpatches.FancyBboxPatch(\n            (cx - 0.55, bot + h + 0.08), 1.1, 0.32,\n            boxstyle=\"round,pad=0.06\",\n            facecolor=\"#fff5f5\", edgecolor=\"#e74c3c\", linewidth=1.0,\n        )\n        ax.add_patch(dobj)\n        ax.text(\n            cx, bot + h + 0.24, f\"dropout = {do_rate:.0%}\",\n            ha=\"center\", va=\"center\",\n            fontsize=8.5, fontweight=\"bold\", color=\"#c0392b\",\n        )\n\n# ---------------------------------------------------------------------------\n# 4. Data-flow arrows (main path, left to right)\n# ---------------------------------------------------------------------------\nfor i in range(len(LAYER_SPECS) - 1):\n    x1 = LAYER_SPECS[i][0]   + W / 2 + 0.05\n    x2 = LAYER_SPECS[i + 1][0] - W / 2 - 0.05\n    y  = LAYER_SPECS[i][1]\n    ax.annotate(\n        \"\", xy=(x2, y), xytext=(x1, y),\n        arrowprops=dict(arrowstyle=\"->\", lw=2.8, color=\"#7f8c8d\"),\n    )\n\n# ---------------------------------------------------------------------------\n# 5. Skip connections (curved, dashed)\n# ---------------------------------------------------------------------------\n\n# 5a. Input ----> LSTM 2  (skip LSTM 1)\nskip_top_y = 3.0 + max(H_INPUT, H_LSTM[1]) / 2 + 0.70\n\n# Draw curved path using Polygon approximation\nverts_skip1 = [\n    (LAYER_SPECS[0][0] + W / 2,  3.0 + H_INPUT / 2 + 0.10),   # start\n    (LAYER_SPECS[0][0] + W / 2,  skip_top_y),                  # up\n    (LAYER_SPECS[2][0] - W / 2,  skip_top_y),                  # across\n    (LAYER_SPECS[2][0] - W / 2,  3.0 + H_LSTM[1] / 2 + 0.10), # down\n]\nax.add_patch(plt.Polygon(\n    verts_skip1, fill=None,\n    edgecolor=\"#e74c3c\", linewidth=1.8, linestyle=\"--\",\n    closed=False,\n))\n# arrowhead\nax.annotate(\n    \"\", xy=verts_skip1[3], xytext=verts_skip1[2],\n    arrowprops=dict(arrowstyle=\"->\", lw=1.8, color=\"#e74c3c\"),\n)\nax.text(\n    (LAYER_SPECS[0][0] + LAYER_SPECS[2][0]) / 2,\n    skip_top_y + 0.30, \"skip connection\",\n    ha=\"center\", va=\"bottom\",\n    fontsize=9, fontstyle=\"italic\", color=\"#e74c3c\",\n    bbox=dict(facecolor=\"white\", edgecolor=\"#e74c3c\",\n              boxstyle=\"round,pad=0.15\", alpha=0.85),\n)\n\n# 5b. LSTM 1 ----> LSTM 3  (skip LSTM 2)\nskip_bot_y = 3.0 - max(H_LSTM[0], H_LSTM[2]) / 2 - 0.70\n\nverts_skip2 = [\n    (LAYER_SPECS[1][0] + W / 2,  3.0 - H_LSTM[0] / 2 - 0.10),\n    (LAYER_SPECS[1][0] + W / 2,  skip_bot_y),\n    (LAYER_SPECS[3][0] - W / 2,  skip_bot_y),\n    (LAYER_SPECS[3][0] - W / 2,  3.0 - H_LSTM[2] / 2 - 0.10),\n]\nax.add_patch(plt.Polygon(\n    verts_skip2, fill=None,\n    edgecolor=\"#e74c3c\", linewidth=1.8, linestyle=\"--\",\n    closed=False,\n))\nax.annotate(\n    \"\", xy=verts_skip2[3], xytext=verts_skip2[2],\n    arrowprops=dict(arrowstyle=\"->\", lw=1.8, color=\"#e74c3c\"),\n)\nax.text(\n    (LAYER_SPECS[1][0] + LAYER_SPECS[3][0]) / 2,\n    skip_bot_y - 0.30, \"skip connection\",\n    ha=\"center\", va=\"top\",\n    fontsize=9, fontstyle=\"italic\", color=\"#e74c3c\",\n    bbox=dict(facecolor=\"white\", edgecolor=\"#e74c3c\",\n              boxstyle=\"round,pad=0.15\", alpha=0.85),\n)\n\n# ---------------------------------------------------------------------------\n# 6. Title & sub-title\n# ---------------------------------------------------------------------------\nax.text(\n    0, 6.8, \"LSTM Neural Network Architecture\",\n    fontsize=17, fontweight=\"bold\", color=\"#2c3e50\", ha=\"left\", va=\"center\",\n)\nax.text(\n    0, 6.2,\n    \"256-dim Embedding → 3 × LSTM Hidden Layers (128 → 64 → 32) → Softmax Output\",\n    fontsize=11, color=\"#7f8c8d\", ha=\"left\", va=\"center\",\n)\n\n# ---------------------------------------------------------------------------\n# 7. Legend\n# ---------------------------------------------------------------------------\nlegend_items = [\n    mpatches.Patch(facecolor=\"#3498db\", edgecolor=\"white\", label=\"Input Layer\"),\n    mpatches.Patch(facecolor=\"#2ecc71\", edgecolor=\"white\", label=\"LSTM Layer\"),\n    mpatches.Patch(facecolor=\"#9b59b6\", edgecolor=\"white\", label=\"Output Layer\"),\n    plt.Line2D([0], [0], color=\"#7f8c8d\", lw=2.8, label=\"Forward Pass\"),\n    plt.Line2D([0], [0], color=\"#e74c3c\", lw=1.8, ls=\"--\", label=\"Skip Connection\"),\n]\nax.legend(\n    handles=legend_items,\n    loc=\"lower center\", bbox_to_anchor=(7.5, -0.15),\n    ncol=5, frameon=True, fancybox=True, shadow=True,\n    fontsize=9.5, columnspacing=2.0,\n)\n\n# ---------------------------------------------------------------------------\n# 8. Save\n# ---------------------------------------------------------------------------\nplt.tight_layout()\nout_path = \"/home/joe/Documents/repo/skill/sci-draw/_diagrams/lstm_architecture.png\"\nplt.savefig(out_path, dpi=250, bbox_inches=\"tight\", facecolor=\"white\")\nplt.close()\nprint(f\"Done: {out_path}\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/_diagrams/lstm_arch.py", "content": "#!/usr/bin/env python3\n\"\"\"\nNeural Network Architecture Diagram\n256-dim Embedding → 3× LSTM Hidden (128, 64, 32) → Softmax Output\nwith Skip Connections and Dropout Annotations\n\"\"\"\n\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nimport numpy as np\n\n# ---------------------------------------------------------------------------\n# 1. Setup\n# ---------------------------------------------------------------------------\nfig, ax = plt.subplots(1, 1, figsize=(18, 7))\nax.set_xlim(-1, 17)\nax.set_ylim(-1, 7.5)\nax.axis(\"off\")\n\n# ---------------------------------------------------------------------------\n# 2. Layer definitions\n# ---------------------------------------------------------------------------\n# (x_center, y_center, name_top, name_bottom, dim, dropout, color)\nLAYER_SPECS = [\n    (1.5,  3.0, \"Input\",       \"Embedding\", 256, None,   \"#3498db\"),\n    (4.5,  3.0, \"LSTM 1\",      \"Hidden\",    128, 0.30,   \"#2ecc71\"),\n    (7.5,  3.0, \"LSTM 2\",      \"Hidden\",     64, 0.30,   \"#f39c12\"),\n    (10.5, 3.0, \"LSTM 3\",      \"Hidden\",     32, 0.20,   \"#e74c3c\"),\n    (13.5, 3.0, \"Softmax\",     \"Output\",    None, None,   \"#9b59b6\"),\n]\n\nW = 1.4                     # width  of each layer block\nH_INPUT = 2.8               # height of input  block\nH_LSTM  = [2.5, 2.0, 1.5]  # heights of LSTM blocks\nH_OUT   = 1.2               # height of output block\nHEIGHTS = [H_INPUT] + H_LSTM + [H_OUT]\n\n# ---------------------------------------------------------------------------\n# 3. Draw layer blocks\n# ---------------------------------------------------------------------------\nfor (cx, cy, name, sub, dim, do_rate, color), h in zip(LAYER_SPECS, HEIGHTS):\n    left = cx - W / 2\n    bot  = cy - h / 2\n\n    # --- rounded rectangle ---\n    rect = mpatches.FancyBboxPatch(\n        (left, bot), W, h,\n        boxstyle=\"round,pad=0.10\",\n        facecolor=color, edgecolor=\"white\", linewidth=2.5,\n        alpha=0.92,\n    )\n    ax.add_patch(rect)\n\n    # --- layer name (centred) ---\n    ax.text(\n        cx, cy, f\"{name}\\n{sub}\",\n        ha=\"center\", va=\"center\",\n        fontsize=11, fontweight=\"bold\", color=\"white\",\n        linespacing=1.3,\n    )\n\n    # --- dimension badge below ---\n    if dim is not None:\n        badge = mpatches.FancyBboxPatch(\n            (cx - 0.45, bot - 0.55), 0.9, 0.35,\n            boxstyle=\"round,pad=0.08\",\n            facecolor=\"white\", edgecolor=\"#bdc3c7\", linewidth=1.0,\n        )\n        ax.add_patch(badge)\n        ax.text(\n            cx, bot - 0.38, f\"dim={dim}\",\n            ha=\"center\", va=\"center\",\n            fontsize=8.5, fontweight=\"bold\", color=\"#2c3e50\",\n        )\n\n    # --- dropout label above ---\n    if do_rate is not None:\n        dobj = mpatches.FancyBboxPatch(\n            (cx - 0.55, bot + h + 0.08), 1.1, 0.32,\n            boxstyle=\"round,pad=0.06\",\n            facecolor=\"#fff5f5\", edgecolor=\"#e74c3c\", linewidth=1.0,\n        )\n        ax.add_patch(dobj)\n        ax.text(\n            cx, bot + h + 0.24, f\"dropout = {do_rate:.0%}\",\n            ha=\"center\", va=\"center\",\n            fontsize=8.5, fontweight=\"bold\", color=\"#c0392b\",\n        )\n\n# ---------------------------------------------------------------------------\n# 4. Data-flow arrows (main path, left to right)\n# ---------------------------------------------------------------------------\nfor i in range(len(LAYER_SPECS) - 1):\n    x1 = LAYER_SPECS[i][0]   + W / 2 + 0.05\n    x2 = LAYER_SPECS[i + 1][0] - W / 2 - 0.05\n    y  = LAYER_SPECS[i][1]\n    ax.annotate(\n        \"\", xy=(x2, y), xytext=(x1, y),\n        arrowprops=dict(arrowstyle=\"->\", lw=2.8, color=\"#7f8c8d\"),\n    )\n\n# ---------------------------------------------------------------------------\n# 5. Skip connections (curved, dashed)\n# ---------------------------------------------------------------------------\n\n# 5a. Input ----> LSTM 2  (skip LSTM 1)\nskip_top_y = 3.0 + max(H_INPUT, H_LSTM[1]) / 2 + 0.70\n\n# Draw curved path using Polygon approximation\nverts_skip1 = [\n    (LAYER_SPECS[0][0] + W / 2,  3.0 + H_INPUT / 2 + 0.10),   # start\n    (LAYER_SPECS[0][0] + W / 2,  skip_top_y),                  # up\n    (LAYER_SPECS[2][0] - W / 2,  skip_top_y),                  # across\n    (LAYER_SPECS[2][0] - W / 2,  3.0 + H_LSTM[1] / 2 + 0.10), # down\n]\nax.add_patch(plt.Polygon(\n    verts_skip1, fill=None,\n    edgecolor=\"#e74c3c\", linewidth=1.8, linestyle=\"--\",\n    closed=False,\n))\n# arrowhead\nax.annotate(\n    \"\", xy=verts_skip1[3], xytext=verts_skip1[2],\n    arrowprops=dict(arrowstyle=\"->\", lw=1.8, color=\"#e74c3c\"),\n)\nax.text(\n    (LAYER_SPECS[0][0] + LAYER_SPECS[2][0]) / 2,\n    skip_top_y + 0.30, \"skip connection\",\n    ha=\"center\", va=\"bottom\",\n    fontsize=9, fontstyle=\"italic\", color=\"#e74c3c\",\n    bbox=dict(facecolor=\"white\", edgecolor=\"#e74c3c\",\n              boxstyle=\"round,pad=0.15\", alpha=0.85),\n)\n\n# 5b. LSTM 1 ----> LSTM 3  (skip LSTM 2)\nskip_bot_y = 3.0 - max(H_LSTM[0], H_LSTM[2]) / 2 - 0.70\n\nverts_skip2 = [\n    (LAYER_SPECS[1][0] + W / 2,  3.0 - H_LSTM[0] / 2 - 0.10),\n    (LAYER_SPECS[1][0] + W / 2,  skip_bot_y),\n    (LAYER_SPECS[3][0] - W / 2,  skip_bot_y),\n    (LAYER_SPECS[3][0] - W / 2,  3.0 - H_LSTM[2] / 2 - 0.10),\n]\nax.add_patch(plt.Polygon(\n    verts_skip2, fill=None,\n    edgecolor=\"#e74c3c\", linewidth=1.8, linestyle=\"--\",\n    closed=False,\n))\nax.annotate(\n    \"\", xy=verts_skip2[3], xytext=verts_skip2[2],\n    arrowprops=dict(arrowstyle=\"->\", lw=1.8, color=\"#e74c3c\"),\n)\nax.text(\n    (LAYER_SPECS[1][0] + LAYER_SPECS[3][0]) / 2,\n    skip_bot_y - 0.30, \"skip connection\",\n    ha=\"center\", va=\"top\",\n    fontsize=9, fontstyle=\"italic\", color=\"#e74c3c\",\n    bbox=dict(facecolor=\"white\", edgecolor=\"#e74c3c\",\n              boxstyle=\"round,pad=0.15\", alpha=0.85),\n)\n\n# ---------------------------------------------------------------------------\n# 6. Title & sub-title\n# ---------------------------------------------------------------------------\nax.text(\n    0, 6.8, \"LSTM Neural Network Architecture\",\n    fontsize=17, fontweight=\"bold\", color=\"#2c3e50\", ha=\"left\", va=\"center\",\n)\nax.text(\n    0, 6.2,\n    \"256-dim Embedding \\u2192 3 \\u00d7 LSTM Hidden Layers (128 \\u2192 64 \\u2192 32) \\u2192 Softmax Output\",\n    fontsize=11, color=\"#7f8c8d\", ha=\"left\", va=\"center\",\n)\n\n# ---------------------------------------------------------------------------\n# 7. Legend\n# ---------------------------------------------------------------------------\nlegend_items = [\n    mpatches.Patch(facecolor=\"#3498db\", edgecolor=\"white\", label=\"Input Layer\"),\n    mpatches.Patch(facecolor=\"#2ecc71\", edgecolor=\"white\", label=\"LSTM Layer\"),\n    mpatches.Patch(facecolor=\"#9b59b6\", edgecolor=\"white\", label=\"Output Layer\"),\n    plt.Line2D([0], [0], color=\"#7f8c8d\", lw=2.8, label=\"Forward Pass\"),\n    plt.Line2D([0], [0], color=\"#e74c3c\", lw=1.8, ls=\"--\", label=\"Skip Connection\"),\n]\nax.legend(\n    handles=legend_items,\n    loc=\"lower center\", bbox_to_anchor=(7.5, -0.15),\n    ncol=5, frameon=True, fancybox=True, shadow=True,\n    fontsize=9.5, columnspacing=2.0,\n)\n\n# ---------------------------------------------------------------------------\n# 8. Save\n# ---------------------------------------------------------------------------\nplt.tight_layout()\nout_path = \"/home/joe/Documents/repo/skill/sci-draw/_diagrams/lstm_architecture.png\"\nplt.savefig(out_path, dpi=250, bbox_inches=\"tight\", facecolor=\"white\")\nplt.close()\nprint(f\"Done: {out_path}\")\n"})
