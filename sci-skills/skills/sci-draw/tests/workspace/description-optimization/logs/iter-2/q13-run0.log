add_patch(rect)\n    boxes.append((x, y_center))\n\n    # Layer label\n    ax.text(x, y_center, label,\n            ha='center', va='center', fontsize=10, fontweight='bold',\n            color=C_TEXT, zorder=4)\n\n    # Dimension tag below\n    if dim is not None:\n        ax.text(x, y_center - box_h/2 - 0.15, f'dim = {dim}',\n                ha='center', va='top', fontsize=8.5,\n                color='#666666', style='italic', zorder=4)\n\n# ---------- Forward arrows (solid) ----------\nfor i in range(len(boxes) - 1):\n    x1, y1 = boxes[i]\n    x2, y2 = boxes[i + 1]\n    ax.annotate('', xy=(x2 - box_w/2 + 0.05, y2),\n                xytext=(x1 + box_w/2 - 0.05, y1),\n                arrowprops=dict(arrowstyle='->', color=C_TEXT,\n                                lw=2.0, zorder=2))\n\n# ---------- Skip connections (dashed) ----------\nfor from_x, to_x in skip_conns:\n    # find the y-top for a skip above the boxes\n    y_top = y_center + box_h/2 + 0.15\n    ax.annotate('', xy=(to_x - box_w/2 + 0.05, y_top),\n                xytext=(from_x + box_w/2 - 0.05, y_top),\n                arrowprops=dict(arrowstyle='->', color=C_SKIP,\n                                lw=1.8, linestyle='dashed', zorder=2))\n    # label\n    mid_x = (from_x + to_x) / 2\n    ax.text(mid_x, y_top + 0.15, 'Skip\\nConnection',\n            ha='center', va='bottom', fontsize=7, color=C_SKIP,\n            fontweight='bold', zorder=4)\n\n# ---------- Dropout annotations ----------\nfor x, rate in dropout_rates:\n    y_drop = y_center - box_h/2 - 0.55\n    # small rounded rect as badge\n    badge = mpatches.FancyBboxPatch(\n        (x - 0.4, y_drop - 0.18),\n        0.8, 0.36,\n        boxstyle=\"round,pad=0.05\",\n        facecolor=C_DROPOUT, alpha=0.85,\n        edgecolor='none', zorder=3,\n    )\n    ax.add_patch(badge)\n    ax.text(x, y_drop, f'Dropout\\nrate={rate}',\n            ha='center', va='center', fontsize=6.5,\n            color='white', fontweight='bold', zorder=4)\n\n# ---------- Data flow label ----------\nax.annotate('', xy=(0.3, y_center), xytext=(0.0, y_center),\n            arrowprops=dict(arrowstyle='->', color=C_TEXT, lw=1.5))\nax.text(0.15, y_center + 0.3, 'Data\\nFlow',\n        ha='center', va='bottom', fontsize=7, color=C_TEXT)\n\n# ---------- Legend ----------\nlegend_elements = [\n    mpatches.Patch(facecolor=C_LSTM_LIGHT, edgecolor=C_LSTM, linewidth=2,\n                   label='LSTM Layer'),\n    mpatches.Patch(facecolor='white', edgecolor=C_OUTPUT, linewidth=2,\n                   label='Softmax Output'),\n    plt.Line2D([0], [0], color=C_SKIP, linestyle='dashed', lw=1.8,\n               label='Skip Connection'),\n    plt.Line2D([0], [0], color=C_TEXT, lw=2.0, label='Forward Pass'),\n    mpatches.Patch(facecolor=C_DROPOUT, alpha=0.85, label='Dropout'),\n]\n\nlegend = ax.legend(handles=legend_elements, loc='lower center',\n                   bbox_to_anchor=(0.5, -0.05),\n                   ncol=5, frameon=True, fancybox=True,\n                   fontsize=8.5, edgecolor='#CCCCCC')\n\n# ---------- Title ----------\nax.set_title('LSTM Neural Network Architecture\\n'\n             'Input → LSTM Layers (with Skip Connections & Dropout) → Softmax',\n             fontsize=13, fontweight='bold', color=C_TEXT,\n             pad=12, loc='center')\n\n# ---------- Export ----------\nout = '/home/joe/Documents/repo/skill/sci-draw/nn_architecture.png'\nfig.savefig(out, dpi=200, bbox_inches='tight', pad_inches=0.3)\nprint(f'Saved to {out}')\n\nout2 = '/home/joe/Documents/repo/skill/sci-draw/nn_architecture.pdf'\nfig.savefig(out2, bbox_inches='tight', pad_inches=0.3)\nprint(f'Saved to {out2}')\n\nplt.close(fig)\nprint('Done.')\n"})
