TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/quantum_cover.py", "content": "#!/usr/bin/env python3\n\"\"\"\n论文封面：量子计算与拓扑量子比特\n风格：蓝紫色科幻几何风\n\"\"\"\n\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom matplotlib.patches import FancyBboxPatch, FancyArrowPatch, Circle, Polygon\nfrom matplotlib.collections import LineCollection\nimport matplotlib.patches as mpatches\n\n# ========== 全局设置 ==========\nfig = plt.figure(figsize=(8.5, 11), dpi=300)\nax = fig.add_axes([0, 0, 1, 1])\nax.set_xlim(0, 8.5)\nax.set_ylim(0, 11)\nax.axis('off')\n\n# ========== 蓝紫色渐变背景 ==========\nbg = np.zeros((1100, 850, 3))\nfor y in range(1100):\n    t = y / 1100\n    # 从深紫(0)渐变到深蓝(0.4)再到深紫(0.7+)再到黑色(1)\n    if t < 0.4:\n        s = t / 0.4\n        r = 0.02 + 0.03 * s\n        g = 0.00 + 0.05 * s\n        b = 0.12 + 0.15 * s\n    elif t < 0.7:\n        s = (t - 0.4) / 0.3\n        r = 0.05 - 0.02 * s\n        g = 0.05 + 0.08 * s\n        b = 0.27 - 0.05 * s\n    else:\n        s = (t - 0.7) / 0.3\n        r = 0.03 * (1 - s)\n        g = 0.13 * (1 - s)\n        b = 0.22 * (1 - s)\n    bg[y, :] = [r, g, b]\n\nax.imshow(bg, extent=[0, 8.5, 0, 11], aspect='auto', alpha=0.9)\n\n# ========== 辅助: 六边形晶格 ==========\ndef draw_hex_lattice(ax, cx, cy, radius, rows, cols, color, lw=0.4, alpha=0.3):\n    \"\"\"绘制六边形晶格\"\"\"\n    dx = radius * 1.5\n    dy = radius * np.sqrt(3)\n    hex_verts = []\n    for a in np.linspace(0, 2*np.pi, 7)[:6]:\n        hex_verts.append([np.cos(a), np.sin(a)])\n    hex_verts = np.array(hex_verts)\n\n    for r in range(rows):\n        for c in range(cols):\n            x = cx + c * dx\n            y = cy + r * dy\n            if r % 2 == 1:\n                x += dx / 2\n            verts = hex_verts * radius + np.array([x, y])\n            poly = Polygon(verts, closed=True, fill=False,\n                          edgecolor=color, lw=lw, alpha=alpha)\n            ax.add_patch(poly)\n            # 在六边形中心画一个小光点\n            ax.plot(x, y, 'o', color=color, markersize=1.5, alpha=alpha*0.5)\n\n# 背景六边形晶格 (代表拓扑量子比特的晶格结构)\ndraw_hex_lattice(ax, 1, 1, 0.2, 12, 8, '#7b68ee', lw=0.5, alpha=0.15)\ndraw_hex_lattice(ax, 1.15, 1.15, 0.22, 10, 7, '#4169e1', lw=0.3, alpha=0.08)\n\n# ========== 量子线/世界线 - 编织图案 (braiding) ==========\n# 拓扑量子比特的核心：任意子的编织操作\ndef draw_braid(ax, x_start, y_start, strands=3, length=8, amp=0.25, color='#00d4ff', lw=1.5, alpha=0.7):\n    \"\"\"绘制编织图案 (braiding)\"\"\"\n    ts = np.linspace(0, length, 500)\n    for i in range(strands):\n        y_offset = -i * 0.35\n        x = x_start + ts\n        y = y_start + y_offset\n        for j in range(int(length)):\n            t_seg = ts[j*50:min((j+1)*50+1, len(ts))]\n            if len(t_seg) < 2:\n                continue\n            # 编织：相邻 strand 交换位置\n            phase = 0\n            if (j // 2) % 2 == 0:\n                if i == 0:\n                    phase = amp * np.sin(t_seg * np.pi)\n                elif i == 1:\n                    phase = -amp * np.sin(t_seg * np.pi)\n            else:\n                if i == 1:\n                    phase = amp * np.sin(t_seg * np.pi)\n                elif i == 2:\n                    phase = -amp * np.sin(t_seg * np.pi)\n            x_seg = x_start + t_seg\n            y_seg = y_start + y_offset + phase\n            points = np.array([x_seg, y_seg]).T.reshape(-1, 1, 2)\n            segments = np.concatenate([points[:-1], points[1:]], axis=1)\n            lc = LineCollection(segments, colors=color, lw=lw, alpha=alpha)\n            ax.add_collection(lc)\n        # 每个 strand 末端画个光点\n        ax.plot(x[-1], y[-1], 'o', color=color, markersize=3, alpha=alpha+0.1)\n\n# 主编织图案\ndraw_braid(ax, 3.5, 7.5, strands=3, length=4.5, amp=0.3, color='#7b68ee', lw=2.0, alpha=0.6)\ndraw_braid(ax, 3.2, 7.8, strands=3, length=4.5, amp=0.25, color='#00bfff', lw=1.2, alpha=0.35)\n\n# ========== 拓扑量子比特 ==========\ndef draw_topological_qubit(ax, cx, cy, r, color1='#7b68ee', color2='#00d4ff', alpha=0.6):\n    \"\"\"拓扑量子比特表示：环面/甜甜圈上的任意子\"\"\"\n    # 主环 (torus 示意)\n    theta = np.linspace(0, 2*np.pi, 100)\n    phi = np.linspace(0, 2*np.pi, 50)\n\n    # 画一个2D投影环\n    circle_outer = plt.Circle((cx, cy), r, fill=False, color=color1, lw=1.5, alpha=alpha)\n    circle_inner = plt.Circle((cx, cy), r*0.4, fill=False, color=color2, lw=0.8, alpha=alpha*0.5)\n    ax.add_patch(circle_outer)\n    ax.add_patch(circle_inner)\n\n    # 用虚线表示内环\n    for a in np.linspace(0, 2*np.pi, 12):\n        x1 = cx + r * np.cos(a)\n        y1 = cy + r * np.sin(a)\n        x2 = cx + r * 0.4 * np.cos(a)\n        y2 = cy + r * 0.4 * np.sin(a)\n        ax.plot([x1, x2], [y1, y2], '-', color=color2, lw=0.3, alpha=alpha*0.2)\n\n    # 任意子 (anyon) 标记 - 小十字/旋量\n    for angle in [0, np.pi/2, np.pi, 3*np.pi/2]:\n        x = cx + r * 0.7 * np.cos(angle)\n        y = cy + r * 0.7 * np.sin(angle)\n        size = 0.04\n        ax.plot([x-size, x+size], [y, y], '-', color='#ff6eb4', lw=1, alpha=0.8)\n        ax.plot([x, x], [y-size, y+size], '-', color='#ff6eb4', lw=1, alpha=0.8)\n\n# 主量子比特\ndraw_topological_qubit(ax, 5.8, 8.0, 0.5, '#7b68ee', '#00d4ff', 0.7)\ndraw_topological_qubit(ax, 5.8, 8.0, 0.35, '#9b7eee', '#00ffff', 0.3)\n\n# ========== 抽象量子态 ==========\ndef draw_quantum_state(ax, cx, cy, r, n_pts=80, color='#00bfff'):\n    \"\"\"抽象量子态：概率云\"\"\"\n    angles = np.random.uniform(0, 2*np.pi, n_pts)\n    radii = np.random.exponential(0.3, n_pts) * r\n    xs = cx + radii * np.cos(angles)\n    ys = cy + radii * np.sin(angles)\n    sizes = np.random.uniform(1, 6, n_pts)\n    alpha_vals = np.random.uniform(0.1, 0.5, n_pts)\n    ax.scatter(xs, ys, s=sizes, c=color, alpha=alpha_vals, edgecolors='none')\n\n# 量子态云\ndraw_quantum_state(ax, 2, 2.5, 0.8, 120, '#00d4ff')\ndraw_quantum_state(ax, 2, 3.8, 0.5, 60, '#7b68ee')\n\n# ========== 几何装饰线条 ==========\n# 连线\ndef draw_connecting_lines(ax, points, color='#4169e1', lw=0.5, alpha=0.3):\n    for i in range(len(points)):\n        for j in range(i+1, len(points)):\n            ax.plot([points[i][0], points[j][0]],\n                    [points[i][1], points[j][1]],\n                    '-', color=color, lw=lw, alpha=alpha)\n\n# 一些随机锚点\nnp.random.seed(42)\nanchors = np.random.uniform([0.5, 0.5], [8, 10.5], (15, 2))\ndraw_connecting_lines(ax, anchors, '#4169e1', 0.3, 0.08)\n\n# ========== 底部的量子电路抽象 ==========\ndef draw_quantum_circuit(ax, x, y, w, h, n_lines=4, color='#00d4ff', alpha=0.3):\n    \"\"\"底部简化的量子电路\"\"\"\n    for i in range(n_lines):\n        yy = y + i * h / (n_lines - 1)\n        ax.plot([x, x + w], [yy, yy], '-', color=color, lw=0.8, alpha=alpha)\n\n    # 门操作标记\n    for i in range(1, n_lines-1):\n        yy = y + i * h / (n_lines - 1)\n        for gx in [x + w*0.3, x + w*0.6]:\n            size = h / (n_lines - 1) * 0.3\n            rect = FancyBboxPatch((gx - size/2, yy - size/2), size, size,\n                                  boxstyle=\"round,pad=0.02\",\n                                  facecolor='none', edgecolor=color, lw=0.6, alpha=alpha*0.6)\n            ax.add_patch(rect)\n            # 交叉连线\n            if i < n_lines - 2:\n                yy2 = y + (i+1) * h / (n_lines - 1)\n                ax.plot([gx, gx], [yy + size/2, yy2 - size/2],\n                        '-', color=color, lw=0.4, alpha=alpha*0.4)\n\ndraw_quantum_circuit(ax, 0.8, 0.5, 4, 1.2, 5, '#7b68ee', 0.3)\ndraw_quantum_circuit(ax, 3.5, 0.3, 4.5, 1.5, 4, '#00bfff', 0.2)\n\n# ========== 标题文字 ==========\n# 使用 matplotlib ��文本作为标题\ntitle_props = dict(\n    fontsize=22, fontweight='bold',\n    color='#e0e0ff', alpha=0.9,\n    fontfamily='sans-serif',\n    horizontalalignment='center'\n)\nsub_props = dict(\n    fontsize=13, fontweight='normal',\n    color='#a0a0dd', alpha=0.7,\n    fontfamily='sans-serif',\n    horizontalalignment='center'\n)\n\n# 主标题 - 使用文本\nax.text(4.25, 9.8, 'TOPOLOGICAL QUANTUM COMPUTING', **title_props)\nax.text(4.25, 9.4, 'Non-Abelian Anyons & Topological Qubits', **sub_props)\n\n# 装饰性横线\nax.plot([1.5, 7.0], [9.2, 9.2], '-', color='#7b68ee', lw=1.0, alpha=0.5)\nax.plot([2.0, 6.5], [9.05, 9.05], '-', color='#4169e1', lw=0.5, alpha=0.3)\n\n# 底部小字\nax.text(4.25, 0.15, 'arXiv: 2026 | Quantum Information Theory',\n        fontsize=8, color='#606090', alpha=0.5,\n        fontfamily='sans-serif', horizontalalignment='center',\n        style='italic')\n\n# ========== 边框发光效果 ==========\n# 顶部和底部的光带\nfor y_pos, alpha in [(10.85, 0.15), (10.9, 0.08), (0.08, 0.1), (0.05, 0.06)]:\n    ax.axhline(y=y_pos, xmin=0.05, xmax=0.95, color='#7b68ee', lw=0.5, alpha=alpha)\n\n# ========== 任意子世界线特写 ==========\ndef draw_anyon_worldlines(ax, cx, cy, scale=1.0, color='#00d4ff'):\n    \"\"\"任意子世界线交织\"\"\"\n    t = np.linspace(0, 4*np.pi, 200)\n    for i in range(3):\n        offset = (i - 1) * 0.15 * scale\n        for j in range(3):\n            offset2 = (j - 1) * 0.15 * scale\n            x = cx + t * 0.08 * scale\n            y = cy + offset + offset2 * np.sin(t * 1.5 + i * np.pi/3)\n            alpha = 0.2 + 0.1 * np.sin(t + i)\n            ax.plot(x, y, '-', color=color, lw=0.6, alpha=0.3)\n\ndraw_anyon_worldlines(ax, 6.8, 5.5, 1.2, '#7b68ee')\ndraw_anyon_worldlines(ax, 7.0, 5.3, 1.0, '#00bfff')\n\n# ========== 额外的几何装饰 ==========\n# 半透明圆形光环\nfor cx, cy, r, alpha in [(5.8, 8.0, 0.8, 0.08), (5.8, 8.0, 1.1, 0.04),\n                          (2, 2.5, 1.2, 0.05), (7.5, 3, 1.0, 0.06)]:\n    circle = plt.Circle((cx, cy), r, fill=False, color='#7b68ee', lw=0.5, alpha=alpha)\n    ax.add_patch(circle)\n\n# ========== 散落的粒子 ==========\nnp.random.seed(123)\nstars_x = np.random.uniform(0, 8.5, 200)\nstars_y = np.random.uniform(0, 11, 200)\nstars_s = np.random.exponential(1, 200) * 2\nstars_a = np.random.uniform(0.1, 0.5, 200)\nax.scatter(stars_x, stars_y, s=stars_s, c='#8888cc', alpha=stars_a, edgecolors='none')\n\n# ========== 保存 ==========\nfig.savefig('/home/joe/Documents/repo/skill/sci-draw/quantum_cover.png',\n            dpi=300, bbox_inches='tight', pad_inches=0,\n            facecolor='black')\nplt.close()\n\nprint(\"✅ 图片已保存: quantum_cover.png\")\nprint(\"📐 尺寸: 8.5\\\" × 11\\\" (letter)，300 DPI\")\nprint(\"🎨 配色: 蓝紫色调，暗色背景\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/quantum_cover.py", "content": "#!/usr/bin/env python3\n\"\"\"\n论文封面：量子计算与拓扑量子比特\n风格：蓝紫色科幻几何风\n\"\"\"\n\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom matplotlib.patches import FancyBboxPatch, FancyArrowPatch, Circle, Polygon\nfrom matplotlib.collections import LineCollection\nimport matplotlib.patches as mpatches\n\n# ========== 全局设置 ==========\nfig = plt.figure(figsize=(8.5, 11), dpi=300)\nax = fig.add_axes([0, 0, 1, 1])\nax.set_xlim(0, 8.5)\nax.set_ylim(0, 11)\nax.axis('off')\n\n# ========== 蓝紫色渐变背景 ==========\nbg = np.zeros((1100, 850, 3))\nfor y in range(1100):\n    t = y / 1100\n    # 从深紫(0)渐变到深蓝(0.4)再到深紫(0.7+)再到黑色(1)\n    if t < 0.4:\n        s = t / 0.4\n        r = 0.02 + 0.03 * s\n        g = 0.00 + 0.05 * s\n        b = 0.12 + 0.15 * s\n    elif t < 0.7:\n        s = (t - 0.4) / 0.3\n        r = 0.05 - 0.02 * s\n        g = 0.05 + 0.08 * s\n        b = 0.27 - 0.05 * s\n    else:\n        s = (t - 0.7) / 0.3\n        r = 0.03 * (1 - s)\n        g = 0.13 * (1 - s)\n        b = 0.22 * (1 - s)\n    bg[y, :] = [r, g, b]\n\nax.imshow(bg, extent=[0, 8.5, 0, 11], aspect='auto', alpha=0.9)\n\n# ========== 辅助: 六边形晶格 ==========\ndef draw_hex_lattice(ax, cx, cy, radius, rows, cols, color, lw=0.4, alpha=0.3):\n    \"\"\"绘制六边形晶格\"\"\"\n    dx = radius * 1.5\n    dy = radius * np.sqrt(3)\n    hex_verts = []\n    for a in np.linspace(0, 2*np.pi, 7)[:6]:\n        hex_verts.append([np.cos(a), np.sin(a)])\n    hex_verts = np.array(hex_verts)\n\n    for r in range(rows):\n        for c in range(cols):\n            x = cx + c * dx\n            y = cy + r * dy\n            if r % 2 == 1:\n                x += dx / 2\n            verts = hex_verts * radius + np.array([x, y])\n            poly = Polygon(verts, closed=True, fill=False,\n                          edgecolor=color, lw=lw, alpha=alpha)\n            ax.add_patch(poly)\n            # 在六边形中心画一个小光点\n            ax.plot(x, y, 'o', color=color, markersize=1.5, alpha=alpha*0.5)\n\n# 背景六边形晶格 (代表拓扑量子比特的晶格结构)\ndraw_hex_lattice(ax, 1, 1, 0.2, 12, 8, '#7b68ee', lw=0.5, alpha=0.15)\ndraw_hex_lattice(ax, 1.15, 1.15, 0.22, 10, 7, '#4169e1', lw=0.3, alpha=0.08)\n\n# ========== 量子线/世界线 - 编织图案 (braiding) ==========\n# 拓扑量子比特的核心：任意子的编织操作\ndef draw_braid(ax, x_start, y_start, strands=3, length=8, amp=0.25, color='#00d4ff', lw=1.5, alpha=0.7):\n    \"\"\"绘制编织图案 (braiding)\"\"\"\n    ts = np.linspace(0, length, 500)\n    for i in range(strands):\n        y_offset = -i * 0.35\n        x = x_start + ts\n        y = y_start + y_offset\n        for j in range(int(length)):\n            t_seg = ts[j*50:min((j+1)*50+1, len(ts))]\n            if len(t_seg) < 2:\n                continue\n            # 编织：相邻 strand 交换位置\n            phase = 0\n            if (j // 2) % 2 == 0:\n                if i == 0:\n                    phase = amp * np.sin(t_seg * np.pi)\n                elif i == 1:\n                    phase = -amp * np.sin(t_seg * np.pi)\n            else:\n                if i == 1:\n                    phase = amp * np.sin(t_seg * np.pi)\n                elif i == 2:\n                    phase = -amp * np.sin(t_seg * np.pi)\n            x_seg = x_start + t_seg\n            y_seg = y_start + y_offset + phase\n            points = np.array([x_seg, y_seg]).T.reshape(-1, 1, 2)\n            segments = np.concatenate([points[:-1], points[1:]], axis=1)\n            lc = LineCollection(segments, colors=color, lw=lw, alpha=alpha)\n            ax.add_collection(lc)\n        # 每个 strand 末端画个光点\n        ax.plot(x[-1], y[-1], 'o', color=color, markersize=3, alpha=alpha+0.1)\n\n# 主编织图案\ndraw_braid(ax, 3.5, 7.5, strands=3, length=4.5, amp=0.3, color='#7b68ee', lw=2.0, alpha=0.6)\ndraw_braid(ax, 3.2, 7.8, strands=3, length=4.5, amp=0.25, color='#00bfff', lw=1.2, alpha=0.35)\n\n# ========== 拓扑量子比特 ==========\ndef draw_topological_qubit(ax, cx, cy, r, color1='#7b68ee', color2='#00d4ff', alpha=0.6):\n    \"\"\"拓扑量子比特表示：环面/甜甜圈上的任意子\"\"\"\n    # 主环 (torus 示意)\n    theta = np.linspace(0, 2*np.pi, 100)\n    phi = np.linspace(0, 2*np.pi, 50)\n\n    # 画一个2D投影环\n    circle_outer = plt.Circle((cx, cy), r, fill=False, color=color1, lw=1.5, alpha=alpha)\n    circle_inner = plt.Circle((cx, cy), r*0.4, fill=False, color=color2, lw=0.8, alpha=alpha*0.5)\n    ax.add_patch(circle_outer)\n    ax.add_patch(circle_inner)\n\n    # 用虚线表示内环\n    for a in np.linspace(0, 2*np.pi, 12):\n        x1 = cx + r * np.cos(a)\n        y1 = cy + r * np.sin(a)\n        x2 = cx + r * 0.4 * np.cos(a)\n        y2 = cy + r * 0.4 * np.sin(a)\n        ax.plot([x1, x2], [y1, y2], '-', color=color2, lw=0.3, alpha=alpha*0.2)\n\n    # 任意子 (anyon) 标记 - 小十字/旋量\n    for angle in [0, np.pi/2, np.pi, 3*np.pi/2]:\n        x = cx + r * 0.7 * np.cos(angle)\n        y = cy + r * 0.7 * np.sin(angle)\n        size = 0.04\n        ax.plot([x-size, x+size], [y, y], '-', color='#ff6eb4', lw=1, alpha=0.8)\n        ax.plot([x, x], [y-size, y+size], '-', color='#ff6eb4', lw=1, alpha=0.8)\n\n# 主量子比特\ndraw_topological_qubit(ax, 5.8, 8.0, 0.5, '#7b68ee', '#00d4ff', 0.7)\ndraw_topological_qubit(ax, 5.8, 8.0, 0.35, '#9b7eee', '#00ffff', 0.3)\n\n# ========== 抽象量子态 ==========\ndef draw_quantum_state(ax, cx, cy, r, n_pts=80, color='#00bfff'):\n    \"\"\"抽象量子态：概率云\"\"\"\n    angles = np.random.uniform(0, 2*np.pi, n_pts)\n    radii = np.random.exponential(0.3, n_pts) * r\n    xs = cx + radii * np.cos(angles)\n    ys = cy + radii * np.sin(angles)\n    sizes = np.random.uniform(1, 6, n_pts)\n    alpha_vals = np.random.uniform(0.1, 0.5, n_pts)\n    ax.scatter(xs, ys, s=sizes, c=color, alpha=alpha_vals, edgecolors='none')\n\n# 量子态云\ndraw_quantum_state(ax, 2, 2.5, 0.8, 120, '#00d4ff')\ndraw_quantum_state(ax, 2, 3.8, 0.5, 60, '#7b68ee')\n\n# ========== 几何装饰线条 ==========\n# 连线\ndef draw_connecting_lines(ax, points, color='#4169e1', lw=0.5, alpha=0.3):\n    for i in range(len(points)):\n        for j in range(i+1, len(points)):\n            ax.plot([points[i][0], points[j][0]],\n                    [points[i][1], points[j][1]],\n                    '-', color=color, lw=lw, alpha=alpha)\n\n# 一些随机锚点\nnp.random.seed(42)\nanchors = np.random.uniform([0.5, 0.5], [8, 10.5], (15, 2))\ndraw_connecting_lines(ax, anchors, '#4169e1', 0.3, 0.08)\n\n# ========== 底部的量子电路抽象 ==========\ndef draw_quantum_circuit(ax, x, y, w, h, n_lines=4, color='#00d4ff', alpha=0.3):\n    \"\"\"底部简化的量子电路\"\"\"\n    for i in range(n_lines):\n        yy = y + i * h / (n_lines - 1)\n        ax.plot([x, x + w], [yy, yy], '-', color=color, lw=0.8, alpha=alpha)\n\n    # 门操作标记\n    for i in range(1, n_lines-1):\n        yy = y + i * h / (n_lines - 1)\n        for gx in [x + w*0.3, x + w*0.6]:\n            size = h / (n_lines - 1) * 0.3\n            rect = FancyBboxPatch((gx - size/2, yy - size/2), size, size,\n                                  boxstyle=\"round,pad=0.02\",\n                                  facecolor='none', edgecolor=color, lw=0.6, alpha=alpha*0.6)\n            ax.add_patch(rect)\n            # 交叉连线\n            if i < n_lines - 2:\n                yy2 = y + (i+1) * h / (n_lines - 1)\n                ax.plot([gx, gx], [yy + size/2, yy2 - size/2],\n                        '-', color=color, lw=0.4, alpha=alpha*0.4)\n\ndraw_quantum_circuit(ax, 0.8, 0.5, 4, 1.2, 5, '#7b68ee', 0.3)\ndraw_quantum_circuit(ax, 3.5, 0.3, 4.5, 1.5, 4, '#00bfff', 0.2)\n\n# ========== 标题文字 ==========\n# 使用 matplotlib 的文本作为标题\ntitle_props = dict(\n    fontsize=22, fontweight='bold',\n    color='#e0e0ff', alpha=0.9,\n    fontfamily='sans-serif',\n    horizontalalignment='center'\n)\nsub_props = dict(\n    fontsize=13, fontweight='normal',\n    color='#a0a0dd', alpha=0.7,\n    fontfamily='sans-serif',\n    horizontalalignment='center'\n)\n\n# 主标题 - 使用文本\nax.text(4.25, 9.8, 'TOPOLOGICAL QUANTUM COMPUTING', **title_props)\nax.text(4.25, 9.4, 'Non-Abelian Anyons & Topological Qubits', **sub_props)\n\n# 装饰性横线\nax.plot([1.5, 7.0], [9.2, 9.2], '-', color='#7b68ee', lw=1.0, alpha=0.5)\nax.plot([2.0, 6.5], [9.05, 9.05], '-', color='#4169e1', lw=0.5, alpha=0.3)\n\n# 底部小字\nax.text(4.25, 0.15, 'arXiv: 2026 | Quantum Information Theory',\n        fontsize=8, color='#606090', alpha=0.5,\n        fontfamily='sans-serif', horizontalalignment='center',\n        style='italic')\n\n# ========== 边框发光效果 ==========\n# 顶部和底部的光带\nfor y_pos, alpha in [(10.85, 0.15), (10.9, 0.08), (0.08, 0.1), (0.05, 0.06)]:\n    ax.axhline(y=y_pos, xmin=0.05, xmax=0.95, color='#7b68ee', lw=0.5, alpha=alpha)\n\n# ========== 任意子世界线特写 ==========\ndef draw_anyon_worldlines(ax, cx, cy, scale=1.0, color='#00d4ff'):\n    \"\"\"任意子世界线交织\"\"\"\n    t = np.linspace(0, 4*np.pi, 200)\n    for i in range(3):\n        offset = (i - 1) * 0.15 * scale\n        for j in range(3):\n            offset2 = (j - 1) * 0.15 * scale\n            x = cx + t * 0.08 * scale\n            y = cy + offset + offset2 * np.sin(t * 1.5 + i * np.pi/3)\n            alpha = 0.2 + 0.1 * np.sin(t + i)\n            ax.plot(x, y, '-', color=color, lw=0.6, alpha=0.3)\n\ndraw_anyon_worldlines(ax, 6.8, 5.5, 1.2, '#7b68ee')\ndraw_anyon_worldlines(ax, 7.0, 5.3, 1.0, '#00bfff')\n\n# ========== 额外的几何装饰 ==========\n# 半透明圆形光环\nfor cx, cy, r, alpha in [(5.8, 8.0, 0.8, 0.08), (5.8, 8.0, 1.1, 0.04),\n                          (2, 2.5, 1.2, 0.05), (7.5, 3, 1.0, 0.06)]:\n    circle = plt.Circle((cx, cy), r, fill=False, color='#7b68ee', lw=0.5, alpha=alpha)\n    ax.add_patch(circle)\n\n# ========== 散落的粒子 ==========\nnp.random.seed(123)\nstars_x = np.random.uniform(0, 8.5, 200)\nstars_y = np.random.uniform(0, 11, 200)\nstars_s = np.random.exponential(1, 200) * 2\nstars_a = np.random.uniform(0.1, 0.5, 200)\nax.scatter(stars_x, stars_y, s=stars_s, c='#8888cc', alpha=stars_a, edgecolors='none')\n\n# ========== 保存 ==========\nfig.savefig('/home/joe/Documents/repo/skill/sci-draw/quantum_cover.png',\n            dpi=300, bbox_inches='tight', pad_inches=0,\n            facecolor='black')\nplt.close()\n\nprint(\"✅ 图片已保存: quantum_cover.png\")\nprint(\"📐 尺寸: 8.5\\\" × 11\\\" (letter)，300 DPI\")\nprint(\"🎨 配色: 蓝紫色调，暗色背景\")\n"})
