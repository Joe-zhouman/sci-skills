TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure2_scRNAseq.R", "content": "###############################################################################\n# Figure 2 – scRNA-seq Stacked Bar (a) & Volcano Plot (b)\n# Cell-journal submission grade\n#\n# Usage:\n#   1. Replace simulated data with your real data (see comments marked # REAL)\n#   2. Run: Rscript figure2_scRNAseq.R\n#   3. Outputs: output/Figure2a.pdf, Figure2b.pdf, Figure2.png (combined)\n###############################################################################\n\nsuppressPackageStartupMessages({\n  library(ggplot2)\n  library(ggrepel)\n  library(dplyr)\n  library(tidyr)\n  library(scales)\n  library(gridExtra)\n  library(grid)\n})\n\n# ---- Directories ----\ndir.create(\"output\", showWarnings = FALSE)\n\n# ===========================================================================\n# 1. COLOUR PALETTE (unified across panels)\n# ===========================================================================\n# Cell-friendly qualitative palette – 8 distinct colours suitable for\n# both clusters (stacked bar) and volcano highlight groups.\ncluster_palette <- c(\n  \"C1_T Cells\"     = \"#3B4992FF\",  # navy\n  \"C2_NK Cells\"    = \"#EE0000FF\",  # red\n  \"C3_B Cells\"     = \"#008B45FF\",  # green\n  \"C4_Monocytes\"   = \"#631879FF\",  # purple\n  \"C5_DCs\"         = \"#FF6A00FF\",  # orange\n  \"C6_Neutrophils\" = \"#5F559BFF\",  # lavender\n  \"C7_Fibroblasts\" = \"#A20056FF\",  # magenta\n  \"C8_Epithelial\"  = \"#00A9FFFF\"   # cyan\n)\n\n# Volcano annotation colours – derived from same palette\nvolcano_up_col   <- \"#EE0000FF\"   # up-regulated (cluster red)\nvolcano_down_col <- \"#3B4992FF\"   # down-regulated (cluster navy)\nvolcano_ns_col   <- \"grey65\"      # non-significant\n\n# ===========================================================================\n# 2. SIMULATE DATA — replace with your real data\n# ===========================================================================\n\n# ----- Panel a: Cluster proportions ---------------------------------------\nset.seed(2026)\nclusters <- names(cluster_palette)\nn_cells <- 5000\n\nsim_cell_data <- data.frame(\n  cell_barcode = paste0(\"cell_\", 1:n_cells),\n  cluster = sample(clusters, n_cells, replace = TRUE,\n                    prob = c(0.25, 0.15, 0.12, 0.18, 0.08, 0.10, 0.07, 0.05)),\n  condition = sample(c(\"Control\", \"Treatment\"), n_cells, replace = TRUE,\n                     prob = c(0.5, 0.5))\n)\n\n# Simulate condition-specific shifts: some clusters change proportion\nprop_shifts <- list(\n  \"C1_T Cells\"     = c(Control = 0.30, Treatment = 0.20),\n  \"C2_NK Cells\"    = c(Control = 0.10, Treatment = 0.20),\n  \"C3_B Cells\"     = c(Control = 0.12, Treatment = 0.12),\n  \"C4_Monocytes\"   = c(Control = 0.18, Treatment = 0.18),\n  \"C5_DCs\"         = c(Control = 0.05, Treatment = 0.11),\n  \"C6_Neutrophils\" = c(Control = 0.12, Treatment = 0.08),\n  \"C7_Fibroblasts\" = c(Control = 0.08, Treatment = 0.06),\n  \"C8_Epithelial\"  = c(Control = 0.05, Treatment = 0.05)\n)\n\nset.seed(42)\nprop_data <- do.call(rbind, lapply(names(prop_shifts), function(cl) {\n  ctrl_p <- prop_shifts[[cl]][\"Control\"]\n  trt_p  <- prop_shifts[[cl]][\"Treatment\"]\n  data.frame(\n    cluster   = cl,\n    condition = c(\"Control\", \"Treatment\"),\n    proportion = c(ctrl_p, trt_p),\n    count     = round(c(ctrl_p * 2000, trt_p * 2000))\n  )\n}))\n\n# REAL DATA SUBSTITUTION (Panel a):\n# Your real data should have columns: cluster, condition, proportion (0-1)\n# prop_data <- read.csv(\"your_cluster_proportions.csv\")\n# ------------------------------------------------------------------\n\n# ----- Panel b: Differential expression (volcano) --------------------------\nn_genes <- 2000\nset.seed(123)\n\nsim_de <- data.frame(\n  gene = paste0(\"Gene\", 1:n_genes),\n  baseMean = 10^runif(n_genes, 0.5, 4),\n  log2FC  = rnorm(n_genes, mean = 0, sd = 1.2),\n  pvalue  = runif(n_genes)\n)\n\n# Inject ~30 real DEGs\nn_degs <- 30\ndeg_idx <- sample(n_genes, n_degs)\nsim_de[deg_idx, \"log2FC\"] <- rnorm(n_degs, mean = ifelse(runif(n_degs) > 0.5, 2.5, -2.5), sd = 0.6)\nsim_de[deg_idx, \"pvalue\"] <- 10^runif(n_degs, -12, -4)\n\n# Name some top DEGs with recognisable gene symbols\nknown_genes <- c(\"CD8A\", \"GZMB\", \"CCL5\", \"IFNG\", \"GZMK\",\n                 \"FCGR3A\", \"CD14\", \"CD74\", \"HLA-DRA\", \"CD3E\",\n                 \"NKG7\", \"GNLY\", \"PRF1\", \"CST7\", \"FGFBP2\",\n                 \"SPON2\", \"KLRD1\", \"CD79A\", \"MS4A1\", \"CD19\",\n                 \"IL7R\", \"LEF1\", \"TCF7\", \"CCR7\", \"SELL\",\n                 \"S100A4\", \"S100A8\", \"VCAN\", \"LYZ\", \"FCN1\")\nn_known <- min(length(known_genes), n_degs)\nsim_de[deg_idx[1:n_known], \"gene\"] <- known_genes[1:n_known]\n\n# Adjusted p-value via Benjamini–Hochberg (simulated)\nsim_de$padj <- p.adjust(sim_de$pvalue, method = \"BH\")\n\n# Classify\nsim_de <- sim_de %>%\n  mutate(\n    de_status = case_when(\n      padj < 0.01 & abs(log2FC) >= 1  ~ ifelse(log2FC > 0, \"Up\", \"Down\"),\n      TRUE ~ \"NS\"\n    ),\n    neg_log10_padj = -log10(padj)\n  )\n\n# Clip extreme values for visualisation\nsim_de <- sim_de %>%\n  mutate(\n    log2FC_plot  = pmax(pmin(log2FC, 6), -6),\n    neg_log10_padj_plot = pmin(neg_log10_padj, 50)\n  )\n\n# Identify top genes to label on volcano\ntop_genes <- sim_de %>%\n  filter(de_status != \"NS\") %>%\n  group_by(de_status) %>%\n  arrange(desc(abs(log2FC))) %>%\n  slice_head(n = 8) %>%\n  ungroup()\n\n# REAL DATA SUBSTITUTION (Panel b):\n# Your real DE results should have columns: gene, log2FC, padj\n# sim_de <- read.csv(\"your_de_results.csv\")\n# Then re-run the mutate and top_genes steps above\n# ------------------------------------------------------------------\n\n# ===========================================================================\n# 3. PLOT — Panel a: Stacked Bar\n# ===========================================================================\n\np_stacked <- ggplot(prop_data, aes(x = condition, y = proportion, fill = cluster)) +\n  geom_bar(stat = \"identity\", width = 0.6, colour = \"white\", linewidth = 0.3) +\n  geom_text(aes(label = ifelse(proportion >= 0.04,\n                               paste0(round(proportion * 100), \"%\"), \"\")),\n            position = position_stack(vjust = 0.5),\n            size = 2.8, colour = \"white\", fontface = \"bold\") +\n  scale_fill_manual(values = cluster_palette, name = \"Cluster\") +\n  scale_y_continuous(labels = percent_format(),\n                     expand = c(0, 0)) +\n  labs(x = NULL, y = \"Proportion of cells\",\n       title = \"Cluster composition\") +\n  theme_classic(base_size = 11) +\n  theme(\n    plot.title = element_text(size = 12, face = \"bold\", hjust = 0.5),\n    axis.text  = element_text(colour = \"black\", size = 10),\n    axis.title = element_text(size = 11),\n    legend.position = \"right\",\n    legend.title = element_text(size = 9, face = \"bold\"),\n    legend.text  = element_text(size = 8),\n    legend.key.size = unit(0.45, \"cm\"),\n    plot.margin = margin(10, 5, 5, 5)\n  )\n\n# ===========================================================================\n# 4. PLOT — Panel b: Volcano\n# ===========================================================================\n\np_volcano <- ggplot(sim_de, aes(x = log2FC_plot, y = neg_log10_padj_plot)) +\n  geom_point(aes(colour = de_status), alpha = 0.6, size = 1.4) +\n  # Threshold lines\n  geom_vline(xintercept = c(-1, 1), linetype = \"dashed\", colour = \"grey40\", linewidth = 0.4) +\n  geom_hline(yintercept = -log10(0.01), linetype = \"dashed\", colour = \"grey40\", linewidth = 0.4) +\n  # Top gene labels\n  geom_text_repel(data = top_genes,\n                  aes(label = gene),\n                  size = 2.8,\n                  fontface = \"italic\",\n                  max.overlaps = 20,\n                  box.padding = 0.35,\n                  point.padding = 0.15,\n                  segment.colour = \"grey30\",\n                  segment.size = 0.3,\n                  min.segment.length = 0.1) +\n  scale_colour_manual(\n    values = c(\"Up\" = volcano_up_col, \"Down\" = volcano_down_col, \"NS\" = volcano_ns_col),\n    labels = c(\"Up\" = paste0(\"Up (n=\", sum(sim_de$de_status == \"Up\"), \")\"),\n               \"Down\" = paste0(\"Down (n=\", sum(sim_de$de_status == \"Down\"), \")\"),\n               \"NS\" = \"NS\"),\n    name = \"DEG status\"\n  ) +\n  scale_x_continuous(limits = c(-6.5, 6.5), expand = c(0.02, 0.02)) +\n  scale_y_continuous(limits = c(0, NA), expand = c(0.02, 0.1)) +\n  labs(x = expression(log[2]~\"(Fold Change: Treatment / Control)\"),\n       y = expression(-log[10]~\"(adjusted \"*italic(P)*\"-value)\"),\n       title = \"Differentially expressed genes\") +\n  theme_classic(base_size = 11) +\n  theme(\n    plot.title = element_text(size = 12, face = \"bold\", hjust = 0.5),\n    axis.text  = element_text(colour = \"black\", size = 10),\n    axis.title = element_text(size = 11),\n    legend.position = \"right\",\n    legend.title = element_text(size = 9, face = \"bold\"),\n    legend.text  = element_text(size = 8),\n    legend.key.size = unit(0.45, \"cm\"),\n    plot.margin = margin(10, 5, 5, 5)\n  )\n\n# ===========================================================================\n# 5. EXPORT\n# ===========================================================================\n\n# --- Individual panels (PDF vector) ---\nggsave(\"output/Figure2a.pdf\", p_stacked, width = 5, height = 4, device = \"pdf\")\nggsave(\"output/Figure2b.pdf\", p_volcano, width = 5.5, height = 4, device = \"pdf\")\n\n# --- Combined figure (PNG raster, high-res) ---\nfig2 <- arrangeGrob(\n  p_stacked, p_volcano,\n  ncol = 2,\n  widths = c(1, 1.15),\n  top = textGrob(\"Figure 2\", gp = gpar(fontface = \"bold\", fontsize = 14),\n                 x = unit(0.02, \"npc\"), hjust = 0)\n)\n\nggsave(\"output/Figure2.png\", fig2, width = 11, height = 4.5, dpi = 300,\n       device = \"png\")\n\n# Also export a high-res PDF of the combined layout (editable in Illustrator)\nggsave(\"output/Figure2.pdf\", fig2, width = 11, height = 4.5, device = \"pdf\")\n\ncat(\"✓ Figure 2 exported:\\n\")\ncat(\"  output/Figure2a.pdf    (Panel a – stacked bar)\\n\")\ncat(\"  output/Figure2b.pdf    (Panel b – volcano)\\n\")\ncat(\"  output/Figure2.pdf     (Combined vector PDF)\\n\")\ncat(\"  output/Figure2.png     (Combined 300 dpi PNG)\\n\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure2_scRNAseq.R", "content": "###############################################################################\n# Figure 2 – scRNA-seq Stacked Bar (a) & Volcano Plot (b)\n# Cell-journal submission grade\n#\n# Usage:\n#   1. Replace simulated data with your real data (see comments marked # REAL)\n#   2. Run: Rscript figure2_scRNAseq.R\n#   3. Outputs: output/Figure2a.pdf, Figure2b.pdf, Figure2.png (combined)\n###############################################################################\n\nsuppressPackageStartupMessages({\n  library(ggplot2)\n  library(ggrepel)\n  library(dplyr)\n  library(tidyr)\n  library(scales)\n  library(gridExtra)\n  library(grid)\n})\n\n# ---- Directories ----\ndir.create(\"output\", showWarnings = FALSE)\n\n# ===========================================================================\n# 1. COLOUR PALETTE (unified across panels)\n# ===========================================================================\n# Cell-friendly qualitative palette – 8 distinct colours suitable for\n# both clusters (stacked bar) and volcano highlight groups.\ncluster_palette <- c(\n  \"C1_T Cells\"     = \"#3B4992FF\",  # navy\n  \"C2_NK Cells\"    = \"#EE0000FF\",  # red\n  \"C3_B Cells\"     = \"#008B45FF\",  # green\n  \"C4_Monocytes\"   = \"#631879FF\",  # purple\n  \"C5_DCs\"         = \"#FF6A00FF\",  # orange\n  \"C6_Neutrophils\" = \"#5F559BFF\",  # lavender\n  \"C7_Fibroblasts\" = \"#A20056FF\",  # magenta\n  \"C8_Epithelial\"  = \"#00A9FFFF\"   # cyan\n)\n\n# Volcano annotation colours – derived from same palette\nvolcano_up_col   <- \"#EE0000FF\"   # up-regulated (cluster red)\nvolcano_down_col <- \"#3B4992FF\"   # down-regulated (cluster navy)\nvolcano_ns_col   <- \"grey65\"      # non-significant\n\n# ===========================================================================\n# 2. SIMULATE DATA — replace with your real data\n# ===========================================================================\n\n# ----- Panel a: Cluster proportions ---------------------------------------\nset.seed(2026)\nclusters <- names(cluster_palette)\nn_cells <- 5000\n\nsim_cell_data <- data.frame(\n  cell_barcode = paste0(\"cell_\", 1:n_cells),\n  cluster = sample(clusters, n_cells, replace = TRUE,\n                    prob = c(0.25, 0.15, 0.12, 0.18, 0.08, 0.10, 0.07, 0.05)),\n  condition = sample(c(\"Control\", \"Treatment\"), n_cells, replace = TRUE,\n                     prob = c(0.5, 0.5))\n)\n\n# Simulate condition-specific shifts: some clusters change proportion\nprop_shifts <- list(\n  \"C1_T Cells\"     = c(Control = 0.30, Treatment = 0.20),\n  \"C2_NK Cells\"    = c(Control = 0.10, Treatment = 0.20),\n  \"C3_B Cells\"     = c(Control = 0.12, Treatment = 0.12),\n  \"C4_Monocytes\"   = c(Control = 0.18, Treatment = 0.18),\n  \"C5_DCs\"         = c(Control = 0.05, Treatment = 0.11),\n  \"C6_Neutrophils\" = c(Control = 0.12, Treatment = 0.08),\n  \"C7_Fibroblasts\" = c(Control = 0.08, Treatment = 0.06),\n  \"C8_Epithelial\"  = c(Control = 0.05, Treatment = 0.05)\n)\n\nset.seed(42)\nprop_data <- do.call(rbind, lapply(names(prop_shifts), function(cl) {\n  ctrl_p <- prop_shifts[[cl]][\"Control\"]\n  trt_p  <- prop_shifts[[cl]][\"Treatment\"]\n  data.frame(\n    cluster   = cl,\n    condition = c(\"Control\", \"Treatment\"),\n    proportion = c(ctrl_p, trt_p),\n    count     = round(c(ctrl_p * 2000, trt_p * 2000))\n  )\n}))\n\n# REAL DATA SUBSTITUTION (Panel a):\n# Your real data should have columns: cluster, condition, proportion (0-1)\n# prop_data <- read.csv(\"your_cluster_proportions.csv\")\n# ------------------------------------------------------------------\n\n# ----- Panel b: Differential expression (volcano) --------------------------\nn_genes <- 2000\nset.seed(123)\n\nsim_de <- data.frame(\n  gene = paste0(\"Gene\", 1:n_genes),\n  baseMean = 10^runif(n_genes, 0.5, 4),\n  log2FC  = rnorm(n_genes, mean = 0, sd = 1.2),\n  pvalue  = runif(n_genes)\n)\n\n# Inject ~30 real DEGs\nn_degs <- 30\ndeg_idx <- sample(n_genes, n_degs)\nsim_de[deg_idx, \"log2FC\"] <- rnorm(n_degs, mean = ifelse(runif(n_degs) > 0.5, 2.5, -2.5), sd = 0.6)\nsim_de[deg_idx, \"pvalue\"] <- 10^runif(n_degs, -12, -4)\n\n# Name some top DEGs with recognisable gene symbols\nknown_genes <- c(\"CD8A\", \"GZMB\", \"CCL5\", \"IFNG\", \"GZMK\",\n                 \"FCGR3A\", \"CD14\", \"CD74\", \"HLA-DRA\", \"CD3E\",\n                 \"NKG7\", \"GNLY\", \"PRF1\", \"CST7\", \"FGFBP2\",\n                 \"SPON2\", \"KLRD1\", \"CD79A\", \"MS4A1\", \"CD19\",\n                 \"IL7R\", \"LEF1\", \"TCF7\", \"CCR7\", \"SELL\",\n                 \"S100A4\", \"S100A8\", \"VCAN\", \"LYZ\", \"FCN1\")\nn_known <- min(length(known_genes), n_degs)\nsim_de[deg_idx[1:n_known], \"gene\"] <- known_genes[1:n_known]\n\n# Adjusted p-value via Benjamini–Hochberg (simulated)\nsim_de$padj <- p.adjust(sim_de$pvalue, method = \"BH\")\n\n# Classify\nsim_de <- sim_de %>%\n  mutate(\n    de_status = case_when(\n      padj < 0.01 & abs(log2FC) >= 1  ~ ifelse(log2FC > 0, \"Up\", \"Down\"),\n      TRUE ~ \"NS\"\n    ),\n    neg_log10_padj = -log10(padj)\n  )\n\n# Clip extreme values for visualisation\nsim_de <- sim_de %>%\n  mutate(\n    log2FC_plot  = pmax(pmin(log2FC, 6), -6),\n    neg_log10_padj_plot = pmin(neg_log10_padj, 50)\n  )\n\n# Identify top genes to label on volcano\ntop_genes <- sim_de %>%\n  filter(de_status != \"NS\") %>%\n  group_by(de_status) %>%\n  arrange(desc(abs(log2FC))) %>%\n  slice_head(n = 8) %>%\n  ungroup()\n\n# REAL DATA SUBSTITUTION (Panel b):\n# Your real DE results should have columns: gene, log2FC, padj\n# sim_de <- read.csv(\"your_de_results.csv\")\n# Then re-run the mutate and top_genes steps above\n# ------------------------------------------------------------------\n\n# ===========================================================================\n# 3. PLOT — Panel a: Stacked Bar\n# ===========================================================================\n\np_stacked <- ggplot(prop_data, aes(x = condition, y = proportion, fill = cluster)) +\n  geom_bar(stat = \"identity\", width = 0.6, colour = \"white\", linewidth = 0.3) +\n  geom_text(aes(label = ifelse(proportion >= 0.04,\n                               paste0(round(proportion * 100), \"%\"), \"\")),\n            position = position_stack(vjust = 0.5),\n            size = 2.8, colour = \"white\", fontface = \"bold\") +\n  scale_fill_manual(values = cluster_palette, name = \"Cluster\") +\n  scale_y_continuous(labels = percent_format(),\n                     expand = c(0, 0)) +\n  labs(x = NULL, y = \"Proportion of cells\",\n       title = \"Cluster composition\") +\n  theme_classic(base_size = 11) +\n  theme(\n    plot.title = element_text(size = 12, face = \"bold\", hjust = 0.5),\n    axis.text  = element_text(colour = \"black\", size = 10),\n    axis.title = element_text(size = 11),\n    legend.position = \"right\",\n    legend.title = element_text(size = 9, face = \"bold\"),\n    legend.text  = element_text(size = 8),\n    legend.key.size = unit(0.45, \"cm\"),\n    plot.margin = margin(10, 5, 5, 5)\n  )\n\n# ===========================================================================\n# 4. PLOT — Panel b: Volcano\n# ===========================================================================\n\np_volcano <- ggplot(sim_de, aes(x = log2FC_plot, y = neg_log10_padj_plot)) +\n  geom_point(aes(colour = de_status), alpha = 0.6, size = 1.4) +\n  # Threshold lines\n  geom_vline(xintercept = c(-1, 1), linetype = \"dashed\", colour = \"grey40\", linewidth = 0.4) +\n  geom_hline(yintercept = -log10(0.01), linetype = \"dashed\", colour = \"grey40\", linewidth = 0.4) +\n  # Top gene labels\n  geom_text_repel(data = top_genes,\n                  aes(label = gene),\n                  size = 2.8,\n                  fontface = \"italic\",\n                  max.overlaps = 20,\n                  box.padding = 0.35,\n                  point.padding = 0.15,\n                  segment.colour = \"grey30\",\n                  segment.size = 0.3,\n                  min.segment.length = 0.1) +\n  scale_colour_manual(\n    values = c(\"Up\" = volcano_up_col, \"Down\" = volcano_down_col, \"NS\" = volcano_ns_col),\n    labels = c(\"Up\" = paste0(\"Up (n=\", sum(sim_de$de_status == \"Up\"), \")\"),\n               \"Down\" = paste0(\"Down (n=\", sum(sim_de$de_status == \"Down\"), \")\"),\n               \"NS\" = \"NS\"),\n    name = \"DEG status\"\n  ) +\n  scale_x_continuous(limits = c(-6.5, 6.5), expand = c(0.02, 0.02)) +\n  scale_y_continuous(limits = c(0, NA), expand = c(0.02, 0.1)) +\n  labs(x = expression(log[2]~\"(Fold Change: Treatment / Control)\"),\n       y = expression(-log[10]~\"(adjusted \"*italic(P)*\"-value)\"),\n       title = \"Differentially expressed genes\") +\n  theme_classic(base_size = 11) +\n  theme(\n    plot.title = element_text(size = 12, face = \"bold\", hjust = 0.5),\n    axis.text  = element_text(colour = \"black\", size = 10),\n    axis.title = element_text(size = 11),\n    legend.position = \"right\",\n    legend.title = element_text(size = 9, face = \"bold\"),\n    legend.text  = element_text(size = 8),\n    legend.key.size = unit(0.45, \"cm\"),\n    plot.margin = margin(10, 5, 5, 5)\n  )\n\n# ===========================================================================\n# 5. EXPORT\n# ===========================================================================\n\n# --- Individual panels (PDF vector) ---\nggsave(\"output/Figure2a.pdf\", p_stacked, width = 5, height = 4, device = \"pdf\")\nggsave(\"output/Figure2b.pdf\", p_volcano, width = 5.5, height = 4, device = \"pdf\")\n\n# --- Combined figure (PNG raster, high-res) ---\nfig2 <- arrangeGrob(\n  p_stacked, p_volcano,\n  ncol = 2,\n  widths = c(1, 1.15),\n  top = textGrob(\"Figure 2\", gp = gpar(fontface = \"bold\", fontsize = 14),\n                 x = unit(0.02, \"npc\"), hjust = 0)\n)\n\nggsave(\"output/Figure2.png\", fig2, width = 11, height = 4.5, dpi = 300,\n       device = \"png\")\n\n# Also export a high-res PDF of the combined layout (editable in Illustrator)\nggsave(\"output/Figure2.pdf\", fig2, width = 11, height = 4.5, device = \"pdf\")\n\ncat(\"✓ Figure 2 exported:\\n\")\ncat(\"  output/Figure2a.pdf    (Panel a – stacked bar)\\n\")\ncat(\"  output/Figure2b.pdf    (Panel b – volcano)\\n\")\ncat(\"  output/Figure2.pdf     (Combined vector PDF)\\n\")\ncat(\"  output/Figure2.png     (Combined 300 dpi PNG)\\n\")\n"})
