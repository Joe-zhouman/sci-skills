n frames\n\n\n# ---------------------------------------------------------------------------\n# 2.  Missing-value handling\n# ---------------------------------------------------------------------------\n\ndef detect_missing_report(df: pd.DataFrame, name: str) -> pd.DataFrame:\n    \"\"\"Log per-column null / user-defined missing counts; return report.\"\"\"\n    report = pd.DataFrame({\n        \"dtype\": df.dtypes,\n        \"n_nulls\": df.isnull().sum(),\n        \"null_pct\": (df.isnull().mean() * 100).round(1),\n    })\n    log.info(\"Missing-value summary for «%s»:\\n%s\", name, report.to_string())\n    return report\n\n\ndef impute_missing(\n    df: pd.DataFrame,\n    numeric_strategy: str = \"median\",\n    categorical_strategy: str = \"mode\",\n    fill_values: dict[str, object] | None = None,\n    extra_na: list[object] | None = None,\n) -> pd.DataFrame:\n    \"\"\"\n    Impute missing values.\n\n    Parameters\n    ----------\n    numeric_strategy : \"median\" | \"mean\" | \"zero\" | \"drop\"\n        How to handle NaN in numeric columns.  \"zero\" fills 0.\n    categorical_strategy : \"mode\" | \"drop\" | \"<literal>\"\n        How to handle NaN in object/category columns.  A plain string\n        (e.g. ``\"Unknown\"``) is used as the fill value.\n    fill_values : dict, optional\n        Column-specific overrides, e.g. ``{\"age\": -1, \"city\": \"NYC\"}``.\n    extra_na : list, optional\n        Additional values to treat as missing (e.g. ``[\"?\", \"N/A\", \"-\"]``).\n    \"\"\"\n    df = df.replace(extra_na, np.nan) if extra_na else df.copy()\n    fill_values = fill_values or {}\n\n    # ---- column-specific overrides ----\n    for col, val in fill_values.items():\n        if col in df.columns:\n            df[col] = df[col].fillna(val)\n\n    for col in df.columns:\n        if col in fill_values:\n            continue  # already handled\n\n        if pd.api.types.is_numeric_dtype(df[col]):\n            n_null = df[col].isnull().sum()\n            if n_null == 0:\n                continue\n\n            if numeric_strategy == \"drop\":\n                df.dropna(subset=[col], inplace=True)\n            elif numeric_strategy == \"zero\":\n                df[col] = df[col].fillna(0)\n            elif numeric_strategy in (\"median\", \"mean\"):\n                fn = df[col].median if numeric_strategy == \"median\" else df[col].mean\n                df[col] = df[col].fillna(fn())\n            else:\n                raise ValueError(f\"Unknown numeric_strategy: {numeric_strategy}\")\n\n        elif pd.api.types.is_object_dtype(df[col]) or isinstance(\n            df[col].dtype, pd.CategoricalDtype\n        ):\n            n_null = df[col].isnull().sum()\n            if n_null == 0:\n                continue\n\n            if categorical_strategy == \"drop\":\n                df.dropna(subset=[col], inplace=True)\n            elif categorical_strategy == \"mode\":\n                mode_val = df[col].mode()\n                df[col] = df[col].fillna(mode_val[0] if not mode_val.empty else \"MISSING\")\n            else:\n                df[col] = df[col].fillna(categorical_strategy)\n\n    return df\n\n\n# ---------------------------------------------------------------------------\n# 3.  Outlier capping (optional)\n# ---------------------------------------------------------------------------\n\ndef cap_outliers(\n    df: pd.DataFrame,\n    columns: list[str] | None = None,\n    method: str = \"iqr\",\n    factor: float = 1.5,\n    lower: float | None = None,\n    upper: float | None = None,\n) -> pd.DataFrame:\n    \"\"\"\n    Cap extreme values in numeric columns.\n\n    Parameters\n    ----------\n    method : \"iqr\" | \"zscore\" | \"clip\"\n        - ``\"iqr\"``   : values beyond Q1 - factor*IQR / Q3 + factor*IQR\n        - ``\"zscore\"``: values where |z-score| > *factor*\n        - ``\"clip\"``  : hard *lower* / *upper* bounds\n    factor : float\n        Multiplier for IQR or z-score threshold.\n    lower / upper : float, optional\n        Hard bounds used when method=\"clip\".\n    \"\"\"\n    cols = columns or df.select_dtypes(include=[np.number]).columns.tolist()\n    df = df.copy()\n\n    for col in cols:\n        if col not in df.columns or not pd.api.types.is_numeric_dtype(df[col]):\n            continue\n        vals = df[col].dropna()\n        if vals.empty:\n            continue\n\n        if method == \"iqr\":\n            q1, q3 = vals.quantile(0.25), vals.quantile(0.75)\n            iqr = q3 - q1\n            lo, hi = q1 - factor * iqr, q3 + factor * iqr\n        elif method == \"zscore\":\n            mean, std = vals.mean(), vals.std()\n            lo, hi = mean - factor * std, mean + factor * std\n        elif method == \"clip\":\n            lo = lower if lower is not None else vals.min()\n            hi = upper if upper is not None else vals.max()\n        else:\n            raise ValueError(f\"Unknown method: {method}\")\n\n        n = ((df[col] < lo) | (df[col] > hi)).sum()\n        if n:\n            df[col] = df[col].clip(lo, hi)\n            log.info(\"Capped %d value(s) in «%s» to [%.4g, %.4g]\", n, col, lo, hi)\n    return df\n\n\n# ---------------------------------------------------------------------------\n# 4.  Column standardization\n# ---------------------------------------------------------------------------\n\ndef standardize_numeric(\n    df: pd.DataFrame,\n    columns: list[str] | None = None,\n    method: str = \"standard\",\n) -> tuple[pd.DataFrame, dict]:\n    \"\"\"\n    Scale numeric columns.\n\n    Parameters\n    ----------\n    method : \"standard\" | \"minmax\" | \"log\" | \"rank\"\n        - ``\"standard\"`` : zero-mean unit-variance (z-score).\n        - ``\"minmax\"``   : scale to [0, 1].\n        - ``\"log\"``      : log1p transform (unscaled).\n        - ``\"rank\"``     : rank transform.\n    Returns\n    -------\n    (transformed_df, scaler_metadata)\n    \"\"\"\n    cols = columns or df.select_dtypes(include=[np.number]).columns.tolist()\n    df = df.copy()\n    meta: dict[str, object] = {\"method\": method, \"columns\": {}}\n\n    if method in (\"standard\", \"minmax\"):\n        scaler_cls = StandardScaler if method == \"standard\" else MinMaxScaler\n        scaler = scaler_cls()\n        df[cols] = scaler.fit_transform(df[cols])\n        meta[\"scaler\"] = scaler  # save for inverse-transform later\n        for i, col in enumerate(cols):\n            meta[\"columns\"][col] = {}\n    elif method == \"log\":\n        for col in cols:\n            df[col] = np.log1p(df[col].clip(lower=0))\n            meta[\"columns\"][col] = {\"transform\": \"log1p\"}\n    elif method == \"rank\":\n        for col in cols:\n            df[col] = df[col].rank(pct=True)\n            meta[\"columns\"][col] = {\"transform\": \"rank_pct\"}\n    else:\n        raise ValueError(f\"Unknown method: {method}\")\n\n    log.info(\"Standardized %d column(s) via «%s»\", len(cols), method)\n    return df, meta\n\n\n# ---------------------------------------------------------------------------\n# 5.  Categorical encoding (one-hot)\n# ---------------------------------------------------------------------------\n\ndef onehot_encode(\n    df: pd.DataFrame,\n    columns: list[str] | None = None,\n    drop_first: bool = False,\n    max_categories: int | None = 50,\n    min_freq: int | None = None,\n    na_sentinel: bool = True,\n) -> pd.DataFrame:\n    \"\"\"\n    One-hot encode categorical columns.\n\n    Parameters\n    ----------\n    columns : list of str, optional\n        Columns to encode.  If None, all object / category dtypes are used.\n    drop_first : bool\n        Drop the first category to avoid dummy-variable trap.\n    max_categories : int, optional\n        Skip columns with more than this many unique values (log a warning).\n    min_freq : int, optional\n        Group categories appearing fewer than *min_freq* times into \"other\".\n    na_sentinel : bool\n        If True, keep NaN as its own category (``pd.get_dummies(dummy_na=True)``).\n    \"\"\"\n    if columns is None:\n        columns = df.select_dtypes(include=[\"object\", \"category\"]).columns.tolist()\n    if not columns:\n        return df\n\n    df = df.copy()\n\n    for col in columns:\n        if col not in df.columns:\n            continue\n\n        n_unique = df[col].nunique(dropna=False)\n\n        if max_categories and n_unique > max_categories:\n            log.warning(\n                \"Skipping one-hot for «%s» — %d unique values (max=%d). \"\n                \"Consider feature hashing or target encoding instead.\",\n                col, n_unique, max_categories,\n            )\n            continue\n\n        # ---- rare-category grouping ----\n        if min_freq is not None and pd.api.types.is_object_dtype(df[col]):\n            counts = df[col].value_counts()\n            rare = counts[counts < min_freq].index\n            if len(rare):\n                df[col] = df[col].replace(rare, \"other\")\n                log.info(\n                    \"Grouped %d rare value(s) in «%s» → 'other'\",\n                    len(rare), col,\n                )\n\n        # ---- one-hot ----\n        dummies = pd.get_dummies(\n            df[col],\n            prefix=col,\n            drop_first=drop_first,\n            dummy_na=na_sentinel and df[col].isnull().any(),\n        ).astype(int)\n\n        df = pd.concat([df.drop(columns=[col]), dummies], axis=1)\n\n    log.info(\"One-hot encoded %d column(s)\", len(columns))\n    return df\n\n\n# ---------------------------------------------------------------------------\n# 6.  Merge into a single feature matrix\n# ---------------------------------------------------------------------------\n\ndef merge_frames(\n    frames: dict[str, pd.DataFrame],\n    merge_on: str | list[str] | None = None,\n    how: str = \"outer\",\n    fill_value: object = 0,\n) -> pd.DataFrame:\n    \"\"\"\n    Merge multiple DataFrames into one feature matrix.\n\n    Parameters\n    ----------\n    merge_on : str | list of str, optional\n        Key column(s) for merge (e.g. an ``\"id\"`` column).\n        If None, frames are concatenated **column-wise** (axis=1).\n        The caller should ensure rows correspond.\n    how : \"outer\" | \"inner\" | \"left\" | \"right\"\n        Merge method when *merge_on* is given.\n    fill_value : object\n        Fill NaN after merge with this value (default 0).\n\n    Returns\n    -------\n    Merged DataFrame (index reset).\n    \"\"\"\n    names = list(frames.keys())\n\n    if merge_on is None:\n        # ------ column-wise concatenation ------\n        result = pd.concat(list(frames.values()), axis=1, join=\"outer\")\n        log.info(\"Concatenated %d frame(s) column-wise → %s\", len(names), result.shape)\n    else:\n        # ------ key-based merge ------\n        keys = [merge_on] if isinstance(merge_on, str) else merge_on\n        result = frames[names[0]]\n        for name in names[1:]:\n            result = result.merge(frames[name], on=keys, how=how, suffixes=(\"\", f\"_{name}\"))\n        log.info(\"Merged %d frame(s) on %s → %s\", len(names), keys, result.shape)\n\n    if fill_value is not None:\n        n_before = result.isnull().sum().sum()\n        result = result.fillna(fill_value)\n        n_after = result.isnull().sum().sum()\n        if n_before:\n            log.info(\"Filled %d NaN(s) with %r after merge\", n_before - n_after, fill_value)\n\n    return result.reset_index(drop=True)\n\n\n# ---------------------------------------------------------------------------\n# 7.  Full pipeline convenience\n# ---------------------------------------------------------------------------\n\ndef run_pipeline(\n    data_dir: str,\n    csv_kwargs: dict | None = None,\n    extra_na: list[object] | None = None,\n    numeric_strategy: str = \"median\",\n    categorical_strategy: str = \"mode\",\n    fill_values: dict[str, object] | None = None,\n    cap_kwargs: dict | None = None,\n    scale_method: str = \"standard\",\n    drop_first: bool = False,\n    max_categories: int = 50,\n    min_freq: int | None = None,\n    merge_on: str | list[str] | None = None,\n    merge_how: str = \"outer\",\n    merge_fill: object = 0,\n    output_path: str | None = \"feature_matrix.csv\",\n) -> pd.DataFrame:\n    \"\"\"\n    End-to-end data preprocessing pipeline.\n\n    Steps\n    -----\n    1. Discover and load CSVs\n    2. Impute missing values\n    3. (Optional) cap outliers\n    4. Standardize numeric columns\n    5. One-hot encode categorical columns\n    6. Merge into feature matrix\n    7. Export to CSV\n\n    Returns the merged DataFrame.\n    \"\"\"\n\n    # --- Step 1: Load ---\n    paths = discover_csvs(data_dir)\n    frames = load_csvs(paths, **(csv_kwargs or {}))\n\n    # --- Steps 2-5 per frame ---\n    processed: dict[str, pd.DataFrame] = {}\n    for name, df in frames.items():\n        log.info(\"=\" * 50)\n        log.info(\"Processing «%s» …\", name)\n\n        # 2 — impute\n        detect_missing_report(df, name)\n        df = impute_missing(\n            df,\n            numeric_strategy=numeric_strategy,\n            categorical_strategy=categorical_strategy,\n            fill_values=fill_values,\n            extra_na=extra_na,\n        )\n\n        # 3 — cap (optional)\n        if cap_kwargs:\n            df = cap_outliers(df, **cap_kwargs)\n\n        # 4 — scale numeric\n        df, _ = standardize_numeric(df, method=scale_method)\n\n        # 5 — one-hot\n        df = onehot_encode(\n            df,\n            drop_first=drop_first,\n            max_categories=max_categories,\n            min_freq=min_freq,\n        )\n\n        log.info(\"«%s»  post-process  %s rows × %s cols\", name, *df.shape)\n        processed[name] = df\n\n    # --- Step 6: Merge ---\n    log.info(\"=\" * 50)\n    result = merge_frames(processed, merge_on=merge_on, how=merge_how, fill_value=merge_fill)\n\n    # --- Step 7: Export ---\n    if output_path:\n        result.to_csv(output_path, index=False)\n        log.info(\"Exported feature matrix → %s  (%s)\", output_path, result.shape)\n\n    return result\n\n\n# ---------------------------------------------------------------------------\n# 8.  CLI\n# ---------------------------------------------------------------------------\n\ndef _parse_list(value: str) -> list[str]:\n    return [v.strip() for v in value.split(\",\") if v.strip()]\n\n\ndef build_parser() -> argparse.ArgumentParser:\n    p = argparse.ArgumentParser(\n        description=\"Multi-CSV data preprocessing pipeline.\",\n        formatter_class=argparse.RawDescriptionHelpFormatter,\n        epilog=__doc__,\n    )\n    p.add_argument(\"data_dir\", help=\"Directory containing CSV files\")\n    p.add_argument(\"-o\", \"--output\", default=\"feature_matrix.csv\",\n                    help=\"Output CSV path (default: feature_matrix.csv)\")\n    p.add_argument(\"--sep\", default=\",\", help=\"CSV delimiter (default: comma)\")\n    p.add_argument(\"--encoding\", default=\"utf-8\", help=\"CSV encoding\")\n    p.add_argument(\"--extra-na\", type=_parse_list, default=None,\n                    help=\"Extra NA sentinels, comma-separated (e.g. '?,N/A,-')\")\n    p.add_argument(\"--numeric-strategy\", default=\"median\",\n                    choices=[\"median\", \"mean\", \"zero\", \"drop\"])\n    p.add_argument(\"--cat-strategy\", default=\"mode\",\n                    help=\"'mode', 'drop', or a literal fill string\")\n    p.add_argument(\"--scale\", default=\"standard\",\n                    choices=[\"standard\", \"minmax\", \"log\", \"rank\"])\n    p.add_argument(\"--drop-first\", action=\"store_true\",\n                    help=\"Drop first category in one-hot encoding\")\n    p.add_argument(\"--max-categories\", type=int, default=50,\n                    help=\"Skip one-hot for cols with > N unique values\")\n    p.add_argument(\"--min-freq\", type=int, default=None,\n                    help=\"Group rare categories (< N) into 'other'\")\n    p.add_argument(\"--merge-on\", type=_parse_list, default=None,\n                    help=\"Key column(s) for merge, comma-separated\")\n    p.add_argument(\"--merge-how\", default=\"outer\",\n                    choices=[\"outer\", \"inner\", \"left\", \"right\"])\n    p.add_argument(\"--cap-method\", default=None,\n                    choices=[\"iqr\", \"zscore\", \"clip\"])\n    p.add_argument(\"--cap-factor\", type=float, default=1.5)\n    p.add_argument(\"--cap-lower\", type=float, default=None)\n    p.add_argument(\"--cap-upper\", type=float, default=None)\n    return p\n\n\ndef main():\n    parser = build_parser()\n    args = parser.parse_args()\n\n    cap_kwargs = None\n    if args.cap_method:\n        cap_kwargs = {\n            \"method\": args.cap_method,\n            \"factor\": args.cap_factor,\n        }\n        if args.cap_lower is not None:\n            cap_kwargs[\"lower\"] = args.cap_lower\n        if args.cap_upper is not None:\n            cap_kwargs[\"upper\"] = args.cap_upper\n\n    run_pipeline(\n        data_dir=args.data_dir,\n        csv_kwargs={\"sep\": args.sep, \"encoding\": args.encoding},\n        extra_na=args.extra_na,\n        numeric_strategy=args.numeric_strategy,\n        categorical_strategy=args.cat_strategy,\n        cap_kwargs=cap_kwargs,\n        scale_method=args.scale,\n        drop_first=args.drop_first,\n        max_categories=args.max_categories,\n        min_freq=args.min_freq,\n        merge_on=args.merge_on,\n        merge_how=args.merge_how,\n        output_path=args.output,\n    )\n\n\nif __name__ == \"__main__\":\n    main()\n"})
