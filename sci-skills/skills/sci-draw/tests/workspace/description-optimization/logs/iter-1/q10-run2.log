TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/pi3k_akt_mtor_figure.py", "content": "#!/usr/bin/env python3\n\"\"\"\nPI3K/AKT/mTOR Signaling Pathway — Nature Reviews Style Mechanism Figure\n\nGenerates a publication-quality signal transduction figure showing the\nPI3K/AKT/mTOR cascade from receptor activation to cellular outcomes.\n\nOutput: pi3k_akt_mtor.pdf (600 DPI) + pi3k_akt_mtor.png (preview)\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.patches import FancyBboxPatch, FancyArrowPatch, Circle\nimport numpy as np\n\n# ============================================================================\n# Style Configuration — Nature Reviews muted palette\n# ============================================================================\nplt.rcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': 9,\n    'axes.linewidth': 0.5,\n    'xtick.major.width': 0.5,\n    'ytick.major.width': 0.5,\n})\n\n# Color palette\nCOLORS = {\n    'membrane':        '#E8D5B7',   # soft tan\n    'membrane_border': '#B8A07A',\n    'receptor':        '#4A7B9D',   # muted blue\n    'ligand':          '#6B9E7A',   # muted green\n    'pi3k':            '#7B8FAA',   # slate blue\n    'pip2':            '#D4A574',   # golden tan\n    'pip3':            '#C4A882',   # darker tan\n    'akt':             '#5B8FA8',   # teal blue\n    'pdk1':            '#8B9DAF',   # gray-blue\n    'mtorc2':          '#7DA5A0',   # sage\n    'mtorc1':          '#6D9B8A',   # forest sage\n    'tsc':             '#A8896E',   # brown\n    'rheb':            '#B8956A',   # amber\n    'gsk3':            '#9D8A7C',   # warm gray\n    'foxo':            '#8D9B9B',   # gray-green\n    'mdm2':            '#A08B8B',   # mauve-gray\n    'p53':             '#7A6B6B',   # dark mauve\n    's6k':             '#6B8F8F',   # teal-gray\n    'ebp1':            '#7A9D8F',   # sage-green\n    'outcome_growth':  '#4A7B6B',   # dark green\n    'outcome_synth':   '#5B8F7A',   # medium green\n    'outcome_survival':'#6B8F8F',   # teal\n    'outcome_metab':   '#7A8F6B',   # olive\n    'phospho':         '#F0D060',   # yellow-gold\n    'phospho_edge':    '#C8A830',\n    'activation':      '#6A8A6A',   # green for activation arrows\n    'inhibition':      '#C06060',   # red for inhibition lines\n    'text_dark':       '#2C3E50',\n    'text_light':      '#FFFFFF',\n    'node_edge':       '#4A4A4A',\n    'legend_bg':       '#F8F6F0',\n    'panel_bg':        '#FAFAF7',\n}\n\n\n# ============================================================================\n# Helper Functions\n# ============================================================================\n\ndef rounded_rect(ax, xy, width, height, color, edgecolor='#4A4A4A',\n                 label='', text_color='#2C3E50', fontsize=9, fontweight='normal',\n                 alpha=0.9, corner_radius=0.08):\n    \"\"\"Draw a rounded rectangle node with centered text.\"\"\"\n    box = FancyBboxPatch(\n        xy, width, height,\n        boxstyle=f\"round,pad=0,rounding_size={corner_radius}\",\n        facecolor=color, edgecolor=edgecolor,\n        linewidth=1.0, alpha=alpha, zorder=5\n    )\n    ax.add_patch(box)\n    cx = xy[0] + width / 2\n    cy = xy[1] + height / 2\n    ax.text(cx, cy, label, ha='center', va='center',\n            fontsize=fontsize, color=text_color, fontweight=fontweight,\n            zorder=6)\n\n\ndef phosphorylation_circle(ax, xy, radius=0.15, label='P',\n                           facecolor='#F0D060', edgecolor='#C8A830'):\n    \"\"\"Draw a phosphorylation circle marker.\"\"\"\n    circle = Circle(xy, radius, facecolor=facecolor,\n                    edgecolor=edgecolor, linewidth=1.2, zorder=10)\n    ax.add_patch(circle)\n    ax.text(xy[0], xy[1], label, ha='center', va='center',\n            fontsize=7, fontweight='bold', color='#5C4A10', zorder=11)\n\n\ndef activation_arrow(ax, start, end, color='#6A8A6A', linewidth=1.5,\n                     arrowstyle='-|>', connectionstyle='arc3,rad=0',\n                     linestyle='solid', alpha=0.8):\n    \"\"\"Draw an activation arrow from start to end coordinates.\"\"\"\n    arrow = FancyArrowPatch(\n        start, end,\n        arrowstyle=arrowstyle,\n        connectionstyle=connectionstyle,\n        color=color, linewidth=linewidth,\n        linestyle=linestyle,\n        alpha=alpha, zorder=4\n    )\n    ax.add_patch(arrow)\n\n\ndef inhibition_line(ax, start, end, color='#C06060', linewidth=1.5):\n    \"\"\"Draw an inhibition (⊥) line from start to end.\"\"\"\n    arrow = FancyArrowPatch(\n        start, end,\n        arrowstyle='-|-',\n        connectionstyle='arc3,rad=0',\n        color=color, linewidth=linewidth,\n        alpha=0.8, zorder=4\n    )\n    ax.add_patch(arrow)\n\n\ndef membrane_bilayer(ax, x_start, x_end, y, color='#E8D5B7',\n                     border='#B8A07A'):\n    \"\"\"Draw a stylized phospholipid bilayer membrane.\"\"\"\n    height = 0.4\n    # Main bilayer rectangle\n    rect = FancyBboxPatch(\n        (x_start, y - height/2), x_end - x_start, height,\n        boxstyle=\"round,pad=0,rounding_size=0.05\",\n        facecolor=color, edgecolor=border,\n        linewidth=1.2, zorder=3\n    )\n    ax.add_patch(rect)\n    # Head group dots (stylized)\n    for hx in np.linspace(x_start + 0.3, x_end - 0.3, 20):\n        ax.plot(hx, y + 0.15, 'o', color=border, markersize=2.5,\n                alpha=0.6, zorder=4)\n        ax.plot(hx, y - 0.15, 'o', color=border, markersize=2.5,\n                alpha=0.6, zorder=4)\n    return y\n\n\ndef dashed_region_delineation(ax, x, y_start, y_end, color='#CCCCCC',\n                              linewidth=0.5):\n    \"\"\"Draw a dashed delimitation line across the figure.\"\"\"\n    ax.plot([x, x], [y_start, y_end], '--', color=color,\n            linewidth=linewidth, alpha=0.5, zorder=1)\n\n\ndef label_panel(ax, x, y, text, fontsize=12, fontweight='bold',\n                color='#2C3E50'):\n    \"\"\"Add a panel label (a, b, c, etc.)\"\"\"\n    ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n            color=color, zorder=20)\n\n\n# ============================================================================\n# Figure Setup\n# ============================================================================\nfig_width = 8.5   # inches (approximately Nature Reviews column width)\nfig_height = 11.0\n\nfig, ax = plt.subplots(1, 1, figsize=(fig_width, fig_height))\nax.set_xlim(0, 8.5)\nax.set_ylim(0, 11.0)\nax.set_aspect('equal')\nax.axis('off')\n\n# Background\nax.add_patch(plt.Rectangle((0, 0), 8.5, 11.0, facecolor='#FAFAF7',\n                            edgecolor='none', zorder=0))\n\n# ============================================================================\n# Layout Coordinates (x, y, width, height) — all in inches\n# ============================================================================\n# Each row is a \"layer\" of the pathway\n\n# --- Layer 1: Extracellular / Receptor (y ≈ 9.5–10.5) ---\nmembrane_y = 9.2\nreceptor_x = 4.25  # center\n\n# --- Layer 2: PI3K activation (y ≈ 7.8–8.8) ---\n# --- Layer 3: AKT activation (y ≈ 6.2–7.2) ---\n# --- Layer 4: Downstream effectors (y ≈ 4.2–5.5) ---\n# --- Layer 5: Cellular outcomes (y ≈ 2.0–3.5) ---\n\n# ============================================================================\n# Draw Membrane\n# ============================================================================\nmembrane_bilayer(ax, 0.8, 7.7, membrane_y)\n\n# ============================================================================\n# Layer 1: Receptor Level\n# ============================================================================\n# Ligands (growth factors)\nrounded_rect(ax, (3.0, 10.0), 1.0, 0.45, COLORS['ligand'],\n             label='EGF\\nIGF-1\\nInsulin', fontsize=7.5,\n             text_color=COLORS['text_dark'])\n\n# RTK receptor (transmembrane)\nrounded_rect(ax, (3.5, 9.35), 1.5, 0.65, COLORS['receptor'],\n             label='RTK /\\nIGF-1R / InsR', fontsize=7.5,\n             text_color=COLORS['text_light'], fontweight='bold')\n\n# Co-receptor / GPCR option\nrounded_rect(ax, (5.3, 9.35), 1.2, 0.5, '#6B8F9D',\n             label='GPCR', fontsize=7.5,\n             text_color=COLORS['text_light'])\n\n# Arrow: ligand → receptor\nactivation_arrow(ax, (3.5, 10.0), (3.8, 9.65),\n                 color=COLORS['activation'], linewidth=1.2)\n\n# ============================================================================\n# Layer 2: PI3K Activation\n# ============================================================================\n# PI3K (p85/p110)\nrounded_rect(ax, (3.5, 8.1), 1.8, 0.6, COLORS['pi3k'],\n             label='PI3K\\n(p85 / p110)', fontsize=7.5,\n             text_color=COLORS['text_light'], fontweight='bold')\n\n# Arrow: receptor → PI3K\nactivation_arrow(ax, (4.25, 9.0), (4.25, 8.7),\n                 color=COLORS['activation'])\n\n# PIP2 → PIP3 conversion\nrounded_rect(ax, (5.6, 8.2), 1.2, 0.4, COLORS['pip2'],\n             label='PIP₂', fontsize=8, fontweight='bold')\nrounded_rect(ax, (5.6, 7.7), 1.2, 0.4, COLORS['pip3'],\n             label='PIP₃', fontsize=8, fontweight='bold')\n\n# PI3K → PIP2 → PIP3 arrow\nactivation_arrow(ax, (5.5, 8.3), (6.2, 8.2),\n                 color=COLORS['activation'], linewidth=1.0)\nactivation_arrow(ax, (6.2, 8.0), (6.2, 7.9),\n                 color=COLORS['activation'], linewidth=1.0)\n\n# Phosphorylation marker on PI3K\nphosphorylation_circle(ax, (5.0, 8.4), radius=0.15)\n\n# ============================================================================\n# Layer 3: AKT Activation\n# ============================================================================\n# AKT node\nrounded_rect(ax, (3.5, 6.3), 1.6, 0.7, COLORS['akt'],\n             label='AKT\\n(PKB)', fontsize=9,\n             text_color=COLORS['text_light'], fontweight='bold')\n\n# PDK1 node\nrounded_rect(ax, (1.5, 6.3), 1.2, 0.5, COLORS['pdk1'],\n             label='PDK1', fontsize=8,\n             text_color=COLORS['text_dark'])\n\n# mTORC2 node\nrounded_rect(ax, (5.8, 6.3), 1.3, 0.5, COLORS['mtorc2'],\n             label='mTORC2', fontsize=8,\n             text_color=COLORS['text_dark'])\n\n# Arrows: PIP3 → AKT (membrane recruitment)\nactivation_arrow(ax, (5.6, 7.6), (4.5, 7.0),\n                 color=COLORS['activation'], linewidth=1.2,\n                 connectionstyle='arc3,rad=-0.2')\n\n# PDK1 → AKT (Thr308)\nactivation_arrow(ax, (2.7, 6.5), (3.5, 6.5),\n                 color=COLORS['activation'], linewidth=1.2)\n\n# mTORC2 → AKT (Ser473)\nactivation_arrow(ax, (5.8, 6.5), (5.1, 6.5),\n                 color=COLORS['activation'], linewidth=1.2)\n\n# Phosphporylation markers on AKT\nphosphorylation_circle(ax, (3.9, 6.7), radius=0.15, label='P\\nThr308')\nphosphorylation_circle(ax, (4.6, 6.7), radius=0.15, label='P\\nSer473')\n\n# ============================================================================\n# Layer 4: Downstream Effectors\n# ============================================================================\n\n# --- Branch 1: TSC1/2 → Rheb → mTORC1 (Cell Growth) ---\nrounded_rect(ax, (1.0, 4.7), 1.4, 0.5, COLORS['tsc'],\n             label='TSC1/2\\nComplex', fontsize=7.5,\n             text_color=COLORS['text_dark'])\n\nrounded_rect(ax, (1.0, 3.8), 1.2, 0.45, COLORS['rheb'],\n             label='Rheb-GTP', fontsize=8,\n             text_color=COLORS['text_dark'], fontweight='bold')\n\nrounded_rect(ax, (1.0, 2.8), 1.4, 0.5, COLORS['mtorc1'],\n             label='mTORC1', fontsize=8,\n             text_color=COLORS['text_dark'], fontweight='bold')\n\n# AKT → TSC1/2 (inhibition)\ninhibition_line(ax, (3.8, 6.0), (2.0, 5.0),\n                color=COLORS['inhibition'])\n# TSC1/2 → Rheb (inhibition) — actually TSC inhibits Rheb, so AKT inhibits TSC, relieving Rheb\ninhibition_line(ax, (1.5, 4.5), (1.5, 4.2),\n                color=COLORS['inhibition'])\n# Rheb → mTORC1 (activation)\nactivation_arrow(ax, (1.6, 3.6), (1.7, 3.3),\n                 color=COLORS['activation'])\n\n\n# --- Branch 2: FOXO (Cell Survival) ---\nrounded_rect(ax, (3.0, 4.5), 1.2, 0.5, COLORS['foxo'],\n             label='FOXO', fontsize=8,\n             text_color=COLORS['text_dark'])\n\n# AKT → FOXO (inhibition)\ninhibition_line(ax, (4.0, 6.0), (3.6, 5.0),\n                color=COLORS['inhibition'])\n\n\n# --- Branch 3: GSK3β (Metabolism) ---\nrounded_rect(ax, (4.8, 4.5), 1.2, 0.5, COLORS['gsk3'],\n             label='GSK3β', fontsize=8,\n             text_color=COLORS['text_dark'])\n\n# AKT → GSK3β (inhibition)\ninhibition_line(ax, (4.8, 6.0), (5.0, 5.0),\n                color=COLORS['inhibition'])\n\n\n# --- Branch 4: MDM2/p53 ---\nrounded_rect(ax, (6.5, 4.7), 1.2, 0.45, COLORS['mdm2'],\n             label='MDM2', fontsize=8,\n             text_color=COLORS['text_dark'])\n\nrounded_rect(ax, (6.5, 4.0), 1.0, 0.4, COLORS['p53'],\n             label='p53', fontsize=8,\n             text_color=COLORS['text_light'])\n\n# AKT → MDM2 (activation)\nactivation_arrow(ax, (5.2, 6.0), (6.5, 5.2),\n                 color=COLORS['activation'], linewidth=1.2,\n                 connectionstyle='arc3,rad=0.2')\n\n# MDM2 → p53 (inhibition)\ninhibition_line(ax, (7.1, 4.5), (7.0, 4.4),\n                color=COLORS['inhibition'])\n\n\n# Phosphorylation markers on downstream nodes\nphosphorylation_circle(ax, (1.7, 4.95), radius=0.15)\nphosphorylation_circle(ax, (3.6, 4.75), radius=0.15)\nphosphorylation_circle(ax, (5.1, 4.75), radius=0.15)\n\n# ============================================================================\n# Layer 5: Cellular Outcomes\n# ============================================================================\n\noutcomes = [\n    (1.2, 1.8, 'Cell Growth /\\nProliferation', COLORS['outcome_growth']),\n    (3.0, 1.8, 'Protein\\nSynthesis',           COLORS['outcome_synth']),\n    (4.8, 1.8, 'Cell\\nSurvival',               COLORS['outcome_survival']),\n    (6.6, 1.8, 'Metabolism /\\nGlucose Uptake', COLORS['outcome_metab']),\n]\n\nfor ox, oy, olabel, ocolor in outcomes:\n    rounded_rect(ax, (ox - 0.7, oy), 1.4, 0.6, ocolor,\n                 label=olabel, fontsize=7.5,\n                 text_color=COLORS['text_light'], fontweight='bold')\n\n# mTORC1 → S6K/4E-BP1 → Protein Synthesis\nrounded_rect(ax, (2.3, 2.7), 1.4, 0.4, COLORS['s6k'],\n             label='S6K', fontsize=7.5,\n             text_color=COLORS['text_dark'])\nrounded_rect(ax, (3.7, 2.7), 1.4, 0.4, COLORS['ebp1'],\n             label='4E-BP1', fontsize=7.5,\n             text_color=COLORS['text_dark'])\n\n# mTORC1 → S6K\nactivation_arrow(ax, (1.7, 2.6), (2.0, 2.5),\n                 color=COLORS['activation'], linewidth=1.0)\n# mTORC1 → 4E-BP1\nactivation_arrow(ax, (1.7, 2.5), (3.0, 2.5),\n                 color=COLORS['activation'], linewidth=1.0,\n                 connectionstyle='arc3,rad=0.1')\n\nphosphorylation_circle(ax, (2.7, 2.9), radius=0.15)\nphosphorylation_circle(ax, (3.9, 2.9), radius=0.15)\n\n# S6K → Protein Synthesis\nactivation_arrow(ax, (2.7, 2.5), (3.2, 2.2),\n                 color=COLORS['activation'])\n# 4E-BP1 → Protein Synthesis\nactivation_arrow(ax, (3.9, 2.5), (3.8, 2.2),\n                 color=COLORS['activation'])\n\n# FOXO → Survival\nactivation_arrow(ax, (3.3, 4.2), (3.5, 2.4),\n                 color=COLORS['activation'], linewidth=1.0,\n                 connectionstyle='arc3,rad=0.3')\n\n# GSK3β → Metabolism (inhibition relay)\ninhibition_line(ax, (5.2, 4.2), (6.0, 2.4),\n                color=COLORS['inhibition'],\n                linewidth=1.0)\n\n# MDM2 → p53 → outcomes (simplified)\nactivation_arrow(ax, (6.8, 3.8), (6.8, 2.4),\n                 color=COLORS['activation'], linewidth=1.0)\n\n# ============================================================================\n# Section Labels and Background Panels\n# ============================================================================\n\n# Section background shading\nsections = [\n    (9.6, 'Extracellular Signals',     0.15),\n    (8.5, 'Membrane / Receptor',       0.15),\n    (7.3, 'PI3K Activation',          0.10),\n    (5.9, 'AKT Activation',           0.10),\n    (4.0, 'Downstream Effectors',     0.10),\n    (1.5, 'Cellular Outcomes',        0.10),\n]\n\nfor sy, slabel, salpha in sections:\n    ax.text(0.4, sy, slabel, fontsize=8, fontstyle='italic',\n            color='#888888', ha='left', va='center', alpha=0.8, zorder=2)\n\n# Side bracket / delimiter lines\ndashed_region_delineation(ax, 0.7, 9.6, 10.8, color='#AAAAAA')\ndashed_region_delineation(ax, 0.7, 7.6, 9.0, color='#AAAAAA')\ndashed_region_delineation(ax, 0.7, 6.0, 7.2, color='#AAAAAA')\ndashed_region_delineation(ax, 0.7, 3.6, 5.5, color='#AAAAAA')\ndashed_region_delineation(ax, 0.7, 1.2, 3.2, color='#AAAAAA')\n\n# Title\nax.text(4.25, 10.75, 'PI3K/AKT/mTOR Signaling Pathway',\n        fontsize=14, fontweight='bold', color='#2C3E50',\n        ha='center', va='center', zorder=20)\n\n# Subtitle\nax.text(4.25, 10.45, 'Ligand-induced activation from receptor to cellular responses',\n        fontsize=8.5, fontstyle='italic', color='#666666',\n        ha='center', va='center', zorder=20)\n\n\n# ============================================================================\n# Legend\n# ============================================================================\nlegend_x = 5.8\nlegend_y = 0.8\nlegend_width = 2.2\nlegend_height = 2.4\n\n# Legend background\nlegend_bg = FancyBboxPatch(\n    (legend_x - 0.1, legend_y - 0.1), legend_width, legend_height,\n    boxstyle=\"round,pad=0,rounding_size=0.08\",\n    facecolor=COLORS['legend_bg'], edgecolor='#DDDDDD',\n    linewidth=0.8, zorder=15\n)\nax.add_patch(legend_bg)\n\nax.text(legend_x + legend_width/2 - 0.05, legend_y + legend_height - 0.2,\n        'Legend', fontsize=8.5, fontweight='bold', color='#2C3E50',\n        ha='center', va='center', zorder=20)\n\n# Legend items\nlegend_items = [\n    ('activation', 'Activation', COLORS['activation']),\n    ('inhibition', 'Inhibition', COLORS['inhibition']),\n]\n\nfor li, (ltype, llabel, lcolor) in enumerate(legend_items):\n    ly = legend_y + legend_height - 0.55 - li * 0.35\n    if ltype == 'activation':\n        ax.annotate('', xy=(legend_x + 0.3, ly), xytext=(legend_x + 0.9, ly),\n                    arrowprops=dict(arrowstyle='-|>', color=lcolor,\n                                    linewidth=1.5, alpha=0.8),\n                    zorder=20)\n    elif ltype == 'inhibition':\n        ax.annotate('', xy=(legend_x + 0.3, ly), xytext=(legend_x + 0.9, ly),\n                    arrowprops=dict(arrowstyle='-|-', color=lcolor,\n                                    linewidth=1.5, alpha=0.8),\n                    zorder=20)\n    ax.text(legend_x + 1.05, ly, llabel, fontsize=7.5,\n            color='#2C3E50', va='center', zorder=20)\n\n# Phosphorylation legend\npc_x, pc_y = legend_x + 0.3, legend_y + legend_height - 1.3\npc = Circle((pc_x, pc_y), 0.12, facecolor=COLORS['phospho'],\n            edgecolor=COLORS['phospho_edge'], linewidth=1.0, zorder=20)\nax.add_patch(pc)\nax.text(pc_x, pc_y, 'P', fontsize=6, fontweight='bold',\n        color='#5C4A10', ha='center', va='center', zorder=21)\nax.text(legend_x + 0.55, pc_y, 'Phosphorylation', fontsize=7.5,\n        color='#2C3E50', va='center', zorder=20)\n\n# Protein node legend\nnode_x, node_y = legend_x + 0.3, legend_y + legend_height - 1.7\nnode = FancyBboxPatch(\n    (node_x, node_y - 0.1), 0.5, 0.2,\n    boxstyle=\"round,pad=0,rounding_size=0.04\",\n    facecolor='#D0D0D0', edgecolor='#4A4A4A',\n    linewidth=0.8, zorder=20\n)\nax.add_patch(node)\nax.text(legend_x + 0.95, node_y, 'Protein / Complex', fontsize=7.5,\n        color='#2C3E50', va='center', zorder=20)\n\n# Membrane legend\nmem_x, mem_y = legend_x + 0.3, legend_y + legend_height - 2.1\nmem = FancyBboxPatch(\n    (mem_x, mem_y - 0.05), 0.5, 0.1,\n    boxstyle=\"round,pad=0,rounding_size=0.02\",\n    facecolor=COLORS['membrane'], edgecolor=COLORS['membrane_border'],\n    linewidth=0.8, zorder=20\n)\nax.add_patch(mem)\nax.text(legend_x + 0.95, mem_y, 'Cell Membrane', fontsize=7.5,\n        color='#2C3E50', va='center', zorder=20)\n\n\n# ============================================================================\n# Export\n# ============================================================================\noutput_pdf = 'pi3k_akt_mtor.pdf'\noutput_png = 'pi3k_akt_mtor.png'\n\nfig.savefig(output_pdf, dpi=600, bbox_inches='tight',\n            facecolor=fig.get_facecolor(), edgecolor='none')\nfig.savefig(output_png, dpi=300, bbox_inches='tight',\n            facecolor=fig.get_facecolor(), edgecolor='none')\n\nprint(f\"✓ Saved: {output_pdf} (600 DPI, PDF)\")\nprint(f\"✓ Saved: {output_png} (300 DPI, PNG)\")\nprint(f\"  Figure size: {fig_width}\\\" × {fig_height}\\\"\")\nplt.close(fig)\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/pi3k_akt_mtor_figure.py", "content": "#!/usr/bin/env python3\n\"\"\"\nPI3K/AKT/mTOR Signaling Pathway — Nature Reviews Style Mechanism Figure\n\nGenerates a publication-quality signal transduction figure showing the\nPI3K/AKT/mTOR cascade from receptor activation to cellular outcomes.\n\nOutput: pi3k_akt_mtor.pdf (600 DPI) + pi3k_akt_mtor.png (preview)\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.patches as mpatches\nfrom matplotlib.patches import FancyBboxPatch, FancyArrowPatch, Circle\nimport numpy as np\n\n# ============================================================================\n# Style Configuration — Nature Reviews muted palette\n# ============================================================================\nplt.rcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': 9,\n    'axes.linewidth': 0.5,\n    'xtick.major.width': 0.5,\n    'ytick.major.width': 0.5,\n})\n\n# Color palette\nCOLORS = {\n    'membrane':        '#E8D5B7',   # soft tan\n    'membrane_border': '#B8A07A',\n    'receptor':        '#4A7B9D',   # muted blue\n    'ligand':          '#6B9E7A',   # muted green\n    'pi3k':            '#7B8FAA',   # slate blue\n    'pip2':            '#D4A574',   # golden tan\n    'pip3':            '#C4A882',   # darker tan\n    'akt':             '#5B8FA8',   # teal blue\n    'pdk1':            '#8B9DAF',   # gray-blue\n    'mtorc2':          '#7DA5A0',   # sage\n    'mtorc1':          '#6D9B8A',   # forest sage\n    'tsc':             '#A8896E',   # brown\n    'rheb':            '#B8956A',   # amber\n    'gsk3':            '#9D8A7C',   # warm gray\n    'foxo':            '#8D9B9B',   # gray-green\n    'mdm2':            '#A08B8B',   # mauve-gray\n    'p53':             '#7A6B6B',   # dark mauve\n    's6k':             '#6B8F8F',   # teal-gray\n    'ebp1':            '#7A9D8F',   # sage-green\n    'outcome_growth':  '#4A7B6B',   # dark green\n    'outcome_synth':   '#5B8F7A',   # medium green\n    'outcome_survival':'#6B8F8F',   # teal\n    'outcome_metab':   '#7A8F6B',   # olive\n    'phospho':         '#F0D060',   # yellow-gold\n    'phospho_edge':    '#C8A830',\n    'activation':      '#6A8A6A',   # green for activation arrows\n    'inhibition':      '#C06060',   # red for inhibition lines\n    'text_dark':       '#2C3E50',\n    'text_light':      '#FFFFFF',\n    'node_edge':       '#4A4A4A',\n    'legend_bg':       '#F8F6F0',\n    'panel_bg':        '#FAFAF7',\n}\n\n\n# ============================================================================\n# Helper Functions\n# ============================================================================\n\ndef rounded_rect(ax, xy, width, height, color, edgecolor='#4A4A4A',\n                 label='', text_color='#2C3E50', fontsize=9, fontweight='normal',\n                 alpha=0.9, corner_radius=0.08):\n    \"\"\"Draw a rounded rectangle node with centered text.\"\"\"\n    box = FancyBboxPatch(\n        xy, width, height,\n        boxstyle=f\"round,pad=0,rounding_size={corner_radius}\",\n        facecolor=color, edgecolor=edgecolor,\n        linewidth=1.0, alpha=alpha, zorder=5\n    )\n    ax.add_patch(box)\n    cx = xy[0] + width / 2\n    cy = xy[1] + height / 2\n    ax.text(cx, cy, label, ha='center', va='center',\n            fontsize=fontsize, color=text_color, fontweight=fontweight,\n            zorder=6)\n\n\ndef phosphorylation_circle(ax, xy, radius=0.15, label='P',\n                           facecolor='#F0D060', edgecolor='#C8A830'):\n    \"\"\"Draw a phosphorylation circle marker.\"\"\"\n    circle = Circle(xy, radius, facecolor=facecolor,\n                    edgecolor=edgecolor, linewidth=1.2, zorder=10)\n    ax.add_patch(circle)\n    ax.text(xy[0], xy[1], label, ha='center', va='center',\n            fontsize=7, fontweight='bold', color='#5C4A10', zorder=11)\n\n\ndef activation_arrow(ax, start, end, color='#6A8A6A', linewidth=1.5,\n                     arrowstyle='-|>', connectionstyle='arc3,rad=0',\n                     linestyle='solid', alpha=0.8):\n    \"\"\"Draw an activation arrow from start to end coordinates.\"\"\"\n    arrow = FancyArrowPatch(\n        start, end,\n        arrowstyle=arrowstyle,\n        connectionstyle=connectionstyle,\n        color=color, linewidth=linewidth,\n        linestyle=linestyle,\n        alpha=alpha, zorder=4\n    )\n    ax.add_patch(arrow)\n\n\ndef inhibition_line(ax, start, end, color='#C06060', linewidth=1.5):\n    \"\"\"Draw an inhibition (⊥) line from start to end.\"\"\"\n    arrow = FancyArrowPatch(\n        start, end,\n        arrowstyle='-|-',\n        connectionstyle='arc3,rad=0',\n        color=color, linewidth=linewidth,\n        alpha=0.8, zorder=4\n    )\n    ax.add_patch(arrow)\n\n\ndef membrane_bilayer(ax, x_start, x_end, y, color='#E8D5B7',\n                     border='#B8A07A'):\n    \"\"\"Draw a stylized phospholipid bilayer membrane.\"\"\"\n    height = 0.4\n    # Main bilayer rectangle\n    rect = FancyBboxPatch(\n        (x_start, y - height/2), x_end - x_start, height,\n        boxstyle=\"round,pad=0,rounding_size=0.05\",\n        facecolor=color, edgecolor=border,\n        linewidth=1.2, zorder=3\n    )\n    ax.add_patch(rect)\n    # Head group dots (stylized)\n    for hx in np.linspace(x_start + 0.3, x_end - 0.3, 20):\n        ax.plot(hx, y + 0.15, 'o', color=border, markersize=2.5,\n                alpha=0.6, zorder=4)\n        ax.plot(hx, y - 0.15, 'o', color=border, markersize=2.5,\n                alpha=0.6, zorder=4)\n    return y\n\n\ndef dashed_region_delineation(ax, x, y_start, y_end, color='#CCCCCC',\n                              linewidth=0.5):\n    \"\"\"Draw a dashed delimitation line across the figure.\"\"\"\n    ax.plot([x, x], [y_start, y_end], '--', color=color,\n            linewidth=linewidth, alpha=0.5, zorder=1)\n\n\ndef label_panel(ax, x, y, text, fontsize=12, fontweight='bold',\n                color='#2C3E50'):\n    \"\"\"Add a panel label (a, b, c, etc.)\"\"\"\n    ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n            color=color, zorder=20)\n\n\n# ============================================================================\n# Figure Setup\n# ============================================================================\nfig_width = 8.5   # inches (approximately Nature Reviews column width)\nfig_height = 11.0\n\nfig, ax = plt.subplots(1, 1, figsize=(fig_width, fig_height))\nax.set_xlim(0, 8.5)\nax.set_ylim(0, 11.0)\nax.set_aspect('equal')\nax.axis('off')\n\n# Background\nax.add_patch(plt.Rectangle((0, 0), 8.5, 11.0, facecolor='#FAFAF7',\n                            edgecolor='none', zorder=0))\n\n# ============================================================================\n# Layout Coordinates (x, y, width, height) — all in inches\n# ============================================================================\n# Each row is a \"layer\" of the pathway\n\n# --- Layer 1: Extracellular / Receptor (y ≈ 9.5–10.5) ---\nmembrane_y = 9.2\nreceptor_x = 4.25  # center\n\n# --- Layer 2: PI3K activation (y ≈ 7.8–8.8) ---\n# --- Layer 3: AKT activation (y ≈ 6.2–7.2) ---\n# --- Layer 4: Downstream effectors (y ≈ 4.2–5.5) ---\n# --- Layer 5: Cellular outcomes (y ≈ 2.0–3.5) ---\n\n# ============================================================================\n# Draw Membrane\n# ============================================================================\nmembrane_bilayer(ax, 0.8, 7.7, membrane_y)\n\n# ============================================================================\n# Layer 1: Receptor Level\n# ============================================================================\n# Ligands (growth factors)\nrounded_rect(ax, (3.0, 10.0), 1.0, 0.45, COLORS['ligand'],\n             label='EGF\\nIGF-1\\nInsulin', fontsize=7.5,\n             text_color=COLORS['text_dark'])\n\n# RTK receptor (transmembrane)\nrounded_rect(ax, (3.5, 9.35), 1.5, 0.65, COLORS['receptor'],\n             label='RTK /\\nIGF-1R / InsR', fontsize=7.5,\n             text_color=COLORS['text_light'], fontweight='bold')\n\n# Co-receptor / GPCR option\nrounded_rect(ax, (5.3, 9.35), 1.2, 0.5, '#6B8F9D',\n             label='GPCR', fontsize=7.5,\n             text_color=COLORS['text_light'])\n\n# Arrow: ligand → receptor\nactivation_arrow(ax, (3.5, 10.0), (3.8, 9.65),\n                 color=COLORS['activation'], linewidth=1.2)\n\n# ============================================================================\n# Layer 2: PI3K Activation\n# ============================================================================\n# PI3K (p85/p110)\nrounded_rect(ax, (3.5, 8.1), 1.8, 0.6, COLORS['pi3k'],\n             label='PI3K\\n(p85 / p110)', fontsize=7.5,\n             text_color=COLORS['text_light'], fontweight='bold')\n\n# Arrow: receptor → PI3K\nactivation_arrow(ax, (4.25, 9.0), (4.25, 8.7),\n                 color=COLORS['activation'])\n\n# PIP2 → PIP3 conversion\nrounded_rect(ax, (5.6, 8.2), 1.2, 0.4, COLORS['pip2'],\n             label='PIP₂', fontsize=8, fontweight='bold')\nrounded_rect(ax, (5.6, 7.7), 1.2, 0.4, COLORS['pip3'],\n             label='PIP₃', fontsize=8, fontweight='bold')\n\n# PI3K → PIP2 → PIP3 arrow\nactivation_arrow(ax, (5.5, 8.3), (6.2, 8.2),\n                 color=COLORS['activation'], linewidth=1.0)\nactivation_arrow(ax, (6.2, 8.0), (6.2, 7.9),\n                 color=COLORS['activation'], linewidth=1.0)\n\n# Phosphorylation marker on PI3K\nphosphorylation_circle(ax, (5.0, 8.4), radius=0.15)\n\n# ============================================================================\n# Layer 3: AKT Activation\n# ============================================================================\n# AKT node\nrounded_rect(ax, (3.5, 6.3), 1.6, 0.7, COLORS['akt'],\n             label='AKT\\n(PKB)', fontsize=9,\n             text_color=COLORS['text_light'], fontweight='bold')\n\n# PDK1 node\nrounded_rect(ax, (1.5, 6.3), 1.2, 0.5, COLORS['pdk1'],\n             label='PDK1', fontsize=8,\n             text_color=COLORS['text_dark'])\n\n# mTORC2 node\nrounded_rect(ax, (5.8, 6.3), 1.3, 0.5, COLORS['mtorc2'],\n             label='mTORC2', fontsize=8,\n             text_color=COLORS['text_dark'])\n\n# Arrows: PIP3 → AKT (membrane recruitment)\nactivation_arrow(ax, (5.6, 7.6), (4.5, 7.0),\n                 color=COLORS['activation'], linewidth=1.2,\n                 connectionstyle='arc3,rad=-0.2')\n\n# PDK1 → AKT (Thr308)\nactivation_arrow(ax, (2.7, 6.5), (3.5, 6.5),\n                 color=COLORS['activation'], linewidth=1.2)\n\n# mTORC2 → AKT (Ser473)\nactivation_arrow(ax, (5.8, 6.5), (5.1, 6.5),\n                 color=COLORS['activation'], linewidth=1.2)\n\n# Phosphporylation markers on AKT\nphosphorylation_circle(ax, (3.9, 6.7), radius=0.15, label='P\\nThr308')\nphosphorylation_circle(ax, (4.6, 6.7), radius=0.15, label='P\\nSer473')\n\n# ============================================================================\n# Layer 4: Downstream Effectors\n# ============================================================================\n\n# --- Branch 1: TSC1/2 → Rheb → mTORC1 (Cell Growth) ---\nrounded_rect(ax, (1.0, 4.7), 1.4, 0.5, COLORS['tsc'],\n             label='TSC1/2\\nComplex', fontsize=7.5,\n             text_color=COLORS['text_dark'])\n\nrounded_rect(ax, (1.0, 3.8), 1.2, 0.45, COLORS['rheb'],\n             label='Rheb-GTP', fontsize=8,\n             text_color=COLORS['text_dark'], fontweight='bold')\n\nrounded_rect(ax, (1.0, 2.8), 1.4, 0.5, COLORS['mtorc1'],\n             label='mTORC1', fontsize=8,\n             text_color=COLORS['text_dark'], fontweight='bold')\n\n# AKT → TSC1/2 (inhibition)\ninhibition_line(ax, (3.8, 6.0), (2.0, 5.0),\n                color=COLORS['inhibition'])\n# TSC1/2 → Rheb (inhibition) — actually TSC inhibits Rheb, so AKT inhibits TSC, relieving Rheb\ninhibition_line(ax, (1.5, 4.5), (1.5, 4.2),\n                color=COLORS['inhibition'])\n# Rheb → mTORC1 (activation)\nactivation_arrow(ax, (1.6, 3.6), (1.7, 3.3),\n                 color=COLORS['activation'])\n\n\n# --- Branch 2: FOXO (Cell Survival) ---\nrounded_rect(ax, (3.0, 4.5), 1.2, 0.5, COLORS['foxo'],\n             label='FOXO', fontsize=8,\n             text_color=COLORS['text_dark'])\n\n# AKT → FOXO (inhibition)\ninhibition_line(ax, (4.0, 6.0), (3.6, 5.0),\n                color=COLORS['inhibition'])\n\n\n# --- Branch 3: GSK3β (Metabolism) ---\nrounded_rect(ax, (4.8, 4.5), 1.2, 0.5, COLORS['gsk3'],\n             label='GSK3β', fontsize=8,\n             text_color=COLORS['text_dark'])\n\n# AKT → GSK3β (inhibition)\ninhibition_line(ax, (4.8, 6.0), (5.0, 5.0),\n                color=COLORS['inhibition'])\n\n\n# --- Branch 4: MDM2/p53 ---\nrounded_rect(ax, (6.5, 4.7), 1.2, 0.45, COLORS['mdm2'],\n             label='MDM2', fontsize=8,\n             text_color=COLORS['text_dark'])\n\nrounded_rect(ax, (6.5, 4.0), 1.0, 0.4, COLORS['p53'],\n             label='p53', fontsize=8,\n             text_color=COLORS['text_light'])\n\n# AKT → MDM2 (activation)\nactivation_arrow(ax, (5.2, 6.0), (6.5, 5.2),\n                 color=COLORS['activation'], linewidth=1.2,\n                 connectionstyle='arc3,rad=0.2')\n\n# MDM2 → p53 (inhibition)\ninhibition_line(ax, (7.1, 4.5), (7.0, 4.4),\n                color=COLORS['inhibition'])\n\n\n# Phosphorylation markers on downstream nodes\nphosphorylation_circle(ax, (1.7, 4.95), radius=0.15)\nphosphorylation_circle(ax, (3.6, 4.75), radius=0.15)\nphosphorylation_circle(ax, (5.1, 4.75), radius=0.15)\n\n# ============================================================================\n# Layer 5: Cellular Outcomes\n# ============================================================================\n\noutcomes = [\n    (1.2, 1.8, 'Cell Growth /\\nProliferation', COLORS['outcome_growth']),\n    (3.0, 1.8, 'Protein\\nSynthesis',           COLORS['outcome_synth']),\n    (4.8, 1.8, 'Cell\\nSurvival',               COLORS['outcome_survival']),\n    (6.6, 1.8, 'Metabolism /\\nGlucose Uptake', COLORS['outcome_metab']),\n]\n\nfor ox, oy, olabel, ocolor in outcomes:\n    rounded_rect(ax, (ox - 0.7, oy), 1.4, 0.6, ocolor,\n                 label=olabel, fontsize=7.5,\n                 text_color=COLORS['text_light'], fontweight='bold')\n\n# mTORC1 → S6K/4E-BP1 → Protein Synthesis\nrounded_rect(ax, (2.3, 2.7), 1.4, 0.4, COLORS['s6k'],\n             label='S6K', fontsize=7.5,\n             text_color=COLORS['text_dark'])\nrounded_rect(ax, (3.7, 2.7), 1.4, 0.4, COLORS['ebp1'],\n             label='4E-BP1', fontsize=7.5,\n             text_color=COLORS['text_dark'])\n\n# mTORC1 → S6K\nactivation_arrow(ax, (1.7, 2.6), (2.0, 2.5),\n                 color=COLORS['activation'], linewidth=1.0)\n# mTORC1 → 4E-BP1\nactivation_arrow(ax, (1.7, 2.5), (3.0, 2.5),\n                 color=COLORS['activation'], linewidth=1.0,\n                 connectionstyle='arc3,rad=0.1')\n\nphosphorylation_circle(ax, (2.7, 2.9), radius=0.15)\nphosphorylation_circle(ax, (3.9, 2.9), radius=0.15)\n\n# S6K → Protein Synthesis\nactivation_arrow(ax, (2.7, 2.5), (3.2, 2.2),\n                 color=COLORS['activation'])\n# 4E-BP1 → Protein Synthesis\nactivation_arrow(ax, (3.9, 2.5), (3.8, 2.2),\n                 color=COLORS['activation'])\n\n# FOXO → Survival\nactivation_arrow(ax, (3.3, 4.2), (3.5, 2.4),\n                 color=COLORS['activation'], linewidth=1.0,\n                 connectionstyle='arc3,rad=0.3')\n\n# GSK3β → Metabolism (inhibition relay)\ninhibition_line(ax, (5.2, 4.2), (6.0, 2.4),\n                color=COLORS['inhibition'],\n                linewidth=1.0)\n\n# MDM2 → p53 → outcomes (simplified)\nactivation_arrow(ax, (6.8, 3.8), (6.8, 2.4),\n                 color=COLORS['activation'], linewidth=1.0)\n\n# ============================================================================\n# Section Labels and Background Panels\n# ============================================================================\n\n# Section background shading\nsections = [\n    (9.6, 'Extracellular Signals',     0.15),\n    (8.5, 'Membrane / Receptor',       0.15),\n    (7.3, 'PI3K Activation',          0.10),\n    (5.9, 'AKT Activation',           0.10),\n    (4.0, 'Downstream Effectors',     0.10),\n    (1.5, 'Cellular Outcomes',        0.10),\n]\n\nfor sy, slabel, salpha in sections:\n    ax.text(0.4, sy, slabel, fontsize=8, fontstyle='italic',\n            color='#888888', ha='left', va='center', alpha=0.8, zorder=2)\n\n# Side bracket / delimiter lines\ndashed_region_delineation(ax, 0.7, 9.6, 10.8, color='#AAAAAA')\ndashed_region_delineation(ax, 0.7, 7.6, 9.0, color='#AAAAAA')\ndashed_region_delineation(ax, 0.7, 6.0, 7.2, color='#AAAAAA')\ndashed_region_delineation(ax, 0.7, 3.6, 5.5, color='#AAAAAA')\ndashed_region_delineation(ax, 0.7, 1.2, 3.2, color='#AAAAAA')\n\n# Title\nax.text(4.25, 10.75, 'PI3K/AKT/mTOR Signaling Pathway',\n        fontsize=14, fontweight='bold', color='#2C3E50',\n        ha='center', va='center', zorder=20)\n\n# Subtitle\nax.text(4.25, 10.45, 'Ligand-induced activation from receptor to cellular responses',\n        fontsize=8.5, fontstyle='italic', color='#666666',\n        ha='center', va='center', zorder=20)\n\n\n# ============================================================================\n# Legend\n# ============================================================================\nlegend_x = 5.8\nlegend_y = 0.8\nlegend_width = 2.2\nlegend_height = 2.4\n\n# Legend background\nlegend_bg = FancyBboxPatch(\n    (legend_x - 0.1, legend_y - 0.1), legend_width, legend_height,\n    boxstyle=\"round,pad=0,rounding_size=0.08\",\n    facecolor=COLORS['legend_bg'], edgecolor='#DDDDDD',\n    linewidth=0.8, zorder=15\n)\nax.add_patch(legend_bg)\n\nax.text(legend_x + legend_width/2 - 0.05, legend_y + legend_height - 0.2,\n        'Legend', fontsize=8.5, fontweight='bold', color='#2C3E50',\n        ha='center', va='center', zorder=20)\n\n# Legend items\nlegend_items = [\n    ('activation', 'Activation', COLORS['activation']),\n    ('inhibition', 'Inhibition', COLORS['inhibition']),\n]\n\nfor li, (ltype, llabel, lcolor) in enumerate(legend_items):\n    ly = legend_y + legend_height - 0.55 - li * 0.35\n    if ltype == 'activation':\n        ax.annotate('', xy=(legend_x + 0.3, ly), xytext=(legend_x + 0.9, ly),\n                    arrowprops=dict(arrowstyle='-|>', color=lcolor,\n                                    linewidth=1.5, alpha=0.8),\n                    zorder=20)\n    elif ltype == 'inhibition':\n        ax.annotate('', xy=(legend_x + 0.3, ly), xytext=(legend_x + 0.9, ly),\n                    arrowprops=dict(arrowstyle='-|-', color=lcolor,\n                                    linewidth=1.5, alpha=0.8),\n                    zorder=20)\n    ax.text(legend_x + 1.05, ly, llabel, fontsize=7.5,\n            color='#2C3E50', va='center', zorder=20)\n\n# Phosphorylation legend\npc_x, pc_y = legend_x + 0.3, legend_y + legend_height - 1.3\npc = Circle((pc_x, pc_y), 0.12, facecolor=COLORS['phospho'],\n            edgecolor=COLORS['phospho_edge'], linewidth=1.0, zorder=20)\nax.add_patch(pc)\nax.text(pc_x, pc_y, 'P', fontsize=6, fontweight='bold',\n        color='#5C4A10', ha='center', va='center', zorder=21)\nax.text(legend_x + 0.55, pc_y, 'Phosphorylation', fontsize=7.5,\n        color='#2C3E50', va='center', zorder=20)\n\n# Protein node legend\nnode_x, node_y = legend_x + 0.3, legend_y + legend_height - 1.7\nnode = FancyBboxPatch(\n    (node_x, node_y - 0.1), 0.5, 0.2,\n    boxstyle=\"round,pad=0,rounding_size=0.04\",\n    facecolor='#D0D0D0', edgecolor='#4A4A4A',\n    linewidth=0.8, zorder=20\n)\nax.add_patch(node)\nax.text(legend_x + 0.95, node_y, 'Protein / Complex', fontsize=7.5,\n        color='#2C3E50', va='center', zorder=20)\n\n# Membrane legend\nmem_x, mem_y = legend_x + 0.3, legend_y + legend_height - 2.1\nmem = FancyBboxPatch(\n    (mem_x, mem_y - 0.05), 0.5, 0.1,\n    boxstyle=\"round,pad=0,rounding_size=0.02\",\n    facecolor=COLORS['membrane'], edgecolor=COLORS['membrane_border'],\n    linewidth=0.8, zorder=20\n)\nax.add_patch(mem)\nax.text(legend_x + 0.95, mem_y, 'Cell Membrane', fontsize=7.5,\n        color='#2C3E50', va='center', zorder=20)\n\n\n# ============================================================================\n# Export\n# ============================================================================\noutput_pdf = 'pi3k_akt_mtor.pdf'\noutput_png = 'pi3k_akt_mtor.png'\n\nfig.savefig(output_pdf, dpi=600, bbox_inches='tight',\n            facecolor=fig.get_facecolor(), edgecolor='none')\nfig.savefig(output_png, dpi=300, bbox_inches='tight',\n            facecolor=fig.get_facecolor(), edgecolor='none')\n\nprint(f\"✓ Saved: {output_pdf} (600 DPI, PDF)\")\nprint(f\"✓ Saved: {output_png} (300 DPI, PNG)\")\nprint(f\"  Figure size: {fig_width}\\\" × {fig_height}\\\"\")\nplt.close(fig)\n"})
