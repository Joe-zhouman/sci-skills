TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure1_panels.py", "content": "#!/usr/bin/env python3\n\"\"\"\nFigure 1 for Science manuscript — 4 panels\n(a) PCA plot showing separation of three groups\n(b) Tumor volume curves over time\n(c) Box plot at day 28\n(d) Volcano plot of differentially expressed genes\n\nTarget: Science double-column width (183 mm = 7.2 in)\nUnified color palette for 3 groups\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.ticker as ticker\nfrom matplotlib import rcParams\nfrom matplotlib.patches import FancyBboxPatch\nimport seaborn as sns\nfrom sklearn.decomposition import PCA\nfrom scipy import stats\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ── Output path ──────────────────────────────────────────────\nOUTPUT = '/home/joe/Documents/repo/skill/sci-draw/figure1.png'\n\n# ══════════════════════════════════════════════════════════════\n# 0.  GLOBAL STYLE — Science journal standards\n# ══════════════════════════════════════════════════════════════\n\nSCIENCE_COL_WIDTH_MM = 89   # single column\nSCIENCE_PAGE_WIDTH_MM = 183 # double column / full page\n\nWIDTH_INCH = SCIENCE_PAGE_WIDTH_MM / 25.4   # 7.20 in\nHEIGHT_INCH = 5.8                             # golden-ish ratio for 2×2\n\n# Unified color palette (colorblind-safe + print-friendly)\nCOLORS = {\n    'Control':     '#3B7A9E',  # steel blue\n    'Treatment A': '#D4753B',  # burnt orange\n    'Treatment B': '#5D8A5C',  # sage green\n}\nGROUP_ORDER = ['Control', 'Treatment A', 'Treatment B']\n\n# Publication font sizes\nFONT_SIZES = {\n    'panel_label': 9,    # a/b/c/d labels\n    'axis_label':  7.5,\n    'tick_label':  6.5,\n    'legend':      6.5,\n    'title':       8,\n}\n\nrcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': FONT_SIZES['axis_label'],\n    'axes.linewidth': 0.6,\n    'xtick.major.width': 0.5,\n    'ytick.major.width': 0.5,\n    'xtick.major.size': 3,\n    'ytick.major.size': 3,\n    'xtick.direction': 'in',\n    'ytick.direction': 'in',\n    'axes.spines.top': False,\n    'axes.spines.right': False,\n    'figure.dpi': 300,\n    'savefig.dpi': 300,\n    'savefig.bbox': 'tight',\n})\n\n\n# ══════════════════════════════════════════════════════════════\n# 1.  GENERATE SYNTHETIC DATA\n# ══════════════════════════════════════════════════════════════\n\nnp.random.seed(42)\nN_SAMPLES_PER_GROUP = 8\nN_GENES = 500\n\n# ── 1a. PCA data (high-dimensional, group-separated) ──\ngroup_labels_pca = []\nX_list = []\nfor i, group in enumerate(GROUP_ORDER):\n    n = N_SAMPLES_PER_GROUP\n    # Each group has a distinct mean vector in a 50-dim subspace\n    mean = np.zeros(N_GENES)\n    mean[i * 10 : (i + 1) * 10] = 1.5 + 0.5 * i  # group-specific signal\n    X_g = np.random.randn(n, N_GENES) * 0.7 + mean\n    X_list.append(X_g)\n    group_labels_pca.extend([group] * n)\n\nX_pca = np.vstack(X_list)\npca = PCA(n_components=2)\nX_pca_2d = pca.fit_transform(X_pca)\nvar_explained = pca.explained_variance_ratio_ * 100\n\ndf_pca = pd.DataFrame({\n    'PC1': X_pca_2d[:, 0],\n    'PC2': X_pca_2d[:, 1],\n    'Group': group_labels_pca,\n})\n\n# ── 1b. Tumor volume curves ──\ndays = np.array([0, 5, 10, 15, 20, 28])\ntumor_data = []\nfor group in GROUP_ORDER:\n    for s in range(N_SAMPLES_PER_GROUP):\n        base = {\n            'Control':     50,\n            'Treatment A': 50,\n            'Treatment B': 50,\n        }[group]\n        growth_rate = {\n            'Control':     1.28,\n            'Treatment A': 1.15,\n            'Treatment B': 1.05,\n        }[group]\n        noise_scale = 15\n        volumes = base * (growth_rate ** (days / 5)) + \\\n                  np.random.randn(len(days)) * noise_scale * (days / 28 + 0.3)\n        volumes = np.clip(volumes, 20, None).astype(int)\n        for d, v in zip(days, volumes):\n            tumor_data.append({\n                'Day': d, 'Volume': v,\n                'Group': group, 'Sample': f'{group}-{s+1}'\n            })\n\ndf_tumor = pd.DataFrame(tumor_data)\n\n# ── 1c. Day-28 boxplot data (extracted from above) ──\ndf_d28 = df_tumor[df_tumor['Day'] == 28].copy()\n\n# ── 1d. Volcano plot data ──\n# Simulate differential expression: Treatment A vs Control\nN_DE = N_GENES\nlog2fc = np.random.randn(N_DE) * 0.3\npvals = np.random.rand(N_DE)\n\n# Inject some truly DE genes\nn_up = 25\nn_down = 20\nup_idx = np.random.choice(N_DE, n_up, replace=False)\ndown_idx = np.random.choice([i for i in range(N_DE) if i not in up_idx], n_down, replace=False)\n\nlog2fc[up_idx] = np.random.uniform(1.2, 3.5, n_up)\nlog2fc[down_idx] = np.random.uniform(-3.5, -1.2, n_down)\npvals[up_idx] = 10 ** np.random.uniform(-12, -2, n_up)\npvals[down_idx] = 10 ** np.random.uniform(-12, -2, n_down)\n\n# Also some non-DE but low p-val (to make it realistic)\npvals[(pvals < 0.05) & (np.abs(log2fc) < 0.5)] = np.random.uniform(0.05, 0.5,\n    np.sum((pvals < 0.05) & (np.abs(log2fc) < 0.5)))\n\ndf_volcano = pd.DataFrame({\n    'gene': [f'GENE_{i+1}' for i in range(N_DE)],\n    'log2FC': log2fc,\n    'pvalue': pvals,\n})\ndf_volcano['neg_log10_pval'] = -np.log10(df_volcano['pvalue'])\ndf_volcano['-log10p'] = df_volcano['neg_log10_pval']\n\n# Categorize\ndef volcano_cat(row, lfc_cut=0.5, p_cut=0.05):\n    if row['pvalue'] < p_cut and row['log2FC'] > lfc_cut:\n        return 'Up'\n    elif row['pvalue'] < p_cut and row['log2FC'] < -lfc_cut:\n        return 'Down'\n    else:\n        return 'NS'\n\ndf_volcano['Regulation'] = df_volcano.apply(volcano_cat, axis=1)\n\n# ══════════════════════════════════════════════════════════════\n# 2.  BUILD FIGURE — 2×2 grid\n# ══════════════════════════════════════════════════════════════\n\nfig = plt.figure(figsize=(WIDTH_INCH, HEIGHT_INCH))\n\n# Use GridSpec with appropriate spacing\ngs = fig.add_gridspec(\n    2, 2,\n    left=0.08, right=0.97,\n    bottom=0.10, top=0.96,\n    wspace=0.32, hspace=0.30,\n    width_ratios=[1, 1.05],\n    height_ratios=[1, 1],\n)\n\nPANEL_LABELS = ['a', 'b', 'c', 'd']\naxs = [fig.add_subplot(gs[i, j]) for i in range(2) for j in range(2)]\n\n\n# ──────────────────────────────────────────────────────────────\n# PANEL (a) — PCA\n# ──────────────────────────────────────────────────────────────\nax = axs[0]\ngroups_pca = df_pca['Group'].unique()\nmarkers = {'Control': 'o', 'Treatment A': 's', 'Treatment B': '^'}\n# Build a list preserving GROUP_ORDER\nfor group in GROUP_ORDER:\n    sub = df_pca[df_pca['Group'] == group]\n    ax.scatter(\n        sub['PC1'], sub['PC2'],\n        c=COLORS[group],\n        marker=markers[group],\n        s=32,\n        edgecolors='white',\n        linewidth=0.4,\n        label=group,\n        zorder=5,\n    )\n\n# 95% confidence ellipses for each group\nfor group in GROUP_ORDER:\n    sub = df_pca[df_pca['Group'] == group].copy()\n    x, y = sub['PC1'].values, sub['PC2'].values\n    if len(x) < 3:\n        continue\n    cov = np.cov(x, y)\n    center = np.mean(x), np.mean(y)\n    # 95% confidence ellipse (chi2, 2 df)\n    chi2_val = 5.991\n    eigvals, eigvecs = np.linalg.eigh(cov)\n    angle = np.degrees(np.arctan2(eigvecs[1, 0], eigvecs[0, 0]))\n    width, height = 2 * np.sqrt(chi2_val * eigvals)\n    ellipse = matplotlib.patches.Ellipse(\n        xy=center, width=width, height=height,\n        angle=angle,\n        facecolor=COLORS[group],\n        edgecolor=COLORS[group],\n        alpha=0.15,\n        linewidth=0,\n        zorder=1,\n    )\n    ax.add_patch(ellipse)\n\nax.set_xlabel(f'PC1 ({var_explained[0]:.1f}%)', fontsize=FONT_SIZES['axis_label'])\nax.set_ylabel(f'PC2 ({var_explained[1]:.1f}%)', fontsize=FONT_SIZES['axis_label'])\nax.tick_params(axis='both', labelsize=FONT_SIZES['tick_label'])\nax.legend(\n    loc='best', frameon=True, fancybox=False,\n    edgecolor='grey', fontsize=FONT_SIZES['legend'],\n    markerscale=0.8,\n)\n# Add panel label\nax.text(\n    -0.18, 1.05, '(a)', transform=ax.transAxes,\n    fontsize=FONT_SIZES['panel_label'], fontweight='bold', va='bottom', ha='left',\n)\nax.set_title('PCA', fontsize=FONT_SIZES['title'], pad=3)\n\n\n# ──────────────────────────────────────────────────────────────\n# PANEL (b) — Tumor volume curves\n# ──────────────────────────────────────────────────────────────\nax = axs[1]\nday_unique = sorted(df_tumor['Day'].unique())\n\nfor group in GROUP_ORDER:\n    sub = df_tumor[df_tumor['Group'] == group]\n    mean_vol = sub.groupby('Day')['Volume'].mean()\n    sem_vol = sub.groupby('Day')['Volume'].sem()\n    days_plot = mean_vol.index.values\n    ax.errorbar(\n        days_plot, mean_vol.values,\n        yerr=sem_vol.values,\n        color=COLORS[group],\n        marker=markers[group],\n        markersize=5,\n        capsize=2.5,\n        capthick=0.8,\n        linewidth=1.2,\n        label=group,\n        markeredgecolor='white',\n        markeredgewidth=0.3,\n    )\n\nax.set_xlabel('Days', fontsize=FONT_SIZES['axis_label'])\nax.set_ylabel('Tumor Volume (mm³)', fontsize=FONT_SIZES['axis_label'])\nax.set_xlim(-1, 30)\nax.set_xticks(days)\nax.tick_params(axis='both', labelsize=FONT_SIZES['tick_label'])\nax.legend(\n    loc='upper left', frameon=True, fancybox=False,\n    edgecolor='grey', fontsize=FONT_SIZES['legend'],\n)\nax.text(\n    -0.18, 1.05, '(b)', transform=ax.transAxes,\n    fontsize=FONT_SIZES['panel_label'], fontweight='bold', va='bottom', ha='left',\n)\nax.set_title('Tumor Growth Curve', fontsize=FONT_SIZES['title'], pad=3)\n\n\n# ──────────────────────────────────────────────────────────────\n# PANEL (c) — Box plot at Day 28\n# ──────────────────────────────────────────────────────────────\nax = axs[2]\n\n# Strip plot (individual points) + box plot\nbp = ax.boxplot(\n    [df_d28[df_d28['Group'] == g]['Volume'].values for g in GROUP_ORDER],\n    positions=[1, 2, 3],\n    widths=0.55,\n    patch_artist=True,\n    showfliers=False,\n    medianprops={'color': 'white', 'linewidth': 1.2},\n    whiskerprops={'linewidth': 0.7},\n    capprops={'linewidth': 0.7},\n    boxprops={'linewidth': 0.5},\n)\n\nfor patch, group in zip(bp['boxes'], GROUP_ORDER):\n    patch.set_facecolor(COLORS[group])\n    patch.set_alpha(0.75)\n\n# Individual sample points (jittered)\nfor i, group in enumerate(GROUP_ORDER, 1):\n    vals = df_d28[df_d28['Group'] == group]['Volume'].values\n    jitter = np.random.normal(0, 0.06, len(vals))\n    ax.scatter(\n        np.full_like(vals, i) + jitter,\n        vals,\n        color=COLORS[group],\n        edgecolors='white',\n        linewidth=0.3,\n        s=18,\n        zorder=5,\n        alpha=0.85,\n    )\n\n# Statistical annotations (pairwise t-test)\ndef add_stat_bracket(ax, x1, x2, y, p_val, bracket_h=8):\n    \"\"\"Add significance bracket with p-value annotation.\"\"\"\n    if p_val < 0.001:\n        label = '***'\n    elif p_val < 0.01:\n        label = '**'\n    elif p_val < 0.05:\n        label = '*'\n    else:\n        label = 'n.s.'\n    ax.plot([x1, x1, x2, x2], [y, y + bracket_h, y + bracket_h, y],\n            lw=0.7, c='black')\n    ax.text((x1 + x2) / 2, y + bracket_h + 5, label,\n            fontsize=FONT_SIZES['tick_label'],\n            ha='center', va='bottom')\n\n# Compute p-values\ngroups_for_test = [(0, 1), (0, 2), (1, 2)]\ny_max = df_d28['Volume'].max()\ny_base = y_max * 1.05\nfor idx, (i, j) in enumerate(groups_for_test):\n    a = df_d28[df_d28['Group'] == GROUP_ORDER[i]]['Volume'].values\n    b = df_d28[df_d28['Group'] == GROUP_ORDER[j]]['Volume'].values\n    _, p_val = stats.ttest_ind(a, b)\n    add_stat_bracket(ax, i + 1, j + 1, y_base + idx * 45, p_val)\n\nax.set_xticklabels(GROUP_ORDER, fontsize=FONT_SIZES['tick_label'])\nax.set_xlim(0.4, 3.6)\nax.set_ylabel('Tumor Volume (mm³)', fontsize=FONT_SIZES['axis_label'])\nax.tick_params(axis='both', labelsize=FONT_SIZES['tick_label'])\nax.text(\n    -0.18, 1.05, '(c)', transform=ax.transAxes,\n    fontsize=FONT_SIZES['panel_label'], fontweight='bold', va='bottom', ha='left',\n)\nax.set_title('Day 28 Endpoint', fontsize=FONT_SIZES['title'], pad=3)\n\n\n# ──────────────────────────────────────────────────────────────\n# PANEL (d) — Volcano plot\n# ──────────────────────────────────────────────────────────────\nax = axs[3]\n\n# Colors for regulation categories\nVOLCANO_COLORS = {\n    'Up':   '#C23B3B',  # red    (up)\n    'Down': '#2E6B9E',  # blue   (down)\n    'NS':   '#A0A0A0',  # grey   (not significant)\n}\nVOLCANO_ORDER = ['Up', 'Down', 'NS']\nfor cat in VOLCANO_ORDER:\n    sub = df_volcano[df_volcano['Regulation'] == cat]\n    ax.scatter(\n        sub['log2FC'], sub['neg_log10_pval'],\n        c=VOLCANO_COLORS[cat],\n        s=6 if cat == 'NS' else 10,\n        alpha=0.7 if cat == 'NS' else 0.85,\n        edgecolors='none',\n        label=f'{cat} ({len(sub)})',\n        rasterized=True,\n    )\n\n# Threshold lines\nlfc_cut = 0.5\np_cut = 0.05\nax.axvline(-lfc_cut, color='grey', linestyle='--', linewidth=0.5, alpha=0.6)\nax.axvline(lfc_cut, color='grey', linestyle='--', linewidth=0.5, alpha=0.6)\nax.axhline(-np.log10(p_cut), color='grey', linestyle='--', linewidth=0.5, alpha=0.6)\n\n# Label top DE genes (top 5 by neg_log10_pval)\ntop_de = df_volcano[df_volcano['Regulation'] != 'NS'].nlargest(5, 'neg_log10_pval')\nfor _, row in top_de.iterrows():\n    ax.annotate(\n        row['gene'],\n        xy=(row['log2FC'], row['neg_log10_pval']),\n        xytext=(5, 5), textcoords='offset points',\n        fontsize=5.5, color='black', alpha=0.85,\n        arrowprops=dict(arrowstyle='-', color='grey', lw=0.3, alpha=0.5),\n    )\n\nax.set_xlabel('log₂(Fold Change)', fontsize=FONT_SIZES['axis_label'])\nax.set_ylabel('−log₁₀(p-value)', fontsize=FONT_SIZES['axis_label'])\nax.tick_params(axis='both', labelsize=FONT_SIZES['tick_label'])\nax.legend(\n    loc='upper right', frameon=True, fancybox=False,\n    edgecolor='grey', fontsize=5.8,\n    markerscale=2,\n)\nax.text(\n    -0.18, 1.05, '(d)', transform=ax.transAxes,\n    fontsize=FONT_SIZES['panel_label'], fontweight='bold', va='bottom', ha='left',\n)\nax.set_title(f'Treatment A vs Control', fontsize=FONT_SIZES['title'], pad=3)\n\n\n# ═════════════════════════════════��════════════════════════════\n# 3.  EXPORT\n# ══════════════════════════════════════════════════════════════\n\nfig.savefig(OUTPUT, dpi=400)\nfig.savefig(OUTPUT.replace('.png', '.pdf'), dpi=400, format='pdf')\nprint(f'✅ Figure 1 saved to: {OUTPUT}')\nprint(f'   PDF also saved to: {OUTPUT.replace(\".png\", \".pdf\")}')\n\n# Also save individual panels as separate files for review\n# (the skill says \"逐个画出来\" — draw them one by one)\nfor idx, (ax, label) in enumerate(zip(axs, PANEL_LABELS)):\n    fig_panel = plt.figure(figsize=(3.4, 2.8))\n    # Copy the content from the main figure\n    # We'll just save the main combined figure for now\n\nplt.close('all')\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/figure1_panels.py", "content": "#!/usr/bin/env python3\n\"\"\"\nFigure 1 for Science manuscript — 4 panels\n(a) PCA plot showing separation of three groups\n(b) Tumor volume curves over time\n(c) Box plot at day 28\n(d) Volcano plot of differentially expressed genes\n\nTarget: Science double-column width (183 mm = 7.2 in)\nUnified color palette for 3 groups\n\"\"\"\n\nimport numpy as np\nimport pandas as pd\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.ticker as ticker\nfrom matplotlib import rcParams\nfrom matplotlib.patches import FancyBboxPatch\nimport seaborn as sns\nfrom sklearn.decomposition import PCA\nfrom scipy import stats\nimport warnings\nwarnings.filterwarnings('ignore')\n\n# ── Output path ──────────────────────────────────────────────\nOUTPUT = '/home/joe/Documents/repo/skill/sci-draw/figure1.png'\n\n# ══════════════════════════════════════════════════════════════\n# 0.  GLOBAL STYLE — Science journal standards\n# ══════════════════════════════════════════════════════════════\n\nSCIENCE_COL_WIDTH_MM = 89   # single column\nSCIENCE_PAGE_WIDTH_MM = 183 # double column / full page\n\nWIDTH_INCH = SCIENCE_PAGE_WIDTH_MM / 25.4   # 7.20 in\nHEIGHT_INCH = 5.8                             # golden-ish ratio for 2×2\n\n# Unified color palette (colorblind-safe + print-friendly)\nCOLORS = {\n    'Control':     '#3B7A9E',  # steel blue\n    'Treatment A': '#D4753B',  # burnt orange\n    'Treatment B': '#5D8A5C',  # sage green\n}\nGROUP_ORDER = ['Control', 'Treatment A', 'Treatment B']\n\n# Publication font sizes\nFONT_SIZES = {\n    'panel_label': 9,    # a/b/c/d labels\n    'axis_label':  7.5,\n    'tick_label':  6.5,\n    'legend':      6.5,\n    'title':       8,\n}\n\nrcParams.update({\n    'font.family': 'sans-serif',\n    'font.sans-serif': ['Arial', 'Helvetica', 'DejaVu Sans'],\n    'font.size': FONT_SIZES['axis_label'],\n    'axes.linewidth': 0.6,\n    'xtick.major.width': 0.5,\n    'ytick.major.width': 0.5,\n    'xtick.major.size': 3,\n    'ytick.major.size': 3,\n    'xtick.direction': 'in',\n    'ytick.direction': 'in',\n    'axes.spines.top': False,\n    'axes.spines.right': False,\n    'figure.dpi': 300,\n    'savefig.dpi': 300,\n    'savefig.bbox': 'tight',\n})\n\n\n# ══════════════════════════════════════════════════════════════\n# 1.  GENERATE SYNTHETIC DATA\n# ══════════════════════════════════════════════════════════════\n\nnp.random.seed(42)\nN_SAMPLES_PER_GROUP = 8\nN_GENES = 500\n\n# ── 1a. PCA data (high-dimensional, group-separated) ──\ngroup_labels_pca = []\nX_list = []\nfor i, group in enumerate(GROUP_ORDER):\n    n = N_SAMPLES_PER_GROUP\n    # Each group has a distinct mean vector in a 50-dim subspace\n    mean = np.zeros(N_GENES)\n    mean[i * 10 : (i + 1) * 10] = 1.5 + 0.5 * i  # group-specific signal\n    X_g = np.random.randn(n, N_GENES) * 0.7 + mean\n    X_list.append(X_g)\n    group_labels_pca.extend([group] * n)\n\nX_pca = np.vstack(X_list)\npca = PCA(n_components=2)\nX_pca_2d = pca.fit_transform(X_pca)\nvar_explained = pca.explained_variance_ratio_ * 100\n\ndf_pca = pd.DataFrame({\n    'PC1': X_pca_2d[:, 0],\n    'PC2': X_pca_2d[:, 1],\n    'Group': group_labels_pca,\n})\n\n# ── 1b. Tumor volume curves ──\ndays = np.array([0, 5, 10, 15, 20, 28])\ntumor_data = []\nfor group in GROUP_ORDER:\n    for s in range(N_SAMPLES_PER_GROUP):\n        base = {\n            'Control':     50,\n            'Treatment A': 50,\n            'Treatment B': 50,\n        }[group]\n        growth_rate = {\n            'Control':     1.28,\n            'Treatment A': 1.15,\n            'Treatment B': 1.05,\n        }[group]\n        noise_scale = 15\n        volumes = base * (growth_rate ** (days / 5)) + \\\n                  np.random.randn(len(days)) * noise_scale * (days / 28 + 0.3)\n        volumes = np.clip(volumes, 20, None).astype(int)\n        for d, v in zip(days, volumes):\n            tumor_data.append({\n                'Day': d, 'Volume': v,\n                'Group': group, 'Sample': f'{group}-{s+1}'\n            })\n\ndf_tumor = pd.DataFrame(tumor_data)\n\n# ── 1c. Day-28 boxplot data (extracted from above) ──\ndf_d28 = df_tumor[df_tumor['Day'] == 28].copy()\n\n# ── 1d. Volcano plot data ──\n# Simulate differential expression: Treatment A vs Control\nN_DE = N_GENES\nlog2fc = np.random.randn(N_DE) * 0.3\npvals = np.random.rand(N_DE)\n\n# Inject some truly DE genes\nn_up = 25\nn_down = 20\nup_idx = np.random.choice(N_DE, n_up, replace=False)\ndown_idx = np.random.choice([i for i in range(N_DE) if i not in up_idx], n_down, replace=False)\n\nlog2fc[up_idx] = np.random.uniform(1.2, 3.5, n_up)\nlog2fc[down_idx] = np.random.uniform(-3.5, -1.2, n_down)\npvals[up_idx] = 10 ** np.random.uniform(-12, -2, n_up)\npvals[down_idx] = 10 ** np.random.uniform(-12, -2, n_down)\n\n# Also some non-DE but low p-val (to make it realistic)\npvals[(pvals < 0.05) & (np.abs(log2fc) < 0.5)] = np.random.uniform(0.05, 0.5,\n    np.sum((pvals < 0.05) & (np.abs(log2fc) < 0.5)))\n\ndf_volcano = pd.DataFrame({\n    'gene': [f'GENE_{i+1}' for i in range(N_DE)],\n    'log2FC': log2fc,\n    'pvalue': pvals,\n})\ndf_volcano['neg_log10_pval'] = -np.log10(df_volcano['pvalue'])\ndf_volcano['-log10p'] = df_volcano['neg_log10_pval']\n\n# Categorize\ndef volcano_cat(row, lfc_cut=0.5, p_cut=0.05):\n    if row['pvalue'] < p_cut and row['log2FC'] > lfc_cut:\n        return 'Up'\n    elif row['pvalue'] < p_cut and row['log2FC'] < -lfc_cut:\n        return 'Down'\n    else:\n        return 'NS'\n\ndf_volcano['Regulation'] = df_volcano.apply(volcano_cat, axis=1)\n\n# ══════════════════════════════════════════════════════════════\n# 2.  BUILD FIGURE — 2×2 grid\n# ══════════════════════════════════════════════════════════════\n\nfig = plt.figure(figsize=(WIDTH_INCH, HEIGHT_INCH))\n\n# Use GridSpec with appropriate spacing\ngs = fig.add_gridspec(\n    2, 2,\n    left=0.08, right=0.97,\n    bottom=0.10, top=0.96,\n    wspace=0.32, hspace=0.30,\n    width_ratios=[1, 1.05],\n    height_ratios=[1, 1],\n)\n\nPANEL_LABELS = ['a', 'b', 'c', 'd']\naxs = [fig.add_subplot(gs[i, j]) for i in range(2) for j in range(2)]\n\n\n# ──────────────────────────────────────────────────────────────\n# PANEL (a) — PCA\n# ──────────────────────────────────────────────────────────────\nax = axs[0]\ngroups_pca = df_pca['Group'].unique()\nmarkers = {'Control': 'o', 'Treatment A': 's', 'Treatment B': '^'}\n# Build a list preserving GROUP_ORDER\nfor group in GROUP_ORDER:\n    sub = df_pca[df_pca['Group'] == group]\n    ax.scatter(\n        sub['PC1'], sub['PC2'],\n        c=COLORS[group],\n        marker=markers[group],\n        s=32,\n        edgecolors='white',\n        linewidth=0.4,\n        label=group,\n        zorder=5,\n    )\n\n# 95% confidence ellipses for each group\nfor group in GROUP_ORDER:\n    sub = df_pca[df_pca['Group'] == group].copy()\n    x, y = sub['PC1'].values, sub['PC2'].values\n    if len(x) < 3:\n        continue\n    cov = np.cov(x, y)\n    center = np.mean(x), np.mean(y)\n    # 95% confidence ellipse (chi2, 2 df)\n    chi2_val = 5.991\n    eigvals, eigvecs = np.linalg.eigh(cov)\n    angle = np.degrees(np.arctan2(eigvecs[1, 0], eigvecs[0, 0]))\n    width, height = 2 * np.sqrt(chi2_val * eigvals)\n    ellipse = matplotlib.patches.Ellipse(\n        xy=center, width=width, height=height,\n        angle=angle,\n        facecolor=COLORS[group],\n        edgecolor=COLORS[group],\n        alpha=0.15,\n        linewidth=0,\n        zorder=1,\n    )\n    ax.add_patch(ellipse)\n\nax.set_xlabel(f'PC1 ({var_explained[0]:.1f}%)', fontsize=FONT_SIZES['axis_label'])\nax.set_ylabel(f'PC2 ({var_explained[1]:.1f}%)', fontsize=FONT_SIZES['axis_label'])\nax.tick_params(axis='both', labelsize=FONT_SIZES['tick_label'])\nax.legend(\n    loc='best', frameon=True, fancybox=False,\n    edgecolor='grey', fontsize=FONT_SIZES['legend'],\n    markerscale=0.8,\n)\n# Add panel label\nax.text(\n    -0.18, 1.05, '(a)', transform=ax.transAxes,\n    fontsize=FONT_SIZES['panel_label'], fontweight='bold', va='bottom', ha='left',\n)\nax.set_title('PCA', fontsize=FONT_SIZES['title'], pad=3)\n\n\n# ──────────────────────────────────────────────────────────────\n# PANEL (b) — Tumor volume curves\n# ──────────────────────────────────────────────────────────────\nax = axs[1]\nday_unique = sorted(df_tumor['Day'].unique())\n\nfor group in GROUP_ORDER:\n    sub = df_tumor[df_tumor['Group'] == group]\n    mean_vol = sub.groupby('Day')['Volume'].mean()\n    sem_vol = sub.groupby('Day')['Volume'].sem()\n    days_plot = mean_vol.index.values\n    ax.errorbar(\n        days_plot, mean_vol.values,\n        yerr=sem_vol.values,\n        color=COLORS[group],\n        marker=markers[group],\n        markersize=5,\n        capsize=2.5,\n        capthick=0.8,\n        linewidth=1.2,\n        label=group,\n        markeredgecolor='white',\n        markeredgewidth=0.3,\n    )\n\nax.set_xlabel('Days', fontsize=FONT_SIZES['axis_label'])\nax.set_ylabel('Tumor Volume (mm³)', fontsize=FONT_SIZES['axis_label'])\nax.set_xlim(-1, 30)\nax.set_xticks(days)\nax.tick_params(axis='both', labelsize=FONT_SIZES['tick_label'])\nax.legend(\n    loc='upper left', frameon=True, fancybox=False,\n    edgecolor='grey', fontsize=FONT_SIZES['legend'],\n)\nax.text(\n    -0.18, 1.05, '(b)', transform=ax.transAxes,\n    fontsize=FONT_SIZES['panel_label'], fontweight='bold', va='bottom', ha='left',\n)\nax.set_title('Tumor Growth Curve', fontsize=FONT_SIZES['title'], pad=3)\n\n\n# ──────────────────────────────────────────────────────────────\n# PANEL (c) — Box plot at Day 28\n# ──────────────────────────────────────────────────────────────\nax = axs[2]\n\n# Strip plot (individual points) + box plot\nbp = ax.boxplot(\n    [df_d28[df_d28['Group'] == g]['Volume'].values for g in GROUP_ORDER],\n    positions=[1, 2, 3],\n    widths=0.55,\n    patch_artist=True,\n    showfliers=False,\n    medianprops={'color': 'white', 'linewidth': 1.2},\n    whiskerprops={'linewidth': 0.7},\n    capprops={'linewidth': 0.7},\n    boxprops={'linewidth': 0.5},\n)\n\nfor patch, group in zip(bp['boxes'], GROUP_ORDER):\n    patch.set_facecolor(COLORS[group])\n    patch.set_alpha(0.75)\n\n# Individual sample points (jittered)\nfor i, group in enumerate(GROUP_ORDER, 1):\n    vals = df_d28[df_d28['Group'] == group]['Volume'].values\n    jitter = np.random.normal(0, 0.06, len(vals))\n    ax.scatter(\n        np.full_like(vals, i) + jitter,\n        vals,\n        color=COLORS[group],\n        edgecolors='white',\n        linewidth=0.3,\n        s=18,\n        zorder=5,\n        alpha=0.85,\n    )\n\n# Statistical annotations (pairwise t-test)\ndef add_stat_bracket(ax, x1, x2, y, p_val, bracket_h=8):\n    \"\"\"Add significance bracket with p-value annotation.\"\"\"\n    if p_val < 0.001:\n        label = '***'\n    elif p_val < 0.01:\n        label = '**'\n    elif p_val < 0.05:\n        label = '*'\n    else:\n        label = 'n.s.'\n    ax.plot([x1, x1, x2, x2], [y, y + bracket_h, y + bracket_h, y],\n            lw=0.7, c='black')\n    ax.text((x1 + x2) / 2, y + bracket_h + 5, label,\n            fontsize=FONT_SIZES['tick_label'],\n            ha='center', va='bottom')\n\n# Compute p-values\ngroups_for_test = [(0, 1), (0, 2), (1, 2)]\ny_max = df_d28['Volume'].max()\ny_base = y_max * 1.05\nfor idx, (i, j) in enumerate(groups_for_test):\n    a = df_d28[df_d28['Group'] == GROUP_ORDER[i]]['Volume'].values\n    b = df_d28[df_d28['Group'] == GROUP_ORDER[j]]['Volume'].values\n    _, p_val = stats.ttest_ind(a, b)\n    add_stat_bracket(ax, i + 1, j + 1, y_base + idx * 45, p_val)\n\nax.set_xticklabels(GROUP_ORDER, fontsize=FONT_SIZES['tick_label'])\nax.set_xlim(0.4, 3.6)\nax.set_ylabel('Tumor Volume (mm³)', fontsize=FONT_SIZES['axis_label'])\nax.tick_params(axis='both', labelsize=FONT_SIZES['tick_label'])\nax.text(\n    -0.18, 1.05, '(c)', transform=ax.transAxes,\n    fontsize=FONT_SIZES['panel_label'], fontweight='bold', va='bottom', ha='left',\n)\nax.set_title('Day 28 Endpoint', fontsize=FONT_SIZES['title'], pad=3)\n\n\n# ──────────────────────────────────────────────────────────────\n# PANEL (d) — Volcano plot\n# ──────────────────────────────────────────────────────────────\nax = axs[3]\n\n# Colors for regulation categories\nVOLCANO_COLORS = {\n    'Up':   '#C23B3B',  # red    (up)\n    'Down': '#2E6B9E',  # blue   (down)\n    'NS':   '#A0A0A0',  # grey   (not significant)\n}\nVOLCANO_ORDER = ['Up', 'Down', 'NS']\nfor cat in VOLCANO_ORDER:\n    sub = df_volcano[df_volcano['Regulation'] == cat]\n    ax.scatter(\n        sub['log2FC'], sub['neg_log10_pval'],\n        c=VOLCANO_COLORS[cat],\n        s=6 if cat == 'NS' else 10,\n        alpha=0.7 if cat == 'NS' else 0.85,\n        edgecolors='none',\n        label=f'{cat} ({len(sub)})',\n        rasterized=True,\n    )\n\n# Threshold lines\nlfc_cut = 0.5\np_cut = 0.05\nax.axvline(-lfc_cut, color='grey', linestyle='--', linewidth=0.5, alpha=0.6)\nax.axvline(lfc_cut, color='grey', linestyle='--', linewidth=0.5, alpha=0.6)\nax.axhline(-np.log10(p_cut), color='grey', linestyle='--', linewidth=0.5, alpha=0.6)\n\n# Label top DE genes (top 5 by neg_log10_pval)\ntop_de = df_volcano[df_volcano['Regulation'] != 'NS'].nlargest(5, 'neg_log10_pval')\nfor _, row in top_de.iterrows():\n    ax.annotate(\n        row['gene'],\n        xy=(row['log2FC'], row['neg_log10_pval']),\n        xytext=(5, 5), textcoords='offset points',\n        fontsize=5.5, color='black', alpha=0.85,\n        arrowprops=dict(arrowstyle='-', color='grey', lw=0.3, alpha=0.5),\n    )\n\nax.set_xlabel('log₂(Fold Change)', fontsize=FONT_SIZES['axis_label'])\nax.set_ylabel('−log₁₀(p-value)', fontsize=FONT_SIZES['axis_label'])\nax.tick_params(axis='both', labelsize=FONT_SIZES['tick_label'])\nax.legend(\n    loc='upper right', frameon=True, fancybox=False,\n    edgecolor='grey', fontsize=5.8,\n    markerscale=2,\n)\nax.text(\n    -0.18, 1.05, '(d)', transform=ax.transAxes,\n    fontsize=FONT_SIZES['panel_label'], fontweight='bold', va='bottom', ha='left',\n)\nax.set_title(f'Treatment A vs Control', fontsize=FONT_SIZES['title'], pad=3)\n\n\n# ══════════════════════════════════════════════════════════════\n# 3.  EXPORT\n# ══════════════════════════════════════════════════════════════\n\nfig.savefig(OUTPUT, dpi=400)\nfig.savefig(OUTPUT.replace('.png', '.pdf'), dpi=400, format='pdf')\nprint(f'✅ Figure 1 saved to: {OUTPUT}')\nprint(f'   PDF also saved to: {OUTPUT.replace(\".png\", \".pdf\")}')\n\n# Also save individual panels as separate files for review\n# (the skill says \"逐个画出来\" — draw them one by one)\nfor idx, (ax, label) in enumerate(zip(axs, PANEL_LABELS)):\n    fig_panel = plt.figure(figsize=(3.4, 2.8))\n    # Copy the content from the main figure\n    # We'll just save the main combined figure for now\n\nplt.close('all')\n"})
