TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\nData Preprocessing Pipeline\n===========================\nRead multiple CSV files → handle missing values → standardize numerical cols →\none-hot encode categorical variables → merge into a single feature matrix.\n\nUsage:\n    python data_pipeline.py --config config.yaml\n    python data_pipeline.py --csv data1.csv data2.csv --id_col sample_id\n\"\"\"\n\nimport os\nimport sys\nimport logging\nimport argparse\nfrom pathlib import Path\nfrom typing import Optional, List, Dict, Union, Any, Literal\n\nimport numpy as np\nimport pandas as pd\nfrom sklearn.preprocessing import StandardScaler, MinMaxScaler, RobustScaler\n\n# ---------------------------------------------------------------------------\n# Logging\n# ---------------------------------------------------------------------------\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s | %(levelname)-8s | %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"pipeline\")\n\n\n# ---------------------------------------------------------------------------\n# Scalers\n# ---------------------------------------------------------------------------\nSCALER_MAP: Dict[str, Any] = {\n    \"zscore\": StandardScaler,\n    \"minmax\": MinMaxScaler,\n    \"robust\": RobustScaler,\n}\nVALID_SCALERS = set(SCALER_MAP.keys()) | {None}\n\n\n# ---------------------------------------------------------------------------\n# Pipeline class\n# ---------------------------------------------------------------------------\nclass DataPipeline:\n    \"\"\"Configurable data-cleaning pipeline for multiple CSV files.\n\n    Typical workflow::\n\n        pipe = DataPipeline()\n        pipe.add_csv(\"expr.csv\", index_col=\"gene_id\")\n        pipe.add_csv(\"clinical.csv\", index_col=\"patient_id\")\n        pipe.run(\n            numeric_strategy=\"median\",\n            scaler=\"zscore\",\n            categorical_strategy=\"onehot\",\n            id_col=\"sample_id\",\n        )\n        matrix = pipe.feature_matrix  # pd.DataFrame\n    \"\"\"\n\n    def __init__(self) -> None:\n        self.frames: List[pd.DataFrame] = []\n        self.names: List[str] = []\n        self._report: Dict[str, Any] = {}\n\n    # ---- File I/O ---------------------------------------------------------\n\n    def add_csv(\n        self,\n        path: Union[str, Path],\n        name: Optional[str] = None,\n        **read_kwargs: Any,\n    ) -> \"DataPipeline\":\n        \"\"\"Load a CSV file and store it internally.\n\n        Parameters\n        ----------\n        path : str or Path\n            Path to the CSV file.\n        name : str, optional\n            Short label for this source (used in logging / reports).\n            Defaults to the filename stem.\n        **read_kwargs\n            Extra arguments forwarded to ``pd.read_csv`` (e.g. ``sep``,\n            ``index_col``, ``encoding``, ``dtype``).\n        \"\"\"\n        p = Path(path)\n        if not p.exists():\n            raise FileNotFoundError(f\"CSV not found: {p.resolve()}\")\n        label = name or p.stem\n        log.info(\"Loading  %s  from  %s\", label, p)\n\n        df = pd.read_csv(p, **read_kwargs)\n        log.info(\"  → shape %s, columns %d\", df.shape, len(df.columns))\n        self.frames.append(df)\n        self.names.append(label)\n        return self\n\n    def add_dataframe(\n        self, df: pd.DataFrame, name: Optional[str] = None\n    ) -> \"DataPipeline\":\n        \"\"\"Add an already-in-memory DataFrame.\"\"\"\n        self.frames.append(df.copy())\n        self.names.append(name or f\"df_{len(self.frames)}\")\n        return self\n\n    # ---- Column classification -------------------------------------------\n\n    @staticmethod\n    def _classify_columns(\n        df: pd.DataFrame,\n    ) -> Dict[str, List[str]]:\n        \"\"\"Split columns into numeric, categorical, and id-like.\"\"\"\n        numeric = list(df.select_dtypes(include=[np.number]).columns)\n        categorical = list(\n            df.select_dtypes(include=[\"object\", \"category\", \"bool\"]).columns\n        )\n        # Strings that happen to be dtype=object but can be parsed as numbers\n        # are not auto‑detected; the caller can pass ``dtype`` in read_kwargs.\n        return {\"numeric\": numeric, \"categorical\": categorical}\n\n    # ---- Missing-value handling ------------------------------------------\n\n    def _handle_missing(\n        self,\n        df: pd.DataFrame,\n        numeric_strategy: Union[str, float, None] = \"median\",\n        categorical_strategy: Union[str, str, None] = \"mode\",\n        numeric_cols: Optional[List[str]] = None,\n        categorical_cols: Optional[List[str]] = None,\n        fill_values: Optional[Dict[str, Any]] = None,\n    ) -> pd.DataFrame:\n        \"\"\"Impute missing values *in place* (returns the same DataFrame).\"\"\"\n        df = df.copy()\n        num_cols = numeric_cols or self._classify_columns(df)[\"numeric\"]\n        cat_cols = categorical_cols or self._classify_columns(df)[\"categorical\"]\n\n        # --- Per‑column explicit fill ---\n        if fill_values:\n            for col, val in fill_values.items():\n                if col in df.columns and df[col].isna().any():\n                    df[col] = df[col].fillna(val)\n                    cnt = df[col].isna().sum()\n                    log.info(\"  fill  %s  →  %s  (na left: %d)\", col, val, cnt)\n\n        # --- Numeric ---\n        numeric_strategy = self._resolve_strategy(numeric_strategy)\n        for col in num_cols:\n            if col not in df.columns:\n                continue\n            n_na = df[col].isna().sum()\n            if n_na == 0:\n                continue\n            if numeric_strategy == \"drop\":\n                df.dropna(subset=[col], inplace=True)\n                log.info(\"  dropna  %s  →  -%d rows\", col, n_na)\n            elif numeric_strategy in (\"mean\", \"median\", \"mode\"):\n                val = getattr(df[col], numeric_strategy)()\n                df[col] = df[col].fillna(val)\n                log.info(\"  impute  %s  →  %s (%.4f)\", col, numeric_strategy, val)\n            elif isinstance(numeric_strategy, (int, float)):\n                df[col] = df[col].fillna(numeric_strategy)\n                log.info(\"  impute  %s  →  constant (%.4f)\", col, numeric_strategy)\n            else:\n                log.warning(\"  unknown numeric strategy for %s, skipping\", col)\n\n        # --- Categorical ---\n        categorical_strategy = self._resolve_strategy(categorical_strategy)\n        for col in cat_cols:\n            if col not in df.columns:\n                continue\n            n_na = df[col].isna().sum()\n            if n_na == 0:\n                continue\n            if categorical_strategy == \"drop\":\n                df.dropna(subset=[col], inplace=True)\n                log.info(\"  dropna  %s  →  -%d rows\", col, n_na)\n            elif categorical_strategy == \"mode\":\n                mode_val = df[col].mode(dropna=True)\n                if not mode_val.empty:\n                    df[col] = df[col].fillna(mode_val.iloc[0])\n                    log.info(\"  impute  %s  →  mode (%s)\", col, mode_val.iloc[0])\n                else:\n                    # All NaN → fill with \"missing\"\n                    df[col] = df[col].fillna(\"missing\")\n                    log.info(\"  impute  %s  →  'missing' (all NaN)\", col)\n            elif categorical_strategy == \"missing\":\n                df[col] = df[col].fillna(\"missing\")\n                log.info(\"  impute  %s  →  'missing'\", col)\n            elif isinstance(categorical_strategy, str):\n                df[col] = df[col].fillna(categorical_strategy)\n                log.info(\"  impute  %s  →  constant (%s)\", col, categorical_strategy)\n            else:\n                log.warning(\"  unknown cat strategy for %s, skipping\", col)\n\n        return df\n\n    @staticmethod\n    def _resolve_strategy(strat: Any) -> Any:\n        \"\"\"Resolve common aliases to lowercase strings.\"\"\"\n        if isinstance(strat, str):\n            lowered = strat.lower().strip()\n            return lowered\n        return strat\n\n    # ---- Standardization --------------------------------------------------\n\n    def _standardize_numeric(\n        self,\n        df: pd.DataFrame,\n        scaler: Optional[Union[str, Any]] = \"zscore\",\n        numeric_cols: Optional[List[str]] = None,\n    ) -> pd.DataFrame:\n        \"\"\"Standardize numeric columns (returns new DataFrame with scaled columns).\"\"\"\n        if scaler is None:\n            return df\n\n        cols = numeric_cols or self._classify_columns(df)[\"numeric\"]\n        cols = [c for c in cols if c in df.columns]\n\n        if not cols:\n            log.info(\"  no numeric columns to scale\")\n            return df\n\n        df = df.copy()\n\n        if isinstance(scaler, str):\n            scaler_cls = SCALER_MAP.get(scaler.lower())\n            if scaler_cls is None:\n                raise ValueError(\n                    f\"Unknown scaler '{scaler}'. Choose from {set(SCALER_MAP)}\"\n                )\n            scaler_instance = scaler_cls()\n        else:\n            # User passed a fitted or unfitted sklearn‑like object\n            scaler_instance = scaler\n\n        scaled = scaler_instance.fit_transform(df[cols])\n        df[cols] = np.round(scaled, 10)\n        log.info(\"  scale  %d cols  →  %s\", len(cols), scaler_instance.__class__.__name__)\n        return df\n\n    # ---- One‑hot encoding -------------------------------------------------\n\n    def _encode_categorical(\n        self,\n        df: pd.DataFrame,\n        strategy: Literal[\"onehot\", \"dummy\", \"label\"] = \"onehot\",\n        categorical_cols: Optional[List[str]] = None,\n        drop_first: bool = False,\n        max_categories: Optional[int] = None,\n    ) -> pd.DataFrame:\n        \"\"\"Encode categorical columns.\n\n        Parameters\n        ----------\n        strategy :\n            - ``\"onehot\"`` : one‑hot encoding via ``pd.get_dummies``.\n            - ``\"dummy\"``  : same as onehot but with *drop_first=True*.\n            - ``\"label\"``  : label encoding — map each category to an integer.\n        drop_first :\n            Only used for ``\"onehot\"``. If True, k‑1 dummies are created for\n            k categories.  **Ignored when strategy=\"dummy\"** (always drops).\n        max_categories :\n            If set, only the top‑*max_categories* most frequent categories per\n            column are kept; the rest become \"other\".\n        \"\"\"\n        if strategy is None:\n            return df\n\n        cols = categorical_cols or self._classify_columns(df)[\"categorical\"]\n        cols = [c for c in cols if c in df.columns]\n\n        if not cols:\n            return df\n\n        df = df.copy()\n\n        if strategy == \"label\":\n            for col in cols:\n                df[col] = df[col].astype(\"category\").cat.codes\n                df[col] = df[col].replace(-1, np.nan)  # unseen → NaN\n            log.info(\"  label-encode  %d cols\", len(cols))\n            return df\n\n        # --- one‑hot / dummy ---\n        if max_categories is not None:\n            for col in cols:\n                top = df[col].value_counts().index[:max_categories]\n                df[col] = df[col].where(df[col].isin(top), other=\"other\")\n\n        do_drop = drop_first if strategy == \"onehot\" else True\n        df = pd.get_dummies(df, columns=cols, drop_first=do_drop, dtype=int)\n        log.info(\"  one-hot / dummy  %d cols\", len(cols))\n        return df\n\n    # ---- Merge ------------------------------------------------------------\n\n    def _merge_frames(\n        self,\n        frames: List[pd.DataFrame],\n        how: Literal[\"inner\", \"outer\", \"left\"] = \"outer\",\n        id_col: Optional[str] = None,\n    ) -> pd.DataFrame:\n        \"\"\"Merge multiple DataFrames.\n\n        Parameters\n        ----------\n        how :\n            - ``\"outer\"`` : union of all rows/columns (NaN filled later).\n            - ``\"inner\"`` : intersection of rows (common index).\n            - ``\"left\"``  : keep rows from the **first** DataFrame only.\n        id_col :\n            If given, merge on this column (must exist in all frames).\n            Otherwise merge on the index.\n        \"\"\"\n        if len(frames) == 1:\n            return frames[0]\n\n        merged = frames[0]\n        for i, df in enumerate(frames[1:], start=1):\n            left_on = id_col if id_col else None\n            right_on = id_col if id_col else None\n            left_index = id_col is None\n            right_index = id_col is None or (\n                id_col == merged.index.name and id_col == df.index.name\n            )\n\n            merged = pd.merge(\n                merged,\n                df,\n                how=how,\n                left_on=left_on,\n                right_on=right_on,\n                left_index=left_index,\n                right_index=right_index,\n                suffixes=(\"\", f\"_{self.names[i]}\" if i < len(self.names) else \"_dup\"),\n            )\n            log.info(\n                \"  merge [%s]  →  %s  (rows %d, cols %d)\",\n                how,\n                self.names[i],\n                len(merged),\n                len(merged.columns),\n            )\n\n        if id_col and id_col in merged.columns:\n            merged.set_index(id_col, inplace=True)\n\n        return merged\n\n    # ---- Main entry point -------------------------------------------------\n\n    def run(\n        self,\n        *,\n        # --- Missing values ---\n        numeric_strategy: Union[str, float, None] = \"median\",\n        categorical_strategy: Union[str, None] = \"mode\",\n        fill_values: Optional[Dict[str, Any]] = None,\n        # --- Standardization ---\n        scaler: Optional[Union[str, Any]] = \"zscore\",\n        # --- Encoding ---\n        categorical_encoding: Literal[\"onehot\", \"dummy\", \"label\", None] = \"onehot\",\n        drop_first: bool = False,\n        max_categories: Optional[int] = None,\n        # --- Merge ---\n        merge_how: Literal[\"inner\", \"outer\", \"left\"] = \"outer\",\n        id_col: Optional[str] = None,\n        # --- Output ---\n        drop_original_categorical: bool = True,\n    ) -> pd.DataFrame:\n        \"\"\"Execute the full pipeline.\n\n        Returns the merged feature matrix as a ``pd.DataFrame``, also\n        accessible via ``self.feature_matrix``.\n        \"\"\"\n        log.info(\"=\" * 55)\n        log.info(\"Pipeline start  (%d CSV files)\", len(self.frames))\n        log.info(\"=\" * 55)\n\n        if not self.frames:\n            raise ValueError(\"No data loaded — use .add_csv() or .add_dataframe() first.\")\n\n        processed: List[pd.DataFrame] = []\n\n        for idx, (df, name) in enumerate(zip(self.frames, self.names)):\n            log.info(\"─── Source %d: %s ───\", idx + 1, name)\n            df = self._handle_missing(\n                df,\n                numeric_strategy=numeric_strategy,\n                categorical_strategy=categorical_strategy,\n                fill_values=fill_values,\n            )\n            df = self._standardize_numeric(df, scaler=scaler)\n\n            if categorical_encoding:\n                df = self._encode_categorical(\n                    df,\n                    strategy=categorical_encoding,\n                    drop_first=drop_first,\n                    max_categories=max_categories,\n                )\n                if drop_original_categorical:\n                    orig_cat = self._classify_columns(\n                        self.frames[idx]\n                    )[\"categorical\"]\n                    # Only drop columns that haven't already been replaced\n                    cols_to_drop = [c for c in orig_cat if c in df.columns]\n                    if cols_to_drop:\n                        df.drop(columns=cols_to_drop, inplace=True)\n\n            processed.append(df)\n\n        # ---- Merge ----\n        log.info(\"─── Merging %d processed tables ───\", len(processed))\n        merged = self._merge_frames(processed, how=merge_how, id_col=id_col)\n\n        # ---- Final missing check ----\n        n_na = merged.isna().sum().sum()\n        if n_na > 0:\n            log.warning(\n                \"  ⚠  %d NaN values remain after imputation \"\n                \"(outer join may introduce them). \"\n                \"Final fill with 0.\",\n                n_na,\n            )\n            merged.fillna(0, inplace=True)\n\n        self.feature_matrix = merged\n        self._report = {\n            \"n_sources\": len(self.frames),\n            \"final_shape\": merged.shape,\n            \"final_columns\": list(merged.columns),\n            \"final_dtypes\": merged.dtypes.astype(str).to_dict(),\n        }\n\n        log.info(\"=\" * 55)\n        log.info(\"Pipeline done  →  %s  (%d rows, %d cols)\", merged.shape, *merged.shape)\n        log.info(\"=\" * 55)\n\n        return merged\n\n    # ---- Export -----------------------------------------------------------\n\n    def save(self, path: Union[str, Path], **to_csv_kwargs: Any) -> None:\n        \"\"\"Save the feature matrix to CSV.\n\n        Parameters\n        ----------\n        path : str or Path\n            Output path.\n        **to_csv_kwargs\n            Passed to ``pd.DataFrame.to_csv`` (e.g. ``index=False``).\n        \"\"\"\n        if not hasattr(self, \"feature_matrix\"):\n            raise RuntimeError(\"Call .run() before .save().\")\n        path = Path(path)\n        path.parent.mkdir(parents=True, exist_ok=True)\n        self.feature_matrix.to_csv(path, **to_csv_kwargs)\n        log.info(\"Saved  →  %s\", path.resolve())\n\n    def report(self) -> Dict[str, Any]:\n        \"\"\"Return a summary dict of the pipeline run.\"\"\"\n        return dict(self._report)\n\n    # ---- Convenience: single‑call static method ---------------------------\n\n    @staticmethod\n    def quick(\n        csv_paths: List[Union[str, Path]],\n        id_col: Optional[str] = None,\n        numeric_strategy: str = \"median\",\n        scaler: Optional[str] = \"zscore\",\n        categorical_encoding: str = \"onehot\",\n        merge_how: str = \"outer\",\n        read_kwargs: Optional[Dict[str, Any]] = None,\n    ) -> pd.DataFrame:\n        \"\"\"Minimal‑friction entry point — load, clean, return.\n\n        Examples\n        --------\n        >>> df = DataPipeline.quick([\"a.csv\", \"b.csv\"], id_col=\"sample\")\n        \"\"\"\n        pipe = DataPipeline()\n        kwargs = read_kwargs or {}\n        for p in csv_paths:\n            pipe.add_csv(p, **kwargs)\n        return pipe.run(\n            id_col=id_col,\n            numeric_strategy=numeric_strategy,\n            scaler=scaler,\n            categorical_encoding=categorical_encoding,\n            merge_how=merge_how,\n        )\n\n\n# ---------------------------------------------------------------------------\n# CLI\n# ---------------------------------------------------------------------------\ndef build_parser() -> argparse.ArgumentParser:\n    parser = argparse.ArgumentParser(\n        description=\"Data preprocessing pipeline: clean, scale, encode, merge CSVs.\"\n    )\n    parser.add_argument(\"--csv\", nargs=\"+\", help=\"CSV file(s) to process\")\n    parser.add_argument(\"--id_col\", default=None, help=\"Index / ID column name\")\n    parser.add_argument(\n        \"--numeric_strategy\",\n        default=\"median\",\n        help=\"Missing‑value strategy for numeric cols \"\n        \"(mean / median / mode / drop / a number). Default: median\",\n    )\n    parser.add_argument(\n        \"--categorical_strategy\",\n        default=\"mode\",\n        help=\"Missing‑value strategy for categorical cols \"\n        \"(mode / missing / drop / a string). Default: mode\",\n    )\n    parser.add_argument(\n        \"--scaler\",\n        default=\"zscore\",\n        help=\"Scaler for numeric cols (zscore / minmax / robust / none). \"\n        \"Default: zscore\",\n    )\n    parser.add_argument(\n        \"--encoding\",\n        default=\"onehot\",\n        choices=[\"onehot\", \"dummy\", \"label\", \"none\"],\n        help=\"Categorical encoding. Default: onehot\",\n    )\n    parser.add_argument(\n        \"--merge\",\n        default=\"outer\",\n        choices=[\"inner\", \"outer\", \"left\"],\n        help=\"Merge strategy. Default: outer\",\n    )\n    parser.add_argument(\"--out\", default=\"feature_matrix.csv\", help=\"Output CSV path\")\n    parser.add_argument(\"--sep\", default=\",\", help=\"CSV separator (default: comma)\")\n    return parser\n\n\ndef main() -> None:\n    parser = build_parser()\n    args = parser.parse_args()\n\n    if not args.csv:\n        parser.print_help()\n        log.error(\"No CSV files provided (--csv).\")\n        sys.exit(1)\n\n    pipe = DataPipeline()\n    for csv_path in args.csv:\n        pipe.add_csv(csv_path, sep=args.sep)\n\n    encoding = args.encoding if args.encoding != \"none\" else None\n    scaler = args.scaler if args.scaler.lower() != \"none\" else None\n\n    pipe.run(\n        id_col=args.id_col,\n        numeric_strategy=args.numeric_strategy,\n        categorical_strategy=args.categorical_strategy,\n        scaler=scaler,\n        categorical_encoding=encoding,\n        merge_how=args.merge,\n    )\n    pipe.save(args.out)\n\n\nif __name__ == \"__main__\":\n    main()\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/data_pipeline.py", "content": "#!/usr/bin/env python3\n\"\"\"\nData Preprocessing Pipeline\n===========================\nRead multiple CSV files → handle missing values → standardize numerical cols →\none-hot encode categorical variables → merge into a single feature matrix.\n\nUsage:\n    python data_pipeline.py --config config.yaml\n    python data_pipeline.py --csv data1.csv data2.csv --id_col sample_id\n\"\"\"\n\nimport os\nimport sys\nimport logging\nimport argparse\nfrom pathlib import Path\nfrom typing import Optional, List, Dict, Union, Any, Literal\n\nimport numpy as np\nimport pandas as pd\nfrom sklearn.preprocessing import StandardScaler, MinMaxScaler, RobustScaler\n\n# ---------------------------------------------------------------------------\n# Logging\n# ---------------------------------------------------------------------------\nlogging.basicConfig(\n    level=logging.INFO,\n    format=\"%(asctime)s | %(levelname)-8s | %(message)s\",\n    datefmt=\"%H:%M:%S\",\n)\nlog = logging.getLogger(\"pipeline\")\n\n\n# ---------------------------------------------------------------------------\n# Scalers\n# ---------------------------------------------------------------------------\nSCALER_MAP: Dict[str, Any] = {\n    \"zscore\": StandardScaler,\n    \"minmax\": MinMaxScaler,\n    \"robust\": RobustScaler,\n}\nVALID_SCALERS = set(SCALER_MAP.keys()) | {None}\n\n\n# ---------------------------------------------------------------------------\n# Pipeline class\n# ---------------------------------------------------------------------------\nclass DataPipeline:\n    \"\"\"Configurable data-cleaning pipeline for multiple CSV files.\n\n    Typical workflow::\n\n        pipe = DataPipeline()\n        pipe.add_csv(\"expr.csv\", index_col=\"gene_id\")\n        pipe.add_csv(\"clinical.csv\", index_col=\"patient_id\")\n        pipe.run(\n            numeric_strategy=\"median\",\n            scaler=\"zscore\",\n            categorical_strategy=\"onehot\",\n            id_col=\"sample_id\",\n        )\n        matrix = pipe.feature_matrix  # pd.DataFrame\n    \"\"\"\n\n    def __init__(self) -> None:\n        self.frames: List[pd.DataFrame] = []\n        self.names: List[str] = []\n        self._report: Dict[str, Any] = {}\n\n    # ---- File I/O ---------------------------------------------------------\n\n    def add_csv(\n        self,\n        path: Union[str, Path],\n        name: Optional[str] = None,\n        **read_kwargs: Any,\n    ) -> \"DataPipeline\":\n        \"\"\"Load a CSV file and store it internally.\n\n        Parameters\n        ----------\n        path : str or Path\n            Path to the CSV file.\n        name : str, optional\n            Short label for this source (used in logging / reports).\n            Defaults to the filename stem.\n        **read_kwargs\n            Extra arguments forwarded to ``pd.read_csv`` (e.g. ``sep``,\n            ``index_col``, ``encoding``, ``dtype``).\n        \"\"\"\n        p = Path(path)\n        if not p.exists():\n            raise FileNotFoundError(f\"CSV not found: {p.resolve()}\")\n        label = name or p.stem\n        log.info(\"Loading  %s  from  %s\", label, p)\n\n        df = pd.read_csv(p, **read_kwargs)\n        log.info(\"  → shape %s, columns %d\", df.shape, len(df.columns))\n        self.frames.append(df)\n        self.names.append(label)\n        return self\n\n    def add_dataframe(\n        self, df: pd.DataFrame, name: Optional[str] = None\n    ) -> \"DataPipeline\":\n        \"\"\"Add an already-in-memory DataFrame.\"\"\"\n        self.frames.append(df.copy())\n        self.names.append(name or f\"df_{len(self.frames)}\")\n        return self\n\n    # ---- Column classification -------------------------------------------\n\n    @staticmethod\n    def _classify_columns(\n        df: pd.DataFrame,\n    ) -> Dict[str, List[str]]:\n        \"\"\"Split columns into numeric, categorical, and id-like.\"\"\"\n        numeric = list(df.select_dtypes(include=[np.number]).columns)\n        categorical = list(\n            df.select_dtypes(include=[\"object\", \"category\", \"bool\"]).columns\n        )\n        # Strings that happen to be dtype=object but can be parsed as numbers\n        # are not auto‑detected; the caller can pass ``dtype`` in read_kwargs.\n        return {\"numeric\": numeric, \"categorical\": categorical}\n\n    # ---- Missing-value handling ------------------------------------------\n\n    def _handle_missing(\n        self,\n        df: pd.DataFrame,\n        numeric_strategy: Union[str, float, None] = \"median\",\n        categorical_strategy: Union[str, str, None] = \"mode\",\n        numeric_cols: Optional[List[str]] = None,\n        categorical_cols: Optional[List[str]] = None,\n        fill_values: Optional[Dict[str, Any]] = None,\n    ) -> pd.DataFrame:\n        \"\"\"Impute missing values *in place* (returns the same DataFrame).\"\"\"\n        df = df.copy()\n        num_cols = numeric_cols or self._classify_columns(df)[\"numeric\"]\n        cat_cols = categorical_cols or self._classify_columns(df)[\"categorical\"]\n\n        # --- Per‑column explicit fill ---\n        if fill_values:\n            for col, val in fill_values.items():\n                if col in df.columns and df[col].isna().any():\n                    df[col] = df[col].fillna(val)\n                    cnt = df[col].isna().sum()\n                    log.info(\"  fill  %s  →  %s  (na left: %d)\", col, val, cnt)\n\n        # --- Numeric ---\n        numeric_strategy = self._resolve_strategy(numeric_strategy)\n        for col in num_cols:\n            if col not in df.columns:\n                continue\n            n_na = df[col].isna().sum()\n            if n_na == 0:\n                continue\n            if numeric_strategy == \"drop\":\n                df.dropna(subset=[col], inplace=True)\n                log.info(\"  dropna  %s  →  -%d rows\", col, n_na)\n            elif numeric_strategy in (\"mean\", \"median\", \"mode\"):\n                val = getattr(df[col], numeric_strategy)()\n                df[col] = df[col].fillna(val)\n                log.info(\"  impute  %s  →  %s (%.4f)\", col, numeric_strategy, val)\n            elif isinstance(numeric_strategy, (int, float)):\n                df[col] = df[col].fillna(numeric_strategy)\n                log.info(\"  impute  %s  →  constant (%.4f)\", col, numeric_strategy)\n            else:\n                log.warning(\"  unknown numeric strategy for %s, skipping\", col)\n\n        # --- Categorical ---\n        categorical_strategy = self._resolve_strategy(categorical_strategy)\n        for col in cat_cols:\n            if col not in df.columns:\n                continue\n            n_na = df[col].isna().sum()\n            if n_na == 0:\n                continue\n            if categorical_strategy == \"drop\":\n                df.dropna(subset=[col], inplace=True)\n                log.info(\"  dropna  %s  →  -%d rows\", col, n_na)\n            elif categorical_strategy == \"mode\":\n                mode_val = df[col].mode(dropna=True)\n                if not mode_val.empty:\n                    df[col] = df[col].fillna(mode_val.iloc[0])\n                    log.info(\"  impute  %s  →  mode (%s)\", col, mode_val.iloc[0])\n                else:\n                    # All NaN → fill with \"missing\"\n                    df[col] = df[col].fillna(\"missing\")\n                    log.info(\"  impute  %s  →  'missing' (all NaN)\", col)\n            elif categorical_strategy == \"missing\":\n                df[col] = df[col].fillna(\"missing\")\n                log.info(\"  impute  %s  →  'missing'\", col)\n            elif isinstance(categorical_strategy, str):\n                df[col] = df[col].fillna(categorical_strategy)\n                log.info(\"  impute  %s  →  constant (%s)\", col, categorical_strategy)\n            else:\n                log.warning(\"  unknown cat strategy for %s, skipping\", col)\n\n        return df\n\n    @staticmethod\n    def _resolve_strategy(strat: Any) -> Any:\n        \"\"\"Resolve common aliases to lowercase strings.\"\"\"\n        if isinstance(strat, str):\n            lowered = strat.lower().strip()\n            return lowered\n        return strat\n\n    # ---- Standardization --------------------------------------------------\n\n    def _standardize_numeric(\n        self,\n        df: pd.DataFrame,\n        scaler: Optional[Union[str, Any]] = \"zscore\",\n        numeric_cols: Optional[List[str]] = None,\n    ) -> pd.DataFrame:\n        \"\"\"Standardize numeric columns (returns new DataFrame with scaled columns).\"\"\"\n        if scaler is None:\n            return df\n\n        cols = numeric_cols or self._classify_columns(df)[\"numeric\"]\n        cols = [c for c in cols if c in df.columns]\n\n        if not cols:\n            log.info(\"  no numeric columns to scale\")\n            return df\n\n        df = df.copy()\n\n        if isinstance(scaler, str):\n            scaler_cls = SCALER_MAP.get(scaler.lower())\n            if scaler_cls is None:\n                raise ValueError(\n                    f\"Unknown scaler '{scaler}'. Choose from {set(SCALER_MAP)}\"\n                )\n            scaler_instance = scaler_cls()\n        else:\n            # User passed a fitted or unfitted sklearn‑like object\n            scaler_instance = scaler\n\n        scaled = scaler_instance.fit_transform(df[cols])\n        df[cols] = np.round(scaled, 10)\n        log.info(\"  scale  %d cols  →  %s\", len(cols), scaler_instance.__class__.__name__)\n        return df\n\n    # ---- One‑hot encoding -------------------------------------------------\n\n    def _encode_categorical(\n        self,\n        df: pd.DataFrame,\n        strategy: Literal[\"onehot\", \"dummy\", \"label\"] = \"onehot\",\n        categorical_cols: Optional[List[str]] = None,\n        drop_first: bool = False,\n        max_categories: Optional[int] = None,\n    ) -> pd.DataFrame:\n        \"\"\"Encode categorical columns.\n\n        Parameters\n        ----------\n        strategy :\n            - ``\"onehot\"`` : one‑hot encoding via ``pd.get_dummies``.\n            - ``\"dummy\"``  : same as onehot but with *drop_first=True*.\n            - ``\"label\"``  : label encoding — map each category to an integer.\n        drop_first :\n            Only used for ``\"onehot\"``. If True, k‑1 dummies are created for\n            k categories.  **Ignored when strategy=\"dummy\"** (always drops).\n        max_categories :\n            If set, only the top‑*max_categories* most frequent categories per\n            column are kept; the rest become \"other\".\n        \"\"\"\n        if strategy is None:\n            return df\n\n        cols = categorical_cols or self._classify_columns(df)[\"categorical\"]\n        cols = [c for c in cols if c in df.columns]\n\n        if not cols:\n            return df\n\n        df = df.copy()\n\n        if strategy == \"label\":\n            for col in cols:\n                df[col] = df[col].astype(\"category\").cat.codes\n                df[col] = df[col].replace(-1, np.nan)  # unseen → NaN\n            log.info(\"  label-encode  %d cols\", len(cols))\n            return df\n\n        # --- one‑hot / dummy ---\n        if max_categories is not None:\n            for col in cols:\n                top = df[col].value_counts().index[:max_categories]\n                df[col] = df[col].where(df[col].isin(top), other=\"other\")\n\n        do_drop = drop_first if strategy == \"onehot\" else True\n        df = pd.get_dummies(df, columns=cols, drop_first=do_drop, dtype=int)\n        log.info(\"  one-hot / dummy  %d cols\", len(cols))\n        return df\n\n    # ---- Merge ------------------------------------------------------------\n\n    def _merge_frames(\n        self,\n        frames: List[pd.DataFrame],\n        how: Literal[\"inner\", \"outer\", \"left\"] = \"outer\",\n        id_col: Optional[str] = None,\n    ) -> pd.DataFrame:\n        \"\"\"Merge multiple DataFrames.\n\n        Parameters\n        ----------\n        how :\n            - ``\"outer\"`` : union of all rows/columns (NaN filled later).\n            - ``\"inner\"`` : intersection of rows (common index).\n            - ``\"left\"``  : keep rows from the **first** DataFrame only.\n        id_col :\n            If given, merge on this column (must exist in all frames).\n            Otherwise merge on the index.\n        \"\"\"\n        if len(frames) == 1:\n            return frames[0]\n\n        merged = frames[0]\n        for i, df in enumerate(frames[1:], start=1):\n            left_on = id_col if id_col else None\n            right_on = id_col if id_col else None\n            left_index = id_col is None\n            right_index = id_col is None or (\n                id_col == merged.index.name and id_col == df.index.name\n            )\n\n            merged = pd.merge(\n                merged,\n                df,\n                how=how,\n                left_on=left_on,\n                right_on=right_on,\n                left_index=left_index,\n                right_index=right_index,\n                suffixes=(\"\", f\"_{self.names[i]}\" if i < len(self.names) else \"_dup\"),\n            )\n            log.info(\n                \"  merge [%s]  →  %s  (rows %d, cols %d)\",\n                how,\n                self.names[i],\n                len(merged),\n                len(merged.columns),\n            )\n\n        if id_col and id_col in merged.columns:\n            merged.set_index(id_col, inplace=True)\n\n        return merged\n\n    # ---- Main entry point -------------------------------------------------\n\n    def run(\n        self,\n        *,\n        # --- Missing values ---\n        numeric_strategy: Union[str, float, None] = \"median\",\n        categorical_strategy: Union[str, None] = \"mode\",\n        fill_values: Optional[Dict[str, Any]] = None,\n        # --- Standardization ---\n        scaler: Optional[Union[str, Any]] = \"zscore\",\n        # --- Encoding ---\n        categorical_encoding: Literal[\"onehot\", \"dummy\", \"label\", None] = \"onehot\",\n        drop_first: bool = False,\n        max_categories: Optional[int] = None,\n        # --- Merge ---\n        merge_how: Literal[\"inner\", \"outer\", \"left\"] = \"outer\",\n        id_col: Optional[str] = None,\n        # --- Output ---\n        drop_original_categorical: bool = True,\n    ) -> pd.DataFrame:\n        \"\"\"Execute the full pipeline.\n\n        Returns the merged feature matrix as a ``pd.DataFrame``, also\n        accessible via ``self.feature_matrix``.\n        \"\"\"\n        log.info(\"=\" * 55)\n        log.info(\"Pipeline start  (%d CSV files)\", len(self.frames))\n        log.info(\"=\" * 55)\n\n        if not self.frames:\n            raise ValueError(\"No data loaded — use .add_csv() or .add_dataframe() first.\")\n\n        processed: List[pd.DataFrame] = []\n\n        for idx, (df, name) in enumerate(zip(self.frames, self.names)):\n            log.info(\"─── Source %d: %s ───\", idx + 1, name)\n            df = self._handle_missing(\n                df,\n                numeric_strategy=numeric_strategy,\n                categorical_strategy=categorical_strategy,\n                fill_values=fill_values,\n            )\n            df = self._standardize_numeric(df, scaler=scaler)\n\n            if categorical_encoding:\n                df = self._encode_categorical(\n                    df,\n                    strategy=categorical_encoding,\n                    drop_first=drop_first,\n                    max_categories=max_categories,\n                )\n                if drop_original_categorical:\n                    orig_cat = self._classify_columns(\n                        self.frames[idx]\n                    )[\"categorical\"]\n                    # Only drop columns that haven't already been replaced\n        