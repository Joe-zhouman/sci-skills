TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/pi3k_akt_mtor_pathway.py", "content": "#!/usr/bin/env python3\n\"\"\"\nPI3K/AKT/mTOR Signaling Pathway - Nature Reviews Style Figure\nGenerated with matplotlib for scientific publication quality.\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nfrom matplotlib.patches import FancyBboxPatch, FancyArrowPatch, Circle, Ellipse, Rectangle, ArrowStyle\nfrom matplotlib.patches import PathPatch\nfrom matplotlib.path import Path\nimport numpy as np\n\n# ============================================================\n# FIGURE SETUP - Nature Reviews Molecular Cell Biology style\n# ============================================================\nfig = plt.figure(figsize=(16, 20), facecolor='white')\nax = fig.add_axes([0, 0, 1, 1], facecolor='white')\nax.set_xlim(0, 16)\nax.set_ylim(0, 20)\nax.axis('off')\n\n# ============================================================\n# COLOR PALETTE (Nature Reviews warm/orange-red style)\n# ============================================================\n# Membrane & structural\nMEMBRANE_COLOR = '#F5E6CC'\nMEMBRANE_EDGE = '#C4A882'\nNUCLEUS_COLOR = '#E8F0FE'\nNUCLEUS_EDGE = '#A0B8D8'\n\n# Signaling molecules - warm Nature Reviews palette\nRTK_COLOR = '#E0784C'\nRTK_EDGE = '#B85C30'\nP13K_COLOR = '#D9534F'\nPIP2_COLOR = '#F0AD4E'\nPIP3_COLOR = '#E67E22'\nPTEN_COLOR = '#D9534F'  # red for negative regulator\nPDK1_COLOR = '#5BC0DE'\nAKT_COLOR = '#5CB85C'\nMTORC1_COLOR = '#428BCA'\nMTORC2_COLOR = '#7B68EE'\nS6K_COLOR = '#6B8E23'\nE4BP1_COLOR = '#B8860B'\n\n# Phosphorylation markers\nPHOSPHO_COLOR = '#FF6B6B'\n\n# Arrow colors\nACTIVATION_COLOR = '#2E7D32'\nINHIBITION_COLOR = '#C62828'\nTRANS_COLOR = '#6A1B9A'\n\n# Background regions\nEXTRACELLULAR = '#FAFAF5'\nCYTOPLASM = '#FFFEF9'\nBACKGROUND_COLOR = '#FFFFFF'\n\n# Title\nTITLE_COLOR = '#2C3E50'\n\n# ============================================================\n# HELPER FUNCTIONS\n# ============================================================\n\ndef draw_membrane(ax, x, y, width, height, color=MEMBRANE_COLOR, edgecolor=MEMBRANE_EDGE, alpha=0.8):\n    \"\"\"Draw a phospholipid bilayer membrane segment.\"\"\"\n    # Outer membrane layer\n    main = FancyBboxPatch((x, y), width, height,\n                          boxstyle=\"round,pad=0.05\",\n                          facecolor=color, edgecolor=edgecolor,\n                          linewidth=2, alpha=alpha, zorder=2)\n    ax.add_patch(main)\n    # Inner line for bilayer effect\n    inner = FancyBboxPatch((x + 2, y + height * 0.35), width - 4, height * 0.3,\n                          boxstyle=\"round,pad=0.03\",\n                          facecolor='none', edgecolor=edgecolor,\n                          linewidth=1.2, alpha=0.5, linestyle='--', zorder=2)\n    ax.add_patch(inner)\n    return main\n\n\ndef draw_rounded_box(ax, x, y, w, h, color, edgecolor=None, text='', fontsize=10,\n                     text_color='white', fontweight='bold', alpha=0.9, zorder=5):\n    \"\"\"Draw a rounded rectangle with text.\"\"\"\n    if edgecolor is None:\n        edgecolor = color\n    box = FancyBboxPatch((x, y), w, h,\n                         boxstyle=\"round,pad=0.12\",\n                         facecolor=color, edgecolor=edgecolor,\n                         linewidth=2, alpha=alpha, zorder=zorder)\n    ax.add_patch(box)\n    ax.text(x + w/2, y + h/2, text, fontsize=fontsize, fontweight=fontweight,\n            color=text_color, ha='center', va='center', zorder=zorder+1)\n    return box\n\n\ndef draw_circle(ax, x, y, r, color, edgecolor=None, text='', fontsize=8,\n                text_color='white', fontweight='bold', alpha=0.9, zorder=5):\n    \"\"\"Draw a circle with text.\"\"\"\n    if edgecolor is None:\n        edgecolor = color\n    circle = Circle((x, y), r, facecolor=color, edgecolor=edgecolor,\n                    linewidth=2, alpha=alpha, zorder=zorder)\n    ax.add_patch(circle)\n    ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n            color=text_color, ha='center', va='center', zorder=zorder+1)\n\n\ndef draw_ellipse(ax, x, y, w, h, color, edgecolor=None, text='', fontsize=9,\n                 text_color='white', fontweight='bold', alpha=0.9, zorder=5):\n    \"\"\"Draw an ellipse with text.\"\"\"\n    if edgecolor is None:\n        edgecolor = color\n    ellipse = Ellipse((x, y), w, h, facecolor=color, edgecolor=edgecolor,\n                      linewidth=2, alpha=alpha, zorder=zorder)\n    ax.add_patch(ellipse)\n    ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n            color=text_color, ha='center', va='center', zorder=zorder+1)\n\n\ndef draw_arrow(ax, x1, y1, x2, y2, color=ACTIVATION_COLOR, linewidth=2.5,\n               arrowstyle='-|>', connectionstyle='arc3,rad=0', linestyle='solid',\n               alpha=0.85, zorder=3):\n    \"\"\"Draw an arrow between two points.\"\"\"\n    arrow = FancyArrowPatch((x1, y1), (x2, y2),\n                            arrowstyle=arrowstyle,\n                            color=color,\n                            linewidth=linewidth,\n                            connectionstyle=connectionstyle,\n                            linestyle=linestyle,\n                            alpha=alpha,\n                            zorder=zorder,\n                            mutation_scale=20)\n    ax.add_patch(arrow)\n    return arrow\n\n\ndef draw_dashed_arrow(ax, x1, y1, x2, y2, color=ACTIVATION_COLOR, linewidth=2):\n    \"\"\"Draw a dashed arrow (for indirect/transcriptional effects).\"\"\"\n    return draw_arrow(ax, x1, y1, x2, y2, color=color, linewidth=linewidth,\n                      linestyle='dashed', connectionstyle='arc3,rad=0.1')\n\n\ndef draw_inhibition_arrow(ax, x1, y1, x2, y2, color=INHIBITION_COLOR, linewidth=2.5):\n    \"\"\"Draw an inhibition arrow (with T-bar end).\"\"\"\n    arrow = FancyArrowPatch((x1, y1), (x2, y2),\n                            arrowstyle='-|>',\n                            color=color,\n                            linewidth=linewidth,\n                            connectionstyle='arc3,rad=0',\n                            linestyle='solid',\n                            alpha=0.85,\n                            zorder=3,\n                            mutation_scale=20)\n    ax.add_patch(arrow)\n    # Add T-bar by drawing a small perpendicular line\n    # (We'll use a simple arrow with red color for inhibition)\n    return arrow\n\n\ndef draw_phosphorylation(ax, x, y, size=0.3, color=PHOSPHO_COLOR, zorder=10):\n    \"\"\"Draw a phosphorylation circle (P marker).\"\"\"\n    p = Circle((x, y), size, facecolor=color, edgecolor='#8B0000',\n               linewidth=1.5, alpha=0.9, zorder=zorder)\n    ax.add_patch(p)\n    ax.text(x, y, 'P', fontsize=7, fontweight='bold', color='white',\n            ha='center', va='center', zorder=zorder+1)\n\n\ndef draw_label(ax, x, y, text, fontsize=9, color='#333333', fontweight='normal',\n               ha='center', va='center', style='normal', zorder=5):\n    \"\"\"Draw a text label.\"\"\"\n    ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n            color=color, ha=ha, va=va, style=style, zorder=zorder)\n\n\ndef draw_small_molecule(ax, x, y, text, fontsize=7, color='#555', style='italic'):\n    \"\"\"Draw a small molecule label like PIP2, PIP3.\"\"\"\n    ax.text(x, y, text, fontsize=fontsize, fontweight='normal',\n            color=color, ha='center', va='center', style=style, zorder=5)\n\n\n# ============================================================\n# COMPARTMENT BACKGROUNDS\n# ============================================================\n\n# Extracellular space background\nax.add_patch(Rectangle((0, 16.5), 16, 3.5, facecolor=EXTRACELLULAR,\n                       edgecolor='#DDD', linewidth=0, zorder=0))\n\n# Extracellular label\ndraw_label(ax, 15.2, 19.3, 'Extracellular', fontsize=11, color='#999',\n           fontweight='italic')\n\n# Cytoplasm background\nax.add_patch(Rectangle((0, 0), 16, 14.5, facecolor=CYTOPLASM,\n                       edgecolor='none', linewidth=0, zorder=0))\ndraw_label(ax, 15.2, 13.8, 'Cytoplasm', fontsize=11, color='#999',\n           fontweight='italic')\n\n\n# ============================================================\n# CELL MEMBRANE (horizontal band)\n# ============================================================\n# Phospholipid bilayer in the middle-upper section\nmem_y = 14.8\nmem_h = 0.7\ndraw_membrane(ax, 0.5, mem_y, 15, mem_h, alpha=0.9)\n\n# Membrane label\ndraw_label(ax, 15.2, 15.15, 'Plasma membrane', fontsize=10, color='#999',\n           fontweight='italic')\n\n\n# ============================================================\n# GROWTH FACTORS (top)\n# ============================================================\ndraw_circle(ax, 8, 19.2, 0.5, '#E88D7A', text='GF', fontsize=8)\ndraw_label(ax, 8, 19.9, 'Growth Factors', fontsize=7.5, color='#888',\n           fontweight='normal', style='italic')\ndraw_label(ax, 8, 19.6, '(EGF, IGF, etc.)', fontsize=6.5, color='#AAA',\n           fontweight='normal', style='italic')\n\n# GF → RTK arrow (down)\ndraw_arrow(ax, 8, 18.7, 8, 17.0, color='#D4A574', linewidth=2)\n\n\n# ============================================================\n# RECEPTOR TYROSINE KINASE (RTK) - spanning membrane\n# ============================================================\n# RTK extracellular domain\ndraw_rounded_box(ax, 6.8, 16.2, 2.4, 0.6, RTK_COLOR, text='RTK', fontsize=9, zorder=6)\n# RTK transmembrane (small connector)\nax.add_patch(Rectangle((7.8, 15.5), 0.4, 0.7, facecolor=RTK_COLOR,\n                       edgecolor=RTK_EDGE, linewidth=1.5, zorder=5))\n# RTK intracellular domain\ndraw_rounded_box(ax, 6.8, 13.8, 2.4, 1.7, '#F0B39A', edgecolor=RTK_EDGE,\n                 text='', fontsize=9, text_color='white', zorder=5)\ndraw_label(ax, 8, 14.9, 'RTK', fontsize=9, color=RTK_EDGE, fontweight='bold')\ndraw_label(ax, 8, 14.3, '(Receptor', fontsize=7, color='#888')\ndraw_label(ax, 8, 13.95, 'Tyrosine Kinase)', fontsize=7, color='#888')\n\n# Phosphorylation sites on RTK intracellular (p-Y)\ndraw_phosphorylation(ax, 7.3, 14.2)\ndraw_phosphorylation(ax, 8.7, 14.2)\n\n\n# ============================================================\n# PI3K - recruited to activated RTK\n# ============================================================\np13k_x, p13k_y = 10.5, 14.0\ndraw_rounded_box(ax, p13k_x - 1.1, p13k_y - 0.4, 2.2, 0.8, P13K_COLOR,\n                 text='PI3K', fontsize=10, zorder=6)\ndraw_label(ax, p13k_x, p13k_y - 0.7, 'p110/p85', fontsize=6, color='#999')\n\n# RTK → PI3K arrow (lateral activation)\ndraw_arrow(ax, 9.3, 14.6, 10.2, 14.2, color=ACTIVATION_COLOR, linewidth=2,\n           connectionstyle='arc3,rad=0.15')\n\n\n# ============================================================\n# PIP2 → PIP3 (membrane associated)\n# ============================================================\n# PIP2\npip2_x, pip2_y = 4.5, 13.2\nellipse_pip2 = Ellipse((pip2_x, pip2_y), 1.6, 0.6, facecolor=PIP2_COLOR,\n                       edgecolor='#CC8400', linewidth=1.5, alpha=0.9, zorder=4)\nax.add_patch(ellipse_pip2)\ndraw_label(ax, pip2_x, pip2_y, 'PIP₂', fontsize=8, color='white', fontweight='bold')\n\n# PIP3\npip3_x, pip3_y = 10.5, 12.8\nellipse_pip3 = Ellipse((pip3_x, pip3_y), 1.6, 0.6, facecolor=PIP3_COLOR,\n                       edgecolor='#B85C00', linewidth=1.5, alpha=0.9, zorder=4)\nax.add_patch(ellipse_pip3)\ndraw_label(ax, pip3_x, pip3_y, 'PIP₃', fontsize=8, color='white', fontweight='bold')\n\n# PI3K → PIP3 (PI3K phosphorylates PIP2 to PIP3)\ndraw_arrow(ax, p13k_x - 0.2, 13.6, pip3_x - 0.5, 13.2, color=ACTIVATION_COLOR,\n           linewidth=2, connectionstyle='arc3,rad=-0.2')\ndraw_phosphorylation(ax, pip3_x + 0.5, pip3_y + 0.15, size=0.15, color='#FF4444')\n\n\n# ============================================================\n# PTEN (negative regulator) - converts PIP3 back to PIP2\n# ============================================================\npten_x, pten_y = 2.0, 11.5\ndraw_rounded_box(ax, pten_x - 0.8, pten_y - 0.35, 1.6, 0.7, PTEN_COLOR,\n                 text='PTEN', fontsize=9, zorder=6)\n\n# PTEN → PIP3 (dephosphorylation, inhibition)\ndraw_inhibition_arrow(ax, pten_x + 0.8, pten_y, pip2_x + 0.5, pip2_y - 0.3,\n                      color=INHIBITION_COLOR, linewidth=2,\n                      connectionstyle='arc3,rad=0.2')\n\n\n# ============================================================\n# PDK1 - activated by PIP3\n# ============================================================\npdk1_x, pdk1_y = 11.5, 10.8\ndraw_rounded_box(ax, pdk1_x - 0.8, pdk1_y - 0.35, 1.6, 0.7, PDK1_COLOR,\n                 text='PDK1', fontsize=9, zorder=6)\n\n# PIP3 → PDK1 arrow\ndraw_arrow(ax, pip3_x, 12.5, pdk1_x - 0.3, 11.2, color=ACTIVATION_COLOR,\n           linewidth=2, connectionstyle='arc3,rad=-0.15')\n\n\n# ============================================================\n# AKT - central hub\n# ============================================================\nakt_x, akt_y = 8, 9.8\ndraw_circle(ax, akt_x, akt_y, 0.85, AKT_COLOR, text='AKT', fontsize=11,\n            text_color='white', zorder=7)\n# PH domain label\ndraw_label(ax, akt_x, akt_y - 1.1, 'PH domain', fontsize=6.5, color='#999')\n\n# PIP3 → AKT (recruitment to membrane)\ndraw_arrow(ax, pip3_x, 12.5, akt_x + 1, 10.6, color=ACTIVATION_COLOR,\n           linewidth=2, connectionstyle='arc3,rad=0.15')\n\n# PDK1 → AKT (phosphorylates T308)\ndraw_arrow(ax, pdk1_x - 0.5, 10.5, akt_x + 0.3, 10.0, color=ACTIVATION_COLOR,\n           linewidth=2, connectionstyle='arc3,rad=0.1')\ndraw_phosphorylation(ax, akt_x + 0.3, akt_y + 0.3, size=0.18, color=PHOSPHO_COLOR)\ndraw_label(ax, akt_x + 0.3, akt_y + 0.65, 'T308', fontsize=5.5, color='#999')\n\n\n# ============================================================\n# mTORC2 - activates AKT (S473)\n# ============================================================\nmtorc2_x, mtorc2_y = 6.0, 10.0\ndraw_rounded_box(ax, mtorc2_x - 0.9, mtorc2_y - 0.4, 1.8, 0.8, MTORC2_COLOR,\n                 text='mTORC2', fontsize=8, zorder=6)\ndraw_label(ax, mtorc2_x, mtorc2_y - 0.8, 'rictor/mSin1', fontsize=5.5, color='#999')\n\n# mTORC2 → AKT (S473 phosphorylation)\ndraw_arrow(ax, mtorc2_x + 0.9, mtorc2_y, akt_x - 0.8, akt_y + 0.2,\n           color=ACTIVATION_COLOR, linewidth=2, connectionstyle='arc3,rad=0.15')\ndraw_phosphorylation(ax, akt_x - 0.3, akt_y + 0.3, size=0.18, color=PHOSPHO_COLOR)\ndraw_label(ax, akt_x - 0.3, akt_y + 0.65, 'S473', fontsize=5.5, color='#999')\n\n\n# ============================================================\n# AKT substrate phosphorylation box\n# ============================================================\nakt_substrate_box = FancyBboxPatch((6.5, 8.3), 3, 0.5,\n                                    boxstyle=\"round,pad=0.05\",\n                                    facecolor='#E8F5E9', edgecolor='#A5D6A7',\n                                    linewidth=1, alpha=0.6, zorder=3)\nax.add_patch(akt_substrate_box)\ndraw_label(ax, 8, 8.55, 'Phosphorylates diverse substrates', fontsize=7,\n           color='#666', fontweight='normal', style='italic')\n\n\n# ============================================================\n# mTORC1 - key downstream effector of AKT\n# ============================================================\nmtorc1_x, mtorc1_y = 8, 7.0\ndraw_rounded_box(ax, mtorc1_x - 1.3, mtorc1_y - 0.5, 2.6, 1.0, MTORC1_COLOR,\n                 text='mTORC1', fontsize=10, zorder=6)\ndraw_label(ax, mtorc1_x, mtorc1_y - 0.9, 'Raptor/mLST8', fontsize=6, color='#999')\n\n# AKT → mTORC1 (via TSC1/2 and Rheb)\ndraw_arrow(ax, akt_x, akt_y - 0.85, mtorc1_x, mtorc1_y + 0.5,\n           color=ACTIVATION_COLOR, linewidth=2.5, connectionstyle='arc3,rad=0.05')\n\n# TSC1/2 complex annotation\ndraw_label(ax, 5.0, 7.8, 'TSC1/2', fontsize=7, color='#666', fontweight='normal')\ndraw_label(ax, 5.0, 7.5, '(Tumor suppressor)', fontsize=5.5, color='#999',\n           fontweight='normal', style='italic')\n# Small inhibition of TSC (AKT inhibits TSC1/2 → activates mTORC1)\ndraw_inhibition_arrow(ax, akt_x - 0.2, 9.0, 5.8, 7.8, color=INHIBITION_COLOR,\n                      linewidth=1.5, connectionstyle='arc3,rad=0.3')\n\n# Rheb activation label\ndraw_label(ax, 8, 6.3, 'Rheb-GTP', fontsize=6.5, color='#888',\n           fontweight='normal', style='italic')\ndraw_arrow(ax, 8, 6.5, 8, 6.2, color=ACTIVATION_COLOR, linewidth=1.5)\n\n\n# ============================================================\n# S6K - downstream of mTORC1\n# ============================================================\ns6k_x, s6k_y = 5.5, 5.0\ndraw_rounded_box(ax, s6k_x - 0.7, s6k_y - 0.3, 1.4, 0.6, S6K_COLOR,\n                 text='S6K1', fontsize=9, zorder=6)\n\n# mTORC1 → S6K\ndraw_arrow(ax, mtorc1_x - 0.5, mtorc1_y - 0.5, s6k_x + 0.3, s6k_y + 0.3,\n           color=ACTIVATION_COLOR, linewidth=2, connectionstyle='arc3,rad=0.2')\ndraw_phosphorylation(ax, s6k_x + 0.4, s6k_y + 0.15, size=0.15)\ndraw_phosphorylation(ax, s6k_x - 0.2, s6k_y - 0.1, size=0.12, color='#FF8C00')\n\n# S6K effect arrow\ndraw_dashed_arrow(ax, s6k_x, s6k_y - 0.3, s6k_x - 0.5, 3.5, color=TRANS_COLOR,\n                  linewidth=1.5)\n\n\n# ============================================================\n# 4E-BP1 - downstream of mTORC1\n# ============================================================\nebp_x, ebp_y = 10.5, 5.0\ndraw_rounded_box(ax, ebp_x - 0.7, ebp_y - 0.3, 1.4, 0.6, E4BP1_COLOR,\n                 text='4E-BP1', fontsize=9, zorder=6)\n\n# mTORC1 → 4E-BP1\ndraw_arrow(ax, mtorc1_x + 0.5, mtorc1_y - 0.5, ebp_x - 0.3, ebp_y + 0.3,\n           color=ACTIVATION_COLOR, linewidth=2, connectionstyle='arc3,rad=-0.2')\ndraw_phosphorylation(ax, ebp_x + 0.4, ebp_y + 0.15, size=0.15)\n\n# 4E-BP1 effect arrow\ndraw_dashed_arrow(ax, ebp_x, ebp_y - 0.3, ebp_x + 0.5, 3.5, color=TRANS_COLOR,\n                  linewidth=1.5)\n\n# eIF4E annotation near 4E-BP1\ndraw_label(ax, ebp_x + 1.2, ebp_y, 'eIF4E', fontsize=7, color='#888',\n           fontweight='normal', style='italic')\ndraw_inhibition_arrow(ax, ebp_x + 0.7, ebp_y, ebp_x + 1.6, ebp_y + 0.1,\n                      color=INHIBITION_COLOR, linewidth=1.2,\n                      connectionstyle='arc3,rad=-0.1')\n\n\n# ============================================================\n# DOWNSTREAM CELLULAR EFFECTS\n# ============================================================\n\n# Cellular effects boxes at the bottom\neffects = [\n    (3.0, 2.2, 'Cell Growth', '#E8794A'),\n    (8.0, 2.2, 'Proliferation', '#42A5F5'),\n    (13.0, 2.2, 'Survival', '#66BB6A'),\n]\n\nfor ex, ey, etext, ecolor in effects:\n    box = FancyBboxPatch((ex - 1.3, ey - 0.4), 2.6, 0.8,\n                         boxstyle=\"round,pad=0.1\",\n                         facecolor=ecolor, edgecolor='none',\n                         linewidth=1.5, alpha=0.85, zorder=5)\n    ax.add_patch(box)\n    ax.text(ex, ey, etext, fontsize=9, fontweight='bold',\n            color='white', ha='center', va='center', zorder=6)\n\n# Protein synthesis - larger box at bottom center\nbox = FancyBboxPatch((5.5, 0.8), 5.0, 0.8,\n                     boxstyle=\"round,pad=0.1\",\n                     facecolor='#7B1FA2', edgecolor='none',\n                     linewidth=1.5, alpha=0.85, zorder=5)\nax.add_patch(box)\nax.text(8, 1.2, 'Protein Synthesis & Translation', fontsize=10,\n        fontweight='bold', color='white', ha='center', va='center', zorder=6)\n\n\n# ============================================================\n# CONNECTING DOWNSTREAM EFFECTS\n# ============================================================\n\n# S6K → Protein synthesis\ndraw_arrow(ax, s6k_x - 0.2, s6k_y - 0.3, 6.0, 2.6,\n           color=TRANS_COLOR, linewidth=1.5, connectionstyle='arc3,rad=-0.2')\n\n# S6K → Cell Growth\ndraw_arrow(ax, s6k_x - 0.5, 3.8, 3.0, 3.0,\n           color=TRANS_COLOR, linewidth=1.5, connectionstyle='arc3,rad=0.2')\n\n# 4E-BP1 → Protein synthesis\ndraw_arrow(ax, ebp_x + 0.2, ebp_y - 0.3, 8.5, 2.6,\n           color=TRANS_COLOR, linewidth=1.5, connectionstyle='arc3,rad=0.15')\n\n# mTORC1 → Proliferation (indirect via S6K/4E-BP1)\ndraw_dashed_arrow(ax, mtorc1_x + 0.5, 6.0, 8.5, 3.0,\n                  color=TRANS_COLOR, linewidth=1.5)\n\n\n# ============================================================\n# LEGEND\n# ============================================================\nlegend_x, legend_y = 0.8, 0.2\nlegend_box = FancyBboxPatch((legend_x, legend_y), 5.5, 1.8,\n                            boxstyle=\"round,pad=0.1\",\n                            facecolor='#FAFAFA', edgecolor='#DDD',\n                            linewidth=1.2, alpha=0.9, zorder=8)\nax.add_patch(legend_box)\n\n# Legend title\nax.text(legend_x + 2.75, legend_y + 1.5, 'Legend', fontsize=8,\n        fontweight='bold', color='#555', ha='center', va='center', zorder=9)\n\n# Arrow legend - activation\nax.annotate('', xy=(legend_x + 0.5, legend_y + 0.9), xytext=(legend_x + 1.5, legend_y + 0.9),\n            arrowprops=dict(arrowstyle='-|>', color=ACTIVATION_COLOR, lw=2), zorder=9)\nax.text(legend_x + 1.6, legend_y + 0.9, 'Activation', fontsize=7, color='#555',\n        va='center', zorder=9)\n\n# Arrow legend - inhibition\ndraw_arrow(ax, legend_x + 0.5, legend_y + 0.4, legend_x + 1.5, legend_y + 0.4,\n           color=INHIBITION_COLOR, linewidth=2, zorder=9)\nax.text(legend_x + 1.6, legend_y + 0.4, 'Inhibition', fontsize=7, color='#555',\n        va='center', zorder=9)\n\n# Arrow legend - dashed\ndraw_dashed_arrow(ax, legend_x + 3.2, legend_y + 0.9, legend_x + 4.2, legend_y + 0.9,\n                  color=TRANS_COLOR, linewidth=2)\nax.text(legend_x + 4.3, legend_y + 0.9, 'Indirect /', fontsize=7, color='#555',\n        va='center', zorder=9)\nax.text(legend_x + 4.3, legend_y + 0.6, 'Transcriptional', fontsize=7, color='#555',\n        va='center', zorder=9)\n\n# Phosphorylation legend\ndraw_phosphorylation(ax, legend_x + 3.8, legend_y + 0.3, size=0.15)\nax.text(legend_x + 4.3, legend_y + 0.3, 'Phosphorylation', fontsize=7, color='#555',\n        va='center', zorder=9)\n\n\n# ============================================================\n# TITLE\n# ============================================================\nax.text(8, 19.8, 'PI3K/AKT/mTOR Signaling Pathway', fontsize=16,\n        fontweight='bold', color=TITLE_COLOR, ha='center', va='center',\n        fontfamily='sans-serif', zorder=10)\n\n# Subtitle\nax.text(8, 19.25, 'Mechanisms of cell growth, proliferation, survival and protein synthesis',\n        fontsize=9, color='#888', ha='center', va='center', style='italic',\n        fontfamily='sans-serif', zorder=10)\n\n\n# ============================================================\n# COMPARTMENT LABELS\n# ============================================================\n# Add small labels for each cellular compartment\ncomp_labels = [\n    (4, 16.8, 'Extracellular Space', '#DDD', 7),\n    (4, 14.3, 'Cytoplasmic Membrane', '#DDD', 7),\n    (4, 11, 'Cytoplasm', '#DDD', 7),\n]\n\nfor cx, cy, ctext, ccolor, csize in comp_labels:\n    ax.text(cx, cy, ctext, fontsize=csize, color=ccolor,\n            ha='center', va='center', fontweight='bold',\n            style='italic', zorder=1)\n\n\n# ============================================================\n# ADDITIONAL ANNOTATIONS\n# ============================================================\n\n# PTEN loss note (common in cancer)\nax.annotate('Frequently lost/\\nmutated in cancer',\n            xy=(pten_x - 0.8, pten_y + 0.35),\n            xytext=(pten_x - 2.5, pten_y + 1.5),\n            fontsize=6.5, color=INHIBITION_COLOR,\n            ha='center', va='center',\n            arrowprops=dict(arrowstyle='->', color=INHIBITION_COLOR,\n                          lw=1, connectionstyle='arc3,rad=0.1'),\n            zorder=8,\n            bbox=dict(boxstyle='round,pad=0.15', facecolor='#FFEBEE',\n                     edgecolor='#EF9A9A', alpha=0.8))\n\n# PIK3CA mutation note\nax.annotate('PIK3CA activating\\nmutations common',\n            xy=(p13k_x, p13k_y),\n            xytext=(p13k_x + 2.5, p13k_y + 1.2),\n            fontsize=6.5, color='#D9534F',\n            ha='center', va='center',\n            arrowprops=dict(arrowstyle='->', color='#D9534F',\n                          lw=1, connectionstyle='arc3,rad=0.1'),\n            zorder=8,\n            bbox=dict(boxstyle='round,pad=0.15', facecolor='#FFF3E0',\n                     edgecolor='#FFCC80', alpha=0.8))\n\n\n# ============================================================\n# SAVE\n# ============================================================\noutput_path = '/home/joe/Documents/repo/skill/sci-draw/pi3k_akt_mtor_pathway.png'\nplt.savefig(output_path, dpi=400, bbox_inches='tight', pad_inches=0.3,\n            facecolor='white', edgecolor='none')\nplt.close()\n\nprint(f\"Figure saved to: {output_path}\")\nprint(f\"Size: 16x20 inches @ 400 DPI = 6400x8000 pixels\")\n"})
TOOL_USE: Write({"file_path": "/home/joe/Documents/repo/skill/sci-draw/pi3k_akt_mtor_pathway.py", "content": "#!/usr/bin/env python3\n\"\"\"\nPI3K/AKT/mTOR Signaling Pathway - Nature Reviews Style Figure\nGenerated with matplotlib for scientific publication quality.\n\"\"\"\n\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nfrom matplotlib.patches import FancyBboxPatch, FancyArrowPatch, Circle, Ellipse, Rectangle, ArrowStyle\nfrom matplotlib.patches import PathPatch\nfrom matplotlib.path import Path\nimport numpy as np\n\n# ============================================================\n# FIGURE SETUP - Nature Reviews Molecular Cell Biology style\n# ============================================================\nfig = plt.figure(figsize=(16, 20), facecolor='white')\nax = fig.add_axes([0, 0, 1, 1], facecolor='white')\nax.set_xlim(0, 16)\nax.set_ylim(0, 20)\nax.axis('off')\n\n# ============================================================\n# COLOR PALETTE (Nature Reviews warm/orange-red style)\n# ============================================================\n# Membrane & structural\nMEMBRANE_COLOR = '#F5E6CC'\nMEMBRANE_EDGE = '#C4A882'\nNUCLEUS_COLOR = '#E8F0FE'\nNUCLEUS_EDGE = '#A0B8D8'\n\n# Signaling molecules - warm Nature Reviews palette\nRTK_COLOR = '#E0784C'\nRTK_EDGE = '#B85C30'\nP13K_COLOR = '#D9534F'\nPIP2_COLOR = '#F0AD4E'\nPIP3_COLOR = '#E67E22'\nPTEN_COLOR = '#D9534F'  # red for negative regulator\nPDK1_COLOR = '#5BC0DE'\nAKT_COLOR = '#5CB85C'\nMTORC1_COLOR = '#428BCA'\nMTORC2_COLOR = '#7B68EE'\nS6K_COLOR = '#6B8E23'\nE4BP1_COLOR = '#B8860B'\n\n# Phosphorylation markers\nPHOSPHO_COLOR = '#FF6B6B'\n\n# Arrow colors\nACTIVATION_COLOR = '#2E7D32'\nINHIBITION_COLOR = '#C62828'\nTRANS_COLOR = '#6A1B9A'\n\n# Background regions\nEXTRACELLULAR = '#FAFAF5'\nCYTOPLASM = '#FFFEF9'\nBACKGROUND_COLOR = '#FFFFFF'\n\n# Title\nTITLE_COLOR = '#2C3E50'\n\n# ============================================================\n# HELPER FUNCTIONS\n# ============================================================\n\ndef draw_membrane(ax, x, y, width, height, color=MEMBRANE_COLOR, edgecolor=MEMBRANE_EDGE, alpha=0.8):\n    \"\"\"Draw a phospholipid bilayer membrane segment.\"\"\"\n    # Outer membrane layer\n    main = FancyBboxPatch((x, y), width, height,\n                          boxstyle=\"round,pad=0.05\",\n                          facecolor=color, edgecolor=edgecolor,\n                          linewidth=2, alpha=alpha, zorder=2)\n    ax.add_patch(main)\n    # Inner line for bilayer effect\n    inner = FancyBboxPatch((x + 2, y + height * 0.35), width - 4, height * 0.3,\n                          boxstyle=\"round,pad=0.03\",\n                          facecolor='none', edgecolor=edgecolor,\n                          linewidth=1.2, alpha=0.5, linestyle='--', zorder=2)\n    ax.add_patch(inner)\n    return main\n\n\ndef draw_rounded_box(ax, x, y, w, h, color, edgecolor=None, text='', fontsize=10,\n                     text_color='white', fontweight='bold', alpha=0.9, zorder=5):\n    \"\"\"Draw a rounded rectangle with text.\"\"\"\n    if edgecolor is None:\n        edgecolor = color\n    box = FancyBboxPatch((x, y), w, h,\n                         boxstyle=\"round,pad=0.12\",\n                         facecolor=color, edgecolor=edgecolor,\n                         linewidth=2, alpha=alpha, zorder=zorder)\n    ax.add_patch(box)\n    ax.text(x + w/2, y + h/2, text, fontsize=fontsize, fontweight=fontweight,\n            color=text_color, ha='center', va='center', zorder=zorder+1)\n    return box\n\n\ndef draw_circle(ax, x, y, r, color, edgecolor=None, text='', fontsize=8,\n                text_color='white', fontweight='bold', alpha=0.9, zorder=5):\n    \"\"\"Draw a circle with text.\"\"\"\n    if edgecolor is None:\n        edgecolor = color\n    circle = Circle((x, y), r, facecolor=color, edgecolor=edgecolor,\n                    linewidth=2, alpha=alpha, zorder=zorder)\n    ax.add_patch(circle)\n    ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n            color=text_color, ha='center', va='center', zorder=zorder+1)\n\n\ndef draw_ellipse(ax, x, y, w, h, color, edgecolor=None, text='', fontsize=9,\n                 text_color='white', fontweight='bold', alpha=0.9, zorder=5):\n    \"\"\"Draw an ellipse with text.\"\"\"\n    if edgecolor is None:\n        edgecolor = color\n    ellipse = Ellipse((x, y), w, h, facecolor=color, edgecolor=edgecolor,\n                      linewidth=2, alpha=alpha, zorder=zorder)\n    ax.add_patch(ellipse)\n    ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n            color=text_color, ha='center', va='center', zorder=zorder+1)\n\n\ndef draw_arrow(ax, x1, y1, x2, y2, color=ACTIVATION_COLOR, linewidth=2.5,\n               arrowstyle='-|>', connectionstyle='arc3,rad=0', linestyle='solid',\n               alpha=0.85, zorder=3):\n    \"\"\"Draw an arrow between two points.\"\"\"\n    arrow = FancyArrowPatch((x1, y1), (x2, y2),\n                            arrowstyle=arrowstyle,\n                            color=color,\n                            linewidth=linewidth,\n                            connectionstyle=connectionstyle,\n                            linestyle=linestyle,\n                            alpha=alpha,\n                            zorder=zorder,\n                            mutation_scale=20)\n    ax.add_patch(arrow)\n    return arrow\n\n\ndef draw_dashed_arrow(ax, x1, y1, x2, y2, color=ACTIVATION_COLOR, linewidth=2):\n    \"\"\"Draw a dashed arrow (for indirect/transcriptional effects).\"\"\"\n    return draw_arrow(ax, x1, y1, x2, y2, color=color, linewidth=linewidth,\n                      linestyle='dashed', connectionstyle='arc3,rad=0.1')\n\n\ndef draw_inhibition_arrow(ax, x1, y1, x2, y2, color=INHIBITION_COLOR, linewidth=2.5):\n    \"\"\"Draw an inhibition arrow (with T-bar end).\"\"\"\n    arrow = FancyArrowPatch((x1, y1), (x2, y2),\n                            arrowstyle='-|>',\n                            color=color,\n                            linewidth=linewidth,\n                            connectionstyle='arc3,rad=0',\n                            linestyle='solid',\n                            alpha=0.85,\n                            zorder=3,\n                            mutation_scale=20)\n    ax.add_patch(arrow)\n    # Add T-bar by drawing a small perpendicular line\n    # (We'll use a simple arrow with red color for inhibition)\n    return arrow\n\n\ndef draw_phosphorylation(ax, x, y, size=0.3, color=PHOSPHO_COLOR, zorder=10):\n    \"\"\"Draw a phosphorylation circle (P marker).\"\"\"\n    p = Circle((x, y), size, facecolor=color, edgecolor='#8B0000',\n               linewidth=1.5, alpha=0.9, zorder=zorder)\n    ax.add_patch(p)\n    ax.text(x, y, 'P', fontsize=7, fontweight='bold', color='white',\n            ha='center', va='center', zorder=zorder+1)\n\n\ndef draw_label(ax, x, y, text, fontsize=9, color='#333333', fontweight='normal',\n               ha='center', va='center', style='normal', zorder=5):\n    \"\"\"Draw a text label.\"\"\"\n    ax.text(x, y, text, fontsize=fontsize, fontweight=fontweight,\n            color=color, ha=ha, va=va, style=style, zorder=zorder)\n\n\ndef draw_small_molecule(ax, x, y, text, fontsize=7, color='#555', style='italic'):\n    \"\"\"Draw a small molecule label like PIP2, PIP3.\"\"\"\n    ax.text(x, y, text, fontsize=fontsize, fontweight='normal',\n            color=color, ha='center', va='center', style=style, zorder=5)\n\n\n# ============================================================\n# COMPARTMENT BACKGROUNDS\n# ============================================================\n\n# Extracellular space background\nax.add_patch(Rectangle((0, 16.5), 16, 3.5, facecolor=EXTRACELLULAR,\n                       edgecolor='#DDD', linewidth=0, zorder=0))\n\n# Extracellular label\ndraw_label(ax, 15.2, 19.3, 'Extracellular', fontsize=11, color='#999',\n           fontweight='italic')\n\n# Cytoplasm background\nax.add_patch(Rectangle((0, 0), 16, 14.5, facecolor=CYTOPLASM,\n                       edgecolor='none', linewidth=0, zorder=0))\ndraw_label(ax, 15.2, 13.8, 'Cytoplasm', fontsize=11, color='#999',\n           fontweight='italic')\n\n\n# ============================================================\n# CELL MEMBRANE (horizontal band)\n# ============================================================\n# Phospholipid bilayer in the middle-upper section\nmem_y = 14.8\nmem_h = 0.7\ndraw_membrane(ax, 0.5, mem_y, 15, mem_h, alpha=0.9)\n\n# Membrane label\ndraw_label(ax, 15.2, 15.15, 'Plasma membrane', fontsize=10, color='#999',\n           fontweight='italic')\n\n\n# ============================================================\n# GROWTH FACTORS (top)\n# ============================================================\ndraw_circle(ax, 8, 19.2, 0.5, '#E88D7A', text='GF', fontsize=8)\ndraw_label(ax, 8, 19.9, 'Growth Factors', fontsize=7.5, color='#888',\n           fontweight='normal', style='italic')\ndraw_label(ax, 8, 19.6, '(EGF, IGF, etc.)', fontsize=6.5, color='#AAA',\n           fontweight='normal', style='italic')\n\n# GF → RTK arrow (down)\ndraw_arrow(ax, 8, 18.7, 8, 17.0, color='#D4A574', linewidth=2)\n\n\n# ============================================================\n# RECEPTOR TYROSINE KINASE (RTK) - spanning membrane\n# ============================================================\n# RTK extracellular domain\ndraw_rounded_box(ax, 6.8, 16.2, 2.4, 0.6, RTK_COLOR, text='RTK', fontsize=9, zorder=6)\n# RTK transmembrane (small connector)\nax.add_patch(Rectangle((7.8, 15.5), 0.4, 0.7, facecolor=RTK_COLOR,\n                       edgecolor=RTK_EDGE, linewidth=1.5, zorder=5))\n# RTK intracellular domain\ndraw_rounded_box(ax, 6.8, 13.8, 2.4, 1.7, '#F0B39A', edgecolor=RTK_EDGE,\n                 text='', fontsize=9, text_color='white', zorder=5)\ndraw_label(ax, 8, 14.9, 'RTK', fontsize=9, color=RTK_EDGE, fontweight='bold')\ndraw_label(ax, 8, 14.3, '(Receptor', fontsize=7, color='#888')\ndraw_label(ax, 8, 13.95, 'Tyrosine Kinase)', fontsize=7, color='#888')\n\n# Phosphorylation sites on RTK intracellular (p-Y)\ndraw_phosphorylation(ax, 7.3, 14.2)\ndraw_phosphorylation(ax, 8.7, 14.2)\n\n\n# ============================================================\n# PI3K - recruited to activated RTK\n# ============================================================\np13k_x, p13k_y = 10.5, 14.0\ndraw_rounded_box(ax, p13k_x - 1.1, p13k_y - 0.4, 2.2, 0.8, P13K_COLOR,\n                 text='PI3K', fontsize=10, zorder=6)\ndraw_label(ax, p13k_x, p13k_y - 0.7, 'p110/p85', fontsize=6, color='#999')\n\n# RTK → PI3K arrow (lateral activation)\ndraw_arrow(ax, 9.3, 14.6, 10.2, 14.2, color=ACTIVATION_COLOR, linewidth=2,\n           connectionstyle='arc3,rad=0.15')\n\n\n# ============================================================\n# PIP2 → PIP3 (membrane associated)\n# ============================================================\n# PIP2\npip2_x, pip2_y = 4.5, 13.2\nellipse_pip2 = Ellipse((pip2_x, pip2_y), 1.6, 0.6, facecolor=PIP2_COLOR,\n                       edgecolor='#CC8400', linewidth=1.5, alpha=0.9, zorder=4)\nax.add_patch(ellipse_pip2)\ndraw_label(ax, pip2_x, pip2_y, 'PIP₂', fontsize=8, color='white', fontweight='bold')\n\n# PIP3\npip3_x, pip3_y = 10.5, 12.8\nellipse_pip3 = Ellipse((pip3_x, pip3_y), 1.6, 0.6, facecolor=PIP3_COLOR,\n                       edgecolor='#B85C00', linewidth=1.5, alpha=0.9, zorder=4)\nax.add_patch(ellipse_pip3)\ndraw_label(ax, pip3_x, pip3_y, 'PIP₃', fontsize=8, color='white', fontweight='bold')\n\n# PI3K → PIP3 (PI3K phosphorylates PIP2 to PIP3)\ndraw_arrow(ax, p13k_x - 0.2, 13.6, pip3_x - 0.5, 13.2, color=ACTIVATION_COLOR,\n           linewidth=2, connectionstyle='arc3,rad=-0.2')\ndraw_phosphorylation(ax, pip3_x + 0.5, pip3_y + 0.15, size=0.15, color='#FF4444')\n\n\n# ============================================================\n# PTEN (negative regulator) - converts PIP3 back to PIP2\n# ============================================================\npten_x, pten_y = 2.0, 11.5\ndraw_rounded_box(ax, pten_x - 0.8, pten_y - 0.35, 1.6, 0.7, PTEN_COLOR,\n                 text='PTEN', fontsize=9, zorder=6)\n\n# PTEN → PIP3 (dephosphorylation, inhibition)\ndraw_inhibition_arrow(ax, pten_x + 0.8, pten_y, pip2_x + 0.5, pip2_y - 0.3,\n                      color=INHIBITION_COLOR, linewidth=2,\n                      connectionstyle='arc3,rad=0.2')\n\n\n# ============================================================\n# PDK1 - activated by PIP3\n# ============================================================\npdk1_x, pdk1_y = 11.5, 10.8\ndraw_rounded_box(ax, pdk1_x - 0.8, pdk1_y - 0.35, 1.6, 0.7, PDK1_COLOR,\n                 text='PDK1', fontsize=9, zorder=6)\n\n# PIP3 → PDK1 arrow\ndraw_arrow(ax, pip3_x, 12.5, pdk1_x - 0.3, 11.2, color=ACTIVATION_COLOR,\n           linewidth=2, connectionstyle='arc3,rad=-0.15')\n\n\n# ============================================================\n# AKT - central hub\n# ============================================================\nakt_x, akt_y = 8, 9.8\ndraw_circle(ax, akt_x, akt_y, 0.85, AKT_COLOR, text='AKT', fontsize=11,\n            text_color='white', zorder=7)\n# PH domain label\ndraw_label(ax, akt_x, akt_y - 1.1, 'PH domain', fontsize=6.5, color='#999')\n\n# PIP3 → AKT (recruitment to membrane)\ndraw_arrow(ax, pip3_x, 12.5, akt_x + 1, 10.6, color=ACTIVATION_COLOR,\n           linewidth=2, connectionstyle='arc3,rad=0.15')\n\n# PDK1 → AKT (phosphorylates T308)\ndraw_arrow(ax, pdk1_x - 0.5, 10.5, akt_x + 0.3, 10.0, color=ACTIVATION_COLOR,\n           linewidth=2, connectionstyle='arc3,rad=0.1')\ndraw_phosphorylation(ax, akt_x + 0.3, akt_y + 0.3, size=0.18, color=PHOSPHO_COLOR)\ndraw_label(ax, akt_x + 0.3, akt_y + 0.65, 'T308', fontsize=5.5, color='#999')\n\n\n# ============================================================\n# mTORC2 - activates AKT (S473)\n# ============================================================\nmtorc2_x, mtorc2_y = 6.0, 10.0\ndraw_rounded_box(ax, mtorc2_x - 0.9, mtorc2_y - 0.4, 1.8, 0.8, MTORC2_COLOR,\n                 text='mTORC2', fontsize=8, zorder=6)\ndraw_label(ax, mtorc2_x, mtorc2_y - 0.8, 'rictor/mSin1', fontsize=5.5, color='#999')\n\n# mTORC2 → AKT (S473 phosphorylation)\ndraw_arrow(ax, mtorc2_x + 0.9, mtorc2_y, akt_x - 0.8, akt_y + 0.2,\n           color=ACTIVATION_COLOR, linewidth=2, connectionstyle='arc3,rad=0.15')\ndraw_phosphorylation(ax, akt_x - 0.3, akt_y + 0.3, size=0.18, color=PHOSPHO_COLOR)\ndraw_label(ax, akt_x - 0.3, akt_y + 0.65, 'S473', fontsize=5.5, color='#999')\n\n\n# ============================================================\n# AKT substrate phosphorylation box\n# ============================================================\nakt_substrate_box = FancyBboxPatch((6.5, 8.3), 3, 0.5,\n                                    boxstyle=\"round,pad=0.05\",\n                                    facecolor='#E8F5E9', edgecolor='#A5D6A7',\n                                    linewidth=1, alpha=0.6, zorder=3)\nax.add_patch(akt_substrate_box)\ndraw_label(ax, 8, 8.55, 'Phosphorylates diverse substrates', fontsize=7,\n           color='#666', fontweight='normal', style='italic')\n\n\n# ============================================================\n# mTORC1 - key downstream effector of AKT\n# ============================================================\nmtorc1_x, mtorc1_y = 8, 7.0\ndraw_rounded_box(ax, mtorc1_x - 1.3, mtorc1_y - 0.5, 2.6, 1.0, MTORC1_COLOR,\n                 text='mTORC1', fontsize=10, zorder=6)\ndraw_label(ax, mtorc1_x, mtorc1_y - 0.9, 'Raptor/mLST8', fontsize=6, color='#999')\n\n# AKT → mTORC1 (via TSC1/2 and Rheb)\ndraw_arrow(ax, akt_x, akt_y - 0.85, mtorc1_x, mtorc1_y + 0.5,\n           color=ACTIVATION_COLOR, linewidth=2.5, connectionstyle='arc3,rad=0.05')\n\n# TSC1/2 complex annotation\ndraw_label(ax, 5.0, 7.8, 'TSC1/2', fontsize=7, color='#666', fontweight='normal')\ndraw_label(ax, 5.0, 7.5, '(Tumor suppressor)', fontsize=5.5, color='#999',\n           fontweight='normal', style='italic')\n# Small inhibition of TSC (AKT inhibits TSC1/2 → activates mTORC1)\ndraw_inhibition_arrow(ax, akt_x - 0.2, 9.0, 5.8, 7.8, color=INHIBITION_COLOR,\n                      linewidth=1.5, connectionstyle='arc3,rad=0.3')\n\n# Rheb activation label\ndraw_label(ax, 8, 6.3, 'Rheb-GTP', fontsize=6.5, color='#888',\n           fontweight='normal', style='italic')\ndraw_arrow(ax, 8, 6.5, 8, 6.2, color=ACTIVATION_COLOR, linewidth=1.5)\n\n\n# ============================================================\n# S6K - downstream of mTORC1\n# ============================================================\ns6k_x, s6k_y = 5.5, 5.0\ndraw_rounded_box(ax, s6k_x - 0.7, s6k_y - 0.3, 1.4, 0.6, S6K_COLOR,\n                 text='S6K1', fontsize=9, zorder=6)\n\n# mTORC1 → S6K\ndraw_arrow(ax, mtorc1_x - 0.5, mtorc1_y - 0.5, s6k_x + 0.3, s6k_y + 0.3,\n           color=ACTIVATION_COLOR, linewidth=2, connectionstyle='arc3,rad=0.2')\ndraw_phosphorylation(ax, s6k_x + 0.4, s6k_y + 0.15, size=0.15)\ndraw_phosphorylation(ax, s6k_x - 0.2, s6k_y - 0.1, size=0.12, color='#FF8C00')\n\n# S6K effect arrow\ndraw_dashed_arrow(ax, s6k_x, s6k_y - 0.3, s6k_x - 0.5, 3.5, color=TRANS_COLOR,\n                  linewidth=1.5)\n\n\n# ============================================================\n# 4E-BP1 - downstream of mTORC1\n# ============================================================\nebp_x, ebp_y = 10.5, 5.0\ndraw_rounded_box(ax, ebp_x - 0.7, ebp_y - 0.3, 1.4, 0.6, E4BP1_COLOR,\n                 text='4E-BP1', fontsize=9, zorder=6)\n\n# mTORC1 → 4E-BP1\ndraw_arrow(ax, mtorc1_x + 0.5, mtorc1_y - 0.5, ebp_x - 0.3, ebp_y + 0.3,\n           color=ACTIVATION_COLOR, linewidth=2, connectionstyle='arc3,rad=-0.2')\ndraw_phosphorylation(ax, ebp_x + 0.4, ebp_y + 0.15, size=0.15)\n\n# 4E-BP1 effect arrow\ndraw_dashed_arrow(ax, ebp_x, ebp_y - 0.3, ebp_x + 0.5, 3.5, color=TRANS_COLOR,\n                  linewidth=1.5)\n\n# eIF4E annotation near 4E-BP1\ndraw_label(ax, ebp_x + 1.2, ebp_y, 'eIF4E', fontsize=7, color='#888',\n           fontweight='normal', style='italic')\ndraw_inhibition_arrow(ax, ebp_x + 0.7, ebp_y, ebp_x + 1.6, ebp_y + 0.1,\n                      color=INHIBITION_COLOR, linewidth=1.2,\n                      connectionstyle='arc3,rad=-0.1')\n\n\n# ============================================================\n# DOWNSTREAM CELLULAR EFFECTS\n# ============================================================\n\n# Cellular effects boxes at the bottom\neffects = [\n    (3.0, 2.2, 'Cell Growth', '#E8794A'),\n    (8.0, 2.2, 'Proliferation', '#42A5F5'),\n    (13.0, 2.2, 'Survival', '#66BB6A'),\n]\n\nfor ex, ey, etext, ecolor in effects:\n    box = FancyBboxPatch((ex - 1.3, ey - 0.4), 2.6, 0.8,\n                         boxstyle=\"round,pad=0.1\",\n                         facecolor=ecolor, edgecolor='none',\n                         linewidth=1.5, alpha=0.85, zorder=5)\n    ax.add_patch(box)\n    ax.text(ex, ey, etext, fontsize=9, fontweight='bold',\n            color='white', ha='center', va='center', zorder=6)\n\n# Protein synthesis - larger box at bottom center\nbox = FancyBboxPatch((5.5, 0.8), 5.0, 0.8,\n                     boxstyle=\"round,pad=0.1\",\n                     facecolor='#7B1FA2', edgecolor='none',\n                     linewidth=1.5, alpha=0.85, zorder=5)\nax.add_patch(box)\nax.text(8, 1.2, 'Protein Synthesis & Translation', fontsize=10,\n        fontweight='bold', color='white', ha='center', va='center', zorder=6)\n\n\n# ============================================================\n# CONNECTING DOWNSTREAM EFFECTS\n# ============================================================\n\n# S6K → Protein synthesis\ndraw_arrow(ax, s6k_x - 0.2, s6k_y - 0.3, 6.0, 2.6,\n           color=TRANS_COLOR, linewidth=1.5, connectionstyle='arc3,rad=-0.2')\n\n# S6K → Cell Growth\ndraw_arrow(ax, s6k_x - 0.5, 3.8, 3.0, 3.0,\n           color=TRANS_COLOR, linewidth=1.5, connectionstyle='arc3,rad=0.2')\n\n# 4E-BP1 → Protein synthesis\ndraw_arrow(ax, ebp_x + 0.2, ebp_y - 0.3, 8.5, 2.6,\n           color=TRANS_COLOR, linewidth=1.5, connectionstyle='arc3,rad=0.15')\n\n# mTORC1 → Proliferation (indirect via S6K/4E-BP1)\ndraw_dashed_arrow(ax, mtorc1_x + 0.5, 6.0, 8.5, 3.0,\n                  color=TRANS_COLOR, linewidth=1.5)\n\n\n# ============================================================\n# LEGEND\n# ============================================================\nlegend_x, legend_y = 0.8, 0.2\nlegend_box = FancyBboxPatch((legend_x, legend_y), 5.5, 1.8,\n                            boxstyle=\"round,pad=0.1\",\n                            facecolor='#FAFAFA', edgecolor='#DDD',\n                            linewidth=1.2, alpha=0.9, zorder=8)\nax.add_patch(legend_box)\n\n# Legend title\nax.text(legend_x + 2.75, legend_y + 1.5, 'Legend', fontsize=8,\n        fontweight='bold', color='#555', ha='center', va='center', zorder=9)\n\n# Arrow legend - activation\nax.annotate('', xy=(legend_x + 0.5, legend_y + 0.9), xytext=(legend_x + 1.5, legend_y + 0.9),\n            arrowprops=dict(arrowstyle='-|>', color=ACTIVATION_COLOR, lw=2), zorder=9)\nax.text(legend_x + 1.6, legend_y + 0.9, 'Activation', fontsize=7, color='#555',\n        va='center', zorder=9)\n\n# Arrow legend - inhibition\ndraw_arrow(ax, legend_x + 0.5, legend_y + 0.4, legend_x + 1.5, legend_y + 0.4,\n           color=INHIBITION_COLOR, linewidth=2, zorder=9)\nax.text(legend_x + 1.6, legend_y + 0.4, 'Inhibition', fontsize=7, color='#555',\n        va='center', zorder=9)\n\n# Arrow legend - dashed\ndraw_dashed_arrow(ax, legend_x + 3.2, legend_y + 0.9, legend_x + 4.2, legend_y + 0.9,\n                  color=TRANS_COLOR, linewidth=2)\nax.text(legend_x + 4.3, legend_y + 0.9, 'Indirect /', fontsize=7, color='#555',\n        va='center', zorder=9)\nax.text(legend_x + 4.3, legend_y + 0.6, 'Transcriptional', fontsize=7, color='#555',\n        va='center', zorder=9)\n\n# Phosphorylation legend\ndraw_phosphorylation(ax, legend_x + 3.8, legend_y + 0.3, size=0.15)\nax.text(legend_x + 4.3, legend_y + 0.3, 'Phosphorylation', fontsize=7, color='#555',\n        va='center', zorder=9)\n\n\n# ============================================================\n# TITLE\n# ============================================================\nax.text(8, 19.8, 'PI3K/AKT/mTOR Signaling Pathway', fontsize=16,\n        fontweight='bold', color=TITLE_COLOR, ha='center', va='center',\n        fontfamily='sans-serif', zorder=10)\n\n# Subtitle\nax.text(8, 19.25, 'Mechanisms of cell growth, proliferation, survival and protein synthesis',\n        fontsize=9, color='#888', ha='center', va='center', style='italic',\n        fontfamily='sans-serif', zorder=10)\n\n\n# ============================================================\n# COMPARTMENT LABELS\n# ============================================================\n# Add small labels for each cellular compartment\ncomp_labels = [\n    (4, 16.8, 'Extracellular Space', '#DDD', 7),\n    (4, 14.3, 'Cytoplasmic Membrane', '#DDD', 7),\n    (4, 11, 'Cytoplasm', '#DDD', 7),\n]\n\nfor cx, cy, ctext, ccolor, csize in comp_labels:\n    ax.text(cx, cy, ctext, fontsize=csize, color=ccolor,\n            ha='center', va='center', fontweight='bold',\n            style='italic', zorder=1)\n\n\n# ============================================================\n# ADDITIONAL ANNOTATIONS\n# ============================================================\n\n# PTEN loss note (common in cancer)\nax.annotate('Frequently lost/\\nmutated in cancer',\n            xy=(pten_x - 0.8, pten_y + 0.35),\n            xytext=(pten_x - 2.5, pten_y + 1.5),\n            fontsize=6.5, color=INHIBITION_COLOR,\n            ha='center', va='center',\n            arrowprops=dict(arrowstyle='->', color=INHIBITION_COLOR,\n                          lw=1, connectionstyle='arc3,rad=0.1'),\n            zorder=8,\n            bbox=dict(boxstyle='round,pad=0.15', facecolor='#FFEBEE',\n                     edgecolor='#EF9A9A', alpha=0.8))\n\n# PIK3CA mutation note\nax.annotate('PIK3CA activating\\nmutations common',\n            xy=(p13k_x, p13k_y),\n            xytext=(p13k_x + 2.5, p13k_y + 1.2),\n            fontsize=6.5, color='#D9534F',\n            ha='center', va='center',\n            arrowprops=dict(arrowstyle='->', color='#D9534F',\n                          lw=1, connectionstyle='arc3,rad=0.1'),\n            zorder=8,\n            bbox=dict(boxstyle='round,pad=0.15', facecolor='#FFF3E0',\n                     edgecolor='#FFCC80', alpha=0.8))\n\n\n# ============================================================\n# SAVE\n# ============================================================\noutput_path = '/home/joe/Documents/repo/skill/sci-draw/pi3k_akt_mtor_pathway.png'\nplt.savefig(output_path, dpi=400, bbox_inches='tight', pad_inches=0.3,\n            facecolor='white', edgecolor='none')\nplt.close()\n\nprint(f\"Figure saved to: {output_path}\")\nprint(f\"Size: 16x20 inches @ 400 DPI = 6400x8000 pixels\")\n"})
